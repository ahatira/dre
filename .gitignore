# Ignore directories generated by Composer
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# Ignore Drupal core files
/web/.csslintrc
/web/.eslintignore
/web/.eslintrc.json
/web/.ht.router.php
/web/.htaccess
/web/autoload.php
/web/index.php
/web/update.php
/web/robots.txt
/web/example.gitignore
/web/*.txt

# Ignore contributed modules and profiles
/web/modules/*
!/web/modules/custom
/web/profiles/*
!/web/profiles/custom
/web/themes/*
!/web/themes/custom
!/web/themes/README.txt

# Ignore sites directory (except default settings)
/web/sites/

# Ignore sensitive information
/web/sites/*/settings.php
/web/sites/*/settings.local.php

# Ignore Drupal's file directories
/web/sites/*/files/

# Ignore configuration sync directory
/config/sync/

# Ignore SimpleTest multi-site environment files
/web/sites/simpletest

# Ignore files generated by PhpStorm
/.idea/

# Ignore files generated by Visual Studio Code
/.vscode/
!/.vscode/settings.json

# Ignore Claude AI working files
/.claude/

# Ignore npm dependencies and build artifacts
node_modules/
npm-debug.log

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore paths that contain user-generated content
/web/sites/*/private/

# Ignore Drush
/drush/contrib/
