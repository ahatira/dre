# ------------------------------
# Dependencies (Composer/Drupal)
# ------------------------------
/src/vendor/
/src/web/core/
/src/web/modules/contrib/
/src/web/themes/contrib/
/src/web/profiles/contrib/

# ------------------------------
# Drupal runtime/generated files
# ------------------------------
/src/web/sites/*/files/
/src/web/sites/*/private/
/src/private/
/src/web/sites/default/files/config_*/
/src/web/sites/simpletest/

# Local site settings can contain secrets and env-specific values.
/src/web/sites/*/settings.local.php
/src/web/sites/*/services.local.yml
/src/web/sites/*/local.settings.php

# ------------------------------
# Project runtime outputs
# ------------------------------
/logs/
/migration_output.log
/src/public/
/src/bnppre_sample_100_per_type.xml

# Temporary workspace outputs.
/src/tmp/

# Exclude root tmp workspace artifacts.
/tmp/

# Large local data fixtures/dumps (keep out of core repo by default).
/data/

# ------------------------------
# Local environment / editor
# ------------------------------
.env
.env.*
!/src/.env.dist
/src/.env
!/src/.env.dist

.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------
# Language/build caches
# ------------------------------
node_modules/
/src/web/themes/custom/*/node_modules/
__pycache__/
*.pyc

# ------------------------------
# Logs / temporary / backup files
# ------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.bak
*.backup
*.old
*.orig

# ------------------------------
# OS files
# ------------------------------
.DS_Store
Thumbs.db

# ------------------------------
# Root folders to ignore
# ------------------------------
/.ai/
/.github/
/docs/
/imports/
/tmp/

# Dev workspace / AI tooling — not for dre.git release
/.cursor/
/.claude/
/archived-scripts/
/backup/
/src/backup/

# CMI export — local only (env Config Split overrides are versioned).
/src/config/sites/
/src/config/sync/

# ------------------------------
# Drupal scaffold defaults (docroot)
# ------------------------------
/src/web/.htaccess
/src/web/.ht.router.php
/src/web/autoload.php
/src/web/index.php
/src/web/update.php
/src/web/robots.txt
/src/web/INSTALL.txt
/src/web/README.md
/src/web/example.gitignore
/src/web/modules/README.txt
/src/recipes/README.txt
/src/web/.csslintrc
/src/web/.eslintignore
/src/web/.eslintrc.json

# Ignore default profiles/themes at docroot level, keep room for custom ones.
/src/web/profiles/*
!/src/web/profiles/custom/
!/src/web/profiles/custom/**

/src/web/themes/*
!/src/web/themes/custom/
!/src/web/themes/custom/**
