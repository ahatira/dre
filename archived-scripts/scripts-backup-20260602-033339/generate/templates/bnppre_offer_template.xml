          <AVAILABILITY LANGUAGE="{{LANGUAGE_PRIMARY}}">{{DIVISION_AVAILABILITY_PRIMARY}}</AVAILABILITY>
          <AVAILABILITY LANGUAGE="{{LANGUAGE_SECONDARY}}">{{DIVISION_AVAILABILITY_SECONDARY}}</AVAILABILITY>
