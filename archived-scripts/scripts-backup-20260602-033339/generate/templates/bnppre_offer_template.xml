    <BUSINESS_LEADERS_LIST>
      <BUSINESS_LEADER>
        <CIVILITY>{{BUSINESS_LEADER_CIVILITY}}</CIVILITY>
        <LASTNAME>{{BUSINESS_LEADER_LASTNAME}}</LASTNAME>
        <FIRSTNAME>{{BUSINESS_LEADER_FIRSTNAME}}</FIRSTNAME>
        <PHONE_NUMBER>{{BUSINESS_LEADER_PHONE_NUMBER}}</PHONE_NUMBER>
        <MAIL>{{BUSINESS_LEADER_MAIL}}</MAIL>
        <FAX />
        <UID>{{BUSINESS_LEADER_UID}}</UID>
        <AVATAR_URL>{{BUSINESS_LEADER_AVATAR_URL}}</AVATAR_URL>
        <CREATION_DATE>{{BUSINESS_LEADER_CREATION_DATE}}</CREATION_DATE>
        <LAST_UPDATE_DATE>{{BUSINESS_LEADER_LAST_UPDATE_DATE}}</LAST_UPDATE_DATE>
