        <QUALIFICATION_CODE>{{GLOBAL_SURFACE_QUALIFICATION_CODE}}</QUALIFICATION_CODE>
      </SURFACE>
    </GLOBAL_SURFACES>
    <GROUPING_ID>
    </GROUPING_ID>
