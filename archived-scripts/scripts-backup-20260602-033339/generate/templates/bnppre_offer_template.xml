    <ADDRESS_LIST>
      <ADDRESS>
        <DISPLAY>true</DISPLAY>
        <PRIMARY>true</PRIMARY>
        <ZIP_CODE>{{ZIP_CODE}}</ZIP_CODE>
        <CITY>{{CITY}}</CITY>
        <COUNTRY_ISO>{{COUNTRY_ISO}}</COUNTRY_ISO>
        <STREET_NUMBER>{{STREET_NUMBER}}</STREET_NUMBER>
        <STREET_NAME>{{STREET_NAME}}</STREET_NAME>
        <ADDRESS_LINE_1>{{ADDRESS_LINE_1}}</ADDRESS_LINE_1>
        <ADDRESS_LINE_2 />
        <ADDRESS_LINE_3 />
        <ADDRESS_LINE_4 />
        <ADDRESS_LINE_5 />
        <ADDRESS_LINE_6 />
        <GEOGRAPHICAL_ZONE>{{GEOGRAPHICAL_ZONE}}</GEOGRAPHICAL_ZONE>
        <BUILDING_NAME>{{BUILDING_NAME}}</BUILDING_NAME>
        <DISTRICT>{{DISTRICT}}</DISTRICT>
        <PROJECTION>
          <TYPE_CODE />
          <COORD_X />
          <COORD_Y />
          <COORD_Z />
        </PROJECTION>
        <GPS>
          <LONGITUDE>{{LONGITUDE}}</LONGITUDE>
          <LATITUDE>{{LATITUDE}}</LATITUDE>
        </GPS>
      </ADDRESS>
    </ADDRESS_LIST>
    <DIAGNOSTICS_LIST>
      <DIAGNOSTIC>
        <DIAGNOSTIC_TYPE>{{DIAGNOSTIC_TYPE}}</DIAGNOSTIC_TYPE>
        <CLASS>{{DIAGNOSTIC_CLASS}}</CLASS>
        <VALUE>{{DIAGNOSTIC_VALUE}}</VALUE>
        <DIAGNOSTIC_DATE>{{DIAGNOSTIC_DATE}}</DIAGNOSTIC_DATE>
        <VALIDITY_END_DATE>{{DIAGNOSTIC_VALIDITY_END_DATE}}</VALIDITY_END_DATE>
        <NO_CLASSIFICATION>{{DIAGNOSTIC_NO_CLASSIFICATION}}</NO_CLASSIFICATION>
        <NON_APPLICABLE>{{DIAGNOSTIC_NON_APPLICABLE}}</NON_APPLICABLE>
      </DIAGNOSTIC>
