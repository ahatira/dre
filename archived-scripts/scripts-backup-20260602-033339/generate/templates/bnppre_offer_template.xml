    <OPERATIONS_LIST>
      <OPERATION_CODE>{{OPERATION_CODE}}</OPERATION_CODE>
    </OPERATIONS_LIST>
    <GLOBAL_SURFACES>
      <SURFACE>
        <VALUE>{{SURFACE_VALUE}}</VALUE>
        <TYPE_CODE>{{TYPE_CODE}}</TYPE_CODE>
        <NATURE_CODE>{{NATURE_CODE}}</NATURE_CODE>
