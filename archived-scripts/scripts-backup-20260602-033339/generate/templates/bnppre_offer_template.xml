        <OPERATION_CODE>{{OPERATION_CODE}}</OPERATION_CODE>
        <PERIOD_CODE>{{BUDGET_PERIOD_CODE}}</PERIOD_CODE>
        <UNIT_CODE>{{BUDGET_UNIT_CODE}}</UNIT_CODE>
        <HT>{{BUDGET_HT}}</HT>
        <CC>{{BUDGET_CC}}</CC>
      </BUDGET>
