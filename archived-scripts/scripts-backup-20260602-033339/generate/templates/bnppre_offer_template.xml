    <ML_DESCRIPTION_2>
      <DESCRIPTION LANGUAGE="{{LANGUAGE_PRIMARY}}">{{DESCRIPTION_2_PRIMARY}}</DESCRIPTION>
      <DESCRIPTION LANGUAGE="{{LANGUAGE_SECONDARY}}">{{DESCRIPTION_2_SECONDARY}}</DESCRIPTION>
    </ML_DESCRIPTION_2>
    <ML_DESCRIPTION_3 />
