    <CURRENCY>{{CURRENCY}}</CURRENCY>
    <ML_AVAILABILITY>
      <AVAILABILITY LANGUAGE="{{LANGUAGE_PRIMARY}}">{{AVAILABILITY_PRIMARY}}</AVAILABILITY>
      <AVAILABILITY LANGUAGE="{{LANGUAGE_SECONDARY}}">{{AVAILABILITY_SECONDARY}}</AVAILABILITY>
    </ML_AVAILABILITY>
    <ML_DESCRIPTION_1>
      <DESCRIPTION LANGUAGE="{{LANGUAGE_PRIMARY}}">{{SUMMARY_DESCRIPTION_PRIMARY}}</DESCRIPTION>
      <DESCRIPTION LANGUAGE="{{LANGUAGE_SECONDARY}}">{{SUMMARY_DESCRIPTION_SECONDARY}}</DESCRIPTION>
