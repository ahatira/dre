{{ attach_library('ui_suite_bnppre/header') }}

{% set header_id = 'header-panel-' ~ random() %}
{% set container_class = container_class|default('container-xxl') %}
{% set brand_content = brand|default('')|render %}
{% set switcher_content = switcher|default('')|render %}
{% set navigation_content = navigation|default('')|render %}
{% set actions_content = actions|default('')|render %}
{% set has_switcher = switcher_content|trim is not empty %}
{% set has_navigation = navigation_content|trim is not empty %}
{% set has_actions = actions_content|trim is not empty %}

<div class="ps-header-shell" data-header-shell>
	<header class="ps-header" role="banner" data-header>
		<div class="{{ container_class }} ps-header__container">
			<div class="ps-header__inner">
				<div class="ps-header__row--top-wrap">
					<button class="btn ps-header__menu-button" type="button" aria-controls="{{ header_id }}" aria-expanded="false" aria-label="{{ 'Open menu'|t }}" data-header-open>
						<span class="ps-header__menu-icon" aria-hidden="true"></span>
					</button>

					<div class="ps-header__row ps-header__row--top">
						<div class="ps-header__brand">
							{{ brand_content }}
						</div>

						{% if has_switcher %}
							<div class="ps-header__topbar">
								{{ switcher_content }}
							</div>
						{% endif %}
					</div>

					<button class="btn btn-close ps-header__close-button" type="button" aria-controls="{{ header_id }}" aria-label="{{ 'Close menu'|t }}" data-header-close></button>
				</div>

				<div class="ps-header__row2-wrap" data-header-panel-wrap>
					<div class="ps-header__row ps-header__row--bottom" id="{{ header_id }}" data-header-panel>
						{% if has_navigation %}
							<div class="ps-header__navigation" aria-label="{{ 'Primary navigation'|t }}">
								{{ navigation_content }}
							</div>
						{% endif %}

						{% if has_actions %}
							<div class="ps-header__actions" aria-label="{{ 'Header actions'|t }}">
								{{ actions_content }}
							</div>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</header>
</div>
