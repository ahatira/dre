{{ attach_library('ui_suite_bnppre/header') }}

{% set header_id = 'header-panel-' ~ random() %}
{% set header_label_id = 'header-panel-label-' ~ random() %}
{% set container_class = container_class|default('container-xxl') %}
{% set attributes = create_attribute(attributes|default({})) %}
{% set brand_content = brand|default('')|render %}
{% set switcher_content = switcher|default('')|render %}
{% set navigation_content = navigation|default('')|render %}
{% set actions_content = actions|default('')|render %}
{% set content = content|default('')|render %}
{% set has_switcher = switcher_content|trim is not empty %}
{% set has_navigation = navigation_content|trim is not empty %}
{% set has_actions = actions_content|trim is not empty %}
{% set has_content = content|trim is not empty %}

<header{{attributes.addClass('ps-header','header').setAttribute('role','banner').setAttribute('data-header','true')}}>
	{{ title_prefix|default([]) }}
	<div class="{{ container_class }} ps-header__container">
		<div class="container-wrapper">
			<div class="d-flex align-items-center ps-header__row ps-header__row--top">
				<div class="ps-header__controls">
					<button class="ps-header__menu-toggle" type="button" aria-expanded="false" aria-label="{{ 'Open menu'|t }}" data-header-button-toggle>
						<span class="navbar-toggler-icon" aria-hidden="true"></span>
					</button>
					<button class="ps-header__close-toggle" type="button" aria-expanded="false" aria-label="{{ 'Close menu'|t }}" data-header-button-close>
						<span class="ps-header__close-icon" aria-hidden="true"></span>
					</button>
				</div>

				<div class="ps-header__brand">
					{{ brand_content }}
				</div>

				{% if has_switcher %}
					<div class="ps-header__top d-flex gap-2 ms-auto" aria-label="{{ 'Top bar'|t }}">
						{{ switcher_content }}
					</div>
				{% endif %}
			</div>

			<div class="d-flex align-items-center justify-content-between ps-header__row ps-header__row--bottom" data-header-desktop-row>
				{% if has_navigation %}
					<nav class="d-flex gap-3 ps-header__navigation" aria-label="{{ 'Primary navigation'|t }}">
						{{ navigation_content }}
					</nav>
				{% endif %}

				{% if has_actions %}
					<div class="d-flex gap-2 ps-header__actions" aria-label="{{ 'Header actions'|t }}">
						{{ actions_content }}
					</div>
				{% endif %}
			</div>
		</div>

		<div class="offcanvas offcanvas-end ps-header__offcanvas" tabindex="-1" id="{{ header_id }}" aria-labelledby="{{ header_label_id }}" data-header-panel>
			<div class="offcanvas-header">
				<div class="ps-header__offcanvas-brand">{{ brand_content }}</div>
				<button class="btn-close" type="button" data-bs-dismiss="offcanvas" aria-label="{{ 'Close menu'|t }}"></button>
			</div>
			<div class="offcanvas-body d-flex flex-column">
				<h2 class="visually-hidden" id="{{ header_label_id }}">{{ 'Mobile navigation'|t }}</h2>

				{% if has_navigation %}
					<nav class="mb-4 ps-header__navigation ps-header__navigation--mobile" aria-label="{{ 'Primary navigation mobile'|t }}">
						{{ navigation_content }}
					</nav>
				{% endif %}

				{% if has_actions %}
					<div class="d-grid gap-2 ps-header__actions ps-header__actions--mobile" aria-label="{{ 'Header actions mobile'|t }}">
						{{ actions_content }}
					</div>
				{% endif %}

				{% if has_content %}
					<div class="pt-3 ps-header__content">
						{{ content }}
					</div>
				{% endif %}

				{% if has_switcher %}
					<div class="mt-auto pt-4 ps-header__top ps-header__top--mobile" aria-label="{{ 'Language switcher'|t }}">
						{{ switcher_content }}
					</div>
				{% endif %}
			</div>
		</div>
	</div>
	{{ title_suffix|default([]) }}
</header>
<div class="ps-header-scoller"></div>
