{{ attach_library('ui_suite_bnppre/header') }}

{% set header_id = 'header-panel-' ~ random() %}
{% set header_label_id = 'header-panel-label-' ~ random() %}
{% set container_class = container_class|default('container-xxl') %}
{% set attributes = create_attribute(attributes|default({})) %}
{% set brand_content = brand|default('')|render %}
{% set switcher_content = switcher|default('')|render %}
{% set navigation_content = navigation|default('')|render %}
{% set actions_content = actions|default('')|render %}
{% set content = content|default('')|render %}
{% set has_switcher = switcher_content|trim is not empty %}
{% set has_navigation = navigation_content|trim is not empty %}
{% set has_actions = actions_content|trim is not empty %}
{% set has_content = content|trim is not empty %}

<div class="ps-header-shell" data-header-shell>
	<header{{attributes.addClass('ps-header','header').setAttribute('role','banner').setAttribute('data-header','true')}}>
		{{ title_prefix|default([]) }}
		<div class="{{ container_class }} ps-header__container">
			<nav class="navbar navbar-expand-lg ps-header__navbar ps-header__row ps-header__row--top" aria-label="{{ 'Header primary bar'|t }}">
				<div class="container-fluid px-0">
					<button class="btn ps-header__desktop-toggle" type="button" aria-label="{{ 'Open header panel'|t }}" aria-hidden="true" tabindex="-1" data-header-open-desktop>
						<span class="navbar-toggler-icon" aria-hidden="true"></span>
					</button>

					{{ include('ui_suite_bnppre:close_button', {
						attributes: create_attribute({
							class: ['btn', 'ps-header__desktop-close'],
							'aria-hidden': 'true',
							tabindex: '-1',
							'data-header-close-desktop': 'true',
						}),
						aria_label: 'Close header panel'|t,
					}, with_context = false) }}

					<div class="ps-header__mobile-toggle-wrap d-lg-none" aria-hidden="false">
						<button class="navbar-toggler ps-header__menu-button" type="button" data-bs-toggle="collapse" data-bs-target="#{{ header_id }}" aria-controls="{{ header_id }}" aria-expanded="false" aria-label="{{ 'Toggle navigation'|t }}" data-header-trigger>
							<span class="navbar-toggler-icon"></span>
						</button>

						{{ include('ui_suite_bnppre:close_button', {
							attributes: create_attribute({
								class: ['btn', 'ps-header__mobile-close'],
								'data-bs-toggle': 'collapse',
								'data-bs-target': '#' ~ header_id,
								'aria-controls': header_id,
								'aria-hidden': 'true',
								tabindex: '-1',
								'data-header-close-mobile': 'true',
							}),
							aria_label: 'Close menu'|t,
						}, with_context = false) }}
					</div>

					<div class="ps-header__brand navbar-brand m-0">
						{{ brand_content }}
					</div>

					{% if has_switcher %}
						<div class="ps-header__topbar ms-auto d-none d-lg-flex" aria-label="{{ 'Top bar'|t }}">
							{{ switcher_content }}
						</div>
					{% endif %}
				</div>
			</nav>

			<div class="row align-items-center ps-header__row ps-header__row--bottom" data-header-desktop-row>
				{% if has_navigation %}
					<nav class="col ps-header__navigation" aria-label="{{ 'Primary navigation'|t }}">
						{{ navigation_content }}
					</nav>
				{% endif %}

				{% if has_actions %}
					<div class="col-auto ps-header__actions" aria-label="{{ 'Header actions'|t }}">
						{{ actions_content }}
					</div>
				{% endif %}
			</div>

			<div id="{{ header_id }}" class="collapse d-lg-none ps-header__mobile-panel" aria-labelledby="{{ header_label_id }}" aria-hidden="true" data-header-panel>
				<div class="ps-header__mobile-inner py-2 pb-4">
					<h2 class="visually-hidden" id="{{ header_label_id }}">{{ 'Mobile navigation'|t }}</h2>

					{% if has_navigation %}
						<nav class="ps-header__navigation ps-header__navigation--mobile" aria-label="{{ 'Primary navigation mobile'|t }}">
							{{ navigation_content }}
						</nav>
					{% endif %}

					{% if has_switcher %}
						<div class="ps-header__topbar ps-header__topbar--mobile pt-3" aria-label="{{ 'Language switcher'|t }}">
							{{ switcher_content }}
						</div>
					{% endif %}

					{% if has_actions %}
						<div class="ps-header__actions ps-header__actions--mobile pt-3" aria-label="{{ 'Header actions mobile'|t }}">
							{{ actions_content }}
						</div>
					{% endif %}

					{% if has_content %}
						<div class="ps-header__content pt-3">
							{{ content }}
						</div>
					{% endif %}
				</div>
			</div>
		</div>
		{{ title_suffix|default([]) }}
	</header>
</div>
