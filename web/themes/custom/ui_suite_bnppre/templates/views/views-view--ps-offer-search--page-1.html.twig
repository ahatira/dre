{#
/**
 * @file
 * View override for the offer search page with list/map split layout.
 */
#}
{{ attach_library('ui_suite_bnppre/offer_search') }}
{%
  set classes = [
    dom_id ? 'js-view-dom-id-' ~ dom_id,
    'ps-offer-search-view',
  ]
%}
{% set map_attachment = attachment_after ?: attachment_before %}
{% set header_sort = exposed.sort_by ?? null %}
{% set exposed_filters = exposed ? exposed|without('sort_by') : null %}

<div{{attributes.addClass(classes)}}>
	{{ title_prefix }}
	{{ title }}
	{{ title_suffix }}

	{% if exposed_filters %}
		<div class="ps-offer-search-view__filters mb-3">
			{{ exposed_filters }}
		</div>
	{% endif %}

	{% if map_attachment %}
		<div class="row g-3 align-items-start ps-offer-search-view__content" data-list-visible="true">
			<div class="col-12 col-xl-6 order-2 order-xl-1 ps-offer-search-view__list">
				{% if contextual_title or header_sort %}
					<header class="mb-3 ps-offer-search-view__header">
						<div class="ps-offer-search-view__header-top">
							{% if contextual_title %}
								<h2 class="ps-offer-search-view__title">{{ contextual_title }}</h2>
							{% endif %}
							<a href="{{ path('ps_favorites.my_favorites') }}" class="ps-offer-search-view__create-alert" aria-label="{{ 'Create an alert'|t }}">
								<span class="ps-offer-search-view__create-alert-icon" aria-hidden="true">{{ icon('bnppre', 'notification', {'size': '1rem', 'alt': ''})|render }}</span>
								<span>{{ 'Create an alert'|t }}</span>
							</a>
						</div>
						<div class="ps-offer-search-view__meta">
							{% if header %}
								{{ header }}
							{% endif %}
							{% if header_sort %}
								{{ header_sort }}
							{% endif %}
						</div>
					</header>
				{% endif %}

				{% if rows %}
					{{ rows }}
				{% elseif empty %}
					{{ empty }}
				{% endif %}

				{{ pager }}
				{{ more }}
			</div>

			<aside class="col-12 col-xl-6 order-1 order-xl-2 ps-offer-search-view__map" aria-label="{{ 'Map results'|t }}">
				<button class="ps-offer-search-view__toggle-list" data-toggle-target=".ps-offer-search-view__content" aria-label="{{ 'Hide list'|t }}" aria-pressed="true">
					<span class="ps-offer-search-view__toggle-list-text">{{ 'Hide list'|t }}</span>
				</button>
				{{ map_attachment }}
			</aside>
		</div>
	{% else %}
		{% if header %}
			<header>
				{{ header }}
			</header>
		{% endif %}

		{% if rows %}
			{{ rows }}
		{% elseif empty %}
			{{ empty }}
		{% endif %}

		{{ pager }}
		{{ more }}
	{% endif %}

	{% if footer %}
		<footer>
			{{ footer }}
		</footer>
	{% endif %}

	{{ feed_icons }}
</div>
