<?php

declare(strict_types=1);

use Drupal\Core\Entity\Display\EntityFormDisplayInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\layout_builder\Section;
use Drupal\layout_builder\SectionComponent;

/**
 * Implements hook_install().
 */
function ps_agent_install(): void {
  ps_agent_ensure_offer_agent_reference();
  ps_agent_ensure_agent_configurable_fields();
  ps_agent_ensure_agent_default_displays();
  ps_agent_ensure_agent_card_view_mode();
}

/**
 * Ensure configurable fields exist on Agent entity type.
 */
function ps_agent_ensure_agent_configurable_fields(): void {
  $storage = FieldStorageConfig::loadByName('agent', 'field_summary');
  if ($storage === NULL) {
    $storage = FieldStorageConfig::create([
      'field_name' => 'field_summary',
      'entity_type' => 'agent',
      'type' => 'string_long',
      'cardinality' => 1,
      'translatable' => TRUE,
    ]);
    $storage->save();
  }

  $field = FieldConfig::loadByName('agent', 'agent', 'field_summary');
  if ($field === NULL) {
    $field = FieldConfig::create([
      'field_name' => 'field_summary',
      'entity_type' => 'agent',
      'bundle' => 'agent',
      'label' => 'Summary',
      'required' => FALSE,
    ]);
    $field->save();
  }
}

/**
 * Ensure Agent reference field and displays exist on Offer content type.
 */
function ps_agent_ensure_offer_agent_reference(): void {
  $node_type = \Drupal::entityTypeManager()->getStorage('node_type')->load('offer');
  if ($node_type === NULL) {
    return;
  }

  $storage = FieldStorageConfig::loadByName('node', 'field_agent');
  if ($storage === NULL) {
    $storage = FieldStorageConfig::create([
      'field_name' => 'field_agent',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'settings' => ['target_type' => 'agent'],
      'cardinality' => 1,
      'translatable' => TRUE,
    ]);
    $storage->save();
  }

  $field = FieldConfig::loadByName('node', 'offer', 'field_agent');
  if ($field === NULL) {
    $field = FieldConfig::create([
      'field_name' => 'field_agent',
      'entity_type' => 'node',
      'bundle' => 'offer',
      'label' => 'Agent',
      'required' => FALSE,
      'settings' => [
        'handler' => 'default:agent',
        'handler_settings' => [
          'target_bundles' => NULL,
          'sort' => ['field' => '_none'],
          'auto_create' => FALSE,
        ],
      ],
    ]);
    $field->save();
  }

  $form_display = \Drupal::entityTypeManager()
    ->getStorage('entity_form_display')
    ->load('node.offer.default');
  if (!$form_display instanceof EntityFormDisplayInterface) {
    $form_display = \Drupal\Core\Entity\Entity\EntityFormDisplay::create([
      'targetEntityType' => 'node',
      'bundle' => 'offer',
      'mode' => 'default',
      'status' => TRUE,
    ]);
  }
  $form_display->setComponent('field_agent', [
    'type' => 'entity_reference_autocomplete',
    'weight' => -95,
    'settings' => [
      'match_operator' => 'CONTAINS',
      'match_limit' => 10,
      'size' => 60,
      'placeholder' => '',
    ],
  ]);
  $form_display->save();

  $view_display = \Drupal::entityTypeManager()
    ->getStorage('entity_view_display')
    ->load('node.offer.full');
  if (!$view_display instanceof EntityViewDisplayInterface) {
    $view_display = \Drupal\Core\Entity\Entity\EntityViewDisplay::create([
      'targetEntityType' => 'node',
      'bundle' => 'offer',
      'mode' => 'full',
      'status' => TRUE,
    ]);
  }
  $view_display->setComponent('field_agent', [
    'type' => 'entity_reference_entity_view',
    'label' => 'hidden',
    'weight' => -95,
    'settings' => [
      'view_mode' => 'agent_card',
      'link' => FALSE,
    ],
  ]);
  $view_display->save();
}

/**
 * Ensure a dedicated Agent view mode and display exist.
 */
function ps_agent_ensure_agent_card_view_mode(): void {
  $view_mode = \Drupal::entityTypeManager()
    ->getStorage('entity_view_mode')
    ->load('agent.agent_card');
  if ($view_mode === NULL) {
    $view_mode = \Drupal\Core\Entity\Entity\EntityViewMode::create([
      'id' => 'agent.agent_card',
      'targetEntityType' => 'agent',
      'label' => 'Agent card',
      'status' => TRUE,
    ]);
    $view_mode->save();
  }

  $display = \Drupal::entityTypeManager()
    ->getStorage('entity_view_display')
    ->load('agent.agent.agent_card');
  if (!$display instanceof EntityViewDisplayInterface) {
    $display = \Drupal\Core\Entity\Entity\EntityViewDisplay::create([
      'targetEntityType' => 'agent',
      'bundle' => 'agent',
      'mode' => 'agent_card',
      'status' => TRUE,
    ]);
  }

  $uuid_service = \Drupal::service('uuid');
  $component_uuid = $uuid_service->generate();
  $sections = $display->getThirdPartySetting('layout_builder', 'sections', []);
  $has_agent_card_component = FALSE;
  foreach ($sections as $section) {
    if ($section instanceof Section) {
      foreach ($section->getComponents() as $component) {
        if (($component->getPluginId() ?? '') === 'ps_agent_agent_card_layout_builder') {
          $has_agent_card_component = TRUE;
          break 2;
        }
      }
      continue;
    }
    foreach (($section['components'] ?? []) as $component) {
      if (($component['configuration']['id'] ?? '') === 'ps_agent_agent_card_layout_builder') {
        $has_agent_card_component = TRUE;
        break 2;
      }
    }
  }
  if (!$has_agent_card_component) {
    $component = new SectionComponent(
      $component_uuid,
      'content',
      [
        'id' => 'ps_agent_agent_card_layout_builder',
        'label' => '',
        'label_display' => '0',
        'provider' => 'ps_agent',
        'context_mapping' => [
          'entity' => 'layout_builder.entity',
        ],
      ],
      [],
      0,
    );
    $section = new Section('layout_onecol', [
      'label' => '',
      'context_mapping' => [],
    ]);
    $section->appendComponent($component);
    $display->setThirdPartySetting('layout_builder', 'sections', [$section]);
  }
  $display->setThirdPartySetting('layout_builder', 'enabled', TRUE);
  $display->setThirdPartySetting('layout_builder', 'allow_custom', FALSE);
  $display->set('content', []);

  $hidden = $display->get('hidden') ?: [];
  $hidden += [
    'name' => TRUE,
    'job_title' => TRUE,
    'photo' => TRUE,
    'phone' => TRUE,
    'contact_cta' => TRUE,
    'email' => TRUE,
    'webform_id' => TRUE,
    'status' => TRUE,
    'created' => TRUE,
    'changed' => TRUE,
  ];
  $display->set('hidden', $hidden);
  $display->save();
}

/**
 * Ensure default Agent form/view displays are available in Field UI.
 */
function ps_agent_ensure_agent_default_displays(): void {
  $form_display = \Drupal::entityTypeManager()
    ->getStorage('entity_form_display')
    ->load('agent.agent.default');
  if (!$form_display instanceof EntityFormDisplayInterface) {
    $form_display = \Drupal\Core\Entity\Entity\EntityFormDisplay::create([
      'targetEntityType' => 'agent',
      'bundle' => 'agent',
      'mode' => 'default',
      'status' => TRUE,
    ]);
  }

  $form_display->setComponent('name', [
    'type' => 'string_textfield',
    'weight' => -20,
    'region' => 'content',
    'settings' => ['size' => 60, 'placeholder' => ''],
  ]);
  $form_display->setComponent('job_title', [
    'type' => 'string_textfield',
    'weight' => -19,
    'region' => 'content',
    'settings' => ['size' => 60, 'placeholder' => ''],
  ]);
  $form_display->setComponent('photo', [
    'type' => 'image_image',
    'weight' => -18,
    'region' => 'content',
    'settings' => [
      'progress_indicator' => 'throbber',
      'preview_image_style' => 'thumbnail',
    ],
  ]);
  $form_display->setComponent('phone', [
    'type' => 'string_textfield',
    'weight' => -17,
    'region' => 'content',
    'settings' => ['size' => 30, 'placeholder' => ''],
  ]);
  $form_display->setComponent('email', [
    'type' => 'string_textfield',
    'weight' => -16,
    'region' => 'content',
    'settings' => ['size' => 60, 'placeholder' => ''],
  ]);
  $form_display->setComponent('webform_id', [
    'type' => 'string_textfield',
    'weight' => -15,
    'region' => 'content',
    'settings' => ['size' => 60, 'placeholder' => 'contact'],
  ]);
  $form_display->setComponent('contact_cta', [
    'type' => 'link_default',
    'weight' => -14,
    'region' => 'content',
    'settings' => ['placeholder_url' => 'internal:/webform/contact', 'placeholder_title' => 'Contact the consultancy'],
  ]);
  $form_display->setComponent('field_summary', [
    'type' => 'string_textarea',
    'weight' => -13,
    'region' => 'content',
    'settings' => ['rows' => 4, 'placeholder' => ''],
  ]);
  $form_display->setComponent('status', [
    'type' => 'boolean_checkbox',
    'weight' => 90,
    'region' => 'content',
    'settings' => ['display_label' => TRUE],
  ]);
  $form_display->save();

  $view_display = \Drupal::entityTypeManager()
    ->getStorage('entity_view_display')
    ->load('agent.agent.default');
  if (!$view_display instanceof EntityViewDisplayInterface) {
    $view_display = \Drupal\Core\Entity\Entity\EntityViewDisplay::create([
      'targetEntityType' => 'agent',
      'bundle' => 'agent',
      'mode' => 'default',
      'status' => TRUE,
    ]);
  }

  $view_display->setComponent('photo', [
    'type' => 'image',
    'label' => 'hidden',
    'weight' => -20,
    'region' => 'content',
    'settings' => ['image_style' => '', 'image_link' => ''],
  ]);
  $view_display->setComponent('name', [
    'type' => 'string',
    'label' => 'hidden',
    'weight' => -19,
    'region' => 'content',
    'settings' => ['link_to_entity' => FALSE],
  ]);
  $view_display->setComponent('job_title', [
    'type' => 'string',
    'label' => 'hidden',
    'weight' => -18,
    'region' => 'content',
    'settings' => ['link_to_entity' => FALSE],
  ]);
  $view_display->setComponent('phone', [
    'type' => 'string',
    'label' => 'hidden',
    'weight' => -17,
    'region' => 'content',
    'settings' => ['link_to_entity' => FALSE],
  ]);
  $view_display->setComponent('email', [
    'type' => 'string',
    'label' => 'hidden',
    'weight' => -16,
    'region' => 'content',
    'settings' => ['link_to_entity' => FALSE],
  ]);
  $view_display->setComponent('contact_cta', [
    'type' => 'link',
    'label' => 'hidden',
    'weight' => -15,
    'region' => 'content',
    'settings' => [
      'trim_length' => 80,
      'url_only' => FALSE,
      'url_plain' => FALSE,
      'rel' => '',
      'target' => '',
    ],
  ]);
  $view_display->setComponent('webform_id', [
    'type' => 'string',
    'label' => 'above',
    'weight' => -14,
    'region' => 'content',
    'settings' => ['link_to_entity' => FALSE],
  ]);
  $view_display->setComponent('field_summary', [
    'type' => 'basic_string',
    'label' => 'above',
    'weight' => -13,
    'region' => 'content',
    'settings' => [],
  ]);
  $view_display->save();
}

/**
 * Post-update to apply setup changes on existing installs.
 */
function ps_agent_update_9001(): void {
  ps_agent_ensure_offer_agent_reference();
  ps_agent_ensure_agent_configurable_fields();
  ps_agent_ensure_agent_default_displays();
  ps_agent_ensure_agent_card_view_mode();
}
