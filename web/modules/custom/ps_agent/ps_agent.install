<?php

declare(strict_types=1);

/**
 * @file
 * Install and update hooks for the ps_agent module.
 */

/**
 * Enables Agent entities in Simple XML Sitemap.
 */
function _ps_agent_enable_simple_sitemap(): void {
  if (!\Drupal::moduleHandler()->moduleExists('simple_sitemap')) {
    return;
  }

  $entity_manager = \Drupal::service('simple_sitemap.generator')->entityManager();
  $entity_manager->enableEntityType('agent');

  if (\Drupal::config('simple_sitemap.bundle_settings.default.agent.agent')->isNew()) {
    $entity_manager->setBundleSettings('agent', 'agent', [
      'index' => TRUE,
      'priority' => '0.5',
      'changefreq' => 'weekly',
      'include_images' => FALSE,
    ]);
  }
}

/**
 * Ensures Agent pathauto integration is fully enabled.
 */
function _ps_agent_enable_pathauto(): void {
  if (!\Drupal::moduleHandler()->moduleExists('pathauto')) {
    return;
  }

  $settings = \Drupal::configFactory()->getEditable('pathauto.settings');
  $enabled_entity_types = $settings->get('enabled_entity_types') ?? [];
  if (!in_array('agent', $enabled_entity_types, TRUE)) {
    $enabled_entity_types[] = 'agent';
    $settings->set('enabled_entity_types', $enabled_entity_types)->save();
  }

  $pattern = \Drupal::configFactory()->getEditable('pathauto.pattern.agent');
  if (!$pattern->isNew()) {
    $pattern
      ->set('type', 'canonical_entities:agent')
      ->set('pattern', 'agents/[agent:label]')
      ->set('selection_criteria', [])
      ->set('selection_logic', 'and')
      ->set('relationships', [])
      ->save();
  }

  \Drupal::service('pathauto.generator')->resetCaches();
}

/**
 * Regenerates aliases for existing Agent entities.
 */
function _ps_agent_regenerate_existing_aliases(): void {
  if (!\Drupal::moduleHandler()->moduleExists('pathauto')) {
    return;
  }

  /** @var \Drupal\pathauto\PathautoGeneratorInterface $generator */
  $generator = \Drupal::service('pathauto.generator');
  $storage = \Drupal::entityTypeManager()->getStorage('agent');
  $ids = $storage->getQuery()->accessCheck(FALSE)->execute();
  $state_storage = \Drupal::keyValue('pathauto_state.agent');

  foreach ($ids as $id) {
    /** @var \Drupal\ps_agent\Entity\AgentInterface|null $agent */
    $agent = $storage->load($id);
    if ($agent === NULL || !$agent->hasField('path')) {
      continue;
    }

    $state_storage->set(
      \Drupal\pathauto\PathautoState::getPathautoStateKey($agent->id()),
      \Drupal\pathauto\PathautoState::CREATE,
    );
    $generator->updateEntityAlias($agent, 'update', ['force' => TRUE]);
  }
}

/**
 * Ensures Agent default form and view displays exist.
 */
function _ps_agent_ensure_default_displays(): void {
  $form_display = \Drupal\Core\Entity\Entity\EntityFormDisplay::load('agent.agent.default')
    ?? \Drupal\Core\Entity\Entity\EntityFormDisplay::create([
      'targetEntityType' => 'agent',
      'bundle' => 'agent',
      'mode' => 'default',
      'status' => TRUE,
      'id' => 'agent.agent.default',
    ]);

  $form_display
    ->setComponent('civility', ['type' => 'options_select', 'weight' => 0, 'region' => 'content'])
    ->setComponent('first_name', ['type' => 'string_textfield', 'weight' => 1, 'region' => 'content', 'settings' => ['size' => 60, 'placeholder' => '']])
    ->setComponent('last_name', ['type' => 'string_textfield', 'weight' => 2, 'region' => 'content', 'settings' => ['size' => 60, 'placeholder' => '']])
    ->setComponent('email', ['type' => 'email_default', 'weight' => 3, 'region' => 'content'])
    ->setComponent('phone', ['type' => 'telephone_default', 'weight' => 4, 'region' => 'content'])
    ->setComponent('avatar', ['type' => 'image_image', 'weight' => 5, 'region' => 'content', 'settings' => ['progress_indicator' => 'throbber', 'preview_image_style' => 'thumbnail']])
    ->setComponent('status', ['type' => 'boolean_checkbox', 'weight' => 10, 'region' => 'content', 'settings' => ['display_label' => TRUE]])
    ->setComponent('uid', ['type' => 'entity_reference_autocomplete', 'weight' => 19, 'region' => 'content', 'settings' => ['match_operator' => 'CONTAINS', 'size' => 60, 'placeholder' => '']])
    ->setComponent('created', ['type' => 'datetime_timestamp', 'weight' => 20, 'region' => 'content'])
    ->setComponent('path', ['type' => 'path', 'weight' => 30, 'region' => 'content'])
    ->removeComponent('label')
    ->removeComponent('external_id')
    ->removeComponent('type');
  $form_display->save();

  $view_display = \Drupal\Core\Entity\Entity\EntityViewDisplay::load('agent.agent.default')
    ?? \Drupal\Core\Entity\Entity\EntityViewDisplay::create([
      'targetEntityType' => 'agent',
      'bundle' => 'agent',
      'mode' => 'default',
      'status' => TRUE,
      'id' => 'agent.agent.default',
    ]);

  $view_display
    ->setComponent('civility', ['type' => 'list_default', 'label' => 'above', 'weight' => 0, 'region' => 'content'])
    ->setComponent('first_name', ['type' => 'string', 'label' => 'above', 'weight' => 1, 'region' => 'content'])
    ->setComponent('last_name', ['type' => 'string', 'label' => 'above', 'weight' => 2, 'region' => 'content'])
    ->setComponent('email', ['type' => 'email_mailto', 'label' => 'above', 'weight' => 3, 'region' => 'content'])
    ->setComponent('phone', ['type' => 'telephone_link', 'label' => 'above', 'weight' => 4, 'region' => 'content'])
    ->setComponent('avatar', ['type' => 'image', 'label' => 'above', 'weight' => 5, 'region' => 'content', 'settings' => ['image_style' => 'thumbnail', 'image_link' => '']])
    ->setComponent('status', ['type' => 'boolean', 'label' => 'above', 'weight' => 10, 'region' => 'content', 'settings' => ['format' => 'default', 'format_custom_false' => '', 'format_custom_true' => '']])
    ->setComponent('uid', ['type' => 'entity_reference_label', 'label' => 'above', 'weight' => 19, 'region' => 'content', 'settings' => ['link' => TRUE]])
    ->setComponent('created', ['type' => 'timestamp', 'label' => 'above', 'weight' => 20, 'region' => 'content', 'settings' => ['date_format' => 'medium', 'custom_date_format' => '', 'timezone' => '']])
    ->setComponent('changed', ['type' => 'timestamp', 'label' => 'above', 'weight' => 21, 'region' => 'content', 'settings' => ['date_format' => 'medium', 'custom_date_format' => '', 'timezone' => '']])
    ->removeComponent('label')
    ->removeComponent('external_id')
    ->removeComponent('type')
    ->removeComponent('path');
  $view_display->save();
}

/**
 * Implements hook_install().
 */
function ps_agent_install(): void {
  _ps_agent_enable_simple_sitemap();
  _ps_agent_enable_pathauto();
}

/**
 * Enable Agent support in Simple XML Sitemap on existing sites.
 */
function ps_agent_update_11001(): void {
  _ps_agent_enable_simple_sitemap();
}

/**
 * Creates the default display configuration for Agent entities.
 */
function ps_agent_update_11002(): void {
  _ps_agent_ensure_default_displays();
}

/**
 * Finalizes Pathauto support and regenerates existing Agent aliases.
 */
function ps_agent_update_11003(): void {
  _ps_agent_enable_pathauto();
  _ps_agent_regenerate_existing_aliases();
}
