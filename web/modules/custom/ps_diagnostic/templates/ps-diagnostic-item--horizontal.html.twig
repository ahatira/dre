{#
/**
 * Diagnostic item template - Horizontal layout (Energy label scale).
 *
 * Displays diagnostic information as a horizontal colored scale similar to official energy labels.
 * Shows all classes (A-G) with the current class highlighted.
 *
 * Variables:
 * - class_label: string|null - Class label (A-G, ?, N/A)
 * - type_label: string|null - Diagnostic label (DPE, GES, etc.)
 * - numeric_value: string|null - Formatted numeric value
 * - valid_from: string|null - Start date (ISO 8601)
 * - valid_to: string|null - End date (ISO 8601)
 * - show_type_label: bool - Display type label
 * - show_numeric_value: bool - Display numeric value
 * - show_validity_dates: bool - Display validity dates
 * - dim_diagnostic: bool - Should this diagnostic be dimmed (empty)
 * - dim_opacity: int - Opacity percentage (10-90) when dimmed
 * - no_classification: bool - Special state flag (shows ?)
 * - non_applicable: bool - Special state flag (shows N/A)
 * - diagnostic_type: \Drupal\ps_diagnostic\Entity\PsDiagnostic|null - Diagnostic config entity
 */
#}
{% set opacity_style = dim_diagnostic ? 'opacity: ' ~ (dim_opacity / 100) ~ ';' : '' %}
{% set current_class = class_label|lower %}
{% set has_value = numeric_value is not null and numeric_value is not empty %}

<div
	class="ps-diagnostic-item ps-diagnostic-item--horizontal" {% if opacity_style %} style="{{ opacity_style }}" {% endif %}>
	{# Header with icon and title #}
	<div class="ps-diagnostic-header">
		{% if diagnostic_type.icon %}
			<span class="ps-diagnostic-icon">{{ diagnostic_type.icon }}</span>
		{% else %}
			<span class="ps-diagnostic-icon">⚡</span>
		{% endif %}
		{% if show_type_label and type_label %}
			<h3 class="ps-diagnostic-title">{{ type_label }}</h3>
		{% endif %}
	</div>

	{# Energy scale bar with all classes #}
	<div class="ps-diagnostic-scale">
		{% if diagnostic_type and diagnostic_type.classes %}
			{# Display all classes as a scale #}
			{% for code, class_data in diagnostic_type.classes %}
				{% set is_current = (code == current_class) %}
				{% set segment_class = is_current ? 'ps-diagnostic-segment--current' : '' %}

				<div class="ps-diagnostic-segment {{ segment_class }}" style="background-color: {{ class_data.color }};" data-class="{{ code|upper }}">
					<span class="ps-diagnostic-segment-label">{{ class_data.label }}</span>
					{% if is_current and has_value %}
						<span class="ps-diagnostic-segment-value">{{ numeric_value }}</span>
					{% endif %}
				</div>
			{% endfor %}

			{# Special segment for no classification (?) #}
			{% if no_classification %}
				<div class="ps-diagnostic-segment ps-diagnostic-segment--current ps-diagnostic-segment--unknown" style="background-color: #999999;">
					<span class="ps-diagnostic-segment-label">?</span>
				</div>
			{% endif %}
		{% else %}
			{# Fallback: single segment with current class #}
			<div class="ps-diagnostic-segment ps-diagnostic-segment--current" style="background-color: #CCCCCC;">
				<span class="ps-diagnostic-segment-label">{{ class_label|default('—') }}</span>
				{% if has_value %}
					<span class="ps-diagnostic-segment-value">{{ numeric_value }}</span>
				{% endif %}
			</div>
		{% endif %}
	</div>

	{# Message below scale #}
	<div class="ps-diagnostic-footer">
		{% if no_classification %}
			<p class="ps-diagnostic-message">{{ 'Energy label not provided by the owner'|t }}</p>
		{% elseif non_applicable %}
			<p class="ps-diagnostic-message">{{ 'Energy label not applicable'|t }}</p>
		{% else %}
			{% if show_numeric_value and has_value %}
				<p class="ps-diagnostic-message">
					<strong>{{ class_label }}</strong>:
					{{ numeric_value }}
					{% if diagnostic_type.unit %}
						{{ diagnostic_type.unit }}
					{% endif %}
				</p>
			{% endif %}

			{% if show_validity_dates and (valid_from or valid_to) %}
				<p class="ps-diagnostic-validity">
					{{ 'Valid'|t }}:
					{% if valid_from %}
						{{ valid_from|date('d/m/Y') }}
					{% endif %}
					{% if valid_from and valid_to %}
						→
					{% endif %}
					{% if valid_to %}
						{{ valid_to|date('d/m/Y') }}
					{% endif %}
				</p>
			{% endif %}
		{% endif %}
	</div>
</div>
