{#
 * Toggle (Atom)
 * Accessible on/off switch built on a native checkbox.
 *
 * @param {string} name - Form field name (required for form submission)
 * @param {string} [label] - Visible external label (recommended)
 * @param {string} [description] - Optional helper / context text below
 * @param {boolean} [checked=false] - Initial state
 * @param {boolean} [disabled=false] - Disable interaction
 * @param {string} [size='medium'] - Size variant: small | medium | large
 * @param {string} [color='default'] - Semantic color for checked state
 * @param {boolean} [showLabels=false] - Show internal ON/OFF labels inside track
 * @param {string} [onLabel='On'] - Internal ON text
 * @param {string} [offLabel='Off'] - Internal OFF text
 * @param {object} [attributes] - Additional HTML attributes
 *
 * Accessibility:
 * - role="switch" communicates binary toggle semantics
 * - aria-checked reflects current state
 * - Focus outline must remain visible (handled in CSS)
 * - Provide either external label or internal labels; never omit all
 #}
{%- set class = class|default(null) -%}
{%- set size = size|default('medium') -%}
{%- set size = size in ['small','medium','large']
  ? size
  : (size == 'sm' ? 'small' : (size == 'md' ? 'medium' : (size == 'lg' ? 'large' : 'medium'))) -%}
{%- set checked = checked|default(false) -%}
{%- set disabled = disabled|default(false) -%}
{%- set color = color|default('default') -%}
{%- set showLabels = showLabels|default(false) -%}
{%- set onLabel = onLabel|default('On') -%}
{%- set offLabel = offLabel|default('Off') -%}
{%- set attributes = attributes|default(create_attribute()) -%}
{%- set root_classes = [
  'ps-toggle',
  size != 'medium' ? 'ps-toggle--' ~ size : null,
  color != 'default' ? 'ps-toggle--' ~ color : null,
  disabled ? 'ps-toggle--disabled' : null,
  class ? class : null
] -%}
<label class="{{ root_classes|join(' ')|trim }}"
  {%- if attributes %} {{ attributes|without('class') }}{% endif -%}>
  <div class="ps-toggle__label">
    <input
      class="ps-toggle__input"
      type="checkbox"
      role="switch"
      aria-checked="{{ checked ? 'true' : 'false' }}"
      name="{{ name }}"
      {%- if checked %} checked{% endif -%}
      {%- if disabled %} disabled{% endif -%}
    />
    <span class="ps-toggle__track">
      {%- if showLabels %}
        <span class="ps-toggle__on-label">{{ onLabel }}</span>
        <span class="ps-toggle__off-label">{{ offLabel }}</span>
      {%- endif %}
      <span class="ps-toggle__thumb"></span>
    </span>
    {%- if label %}
      <span>{{ label }}</span>
    {%- endif %}
  </div>
  {%- if description %}
    <span class="ps-toggle__description">{{ description }}</span>
  {%- endif %}
</label>
