{#
 * ps-toggle (Atom)
 * Accessible on/off switch built on a native checkbox.
 *
 * Parameters:
 * - name (string): Form field name (required for form submission)
 * - label (string): Visible external label (recommended)
 * - description (string): Optional helper / context text below
 * - checked (boolean): Initial state (default false)
 * - disabled (boolean): Disable interaction (default false)
 * - size (string): small | medium | large (default medium)
 * - showLabels (boolean): Show internal ON/OFF labels inside track (default false)
 * - onLabel (string): Internal ON text (default 'On')
 * - offLabel (string): Internal OFF text (default 'Off')
 *
 * Accessibility:
 * - role="switch" communicates binary toggle semantics
 * - aria-checked reflects current state
 * - Focus outline must remain visible (handled in CSS)
 * - Provide either external label or internal labels; never omit all
 #}
{# Size mapping: support legacy values and new xs..xxl #}
{% set size = size|default('md') %}
{% set size = size in ['xs','sm','md','lg','xl','xxl']
  ? size
  : (size == 'small' ? 'sm' : (size == 'medium' ? 'md' : (size == 'large' ? 'lg' : 'md'))) %}
{% set checked = checked|default(false) %}
{% set disabled = disabled|default(false) %}
{% set color = color|default('default') %}
{% set showLabels = showLabels|default(false) %}
{% set onLabel = onLabel|default('On') %}
{% set offLabel = offLabel|default('Off') %}
{%- set root_classes = ['ps-toggle', size != 'md' ? 'ps-toggle--' ~ size : null, color != 'default' ? 'ps-toggle--' ~ color : null] -%}
{%- if disabled -%}
  {%- set root_classes = root_classes|merge(['ps-toggle--disabled']) -%}
{%- endif -%}
<label class="{{ root_classes|join(' ') }}">
  <div class="ps-toggle__label">
    <input
      class="ps-toggle__input"
      type="checkbox"
      role="switch"
      aria-checked="{{ checked ? 'true' : 'false' }}"
      name="{{ name }}"
      {% if checked %}checked{% endif %}
      {% if disabled %}disabled{% endif %}
    />
    <span class="ps-toggle__track">
      {% if showLabels %}
        <span class="ps-toggle__on-label">{{ onLabel }}</span>
        <span class="ps-toggle__off-label">{{ offLabel }}</span>
      {% endif %}
      <span class="ps-toggle__thumb"></span>
    </span>
    {% if label %}
      <span>{{ label }}</span>
    {% endif %}
  </div>
  {% if description %}
    <span class="ps-toggle__description">{{ description }}</span>
  {% endif %}
</label>
