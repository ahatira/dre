{#
/**
 * @file
 * Toggle (Element / Atom)
 *
 * Accessible on/off switch component built on native checkbox input.
 * Supports sizes, semantic colors, internal labels, and disabled state.
 *
 * @param {string} name
 *   Form field name attribute (required for form submission).
 * @param {string} [label]
 *   External visible label describing the preference.
 * @param {string} [description]
 *   Optional helper text below the control providing context.
 * @param {boolean} [checked=false]
 *   Initial switch state (true = on, false = off).
 * @param {boolean} [disabled=false]
 *   Disable interaction (reduces opacity, prevents state changes).
 * @param {string} [size='medium']
 *   Size variant: small | medium | large (default: medium).
 * @param {string} [color='default']
 *   Semantic color for checked state track background.
 * @param {boolean} [showLabels=false]
 *   Show internal ON/OFF indicators inside the track.
 * @param {string} [onLabel='On']
 *   Internal ON state label when showLabels = true.
 * @param {string} [offLabel='Off']
 *   Internal OFF state label when showLabels = true.
 * @param {Attribute} [attributes]
 *   Additional HTML attributes for the root label element.
 *
 * Features:
 * - Native checkbox semantics with visual track/thumb UI
 * - role="switch" for assistive technology
 * - Smooth transitions with prefers-reduced-motion support
 * - Three sizes (small, medium, large) with computed thumb sizing
 * - Nine semantic color variants for checked state
 * - Optional internal ON/OFF labels for clarity
 *
 * Accessibility:
 * - role="switch" communicates binary toggle semantics
 * - aria-checked reflects current state (true/false)
 * - Focus outline visible via :focus-visible (WCAG 2.2 AA)
 * - Keyboard operable (native checkbox behavior)
 * - Provide external label or internal labels; never omit all labels
 */
#}
{%- set class = class|default(null) -%}
{%- set size = size|default('medium') -%}
{%- set size = size in ['small','medium','large']
  ? size
  : (size == 'sm' ? 'small' : (size == 'md' ? 'medium' : (size == 'lg' ? 'large' : 'medium'))) -%}
{%- set checked = checked|default(false) -%}
{%- set disabled = disabled|default(false) -%}
{%- set color = color|default('default') -%}
{%- set showLabels = showLabels|default(false) -%}
{%- set onLabel = onLabel|default('On') -%}
{%- set offLabel = offLabel|default('Off') -%}
{%- set root_classes = ['ps-toggle'] -%}
{%- if size != 'medium' -%}
  {%- set root_classes = root_classes|merge(['ps-toggle--' ~ size]) -%}
{%- endif -%}
{%- if color != 'default' -%}
  {%- set root_classes = root_classes|merge(['ps-toggle--' ~ color]) -%}
{%- endif -%}
{%- if disabled -%}
  {%- set root_classes = root_classes|merge(['ps-toggle--disabled']) -%}
{%- endif -%}
{%- if class -%}
  {%- set root_classes = root_classes|merge([class]) -%}
{%- endif -%}
{%- set attr = (attributes ? attributes : create_attribute()).addClass(root_classes) -%}
<label{{ attr }}>
  <div class="ps-toggle__label">
    <input class="ps-toggle__input" type="checkbox" role="switch" aria-checked="{{ checked ? 'true' : 'false' }}" name="{{ name }}"
      {{- checked ? ' checked' : '' -}}
      {{- disabled ? ' disabled' : '' -}}
    />
    <span class="ps-toggle__track">
      {%- if showLabels %}
      <span class="ps-toggle__on-label">{{ onLabel }}</span>
      <span class="ps-toggle__off-label">{{ offLabel }}</span>
      {%- endif %}
      <span class="ps-toggle__thumb"></span>
    </span>
    {%- if label %}
    <span>{{ label }}</span>
    {%- endif %}
  </div>
  {%- if description %}
  <span class="ps-toggle__description">{{ description }}</span>
  {%- endif %}
</label>
