{#
 * Eyebrow (Atom) - Contextual label/kicker above heading
 *
 * @param string text - Displayed text (required)
 * @param string variant - Color: primary, secondary, accent, neutral, muted (optional, default: neutral)
 * @param string size - Size: small, medium (optional, default: medium)
 * @param boolean uppercase - Uppercase text (optional, default: true)
 * @param boolean bold - Bold text (optional, default: false)
 * @param boolean withLine - Decorative line (optional, default: false)
 * @param boolean withDot - Decorative dot (optional, default: false)
 * @param string icon - Optional icon name
 * @param object attributes - Additional HTML attributes
 #}

{% set variant = variant|default('neutral') %}
{% set size = size|default('medium') %}
{% set uppercase = uppercase|default(true) %}
{% set bold = bold|default(false) %}
{% set withLine = withLine|default(false) %}
{% set withDot = withDot|default(false) %}
{% set icon = icon|default('') %}

{% set classes = ['ps-eyebrow'] %}
{% if variant != 'neutral' %}
  {% set classes = classes|merge(['ps-eyebrow--' ~ variant]) %}
{% endif %}
{% if size != 'medium' %}
  {% set classes = classes|merge(['ps-eyebrow--' ~ size]) %}
{% endif %}
{% if uppercase %}
  {% set classes = classes|merge(['ps-eyebrow--uppercase']) %}
{% endif %}
{% if bold %}
  {% set classes = classes|merge(['ps-eyebrow--bold']) %}
{% endif %}
{% if withLine %}
  {% set classes = classes|merge(['ps-eyebrow--with-line']) %}
{% endif %}
{% if withDot %}
  {% set classes = classes|merge(['ps-eyebrow--with-dot']) %}
{% endif %}

<span class="{{ classes|join(' ')|trim }}"{% if attributes %} {{ attributes }}{% endif %}>
  {% if icon %}
    <span class="ps-eyebrow__icon" aria-hidden="true"></span>
  {% endif %}
  <span class="ps-eyebrow__text">{{ text }}</span>
  {% if withLine %}
    <span class="ps-eyebrow__line" aria-hidden="true"></span>
  {% endif %}
  {% if withDot %}
    <span class="ps-eyebrow__dot" aria-hidden="true">•</span>
  {% endif %}
</span>