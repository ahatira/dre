{#
/**
 * @file
 * PS Eyebrow (Atom) - Contextual label above heading with semantic colors
 *
 * @param {string} label - Text content (required)
 * @param {string} variant - Color variant: primary, secondary, success, danger, warning, info, gold, light, dark (optional)
 * @param {boolean} pill - Rounded pill shape (optional, default: false)
 * @param {string} icon - Icon name without 'icon-' prefix (optional)
 * @param {string} iconPosition - start|end (default: start)
 * @param {object} attributes - Additional attributes (optional)
 */
#}

{%- set label = label|default('Label') -%}
{%- set variant = variant|default('') -%}
{%- set pill = pill|default(false) -%}
{%- set icon = icon|default('') -%}
{%- set iconPosition = iconPosition|default('start') -%}

{%- set classes = [] -%}
{%- set classes = classes|merge(['ps-eyebrow']) -%}
{%- if variant -%}
  {%- set classes = classes|merge(['ps-eyebrow--' ~ variant]) -%}
{%- endif -%}
{%- if pill -%}
  {%- set classes = classes|merge(['ps-eyebrow--pill']) -%}
{%- endif -%}
{%- if modifier_class -%}
  {%- set classes = classes|merge([modifier_class]) -%}
{%- endif -%}

{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}

<span{{ attr }}{% if icon %} data-icon="{{ icon }}"{% endif %}{% if icon and iconPosition != 'start' %} data-icon-position="{{ iconPosition }}"{% endif %}>{{ label }}</span>