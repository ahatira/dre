{#
 * Checkbox atom
 * @param string name - Input name (required)
 * @param string value - Input value (required)
 * @param string label - Label text (optional)
 * @param boolean checked - Checked state (default: false)
 * @param boolean disabled - Disabled state (default: false)
 * @param string id - Input ID (optional)
 #}

{%- set checked = checked|default(false) -%}
{%- set disabled = disabled|default(false) -%}
{%- set id = id|default(name ~ '-' ~ value) -%}

{%- set classes = [] -%}
{%- set classes = classes|merge(['ps-checkbox']) -%}
{%- if disabled -%}{%- set classes = classes|merge(['ps-checkbox--disabled']) -%}{%- endif -%}

<label class="{{ classes|join(' ')|trim }}" for="{{ id }}">
  <input
    class="ps-checkbox__input"
    type="checkbox"
    id="{{ id }}"
    name="{{ name }}"
    value="{{ value }}"
    {%- if checked %}checked{% endif -%}
    {%- if disabled %}disabled aria-disabled="true"{% endif -%}
  />
  <span class="ps-checkbox__box" aria-hidden="true">
  </span>
  {%- if label -%}
    <span class="ps-checkbox__label">{{ label }}</span>
  {%- endif -%}
</label>