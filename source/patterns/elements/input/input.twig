{#
/**
 * @file
 * Input component (Atom)
 * 
 * Base text-like input field without label, icon, or helper text.
 * This is an ATOM component - for complete form inputs with labels and validation,
 * use the Form-field (Molecule) component instead.
 * 
 * Available variables:
 * - type: (string) Input type (text|email|password|number|search|tel|url, default: text)
 * - name: (string) Input name attribute (optional but recommended)
 * - value: (string) Input value (optional)
 * - placeholder: (string) Placeholder text (optional)
 * - id: (string) Input ID (optional, defaults to name-based id when provided)
 * - autocomplete: (string) Autocomplete attribute (optional)
 * - disabled: (boolean) Disabled state (default: false)
 * - required: (boolean) Required state (default: false)
 * - state: (string) Validation state: null | error | success | warning (optional)
 * - attributes: (Drupal\Core\Template\Attribute) Additional HTML attributes
 * 
 * @see https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input
 * @see https://www.w3.org/WAI/WCAG21/Understanding/non-text-content.html
 */
#}

{%- set type = type|default('text') -%}
{%- set name = name|default('') -%}
{%- set value = value|default('') -%}
{%- set placeholder = placeholder|default('') -%}
{%- set id = id|default(name ? name ~ '-input' : 'ps-input') -%}
{%- set autocomplete = autocomplete|default(null) -%}
{%- set disabled = disabled|default(false) -%}
{%- set required = required|default(false) -%}
{%- set state = state|default(null) -%}

{%- set classes = [
  'ps-input',
  'form-control',
  disabled ? 'ps-input--disabled' : null,
  state ? 'ps-input--' ~ state : null
] -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

{%- set attr = attr.setAttribute('type', type) -%}
{%- if id %}{% set attr = attr.setAttribute('id', id) %}{% endif -%}
{%- if name %}{% set attr = attr.setAttribute('name', name) %}{% endif -%}
{%- if value is not null and value is not same as(false) %}{% set attr = attr.setAttribute('value', value) %}{% endif -%}
{%- if placeholder %}{% set attr = attr.setAttribute('placeholder', placeholder) %}{% endif -%}
{%- if autocomplete %}{% set attr = attr.setAttribute('autocomplete', autocomplete) %}{% endif -%}
{%- if disabled %}{% set attr = attr.setAttribute('disabled', true) %}{% set attr = attr.setAttribute('aria-disabled', 'true') %}{% endif -%}
{%- if required %}{% set attr = attr.setAttribute('required', true) %}{% set attr = attr.setAttribute('aria-required', 'true') %}{% endif -%}
{%- if state == 'error' %}{% set attr = attr.setAttribute('aria-invalid', 'true') %}{% endif -%}

<input{{ attr }} />
