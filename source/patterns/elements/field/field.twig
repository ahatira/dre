{#
 * Field (Atom) - Base input/select/textarea field component
 * Base field without label or helper text.
 *
 * @param string type - Field type: text|number|email|search|select|textarea (default: 'text')
 * @param string value - Field value (optional)
 * @param string placeholder - Placeholder text (optional)
 * @param boolean disabled - Disabled state (default: false)
 * @param string error - Error message to display (optional, sets aria-invalid)
 * @param boolean done - Success/validated state (default: false, shows green border)
 * @param string icon - Icon name to display (optional, no "icon-" prefix)
 * @param string iconPosition - Icon position: left|right (default: 'right')
 * @param object attributes - Additional HTML attributes (optional)
 #}

{%- set type = type|default('text') -%}
{%- set value = value|default('') -%}
{%- set placeholder = placeholder|default('') -%}
{%- set disabled = disabled|default(false) -%}
{%- set error = error|default('') -%}
{%- set done = done|default(false) -%}
{%- set icon = icon|default('') -%}
{%- set iconPosition = iconPosition|default('right') -%}

{%- set classes = [] -%}
{%- set classes = classes|merge(['ps-field']) -%}
{%- if type != 'text' -%}
  {%- set classes = classes|merge(['ps-field--' ~ type]) -%}
{%- endif -%}
{%- if error -%}
  {%- set classes = classes|merge(['ps-field--error']) -%}
{%- elseif done -%}
  {%- set classes = classes|merge(['ps-field--done']) -%}
{%- endif -%}
{%- if disabled -%}
  {%- set classes = classes|merge(['ps-field--disabled']) -%}
{%- endif -%}
{%- if value -%}
  {%- set classes = classes|merge(['ps-field--filled']) -%}
{%- endif -%}
{%- if icon -%}
  {%- set classes = classes|merge(['ps-field--icon-' ~ iconPosition]) -%}
{%- endif -%}

<div
  class="{{ classes|join(' ')|trim }}"
  {% if attributes %}{{ attributes }}{% endif %}
>
  {%- if icon and iconPosition == 'left' -%}
    <span class="ps-field__icon ps-field__icon--left" data-icon="{{ icon }}" aria-hidden="true"></span>
  {%- endif -%}

  {%- if type == 'textarea' -%}
    <textarea
      class="ps-field__input"
      placeholder="{{ placeholder }}"
      {% if disabled %}disabled aria-disabled="true"{% endif %}
      {% if error %}aria-invalid="true" aria-describedby="field-error"{% endif %}
    >{{ value }}</textarea>
  {%- elseif type == 'select' -%}
    <div
      class="ps-field__input"
      role="combobox"
      aria-expanded="false"
      aria-haspopup="listbox"
      {% if disabled %}aria-disabled="true"{% endif %}
      {% if error %}aria-invalid="true" aria-describedby="field-error"{% endif %}
    >{{ value|default(placeholder) }}</div>
  {%- else -%}
    <input
      class="ps-field__input"
      type="{{ type }}"
      value="{{ value }}"
      placeholder="{{ placeholder }}"
      {% if disabled %}disabled aria-disabled="true"{% endif %}
      {% if error %}aria-invalid="true" aria-describedby="field-error"{% endif %}
    />
  {%- endif -%}

  {%- if icon and iconPosition == 'right' -%}
    <span class="ps-field__icon ps-field__icon--right" data-icon="{{ icon }}" aria-hidden="true"></span>
  {%- endif -%}

  {%- if error -%}
    <div class="ps-field__error" id="field-error" role="alert">{{ error }}</div>
  {%- endif -%}
</div>