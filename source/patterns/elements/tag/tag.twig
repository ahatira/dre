{#
/**
 * @file
 * Tag component template.
 *
 * @component Tag
 * @description
 * Interactive chip/badge for filtering, categorization, and selection.
 * Can render as button or link. Per maquette: 2 variants (filled blue, outline white).
 *
 * @atoms
 * @category Interactive
 *
 * @features
 * - 2 style variants (filled: blue solid, outline: white border)
 * - 3 sizes (sm: 12px, md: 14px, lg: 14px)
 * - Removable with close icon (start or end position)
 * - Selected state (darker background, bolder text)
 * - Can render as <button> or <a> (with url parameter)
 * - WCAG 2.2 AA compliant (aria-pressed, aria-label)
 *
 * @accessibility
 * - aria-pressed for toggle state
 * - aria-label for screen readers on removable tags
 * - Focus-visible indicator
 * - Keyboard accessible
 */
#}

{#
 * @param {string} label - Tag text content (required)
 * @param {string} [variant='filled'] - Style variant: filled (blue #5A8FE3), outline (white + border)
 * @param {string} [size='md'] - Size: sm, md, lg
 * @param {boolean} [removable=false] - Show remove button
 * @param {boolean} [iconStart=false] - Show icon at start (for search input tags)
 * @param {boolean} [selected=false] - Selected state (for filter tags)
 * @param {string} [url] - Optional link URL (renders as <a> instead of <button>)
 * @param {object} [attributes] - Additional HTML attributes for Drupal integration
 *
 * NOTE: Color parameter removed - per maquette only 2 variants exist (filled blue, outline white)
 #}

{%- set label = label|default('Tag') -%}
{%- set variant = variant|default('filled') -%}
{%- set size = size|default('md') -%}
{%- set removable = removable|default(false) -%}
{%- set iconStart = iconStart|default(false) -%}
{%- set selected = selected|default(false) -%}
{%- set url = url|default(null) -%}

{%- set tag_classes = ['ps-tag', 'ps-tag--' ~ variant] -%}
{%- if size != 'md' -%}
  {%- set tag_classes = tag_classes|merge(['ps-tag--' ~ size]) -%}
{%- endif -%}
{%- if selected -%}
  {%- set tag_classes = tag_classes|merge(['ps-tag--selected']) -%}
{%- endif -%}
{%- if removable -%}
  {%- set tag_classes = tag_classes|merge(['ps-tag--removable']) -%}
{%- endif -%}

{% if url -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(tag_classes) -%}
<a{{ attr }} href="{{ url }}">
  {% if iconStart and removable -%}
  <span class="ps-tag__icon ps-tag__icon--start" data-icon="close" aria-hidden="true"></span>
  {%- endif -%}
  <span class="ps-tag__label">{{ label }}</span>
  {%- if removable and not iconStart -%}
  <span class="ps-tag__icon ps-tag__icon--end" data-icon="close" aria-hidden="true"></span>
  {%- endif -%}
</a>
{%- else -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(tag_classes) -%}
{%- set attr = attr.setAttribute('type', 'button') -%}
{%- set attr = attr.setAttribute('aria-pressed', selected ? 'true' : 'false') -%}
{%- if removable -%}
  {%- set attr = attr.setAttribute('aria-label', 'Retirer ' ~ label) -%}
{%- endif -%}

<button{{ attr }}>
  {%- if iconStart and removable %}
  <span class="ps-tag__icon ps-tag__icon--start" data-icon="close" aria-hidden="true"></span>
  {%- endif %}
  <span class="ps-tag__label">{{ label }}</span>
  {%- if removable and not iconStart %}
  <span class="ps-tag__icon ps-tag__icon--end" data-icon="close" aria-hidden="true"></span>
  {%- endif -%}
</button>
{%- endif %}