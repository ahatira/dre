{#
 * Badge atom - Compact indicator
 * Props:
 *   text (string) - Badge text (required)
 *   icon (string) - Icon name (optional, e.g., 'check', 'calendar')
 *   color (string) - default|primary|secondary|gold|info|success|warning|danger (default: default)
 *   pill (boolean) - Rounded pill shape (default: false)
 *   url (string) - Link URL (renders <a>)
 *   size (string) - small|medium|large (default: medium)
 #}

{%- set color = color|default('default') -%}
{%- set size = size|default('medium') -%}
{%- set pill = pill|default(false) -%}
{%- set tag = url ? 'a' : 'span' -%}

{%- set badge_classes = ['ps-badge'] -%}
{%- if color != 'default' -%}
  {%- set badge_classes = badge_classes|merge(['ps-badge--' ~ color]) -%}
{%- endif -%}
{%- if size != 'medium' -%}
  {%- set badge_classes = badge_classes|merge(['ps-badge--' ~ size]) -%}
{%- endif -%}
{%- if pill -%}
  {%- set badge_classes = badge_classes|merge(['ps-badge--pill']) -%}
{%- endif -%}

<{{ tag }} class="{{ badge_classes|join(' ')|trim }}"{% if url %} href="{{ url }}"{% endif %}>
  {%- if icon -%}
    <span class="ps-badge__icon" data-icon="{{ icon }}"></span>
  {%- endif -%}
  <span class="ps-badge__text">{{- text -}}</span>
</{{ tag }}>
