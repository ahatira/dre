{#
 * Badge atom - Compact status/label indicator
 * @param string text - Badge text content (required)
 * @param string icon - Icon name (e.g., 'check', 'calendar')
 * @param string iconPosition - start|end (default: start)
 * @param string color - neutral|primary|secondary|success|danger|warning|info|light|dark|gold (default: neutral)
 * @param boolean pill - Fully rounded pill shape (default: false)
 * @param string url - Link URL (optional, renders <a> tag)
 * @param object attributes - Additional HTML attributes for Drupal integration (optional)
 #}

{%- set color = color|default('neutral') -%}
{%- set pill = pill|default(false) -%}
{%- set icon = icon|default(null) -%}
{%- set iconPosition = iconPosition|default('start') -%}
{%- set tag = url ? 'a' : 'span' -%}

{%- set badge_classes = [
  'ps-badge',
  color ? 'ps-badge--' ~ color : null,
  pill ? 'ps-badge--pill' : null
] -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(badge_classes) -%}

<{{ tag }}{{ attr }}
  {%- if url %} href="{{ url }}"{% endif -%}
  {%- if icon %} data-icon="{{ icon }}"{% endif -%}
  {%- if icon and iconPosition != 'start' %} data-icon-position="{{ iconPosition }}"{% endif -%}>
  {{- text -}}
</{{ tag }}>
