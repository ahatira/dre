{#
 * Badge (Atom) - Compact status/label indicator
 *
 * @param string text - Badge text content (required)
 * @param string icon - Optional icon name (e.g., 'check', 'calendar')
 * @param string color - Semantic color: default|primary|secondary|gold|info|success|warning|danger (default: default)
 * @param boolean pill - Fully rounded pill shape (default: false)
 * @param string url - Optional link URL (renders <a> tag)
 * @param string size - Badge size: small|medium|large (default: medium)
 * @param object attributes - Additional HTML attributes
 #}

{%- set color = color|default('default') -%}
{%- set size = size|default('medium') -%}
{%- set pill = pill|default(false) -%}
{%- set tag = url ? 'a' : 'span' -%}

{%- set badge_classes = ['ps-badge'] -%}
{%- if color != 'default' -%}
  {%- set badge_classes = badge_classes|merge(['ps-badge--' ~ color]) -%}
{%- endif -%}
{%- if size != 'medium' -%}
  {%- set badge_classes = badge_classes|merge(['ps-badge--' ~ size]) -%}
{%- endif -%}
{%- if pill -%}
  {%- set badge_classes = badge_classes|merge(['ps-badge--pill']) -%}
{%- endif -%}

<{{ tag }} class="{{ badge_classes|join(' ')|trim }}"{% if url %} href="{{ url }}"{% endif %}>
  {%- if icon -%}
    <span class="ps-badge__icon" data-icon="{{ icon }}"></span>
  {%- endif -%}
  <span class="ps-badge__text">{{- text -}}</span>
</{{ tag }}>
