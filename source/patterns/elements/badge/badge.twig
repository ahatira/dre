{#
 * Badge (Atom) - Compact status/label indicator
 * Composition-ready: Supports empty text for visual-only badges
 *
 * @param string text - Badge text content (required)
 * @param string icon - Optional icon name (e.g., 'check', 'calendar')
 * @param string iconPosition - Icon position: start|end (default: start)
 * @param string color - Semantic color: primary|secondary|success|danger|warning|info|light|dark|gold (default: primary)
 * @param boolean pill - Fully rounded pill shape (default: false)
 * @param string url - Optional link URL (renders <a> tag)
 * @param object attributes - Additional HTML attributes for composition (optional)
 #}

{%- set color = color|default('primary') -%}
{%- set pill = pill|default(false) -%}
{%- set icon = icon|default(null) -%}
{%- set iconPosition = iconPosition|default('start') -%}
{%- set tag = url ? 'a' : 'span' -%}
{%- set has_text = text is defined and text is not empty -%}
{%- set class = class|default(null) -%}

{%- set badge_classes = [
  'ps-badge',
  color != 'primary' ? 'ps-badge--' ~ color : null,
  pill ? 'ps-badge--pill' : null,
  class ? class : null
] -%}

<{{ tag }} class="{{ badge_classes|join(' ')|trim }}"
  {%- if attributes %} {{ attributes|without('class') }}{% endif -%}
  {%- if url %} href="{{ url }}"{% endif -%}
  {%- if icon %} data-icon="{{ icon }}"{% endif -%}
  {%- if icon and iconPosition != 'start' %} data-icon-position="{{ iconPosition }}"{% endif -%}>
  {%- if has_text -%}
    <span class="ps-badge__text">{{- text -}}</span>
  {%- endif -%}
</{{ tag }}>
