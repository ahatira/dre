{#
 * Badge atom - Compact indicator
 * Props:
 *   text (string) - Badge text (required)
 *   icon (string) - Icon name (optional, e.g., 'icon-eye')
 *   variant (string) - default|primary|secondary|gold|info|success|warning|danger (default: default)
 *   pill (boolean) - Rounded pill shape (default: false)
 *   url (string) - Link URL (renders <a>)
 *   size (string) - small|medium|large (default: medium)
 #}

{%-
  set variant = variant|default('default')
-%}
{%-
  set size = size|default('medium')
-%}
{%-
  set pill = pill|default(false)
-%}
{%-
  set tag = url ? 'a' : 'span'
-%}

{%-
  set badge_classes = 'ps-badge ps-badge--' ~ variant ~ ' ps-badge--' ~ size
-%}
{%- if pill -%}
  {%- set badge_classes = badge_classes ~ ' ps-badge--pill' -%}
{%- endif -%}

<{{ tag }} class="{{ badge_classes }}"{% if url %} href="{{ url }}"{% endif %}>
  {%- if icon -%}
    {%- include '../icon/icon.twig' with {
      name: icon,
      size: 'small'
    } only -%}
  {%- endif -%}
  <span class="ps-badge__text">{{- text -}}</span>
</{{ tag }}>
