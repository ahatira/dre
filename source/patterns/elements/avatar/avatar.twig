{#
/**
 * @file
 * Avatar component (Atom)
 * 
 * User or agent visual representation with image, initials, or icon fallback.
 * Supports sizes, shapes, status badge, and interactive states.
 * 
 * Available variables:
 * - src: (string) Image URL (optional, fallback to initials or icon)
 * - alt: (string) Alt text for image (required when src provided)
 * - initials: (string) Initials text (2 letters max, fallback if no image)
 * - gender: (string) male | female (default: male, used for icon fallback)
 * - size: (string) small | medium | large (default: medium)
 * - shape: (string) circle | square | rounded (default: circle)
 * - status: (string) online | offline | busy (optional status badge)
 * - bordered: (boolean) White border (default: false)
 * - clickable: (boolean) Interactive hover/focus (default: false)
 * - href: (string) Link URL if clickable (transforms to <a>)
 * - attributes: (Drupal\Core\Template\Attribute) Additional HTML attributes (optional, default: create_attribute())
 * 
 * @see https://www.w3.org/WAI/WCAG21/Understanding/non-text-content.html
 */
#}

{%- set size = size|default('medium') -%}
{%- set shape = shape|default('circle') -%}
{%- set gender = gender|default('male') -%}
{%- set bordered = bordered|default(false) -%}
{%- set clickable = clickable|default(false) -%}
{%- set clickable = href ? true : clickable -%}

{%- set has_image = src and src is not empty -%}
{%- set has_initials = initials and initials is not empty and not has_image -%}
{%- set has_fallback = not has_image and not has_initials -%}

{%- set avatar_classes = [
  'ps-avatar',
  size != 'medium' ? 'ps-avatar--' ~ size : null,
  shape != 'circle' ? 'ps-avatar--' ~ shape : null,
  has_initials ? 'ps-avatar--initials' : null,
  has_fallback ? 'ps-avatar--' ~ gender : null,
  bordered ? 'ps-avatar--bordered' : null,
  clickable ? 'ps-avatar--clickable' : null
] -%}

{%- set tag = href ? 'a' : 'div' -%}

{%- set attr = (attributes ? attributes : create_attribute()).addClass(avatar_classes) -%}

<{{ tag }}{{ attr }}
  {%- if href %} href="{{ href }}"{% endif -%}
>
  {# Atom 1: Image #}
  {%- if has_image -%}
    {%- include '@elements/image/image.twig' with {
      src: src,
      alt: alt|default(''),
      fit: 'cover',
      rounded: shape == 'circle' ? 'full' : (shape == 'rounded' ? 'md' : 'none'),
      loading: 'lazy',
      attributes: create_attribute().addClass('ps-avatar__image')
    } only -%}
  {%- endif -%}

  {# Atom 2: Initials Text #}
  {%- if has_initials -%}
    {%- include '@elements/text/text.twig' with {
      text: initials,
      tag: 'span',
      strong: true,
      attributes: create_attribute().addClass('ps-avatar__text')
    } only -%}
  {%- endif -%}

  {# Atom 3: Status Dot #}
  {%- if status -%}
    {%- set status_label = status == 'online' ? 'Online' : (status == 'busy' ? 'Busy' : 'Offline') -%}
    {%- set status_class = status in ['online','offline','busy'] ? 'ps-avatar__status--' ~ status : null -%}
    {%- set status_classes = ['ps-avatar__status', status_class] -%}
    <span class="{{ status_classes|join(' ')|trim }}" aria-label="{{ status_label }}" role="status"></span>
  {%- endif -%}
</{{ tag }}>
