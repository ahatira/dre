{#
 * Avatar atom
 * @param string src - Image URL (optional)
 * @param string alt - Alt text (optional)
 * @param string initials - Initials fallback (optional)
 * @param string gender - male|female (optional, for icon fallback)
 * @param string size - xs|sm|md|lg|xl (default: xl)
 * @param string shape - circle|square|rounded (default: circle)
 * @param string status - online|offline|busy (optional)
 * @param boolean bordered - Border (default: false)
 * @param boolean clickable - Clickable (default: false)
 * @param string href - URL if clickable (optional)
 #}

{%- set size = size|default('md') -%}
{%- set shape = shape|default('circle') -%}
{%- set bordered = bordered|default(false) -%}
{%- set clickable = clickable|default(false) -%}

{%- set has_image = src and src is not empty -%}
{%- set has_initials = initials and initials is not empty and not has_image -%}
{%- set has_icon = not has_image and not has_initials -%}
{%- set gender = gender|default('male') -%}

{%- set wrapper_classes = ['ps-avatar-wrapper'] -%}
{%- if size != 'md' -%}
  {%- set wrapper_classes = wrapper_classes|merge(['ps-avatar-wrapper--' ~ size]) -%}
{%- endif -%}

{%- set avatar_classes = ['ps-avatar'] -%}
{%- if shape != 'circle' -%}
  {%- set avatar_classes = avatar_classes|merge(['ps-avatar--' ~ shape]) -%}
{%- endif -%}
{%- if has_initials -%}
  {%- set avatar_classes = avatar_classes|merge(['ps-avatar--initials']) -%}
{%- endif -%}
{%- if has_icon -%}
  {%- set avatar_classes = avatar_classes|merge(['ps-avatar--icon']) -%}
{%- endif -%}
{%- if bordered -%}
  {%- set avatar_classes = avatar_classes|merge(['ps-avatar--bordered']) -%}
{%- endif -%}
{%- if clickable -%}
  {%- set avatar_classes = avatar_classes|merge(['ps-avatar--clickable']) -%}
{%- endif -%}

{%- set tag = href ? 'a' : 'div' -%}

<div class="{{ wrapper_classes|join(' ')|trim }}"{%- if attributes %} {{ attributes }}{% endif -%}>
  <{{ tag }} class="{{ avatar_classes|join(' ')|trim }}"
    {%- if href %}href="{{ href }}"{% endif -%}
  >
    {%- if has_image -%}
      <img class="ps-avatar__image" src="{{ src }}" alt="{{ alt|default('') }}" loading="lazy" />
    {%- elseif has_initials -%}
      <span class="ps-avatar__text">{{ initials }}</span>
    {%- else -%}
      <span class="ps-avatar__icon" data-agent="{{ gender == 'female' ? 'female' : 'male' }}" aria-hidden="true"></span>
    {%- endif -%}
  </{{ tag }}>
  
  {%- if status -%}
    <span class="ps-avatar__status" data-status="{{ status }}" aria-label="{% if status == 'online' %}Online{% elseif status == 'busy' %}Busy{% else %}Offline{% endif %}"></span>
  {%- endif -%}
</div>