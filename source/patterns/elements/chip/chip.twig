{#
 * Chip atom - Removable tag/filter indicator
 * @param {string} label - Chip text content (required)
 * @param {string} variant - neutral|primary|success|danger|warning|info|gold|light|dark (default: neutral)
 * @param {boolean} pill - Fully rounded pill shape (default: false)
 * @param {string} icon - Icon name (e.g., 'check', 'info')
 * @param {boolean} removable - Show remove button (default: false)
 * @param {object} attributes - Additional HTML attributes for Drupal integration (optional)
 #}

{%- set variant = variant|default('neutral') -%}
{%- set pill = pill|default(false) -%}
{%- set icon = icon|default(null) -%}
{%- set removable = removable|default(false) -%}

{%- set chip_classes = [
  'ps-chip',
  variant ? 'ps-chip--' ~ variant : null,
  pill ? 'ps-chip--pill' : null
] -%}

<span class="{{ chip_classes|join(' ')|trim }}"
  {%- if attributes %} {{ attributes|without('class') }}{% endif -%}
  {%- if icon %} data-icon="{{ icon }}"{% endif -%}>
  {{- label -}}
  {%- if removable -%}
    <button type="button" class="ps-chip__remove" aria-label="Remove {{ label }}" data-chip-remove>
      <span data-icon="x" aria-hidden="true"></span>
    </button>
  {%- endif -%}
</span>
