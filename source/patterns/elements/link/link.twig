{#
 * Link element (Atom)
 * Interactive link with color variants and proper hover/active/visited states
 * @param string label - Link text (required)
 * @param string url - Link URL (required)
 * @param string variant - Color variant: primary, secondary, success, danger, warning, info, gold, light, dark (optional)
 * @param string icon - Icon name without 'icon-' prefix (optional)
 * @param string target - Link target (_self or _blank) (optional, default: '_self')
 * @param Drupal\Core\Template\Attribute attributes - Additional attributes (optional)
 #}

{% set label = label|default('Link text') %}
{% set url = url|default('#') %}
{% set variant = variant|default('') %}
{% set icon = icon|default('') %}
{% set target = target|default('_self') %}

{% set classes = [
  'ps-link',
  variant ? 'ps-link--' ~ variant : null
] %}

<a {% if attributes %}{{ attributes.addClass(classes) }}{% else %}class="{{ classes|join(' ')|trim }}"{% endif %} href="{{ url }}"{% if target == '_blank' %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ label }}{% if icon %}<span class="ps-link__icon" data-icon="{{ icon }}" aria-hidden="true"></span>{% endif %}</a>