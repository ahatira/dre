{#
 * Link element (Atom)
 * Utility-first: Apply color/size/decoration via utilities (.text-primary, .text-lg, .no-underline)
 * @param string label - Link text (required)
 * @param string url - Link URL (required)
 * @param string icon - Icon name without 'icon-' prefix (optional)
 * @param boolean pill - Pill style with padding/background (optional, default: false)
 * @param string target - Link target (_self or _blank) (optional, default: '_self')
 * @param Drupal\Core\Template\Attribute attributes - Additional attributes (optional)
 #}

{% set label = label|default('Link text') %}
{% set url = url|default('#') %}
{% set icon = icon|default('') %}
{% set pill = pill|default(false) %}
{% set target = target|default('_self') %}

{% set classes = [
  'ps-link',
  pill ? 'ps-link--pill' : null
] %}

<a class="{{ classes|join(' ')|trim }}"
  {%- if attributes %} {{ attributes.addClass(classes)|without('class') }}{% endif -%}
  href="{{ url }}"
  {% if target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}
>
  {{ label }}
  {% if icon %}
    <span class="ps-link__icon" data-icon="{{ icon }}" aria-hidden="true"></span>
  {% endif %}
</a>