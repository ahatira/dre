{#
/**
 * @file
 * PS Logo (Atom) - Brand logo for BNP Paribas Real Estate
 *
 * @param {string} [variant='default'] - Logo variant: default | square
 * @param {string} [size='medium'] - Logo size: small | medium | large
 * @param {string} [href='/'] - Link URL (wraps logo in <a> if provided)
 * @param {string} [alt='BNP Paribas Real Estate'] - Accessible alt text for logo
 * @param {Drupal\Core\Template\Attribute} [attributes] - Additional HTML attributes
 */
#}

{%- set variant = variant|default('default') -%}
{%- set size = size|default('medium') -%}
{# Map legacy 5-size system to 3-size system #}
{%- set size = size == 'xs' or size == 'sm' ? 'small' : (size == 'md' ? 'medium' : (size == 'lg' or size == 'xl' ? 'large' : size)) -%}
{%- set href = href|default(null) -%}
{%- set alt = alt|default('BNP Paribas Real Estate') -%}

{%- set classes = [
  'ps-logo',
  size != 'medium' ? 'ps-logo--' ~ size : null,
  variant != 'default' ? 'ps-logo--' ~ variant : null,
  modifier_class
] -%}

{# Determine logo source based on variant #}
{%- set logo_src = variant == 'square' ? '/logo/logo-square-3d.svg' : '/logo/logo.svg' -%}

{# Determine dimensions based on size #}
{%- if size == 'small' -%}
  {%- set img_height = variant == 'square' ? '32' : '24' -%}
  {%- set img_width = variant == 'square' ? '32' : '120' -%}
{%- elseif size == 'large' -%}
  {%- set img_height = variant == 'square' ? '64' : '48' -%}
  {%- set img_width = variant == 'square' ? '64' : '240' -%}
{%- else -%}
  {%- set img_height = variant == 'square' ? '48' : '32' -%}
  {%- set img_width = variant == 'square' ? '48' : '180' -%}
{%- endif -%}

{%- if href -%}
{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}
<a{{ attr }} href="{{ href }}">
  <img class="ps-logo__img" src="{{ logo_src }}" alt="{{ alt }}" width="{{ img_width }}" height="{{ img_height }}" />
</a>
{%- else -%}
{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}
<div{{ attr }}>
  <img class="ps-logo__img" src="{{ logo_src }}" alt="{{ alt }}" width="{{ img_width }}" height="{{ img_height }}" />
</div>
{%- endif -%}
