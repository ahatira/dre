{#
 * Heading (Atom) - Semantic typographic heading (h1-h6)
 * UTILITY-FIRST: Use .text-*, .font-*, .text-center utilities for styling variations
 *
 * @param string text - Heading text content (required)
 * @param string level - h1|h2|h3|h4|h5|h6 (default: h1)
 * @param boolean visuallyHidden - Hide visually but keep for screen readers (default: false)
 * @param Attribute attributes - Additional HTML attributes (optional)
 *
 * EXAMPLES:
 * - Color variant: attributes.addClass('text-primary')
 * - Font weight: attributes.addClass('font-bold')
 * - Alignment: attributes.addClass('text-center')
 * - Combined: attributes.addClass('text-primary font-extrabold text-center')
 #}

{%- set level = level|default('h1') -%}
{%- set visuallyHidden = visuallyHidden|default(false) -%}

{%- set classes = [
  level,
  visuallyHidden ? 'visually-hidden' : null
] -%}

<{{ level }}
  {{- attributes ? attributes.addClass(classes) : 'class="' ~ classes|join(' ')|trim ~ '"' -}}>
  {{- text -}}
</{{ level }}>
