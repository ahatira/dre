{#
 * Flag (Element/Atom)
 * Country/language visual indicator using flag SVG images
 *
 * @param {string} [code] - Country code ISO 3166-1 alpha-2 (FR, GB, DE, ES, IT)
 * @param {string} [locale] - BCP 47 locale tag (fr-FR, en-GB) - auto-extracts country code if provided
 * @param {string} [label] - Accessible label for screen readers (e.g., 'France', 'United Kingdom')
 * @param {string} [src] - Explicit flag image path (overrides auto /flags/{code}.svg)
 * @param {string} [size='medium'] - Flag size: small | medium | large
 * @param {string} [shape='square'] - Flag shape: square | rounded | circle
 * @param {boolean} [disabled=false] - Disabled state (reduced opacity + grayscale)
 * @param {boolean} [decorative=false] - Decorative only (aria-hidden, not announced)
 * @param {Drupal\Core\Template\Attribute} [attributes] - Additional HTML attributes
 #}

{%- set class = class|default(null) -%}
{# Map legacy 5-size system (xs/sm/md/lg/xl) to 3-size system (small/medium/large) #}
{%- set size = size|default('medium') -%}
{%- set size = size == 'xs' or size == 'sm' ? 'small' : (size == 'md' ? 'medium' : (size == 'lg' or size == 'xl' ? 'large' : size)) -%}
{%- set shape = shape|default('square') -%}
{%- set disabled = disabled|default(false) -%}
{%- set decorative = decorative|default(false) -%}
{%- set attributes = attributes|default(create_attribute()) -%}

{%- set classes = [
  'ps-flag',
  size != 'medium' ? 'ps-flag--' ~ size : null,
  shape != 'square' ? 'ps-flag--' ~ shape : null,
  disabled ? 'ps-flag--disabled' : null,
  class ? class : null
] -%}

{# Normalize locale: replace underscore with dash (fr_FR -> fr-FR) #}
{%- set locale_norm = locale is defined and locale ? locale|replace({'_':'-'}) : null -%}
{%- set parts = locale_norm ? locale_norm|split('-') : [] -%}
{%- set region = parts|length > 1 and parts[1]|length == 2 ? parts[1]|upper : null -%}

{# Determine country code: explicit code, or extract from locale #}
{%- set country_code = code is defined and code ? code|upper : (region ?? null) -%}
{%- set asset_code = country_code ? country_code|lower : 'xx' -%}

{# Build image source #}
{%- set img_src = src ?? ('/flags/' ~ asset_code ~ '.svg') -%}

{# Build alt text #}
{%- set alt_text = decorative ? '' : (label ?? country_code ?? 'Flag') -%}

{# Build title attribute #}
{%- set title_text = decorative ? '' : (label ?? country_code) -%}

{# Determine image dimensions based on size (4:3 aspect ratio, 1:1 for circle) #}
{%- if size == 'small' -%}
  {%- set img_height = '16' -%}
  {%- set img_width = shape == 'circle' ? '16' : '21' -%}
{%- elseif size == 'large' -%}
  {%- set img_height = '24' -%}
  {%- set img_width = shape == 'circle' ? '24' : '32' -%}
{%- else -%}
  {%- set img_height = '20' -%}
  {%- set img_width = shape == 'circle' ? '20' : '27' -%}
{%- endif -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<span{{ attr }}
  {{- title_text ? ' title="' ~ title_text ~ '"' : '' -}}>
  <img class="ps-flag__img" src="{{ img_src }}" alt="{{ alt_text }}" width="{{ img_width }}" height="{{ img_height }}"{{- decorative ? ' aria-hidden="true"' : '' -}} />
</span>