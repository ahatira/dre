{#
 * Icon (Atom) - Icon font element from bnpre-icons
 *
 * @param string name - Icon name WITHOUT "icon-" prefix (e.g., 'search', 'check', 'poi-hotel') (required)
 * @param string size - small|medium|large|xlarge (default: medium)
 * @param string color - Custom CSS color value or design token (default: inherit)
 * @param boolean disabled - Disabled state with reduced opacity (default: false)
 * @param string ariaLabel - Accessibility label for informative icons (optional, omit for decorative)
 #}

{% set name = name|default('search') %}
{% set size = size|default('medium') %}
{% set disabled = disabled|default(false) %}

{% set classes = [] %}
{% set classes = classes|merge(['icon-' ~ name]) %}
{% if size %}
  {% set classes = classes|merge(['ps-icon--' ~ size]) %}
{% endif %}
{% if disabled %}
  {% set classes = classes|merge(['ps-icon--disabled']) %}
{% endif %}

<i
  class="{{ classes|join(' ')|trim }}"
  {% if attributes %}{{ attributes }}{% endif %}
  {% if color %}style="color: {{ color }};"{% endif %}
  {% if ariaLabel %}aria-label="{{ ariaLabel }}" role="img"{% else %}aria-hidden="true"{% endif %}
></i>
