{#
 * Icon element - Uses icon fonts from source/props/icons.css
 * @param string name - Icon class name (required) - Full class: 'icon-account', 'icon-search', 'icon-poi-hotel', etc.
 * @param string size - small | medium | large | xlarge (default: medium)
 * @param string color - Custom color (optional, inherits by default)
 * @param boolean disabled - Disabled state (default: false)
 * @param string ariaLabel - Accessibility label (optional, use for informative icons)
 #}

{% set name = name|default('icon-search') %}
{% set size = size|default('medium') %}
{% set disabled = disabled|default(false) %}

{% set classes = [] %}
{% set classes = classes|merge([name]) %}
{% if size %}
  {% set classes = classes|merge(['ps-icon--' ~ size]) %}
{% endif %}
{% if disabled %}
  {% set classes = classes|merge(['ps-icon--disabled']) %}
{% endif %}

<i
  class="{{ classes|join(' ')|trim }}"
  {% if attributes %}{{ attributes }}{% endif %}
  {% if color %}style="color: {{ color }};"{% endif %}
  {% if ariaLabel %}aria-label="{{ ariaLabel }}" role="img"{% else %}aria-hidden="true"{% endif %}
></i>
