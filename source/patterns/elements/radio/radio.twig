{#
 * PS Radio (Atom) - Radio button for single selection
 *
 * @param string name - Radio group name for single selection (required, all radios in group share same name)
 * @param string value - Unique value for this radio button (required)
 * @param string label - Visible label text displayed next to radio (optional but recommended)
 * @param boolean checked - Checked state, only one per group should be true (default: false)
 * @param boolean disabled - Disabled state with 50% opacity (default: false)
 #}
{%- set name = name|default('radio') -%}
{%- set value = value|default('1') -%}
{%- set label = label|default('Option label') -%}
{%- set checked = checked|default(false) -%}
{%- set disabled = disabled|default(false) -%}

<label class="ps-radio{% if disabled %} ps-radio--disabled{% endif %}">
  <input
    type="radio"
    class="ps-radio__input"
    name="{{ name }}"
    value="{{ value }}"
    {% if checked %}checked{% endif %}
    {% if disabled %}disabled{% endif %}
  />
  <span class="ps-radio__circle" aria-hidden="true"></span>
  {% if label %}
    <span class="ps-radio__label">{{ label }}</span>
  {% endif %}
</label>