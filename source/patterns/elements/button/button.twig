{#
 * Button atom
 * @param string label - Button text (required)
 * @param string variant - primary|secondary|success|info|warning|danger|dark|light (default: primary)
 * @param boolean outline - Outline style (default: false)
 * @param string size - small|medium|large (default: medium)
 * @param string url - Destination URL (optional)
 * @param string target - _self|_blank (default: _self)
 * @param string icon - Icon name (optional)
 * @param string iconPosition - left|right (default: right)
 * @param boolean disabled - Disabled state (default: false)
 * @param boolean loading - Loading state (default: false)
 * @param boolean fullWidth - Full width (default: false)
 #}

{%- set variant = variant|default('primary') -%}
{%- set outline = outline|default(false) -%}
{%- set size = size|default('medium') -%}
{%- set iconPosition = iconPosition|default('right') -%}
{%- set target = target|default('_self') -%}
{%- set disabled = disabled|default(false) -%}
{%- set loading = loading|default(false) -%}
{%- set fullWidth = fullWidth|default(false) -%}

{%- set classes = [] -%}
{%- set classes = classes|merge(['ps-button']) -%}
{%- set classes = classes|merge(['ps-button--' ~ variant]) -%}
{%- set classes = classes|merge(['ps-button--' ~ size]) -%}
{%- if outline -%}{%- set classes = classes|merge(['ps-button--outline']) -%}{%- endif -%}
{%- if icon and not label -%}{%- set classes = classes|merge(['ps-button--icon-only']) -%}{%- endif -%}
{%- if icon and label and iconPosition -%}{%- set classes = classes|merge(['ps-button--icon-' ~ iconPosition]) -%}{%- endif -%}
{%- if disabled -%}{%- set classes = classes|merge(['ps-button--disabled']) -%}{%- endif -%}
{%- if loading -%}{%- set classes = classes|merge(['ps-button--loading']) -%}{%- endif -%}
{%- if fullWidth -%}{%- set classes = classes|merge(['ps-button--full-width']) -%}{%- endif -%}

{%- set tag = url ? 'a' : 'button' -%}

<{{ tag }} class="{{ classes|join(' ')|trim }}"
  {%- if attributes %}{{ attributes }}{% endif -%}
  {%- if url %}href="{{ url }}"{% endif -%}
  {%- if target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif -%}
  {%- if disabled and tag == 'button' %}disabled aria-disabled="true"{% endif -%}
  {%- if loading %}aria-busy="true"{% endif -%}
>
  {%- if loading -%}
    <span class="ps-button__spinner" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10" opacity="0.25"/>
        <path d="M12 2a10 10 0 0 1 10 10" opacity="0.75"/>
      </svg>
    </span>
  {%- endif -%}

  {%- if icon and iconPosition == 'left' and label -%}
    <span class="ps-button__icon ps-button__icon--left" aria-hidden="true">
      {%- include '@elements/icon/icon.twig' with {
        name: icon,
        size: size == 'small' ? 'small' : (size == 'large' ? 'large' : 'medium')
      } only -%}
    </span>
  {%- endif -%}

  {%- if label -%}
    <span class="ps-button__label">{{- label -}}</span>
  {%- endif -%}

  {%- if icon and (iconPosition == 'right' or not label) -%}
    <span class="ps-button__icon{% if iconPosition == 'right' %} ps-button__icon--right{% endif %}" aria-hidden="true">
      {%- include '@elements/icon/icon.twig' with {
        name: icon,
        size: size == 'small' ? 'small' : (size == 'large' ? 'large' : 'medium')
      } only -%}
    </span>
  {%- endif -%}
</{{ tag }}>
