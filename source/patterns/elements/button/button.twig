{#
 * Button atom
 * @param {string} label - Button text (required)
 * @param {string} [variant] - Semantic variant: primary|secondary|gold|success|info|warning|danger|light|dark (omit for neutral/gray)
 * @param {boolean} [outline=false] - Outline style
 * @param {string} [size] - Size: small|large (omit for medium/default)
 * @param {string} [url] - Link URL (renders <a> tag)
 * @param {string} [target='_self'] - Link target: _self|_blank
 * @param {string} [icon] - Icon name (e.g., 'check', 'arrow-right')
 * @param {string} [iconPosition='start'] - Icon position: start|end
 * @param {boolean} [disabled=false] - Disabled state
 * @param {boolean} [loading=false] - Loading state
 * @param {boolean} [fullWidth=false] - Full width
 * @param {boolean} [toggle=false] - Enable toggle state behavior
 * @param {boolean} [active=false] - Pre-toggle button (requires toggle=true)
 * @param {string} [ariaLabel] - Custom aria-label (overrides label)
 * @param {string} [dataAction] - Custom data-action attribute
 * @param {string} [class] - Additional CSS classes
 * @param {object} [attributes] - Additional HTML attributes for Drupal integration
 #}

{%- set variant = variant|default(null) -%}
{%- set outline = outline|default(false) -%}
{%- set size = size|default(null) -%}
{%- set icon = icon|default(null) -%}
{%- set iconPosition = iconPosition|default('start') -%}
{%- set target = target|default('_self') -%}
{%- set disabled = disabled|default(false) -%}
{%- set loading = loading|default(false) -%}
{%- set fullWidth = fullWidth|default(false) -%}
{%- set toggle = toggle|default(false) -%}
{%- set active = active|default(false) -%}
{%- set ariaLabel = ariaLabel|default(null) -%}
{%- set dataAction = dataAction|default(null) -%}
{%- set class = class|default(null) -%}

{%- set classes = [
  'ps-button',
  variant ? 'ps-button--' ~ variant : null,
  size ? 'ps-button--' ~ size : null,
  outline ? 'ps-button--outline' : null,
  (not label) ? 'ps-button--icon-only' : null,
  disabled ? 'ps-button--disabled' : null,
  loading ? 'ps-button--loading' : null,
  fullWidth ? 'ps-button--full-width' : null,
  (toggle and active) ? 'active' : null,
  class ? class : null
] -%}

{%- set tag = url ? 'a' : 'button' -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<{{ tag }}{{ attr }}
  {%- if url %} href="{{ url }}"{% endif -%}
  {%- if target == '_blank' %} target="_blank" rel="noopener noreferrer"{% endif -%}
  {%- if disabled and tag == 'button' %} disabled aria-disabled="true"{% endif -%}
  {%- if loading %} aria-busy="true"{% endif -%}
  {%- if toggle %} data-ps-toggle="button" aria-pressed="{{ active ? 'true' : 'false' }}"{% endif -%}
  {%- if ariaLabel %} aria-label="{{ ariaLabel }}"{% endif -%}
  {%- if dataAction %} data-action="{{ dataAction }}"{% endif -%}
  {%- if icon %} data-icon="{{ icon }}"{% endif -%}
  {%- if icon and iconPosition != 'start' %} data-icon-position="{{ iconPosition }}"{% endif -%}
>
  {%- if loading -%}
    <span class="ps-button__spinner" aria-hidden="true"></span>
  {%- endif -%}
  {{- label -}}
</{{ tag }}>
