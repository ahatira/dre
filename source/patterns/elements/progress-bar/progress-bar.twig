{#
/**
 * @file
 * PS Progress Bar (Atom) - Linear or circular progress indicator
 *
 * @param {number} [value=0] - Current progress value (0-100)
 * @param {number} [min=0] - Minimum value
 * @param {number} [max=100] - Maximum value
 * @param {string} [variant='linear'] - Variant: linear | circular
 * @param {string} [color='neutral'] - Color: neutral | primary | secondary | gold | info | warning | success | danger | light | dark
 * @param {string} [size='medium'] - Size: small (8px/40px) | medium (12px/56px) | large (16px/72px)
 * @param {boolean} [indeterminate=false] - Infinite animation without value
 * @param {boolean} [striped=false] - Animated stripes (linear only)
 * @param {boolean} [showLabel=false] - Display percentage label
 * @param {string} [label] - Accessibility label for screen readers
 * @param {Drupal\Core\Template\Attribute} [attributes] - Additional HTML attributes
 */
#}

{%- set variant = variant|default('linear') -%}
{%- set color = color|default('neutral') -%}
{# Map legacy 6-size system to 3-size system #}
{%- set size = size|default('medium') -%}
{%- set size = size == 'xs' or size == 'sm' ? 'small' : (size == 'md' ? 'medium' : (size == 'lg' or size == 'xl' or size == 'xxl' ? 'large' : size)) -%}
{# Map legacy 'default' color to 'neutral' #}
{%- set color = color == 'default' ? 'neutral' : color -%}
{%- set indeterminate = indeterminate|default(false) -%}
{%- set striped = striped|default(false) -%}
{%- set showLabel = showLabel|default(false) -%}
{%- set value = indeterminate ? null : (value ?? 0) -%}
{%- set min = min|default(0) -%}
{%- set max = max|default(100) -%}
{%- set percent = value is not null ? ((value - min) / (max - min) * 100)|round : 0 -%}

{%- set classes = [] -%}
{%- set classes = classes|merge(['ps-progress']) -%}
{%- if variant != 'linear' -%}
  {%- set classes = classes|merge(['ps-progress--' ~ variant]) -%}
{%- endif -%}
{%- if color != 'neutral' -%}
  {%- set classes = classes|merge(['ps-progress--' ~ color]) -%}
{%- endif -%}
{%- if size != 'medium' -%}
  {%- set classes = classes|merge(['ps-progress--' ~ size]) -%}
{%- endif -%}
{%- if indeterminate -%}
  {%- set classes = classes|merge(['ps-progress--indeterminate']) -%}
{%- endif -%}
{%- if striped and variant == 'linear' -%}
  {%- set classes = classes|merge(['ps-progress--striped']) -%}
{%- endif -%}
{%- if showLabel -%}
  {%- set classes = classes|merge(['ps-progress--with-label']) -%}
{%- endif -%}
{%- if modifier_class -%}
  {%- set classes = classes|merge([modifier_class]) -%}
{%- endif -%}
{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}
{%- if not indeterminate -%}
  {%- set attr = attr.setAttribute('aria-valuenow', value) -%}
  {%- set attr = attr.setAttribute('aria-valuemin', min) -%}
  {%- set attr = attr.setAttribute('aria-valuemax', max) -%}
{%- endif -%}
{%- if label -%}
  {%- set attr = attr.setAttribute('aria-label', label) -%}
{%- endif -%}

{% if variant == 'linear' %}
<div{{ attr }} role="progressbar">
  <div class="ps-progress__track">
    <div class="ps-progress__fill"{% if not indeterminate %} style="width: {{ percent }}%;"{% endif %}></div>
  </div>
{% if showLabel and not indeterminate %}
  <span class="ps-progress__label">{{ percent }}%</span>
{% endif %}
</div>
{% else %}
{%- set circumference = 2 * 3.14159 * 45 -%}
{%- set offset = indeterminate ? 0 : (circumference * (1 - percent / 100)) -%}
<div{{ attr }} role="progressbar">
  <svg class="ps-progress__svg" viewBox="0 0 100 100">
    <circle class="ps-progress__track-circle" cx="50" cy="50" r="45" fill="none" stroke-width="8"></circle>
    <circle class="ps-progress__fill-circle" cx="50" cy="50" r="45" fill="none" stroke-width="8" stroke-dasharray="{{ circumference }}" stroke-dashoffset="{{ offset }}"></circle>
  </svg>
{% if showLabel and not indeterminate %}
  <span class="ps-progress__label">{{ percent }}%</span>
{% endif %}
</div>
{% endif %}
