{#
 * Skip Link (Element/Atom) - WCAG skip link for keyboard navigation
 *
 * @param string targetId - ID of the target anchor element (required, e.g., 'main-content', 'navigation', 'search')
 * @param string label - Link text displayed on focus (required, e.g., 'Skip to main content')
 * @param Attribute attributes - Additional HTML attributes (optional)
 #}

{%- set targetId = targetId|default('main-content') -%}
{%- set label = label|default('Skip to main content') -%}
{%- set href = '#' ~ targetId -%}
{%- set attributes = attributes|default(create_attribute()) -%}
{%- set class = class|default(null) -%}

{%- set classes = [
  'ps-skip-link',
  class ? class : null
] -%}

<a class="{{ classes|join(' ')|trim }}" href="{{ href }}"
  {%- if attributes %} {{ attributes|without('class') }}{% endif -%}>{{ label }}</a>