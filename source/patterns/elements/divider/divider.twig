{#
 * Divider atom - Visual separator for content sections
 * @param {string} orientation - horizontal|vertical (default: horizontal)
 * @param {string} style - solid|dashed|dotted (default: solid)
 * @param {string} thickness - small|medium|large (default: medium)
 * @param {string} color - neutral|primary|secondary|success|danger|warning|info|light|dark (default: neutral)
 * @param {string} spacing - small|medium|large (default: medium)
 * @param {string} text - Centered text content (optional)
 * @param {string} icon - Centered icon name (e.g., 'star', 'heart')
 * @param {object} attributes - Additional HTML attributes for Drupal integration (optional)
 #}
{%- set class = class|default(null) -%}
{%- set orientation = orientation|default('horizontal') -%}
{%- set style = style|default('solid') -%}
{%- set thickness = thickness|default('medium') -%}
{%- set color = color|default('neutral') -%}
{%- set spacing = spacing|default('md') -%}
{%- set text = text|default('') -%}
{%- set icon = icon|default('') -%}

{%- set root_classes = [
  'ps-divider',
  orientation == 'vertical' ? 'ps-divider--vertical' : null,
  style == 'dashed' ? 'ps-divider--dashed' : (style == 'dotted' ? 'ps-divider--dotted' : null),
  thickness == 'small' ? 'ps-divider--small' : (thickness == 'large' ? 'ps-divider--large' : null),
  color != 'neutral' ? 'ps-divider--' ~ color : null,
  spacing == 'small' ? 'ps-divider--spacing-small' : (spacing == 'large' ? 'ps-divider--spacing-large' : null),
  text ? 'ps-divider--with-text' : (icon ? 'ps-divider--with-icon' : null),
  class ? class : null
] -%}

{%- if text or icon -%}
  <div class="{{ root_classes|join(' ')|trim }}"
    {%- if attributes %} {{ attributes|without('class') }}{% endif -%}>
    <span class="ps-divider__line" aria-hidden="true"></span>
    {%- if text -%}
      <span class="ps-divider__text">{{ text }}</span>
    {%- elseif icon -%}
      <span class="ps-divider__icon" data-icon="{{ icon }}" aria-hidden="true"></span>
    {%- endif -%}
    <span class="ps-divider__line" aria-hidden="true"></span>
  </div>
{%- else -%}
  {%- if orientation == 'horizontal' -%}
    <hr class="{{ root_classes|join(' ')|trim }}"
      {%- if attributes %} {{ attributes|without('class') }}{% endif -%} />
  {%- else -%}
    <span class="{{ root_classes|join(' ')|trim }}" role="separator" aria-orientation="vertical"
      {%- if attributes %} {{ attributes|without('class') }}{% endif -%}></span>
  {%- endif -%}
{%- endif -%}