{# ps-divider (element) - PS Theme #}
{%- set orientation = orientation|default('horizontal') -%}
{%- set style = style|default('solid') -%}
{%- set thickness = thickness|default('medium') -%}
{%- set color = color|default('neutral') -%}
{%- set spacing = spacing|default('md') -%}
{%- set text = text|default('') -%}
{%- set icon = icon|default('') -%}
{%- set has_content = text or icon -%}

{%- set root_classes = ['ps-divider'] -%}
{%- if orientation != 'horizontal' -%}
  {%- set root_classes = root_classes|merge(['ps-divider--' ~ orientation]) -%}
{%- endif -%}
{%- if style != 'solid' -%}
  {%- set root_classes = root_classes|merge(['ps-divider--' ~ style]) -%}
{%- endif -%}
{%- if thickness != 'medium' -%}
  {%- set root_classes = root_classes|merge(['ps-divider--' ~ thickness]) -%}
{%- endif -%}
{%- if color != 'neutral' -%}
  {%- set root_classes = root_classes|merge(['ps-divider--' ~ color]) -%}
{%- endif -%}
{%- if spacing != 'md' -%}
  {%- set root_classes = root_classes|merge(['ps-divider--spacing-' ~ spacing]) -%}
{%- endif -%}
{%- if text -%}
  {%- set root_classes = root_classes|merge(['ps-divider--with-text']) -%}
{%- endif -%}
{%- if icon -%}
  {%- set root_classes = root_classes|merge(['ps-divider--with-icon']) -%}
{%- endif -%}

{%- if has_content -%}
  <div class="{{ root_classes|join(' ') }}">
    <span class="ps-divider__line"></span>
    {%- if text -%}
      <span class="ps-divider__text">{{ text }}</span>
    {%- elseif icon -%}
      <i class="ps-divider__icon icon-{{ icon }}" aria-hidden="true"></i>
    {%- endif -%}
    <span class="ps-divider__line"></span>
  </div>
{%- else -%}
  {%- if orientation == 'horizontal' -%}
    <hr class="{{ root_classes|join(' ') }}" />
  {%- else -%}
    <span class="{{ root_classes|join(' ') }}" role="separator" aria-orientation="vertical"></span>
  {%- endif -%}
{%- endif -%}