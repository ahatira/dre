{#
/**
 * @file
 * PS Label (Atom) - Form field label with required indicator
 *
 * Semantic form label with required asterisk indicator and accessibility support.
 * Integrates with Drupal form API via form-label/form-required classes.
 *
 * @param {string} text - Label text content (required)
 * @param {string} [forId] - ID of the associated form field for label-input binding
 * @param {boolean} [required=false] - Adds visual asterisk (*) and accessible required text
 * @param {boolean} [disabled=false] - Disabled state with reduced opacity and muted color
 * @param {object} [attributes] - Additional HTML attributes (e.g., class, data-*)
 */
#}

{%- set required = required|default(false) -%}
{%- set disabled = disabled|default(false) -%}

{%- set classes = [
  'ps-label',
  'form-label',
  required ? 'form-required' : null,
  disabled ? 'ps-label--disabled' : null,
  modifier_class
] -%}

<label class="{{ classes|join(' ')|trim }}"{% if attributes %} {{ attributes|without('class') }}{% endif %}{%- if forId %} for="{{ forId }}"{% endif -%}>
  {{- text -}}
  {%- if required %}
    <span aria-hidden="true">*</span>
    <span class="visually-hidden">(required field)</span>
  {%- endif %}
</label>