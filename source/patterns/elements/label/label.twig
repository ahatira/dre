{#
 * PS Label (Atom) - Form field label with required indicator
 *
 * @param string text - Label text content (required)
 * @param string forId - ID of the associated form field for label-input binding
 * @param boolean required - Adds visual asterisk and accessible required text (default: false)
 * @param boolean disabled - Disabled state with reduced opacity (default: false)
 * @param Attribute attributes - Additional HTML attributes
 #}

{%- set baseClass = baseClass|default('ps-label') -%}
{%- set color = color|default('default') -%}
{%- set size = size|default('md') -%}
{%- set classes = [
  baseClass,
  required ? baseClass ~ '--required' : null,
  disabled ? baseClass ~ '--disabled' : null,
  color != 'default' ? baseClass ~ '--' ~ color : null,
  size != 'md' ? baseClass ~ '--' ~ size : null
] -%}

<label{% if attributes %} {{ attributes.addClass(classes) }}{% else %} class="{{ classes|join(' ')|trim }}"{% endif %}{% if forId %} for="{{ forId }}"{% endif %}>
  <span class="{{ baseClass }}__text">{{ text }}</span>
  {% if required %}
    <span class="{{ baseClass }}__required" aria-hidden="true">*</span>
    <span class="visually-hidden">(required field)</span>
  {% endif %}
</label>