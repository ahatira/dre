{#
/**
 * @file
 * Skeleton component template.
 *
 * @component Skeleton
 * @description
 * Loading placeholder with pulse or wave animation.
 * Used to indicate content loading state in a visually appealing way.
 *
 * @atoms
 * @category Feedback
 *
 * @features
 * - Multiple variants (text, circle, rectangle, avatar, button, card)
 * - 3 animation types (pulse, wave, none)
 * - Fully customizable dimensions via CSS custom properties
 * - Accessible with ARIA attributes
 * - Real Estate context (property cards, agent profiles)
 *
 * @accessibility
 * - aria-busy="true" indicates loading state
 * - aria-live="polite" announces completion
 * - role="status" for screen reader context
 * - visually-hidden text for screen readers
 */
#}

{#
 * @param {string} variant - text|circle|rectangle|avatar|button|card (default: text)
 * @param {string} width - CSS width value (default: 100%)
 * @param {string} height - CSS height value (default: auto, depends on variant)
 * @param {string} animation - pulse|wave|none (default: pulse)
 * @param {string} borderRadius - CSS border-radius value (default: auto, depends on variant)
 * @param {object} attributes - Additional HTML attributes for Drupal integration (optional)
 #}

{%- set variant = variant|default('text') -%}
{%- set width = width|default('100%') -%}
{%- set height = height|default(null) -%}
{%- set animation = animation|default('pulse') -%}
{%- set borderRadius = borderRadius|default(null) -%}

{%- set skeleton_classes = ['ps-skeleton'] -%}
{%- if variant -%}
  {%- set skeleton_classes = skeleton_classes|merge(['ps-skeleton--' ~ variant]) -%}
{%- endif -%}
{%- if animation == 'wave' -%}
  {%- set skeleton_classes = skeleton_classes|merge(['ps-skeleton--wave']) -%}
{%- elseif animation == 'none' -%}
  {%- set skeleton_classes = skeleton_classes|merge(['ps-skeleton--no-animation']) -%}
{%- endif -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(skeleton_classes) -%}
{%- set style_value = width ? '--skeleton-width: ' ~ width ~ ';' : '' -%}
{%- set style_value = style_value ~ (height ? ' --skeleton-height: ' ~ height ~ ';' : '') -%}
{%- set style_value = style_value ~ (borderRadius ? ' --skeleton-radius: ' ~ borderRadius ~ ';' : '') -%}
{%- if style_value -%}
  {%- set attr = attr.setAttribute('style', style_value) -%}
{%- endif -%}
{%- set attr = attr.setAttribute('aria-busy', 'true') -%}
{%- set attr = attr.setAttribute('aria-live', 'polite') -%}
{%- set attr = attr.setAttribute('role', 'status') -%}

<div{{ attr }}>
  <span class="visually-hidden">Loading content...</span>
</div>
