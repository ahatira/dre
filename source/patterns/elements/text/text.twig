{#
 * Text atom - Typography for paragraphs and text content
 * Props:
 *   text (string) - Text content (required)
 *   variant (string) - body|small|large (default: body)
 *   tag (string) - p|span|div (default: p)
 *   align (string) - left|center|right (default: left)
 *   muted (boolean) - Muted color (default: false)
 *   strong (boolean) - Bold weight (default: false)
 #}

{%- set variant = variant|default('body') -%}
{%- set size = size|default('md') -%}
{%- set color = color|default('default') -%}
{%- set tag = tag|default('p') -%}
{%- set align = align|default('left') -%}
{%- set muted = muted|default(false) -%}
{%- set strong = strong|default(false) -%}

{%- set classes = ['ps-text'] -%}
{%- if variant != 'body' -%}
  {# Back-compat mapping: body|small|large → md|sm|lg #}
  {%- set _size = variant == 'small' ? 'sm' : (variant == 'large' ? 'lg' : 'md') -%}
  {%- if _size != 'md' -%}
    {%- set classes = classes|merge(['ps-text--' ~ _size]) -%}
  {%- endif -%}
{%- endif -%}
{%- if size != 'md' -%}
  {%- set classes = classes|merge(['ps-text--' ~ size]) -%}
{%- endif -%}
{%- if color != 'default' -%}
  {%- set classes = classes|merge(['ps-text--' ~ color]) -%}
{%- endif -%}
{%- if align != 'left' -%}
  {%- set classes = classes|merge(['ps-text--align-' ~ align]) -%}
{%- endif -%}
{%- if muted -%}
  {%- set classes = classes|merge(['ps-text--muted']) -%}
{%- endif -%}
{%- if strong -%}
  {%- set classes = classes|merge(['ps-text--strong']) -%}
{%- endif -%}

<{{ tag }} class="{{ classes|join(' ') }}">
  {{- text -}}
</{{ tag }}>
