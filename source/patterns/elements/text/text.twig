{#
 * Text (Element / Atom)
 * Semantic text for paragraphs and inline content.
 * UTILITY-FIRST: Use .text-*, .font-*, .text-center utilities for styling variations
 *
 * @param string text - Text content (required)
 * @param string tag - p|span|div (default: p)
 * @param Attribute attributes - Additional HTML attributes (optional)
 *
 * EXAMPLES:
 * - Color: attributes.addClass('text-primary')
 * - Size: Use native text classes or inline font-size
 * - Weight: attributes.addClass('font-semibold')
 * - Alignment: attributes.addClass('text-center')
 * - Muted: attributes.addClass('text-gray-600')
 #}

{%- set tag = tag|default('p') -%}

<{{ tag }}
  {{- attributes ? attributes : '' -}}>
  {{- text -}}
</{{ tag }}>
