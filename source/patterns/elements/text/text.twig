{#
 * Text (Element / Atom)
 * Typographic helper for paragraphs and inline content.
 *
 * Props:
 *   string text - Text content (required)
 *   string size - xs|sm|md|lg|xl|xxl (optional, default: md)
 *   string color - default|primary|secondary|success|info|warning|danger|gold|dark|light (optional, default: default)
 *   string tag - p|span|div (optional, default: p)
 *   string align - left|center|right (optional, default: left)
 *   boolean muted - Muted tone using secondary text color (optional, default: false)
 *   boolean strong - Bold emphasis (optional, default: false)
 *   Attribute attributes - Additional HTML attributes for composition (optional)
 #}

{%- set size = size|default('md') -%}
{%- set color = color|default('default') -%}
{%- set tag = tag|default('p') -%}
{%- set align = align|default('left') -%}
{%- set muted = muted|default(false) -%}
{%- set strong = strong|default(false) -%}
{%- set attributes = attributes|default(create_attribute()) -%}

{%- set classes = [
  'ps-text',
  size != 'md' ? 'ps-text--' ~ size : null,
  color != 'default' ? 'ps-text--' ~ color : null,
  align != 'left' ? 'ps-text--align-' ~ align : null,
  muted ? 'ps-text--muted' : null,
  strong ? 'ps-text--strong' : null
] -%}

<{{ tag }}{{ attributes.addClass(classes) }}>
  {{ text }}
</{{ tag }}>
