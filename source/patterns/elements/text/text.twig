{#
 * Text atom - Typography for paragraphs and text content
 * Composition-ready: Supports attributes for class injection
 * 
 * Props:
 *   text (string) - Text content (required)
 *   size (string) - xs|sm|md|lg|xl|xxl (default: md)
 *   color (string) - default|primary|secondary|success|info|warning|danger|dark|light (default: default)
 *   tag (string) - p|span|div (default: p)
 *   align (string) - left|center|right (default: left)
 *   muted (boolean) - Muted color (default: false)
 *   strong (boolean) - Bold weight (default: false)
 *   attributes (Attribute) - Additional HTML attributes for composition
 #}

{%- set size = size|default('md') -%}
{%- set color = color|default('default') -%}
{%- set tag = tag|default('p') -%}
{%- set align = align|default('left') -%}
{%- set muted = muted|default(false) -%}
{%- set strong = strong|default(false) -%}
{%- set baseClass = baseClass|default(null) -%}

{%- set classes = baseClass ? [
  baseClass,
  strong ? baseClass ~ '--strong' : null
] : [
  'ps-text',
  size != 'md' ? 'ps-text--' ~ size : null,
  color != 'default' ? 'ps-text--' ~ color : null,
  align != 'left' ? 'ps-text--align-' ~ align : null,
  muted ? 'ps-text--muted' : null,
  strong ? 'ps-text--strong' : null
] -%}

<{{ tag }}{{ attributes ? attributes.addClass(classes) : ' class="' ~ classes|join(' ')|trim ~ '"' }}>
  {{- text -}}
</{{ tag }}>
