{#
/**
 * @file
 * Image component (Atom)
 * 
 * Responsive image with lazy loading, srcset/sizes support, object-fit and border-radius options.
 * This component handles the <img> element only. For figures with captions, see Figure component.
 * 
 * Available variables:
 * - src: (string) Image source URL (required)
 * - alt: (string) Alternative text for accessibility (required)
 * - width: (int) Intrinsic width in pixels
 * - height: (int) Intrinsic height in pixels
 * - srcset: (array<string>) Responsive image sources (e.g., ['/img-400.jpg 400w', '/img-800.jpg 800w'])
 * - sizes: (string) Sizes attribute for responsive images (e.g., '(min-width: 768px) 50vw, 100vw')
 * - loading: (string) Loading strategy: 'lazy' (default) | 'eager'
 * - decoding: (string) Decoding hint: 'auto' (default) | 'async' | 'sync'
 * - fit: (string) Object-fit behavior: 'none' (default) | 'cover' | 'contain' | 'fill' | 'scale-down'
 * - rounded: (string) Border-radius style: 'none' (default) | 'sm' | 'md' | 'lg' | 'full'
 * - attributes: (Drupal\Core\Template\Attribute) Additional HTML attributes
 * 
 * @see https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img
 * @see https://web.dev/learn/design/responsive-images/
 */
#}

{%- set fit = fit|default('none') -%}
{%- set rounded = rounded|default('none') -%}
{%- set loading = loading|default('lazy') -%}
{%- set decoding = decoding|default('auto') -%}

{# Build minimal class array - only add modifiers if different from default #}
{%- set classes = [
  'ps-image',
  fit != 'none' ? 'ps-image--fit-' ~ fit : null,
  rounded != 'none' ? 'ps-image--rounded-' ~ rounded : null,
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<img{{ attr }} src="{{ src }}" alt="{{ alt }}"{%- if width %} width="{{ width }}"{% endif %}{%- if height %} height="{{ height }}"{% endif %}{%- if srcset %} srcset="{{ srcset|join(', ') }}"{% endif %}{%- if sizes %} sizes="{{ sizes }}"{% endif %} loading="{{ loading }}" decoding="{{ decoding }}" />
