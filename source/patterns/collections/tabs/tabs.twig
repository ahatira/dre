{#
 * Tabs collection (organism) - Accessible tab navigation
 *
 * Composes Tab components with keyboard navigation and animated indicator.
 * Implements WAI-ARIA Tabs pattern with roving tabindex.
 *
 * @param {string} [label] - Accessible label for the tablist (aria-label)
 * @param {string} [variant='neutral'] - Semantic variant: neutral|primary|success|danger|warning|info|gold|light|dark
 * @param {boolean} [pill=false] - Enables pill presentation style (passed to Tab components)
 * @param {string} [icon] - Default icon name applied to tabs missing an icon (check, info, etc.)
 * @param {boolean} [vertical=false] - Vertical orientation (default: horizontal)
 * @param {boolean} [auto=false] - Auto activation mode (default: manual, requires Enter/Space)
 * @param {array} tabs - Collection of tab objects (required)
 *   - {string} [id] - Unique identifier (auto-generated if missing)
 *   - {string} label - Tab label text (required)
 *   - {string} content - Tab panel content (HTML allowed)
 *   - {boolean} [active=false] - Marks tab as active
 *   - {boolean} [disabled=false] - Disables the tab
 *   - {string} [icon] - Icon name specific to the tab (overrides global icon)
 * @param {object} [attributes] - Drupal attribute bag (required for integration)
 #}

{%- set tabs = tabs|default([]) -%}
{%- set variant = variant|default('neutral') -%}
{%- set pill = pill|default(false) -%}
{%- set icon = icon|default(null) -%}
{%- set label = label|default('Tabs navigation') -%}
{%- set vertical = vertical|default(false) -%}
{%- set auto = auto|default(false) -%}
{%- set attributes = attributes ? attributes : create_attribute() -%}

{# Determine if any tab uses an icon #}
{%- set has_icons = false -%}
{%- for tab in tabs -%}
  {%- if not has_icons and (tab.icon is defined and tab.icon) -%}
    {%- set has_icons = true -%}
  {%- elseif not has_icons and icon -%}
    {%- set has_icons = true -%}
  {%- endif -%}
{%- endfor -%}

{# Determine default active index (first active, otherwise first enabled) #}
{%- set active_index = null -%}
{%- set fallback_index = null -%}
{%- for tab in tabs -%}
  {%- if fallback_index is null and (tab.disabled is not defined or not tab.disabled) -%}
    {%- set fallback_index = loop.index0 -%}
  {%- endif -%}
  {%- if active_index is null and (tab.active is defined and tab.active) and (tab.disabled is not defined or not tab.disabled) -%}
    {%- set active_index = loop.index0 -%}
  {%- endif -%}
{%- endfor -%}
{%- if active_index is null -%}
  {%- set active_index = fallback_index is not null ? fallback_index : 0 -%}
{%- endif -%}

{%- set root_classes = ['ps-tabs'] -%}
{%- if variant -%}
  {%- set root_classes = root_classes|merge(['ps-tabs--' ~ variant]) -%}
{%- endif -%}
{%- if pill -%}
  {%- set root_classes = root_classes|merge(['ps-tabs--pill']) -%}
{%- endif -%}
{%- if has_icons -%}
  {%- set root_classes = root_classes|merge(['ps-tabs--with-icon']) -%}
{%- endif -%}

<div{{ attributes.addClass(root_classes)|without('class') }} data-tabs data-variant="{{ variant }}"{% if pill %} data-pill="true"{% endif %}{% if vertical %} data-orientation="vertical"{% endif %}{% if not auto %} data-activation="manual"{% endif %}>
  <div class="ps-tabs__list" role="tablist" aria-label="{{ label }}">
    {%- for tab in tabs -%}
      {%- set tab_id = tab.id is defined and tab.id ? tab.id : 'tab-' ~ loop.index -%}
      {%- set panel_id = 'panel-' ~ (tab.id is defined and tab.id ? tab.id : loop.index) -%}
      {%- set tab_icon = tab.icon is defined and tab.icon ? tab.icon : icon -%}
      {%- set is_disabled = tab.disabled is defined and tab.disabled -%}
      {%- set is_active = loop.index0 == active_index and not is_disabled -%}

      {# Compose Tab component (molecule) #}
      {% include '@components/tab/tab.twig' with {
        label: tab.label,
        id: tab_id,
        panel_id: panel_id,
        variant: variant,
        pill: pill,
        active: is_active,
        disabled: is_disabled,
        icon: tab_icon,
        attributes: create_attribute().addClass('ps-tabs__tab')
      } only %}
    {%- endfor -%}
    <span class="ps-tabs__indicator" aria-hidden="true"></span>
  </div>

  <div class="ps-tabs__content">
    {%- for tab in tabs -%}
      {%- set tab_id = tab.id is defined and tab.id ? tab.id : 'tab-' ~ loop.index -%}
      {%- set panel_id = 'panel-' ~ (tab.id is defined and tab.id ? tab.id : loop.index) -%}
      {%- set is_disabled = tab.disabled is defined and tab.disabled -%}
      {%- set is_active = loop.index0 == active_index and not is_disabled -%}

      <div
        class="ps-tabs__panel{% if is_active %} is-selected{% endif %}"
        id="{{ panel_id }}"
        role="tabpanel"
        aria-labelledby="{{ tab_id }}"
        {% if not is_active %}hidden{% endif %}
        data-tabpanel
      >
        {{ tab.content|raw }}
      </div>
    {%- endfor -%}
  </div>
</div>
