{#
/**
 * Features - Collection/Organism
 *
 * Thematic section composing Icon + Heading + List atoms.
 * Used for property features, services, building amenities, and information.
 *
 * @param {string} title - Section title (required)
 * @param {string} icon - Icon name for data-icon attribute (required)
 * @param {array} items - Array of list items: strings or HTML (required)
 * @param {number} columns_min_items - Minimum items to enable two-column layout (default: 0 = disabled)
 * @param {object} attributes - Drupal attributes object for root element
 */
#}

{%- set html_tag = html_tag|default('div') -%}
{%- set title_level = title_level|default('h4') -%}
{%- set title = title|default('') -%}
{%- set icon = icon|default('') -%}
{%- set items = items|default([]) -%}
{%- set columns_min_items = columns_min_items|default(0) -%}

{{ attach_library('ps_theme/features') }}

{%- set features_classes = [
  'ps-features',
  columns_min_items > 0 and items|length >= columns_min_items ? 'ps-features--two-columns' : null
] -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(features_classes) -%}

<{{ html_tag }}{{ attr }}{% if columns_min_items > 0 and items|length >= columns_min_items %} data-columns-min-items="{{ columns_min_items }}"{% endif %}>
  {% include '@elements/heading/heading.twig' with {
    level: title_level,
    text: title,
    icon: icon,
    attributes: create_attribute().addClass('ps-features__title')
  } only %}

  {% include '@elements/list/list.twig' with {
    items: items,
    attributes: create_attribute().addClass('ps-features__list')
  } only %}
</{{ html_tag }}>
