{#
/**
 * @file
 * Primary navigation menu - matching menu.html structure exactly
 *
 * Available variables:
 * - menu_name: The machine name of the menu
 * - items: Menu items array with:
 *   - title: Link text
 *   - url: Link URL
 *   - link_class: Array of classes for the <a> element
 *   - aria_haspopup: Boolean for aria-haspopup attribute
 *   - submenu_class: Array of classes for the submenu <ul>
 *   - below: Nested menu items
 *   - in_active_trail: Boolean for active trail
 *   - description: Optional description text (for some link types)
 * - modifier: Optional modifier class (compact, dark)
 */
#}
{%- set modifier_class = modifier ? 'ps-menu-primary--' ~ modifier : null -%}
{%- set menu_classes = [
  'ps-menu-primary',
  modifier_class
] -%}

{#
/**
 * Macro: menu_links
 * Recursive macro to render menu items matching menu.html structure
 *
 * @param array items - Menu items to render
 * @param int level - Current nesting level (1 = menu-bar, 2 = mega-menu, 3+ = menu-list)
 */
#}
{%- macro menu_links(items, level) -%}
  {%- import _self as menus -%}
  
  {#- Determine ul classes based on level -#}
  {%- if level == 1 -%}
    {%- set ul_default_classes = ['menu', 'menu-bar'] -%}
  {%- endif -%}
  
  {%- for item in items -%}
    {%- set item_classes = [
      item.in_active_trail ? 'is-active-trail' : null
    ] -%}
    {%- set item_attr = create_attribute().addClass(item_classes) -%}
    
    {#- Build link classes from YAML or defaults -#}
    {%- set link_classes = item.link_class|default([]) -%}
    {%- set link_attr = create_attribute().addClass(link_classes) -%}
    
    {#- Add aria-haspopup if specified -#}
    {%- if item.aria_haspopup and item.below -%}
      {%- set link_attr = link_attr.setAttribute('aria-haspopup', 'true') -%}
    {%- endif -%}
    
    <li{{- item_attr -}}>
      {#- Link with description support (for some flat menus) -#}
      {%- if item.description -%}
        <a href="{{ item.url }}"{{- link_attr -}}>
          {{- item.title -}}<br>
          <small>{{ item.description }}</small>
        </a>
      {%- else -%}
        <a href="{{ item.url }}"{{- link_attr -}}>{{ item.title }}</a>
      {%- endif -%}
      
      {#- Recursive submenu rendering -#}
      {%- if item.below -%}
        {%- set submenu_classes = item.submenu_class|default([]) -%}
        {%- set submenu_attr = create_attribute().addClass(submenu_classes) -%}
        
        <ul{{- submenu_attr -}}>
          {{- menus.menu_links(item.below, level + 1) -}}
          
          {#- Mobile back button (only on level 2 mega-menus) -#}
          {%- if level == 1 and item.below -%}
            <li class="mobile-menu-back-item">
              <a href="#" class="menu-link mobile-menu-back-link">Back</a>
            </li>
          {%- endif -%}
        </ul>
      {%- endif -%}
    </li>
  {%- endfor -%}
{%- endmacro -%}

{#- Render the menu -#}
{%- import _self as menus -%}
{%- set root_attr = create_attribute().addClass(menu_classes) -%}

<nav{{- root_attr -}}>
  <a href="#" class="mobile-menu-trigger">Menu</a>
  <ul class="menu menu-bar">
    {{- menus.menu_links(items, 1) -}}
  </ul>
</nav>
