{#
  @file
  Block CTA (Button/Link block wrapper)

  Extends the Block layout structure with a Button or Link component.

  Available variables:
  - plugin_id: Drupal block plugin ID (default: block_cta)
  - layout: Optional layout modifier
  - label: Block title (optional)
  - button: Button or Link component render array
    - label: Button/Link text
    - variant: Color variant
    - outline: Apply outline style (button only)
    - fullWidth: Full width button (button only)
    - icon: Icon name (optional)
    - url: Link URL (optional)
    - disabled: Disabled state (button only)
    - component: 'button' or 'link' (optional, default: 'button')
  - attributes: Drupal Attribute object
#}

{% extends '@layouts/block/block.twig' %}

{%- set plugin_id = plugin_id|default('block_cta') -%}
{%- set configuration = configuration|default({ provider: 'cta' }) -%}
{%- set button = button|default({}) -%}
{%- set component = button.component|default('button') -%}

{%- block content -%}
  {%- if component == 'link' -%}
    {%- include '@elements/link/link.twig' with button only -%}
  {%- else -%}
    {%- include '@elements/button/button.twig' with button only -%}
  {%- endif -%}
{%- endblock -%}
