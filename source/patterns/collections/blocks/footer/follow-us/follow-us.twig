{#
  Follow Us Block
  - Simple social media links in footer
  - Extends block.twig, renders list of icon links
#}

{% extends "@layouts/block/block.twig" %}

{%- set plugin_id = plugin_id|default('block_footer_follow_us') -%}
{%- set configuration = configuration|default({ provider: 'follow_us' }) -%}

{%- set label = label|default('Follow us') -%}

{%- set attributes = attributes is defined ? attributes : create_attribute() -%}
{%- set attributes = attributes.addClass(['ps-follow-us']) -%}

{% block content %}
  <div class="ps-follow-us__inner">
    <ul class="ps-follow-us__list">
        {% for item in items %}
        <li class="ps-follow-us__item">
            <a
            href="{{ item.url }}"
            class="ps-follow-us__link"
            title="{{ item.label }}"
            {% if item.external %}target="_blank" rel="noopener noreferrer"{% endif %}
            {{ attributes }}
            >
            <span class="ps-follow-us__icon" data-icon="{{ item.icon }}" aria-hidden="true"></span>
            <span class="ps-follow-us__text">{{ item.label }}</span>
            </a>
        </li>
        {% endfor %}
    </ul>
  </div>
{% endblock %}
