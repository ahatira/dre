{#
/**
 * @file
 * Footer Menu Block
 *
 * Extends the Block layout structure for footer context.
 * Simple horizontal menu on desktop, vertical on mobile.
 *
 * Available variables:
 * - label: Section title/label (string) - typically hidden
 * - items: Array of menu links [{ title, url }, ...] (array)
 * - attributes: Drupal Attribute object for the block wrapper (Attribute)
 */
#}

{% extends '@layouts/block/block.twig' %}

{%- set plugin_id = plugin_id|default('block_footer_menu') -%}
{%- set configuration = configuration|default({ provider: 'menu' }) -%}

{%- set label = label|default('Footer Menu') -%}
{%- set label_display = label_display|default('hidden') -%}
{%- set items = items|default([]) -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass('ps-footer-menu') -%}

{%- block content -%}
  {% include '@collections/menu/menu.twig' with {
    items: items
  } only %}
{%- endblock -%}
