{#
 * Offer Meta organism - Main metadata display for real estate offers
 * Displays reference, title, price, surface, location, availability, mandate type, and action buttons
 * @param {string} title - Offer title (required)
 * @param {object} reference - Reference data {label, value}
 * @param {object} building - Building name data {label, value}
 * @param {object} price - Price data {label, value, unit, tooltip}
 * @param {object} surface_total - Total surface data {label, value, unit}
 * @param {object} location - Location data with address structure
 * @param {object} availability - Availability data {label, value}
 * @param {object} mandate_type - Mandate type data {label, value}
 * @param {object} actions - Actions data with items array [{label, url, variant, outline, icon, icon_position}]
 * @param {object} attributes - Additional HTML attributes for Drupal integration
 #}

{%- set reference = reference|default(null) -%}
{%- set building = building|default(null) -%}
{%- set price = price|default(null) -%}
{%- set surface_total = surface_total|default(null) -%}
{%- set location = location|default(null) -%}
{%- set availability = availability|default(null) -%}
{%- set mandate_type = mandate_type|default(null) -%}
{%- set actions = actions|default(null) -%}

{%- set classes = [
  'ps-offer-meta'
] -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<div{{ attr }}>
  {# Header section: reference + title + building #}
  <header class="ps-offer-meta__header">
    {# Reference #}
    {% if reference and reference.value %}
      <div class="ps-offer-meta__reference">
        {{ reference.label }}{{ reference.label ? ': ' : '' }}<span>{{ reference.value }}</span>
      </div>
    {% endif %}

    {# Title and price container #}
    <div class="ps-offer-meta__title-container">
      {# Building name, title, and primary info (surface + location) #}
      <div class="ps-offer-meta__title-group">
        {% if building and building.value %}
          <h1 class="ps-offer-meta__building">{{ building.value }}</h1>
        {% endif %}
        {% if title %}
          <h2 class="ps-offer-meta__title">{{ title }}</h2>
        {% endif %}
        
        {# Primary info: surface + location (directly under title) #}
        <div class="ps-offer-meta__primary-info">
          {% if surface_total and surface_total.value %}
            <span class="ps-offer-meta__surface">
              {{ surface_total.value }}{{ surface_total.unit ? ' ' ~ surface_total.unit : '' }}
            </span>
          {% endif %}
          {% if surface_total and surface_total.value and location and location.address %}
            <span class="offer-meta__separator" aria-hidden="true">•</span>
          {% endif %}
          {% if location and location.address %}
            <span class="ps-offer-meta__location">
              {% if location.address.postal_code %}{{ location.address.postal_code }}{% endif %}
              {% if location.address.locality %} {{ location.address.locality }}{% endif %}
            </span>
          {% endif %}
        </div>
      </div>

      {# Price (in header for desktop, after primary-info for mobile) #}
      {% if price and price.value %}
        <div class="ps-offer-meta__price">
          <span class="ps-offer-meta__price-value">{{ price.value }}</span>
          {% if price.unit %}
            <span class="ps-offer-meta__price-unit">{{ price.unit }}</span>
          {% endif %}
          {% if price.tooltip %}
            <button 
              class="ps-offer-meta__price-tooltip" 
              type="button"
              aria-label="{{ price.tooltip }}"
              data-icon="tooltip"
              title="{{ price.tooltip }}"
            ></button>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </header>

  {# Metadata section: availability + mandate type #}
  <div class="ps-offer-meta__metadata">
    {# Availability and mandate type (one per line) #}
    <div class="ps-offer-meta__secondary-info">
      {% if availability and availability.value %}
        <div class="ps-offer-meta__availability">
          <span class="ps-offer-meta__label">{{ availability.label }}{{ availability.label ? ': ' : '' }}</span>
          <strong class="ps-offer-meta__value">{{ availability.value }}</strong>
        </div>
      {% endif %}
      {% if mandate_type and mandate_type.value %}
        <div class="ps-offer-meta__mandate">
          <span class="ps-offer-meta__label">{{ mandate_type.label }}{{ mandate_type.label ? ': ' : '' }}</span>
          <strong class="ps-offer-meta__value">{{ mandate_type.value }}</strong>
        </div>
      {% endif %}
    </div>
  </div>

  {# Actions section: buttons #}
  {% if actions and actions.items %}
    <div class="ps-offer-meta__actions">
      {% for action in actions.items %}
        {% include '@elements/button/button.twig' with {
          label: action.label,
          url: action.url,
          variant: action.variant|default('primary'),
          outline: action.outline|default(false),
          icon: action.icon|default(null),
          iconPosition: action.icon_position|default('start')
        } only %}
      {% endfor %}
    </div>
  {% endif %}
</div>
