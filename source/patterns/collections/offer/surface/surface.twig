{#
/**
 * Surface - Collection/Organism
 *
 * Displays a property surface data table with heading icon and responsive layout.
 * Composes Heading and Table atoms to present property characteristics.
 *
 * @param {string} title - Table heading (required)
 * @param {string} icon - Icon name for data-icon attribute (required)
 * @param {string} html_tag - Root HTML tag (default: 'section')
 * @param {string} title_level - h1-h6 heading level (default: 'h3')
 * @param {array} headers - Column headers for table
 * @param {array} rows - Data rows for table
 * @param {string} [variant='default'] - Color variant for table
 * @param {boolean} [striped=false] - Zebra striping
 * @param {boolean} [hover=true] - Row hover effect
 * @param {boolean} [bordered=false] - Cell borders
 * @param {object} attributes - Drupal attributes object
 */
#}

{%- set html_tag = html_tag|default('div') -%}
{%- set title_level = title_level|default('h4') -%}
{%- set title = title|default('Surface table') -%}
{%- set icon = icon|default('area') -%}
{%- set headers = headers|default([]) -%}
{%- set rows = rows|default([]) -%}
{%- set variant = variant|default('default') -%}
{%- set striped = striped|default(false) -%}
{%- set hover = hover|default(true) -%}
{%- set bordered = bordered|default(false) -%}

{%- set surface_classes = [
  'ps-surface'
] -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(surface_classes) -%}

<{{ html_tag }}{{ attr }}>
  {% if title %}
    {% include '@elements/heading/heading.twig' with {
      level: title_level,
      text: title,
      icon: icon,
      attributes: create_attribute().addClass('ps-surface__title')
    } only %}
  {% endif %}

  {% if headers and rows %}
    {% include '@components/table/table.twig' with {
      headers: headers,
      rows: rows,
      variant: variant,
      striped: striped,
      hover: hover,
      bordered: bordered,
      attributes: create_attribute().addClass('ps-surface__table')
    } only %}
  {% endif %}
</{{ html_tag }}>
