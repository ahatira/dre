{#
/**
 * @file
 * PS Navigation Menu (Collection/Organism)
 * 
 * Responsive navigation menu for header with multi-level support.
 * Desktop: horizontal menu with dropdown submenus (hover or click configurable)
 * Mobile: vertical accordion menu in drawer/fullscreen
 * 
 * @param {array} items - Menu items array (required)
 *   Each item structure:
 *   - title {string} - Menu item label
 *   - url {string} - Link URL (Drupal\Core\Url or string)
 *   - below {array} - Child menu items (optional)
 *   - attributes {object} - Drupal Attribute object (optional)
 *   - is_expanded {boolean} - Has visible children (optional)
 *   - is_collapsed {boolean} - Has hidden children (optional)
 *   - in_active_trail {boolean} - Is in active path (optional)
 * @param {string} [menu_name='main'] - Machine name of the menu
 * @param {string} [variant='default'] - Visual variant: 'default', 'dark', 'mobile'
 * @param {string} [behavior='hover'] - Desktop submenu behavior: 'hover', 'click'
 * @param {boolean} [accordion=false] - Mobile accordion mode (one item open at a time)
 * @param {object} [attributes] - Additional HTML attributes for nav root
 * @param {string} [modifier_class] - Additional CSS classes
 */
#}

{%- import _self as nav_menu -%}

{%- set menu_name = menu_name|default('main') -%}
{%- set variant = variant|default('default') -%}
{%- set behavior = behavior|default('hover') -%}
{%- set accordion = accordion|default(false) -%}

{%- set nav_classes = [
  'ps-navigation-menu',
  variant != 'default' ? 'ps-navigation-menu--' ~ variant : null,
  behavior == 'click' ? 'ps-navigation-menu--click' : null,
  accordion ? 'ps-navigation-menu--accordion' : null,
  modifier_class
] -%}

{%- set attr = (attributes ? attributes : create_attribute()).addClass(nav_classes) -%}
{%- set attr = attr.setAttribute('data-menu-name', menu_name) -%}
{%- set attr = attr.setAttribute('data-behavior', behavior) -%}
{%- if accordion -%}
  {%- set attr = attr.setAttribute('data-accordion', 'true') -%}
{%- endif -%}

{#
/**
 * Recursive macro to render menu items
 * 
 * @param {array} items - Menu items to render
 * @param {int} menu_level - Current depth level (0 = root)
 */
#}
{%- macro render_items(items, menu_level) -%}
  {%- import _self as nav_menu -%}
  
  {%- if items -%}
    {%- set list_classes = [
      'ps-navigation-menu__list',
      menu_level == 0 ? 'ps-navigation-menu__list--root' : 'ps-navigation-menu__list--submenu'
    ] -%}
    
    <ul class="{{ list_classes|join(' ')|trim }}">
      {%- for item in items -%}
        {%- set has_children = item.below and item.below|length > 0 -%}
        
        {%- set item_classes = [
          'ps-navigation-menu__item',
          item.is_expanded ? 'ps-navigation-menu__item--expanded' : null,
          item.is_collapsed ? 'ps-navigation-menu__item--collapsed' : null,
          item.in_active_trail ? 'ps-navigation-menu__item--active-trail' : null,
          has_children ? 'ps-navigation-menu__item--has-children' : null
        ] -%}
        
        {%- set item_attr = (item.attributes ? item.attributes : create_attribute()).addClass(item_classes) -%}
        
        <li{{ item_attr }}>
          <div class="ps-navigation-menu__item-wrapper">
            {%- if item.url -%}
              {%- set link_classes = [
                'ps-navigation-menu__link',
                item.in_active_trail ? 'ps-navigation-menu__link--active' : null
              ] -%}
              {%- set link_attr = create_attribute().addClass(link_classes) -%}
              {{- link(item.title, item.url, link_attr) -}}
            {%- else -%}
              <span class="ps-navigation-menu__link ps-navigation-menu__link--disabled">
                {{- item.title -}}
              </span>
            {%- endif -%}
            
            {%- if has_children -%}
              <button 
                class="ps-navigation-menu__toggle"
                type="button"
                aria-expanded="false"
                aria-label="{{ 'Toggle submenu'|t }}"
              >
                <i class="ps-navigation-menu__chevron" data-icon="chevron-down" aria-hidden="true"></i>
              </button>
            {%- endif -%}
          </div>
          
          {%- if has_children -%}
            {{- nav_menu.render_items(item.below, menu_level + 1) -}}
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
{%- endmacro -%}

<nav{{ attr }} role="navigation" aria-label="{{ 'Main navigation'|t }}">
  {{- nav_menu.render_items(items, 0) -}}
</nav>
