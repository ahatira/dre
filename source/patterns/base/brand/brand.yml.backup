---
# BNP Paribas RealEstate Brand System - Semantic Color Tokens
# Bootstrap-style structure with rowspan grouping
# 3-Layer Architecture:
# 1. source/props/colors.css   → Official BNP palettes (GREEN, PINK, TEAL, RED, YELLOW, BLUE, SKY, GREY)
# 2. source/props/brand.css    → Semantic tokens mapping colors to meanings
# 3. Components               → Reference semantic tokens only

brands:
  'Semantic Colors':
    - name: 'Primary'
      slug: 'primary'
      description: 'Main theme color, used for hyperlinks, focus styles, and component and form active states. Official BNP green #00915A.'
      variants:
        - type: 'base'
          var: '--primary'
          value: '#00915A'
        - type: 'subtle'
          var: '--primary-bg-subtle'
          value: 'rgba(0, 145, 90, 0.1)'
        - type: 'border'
          var: '--primary-border-subtle'
          value: 'rgba(0, 145, 90, 0.3)'
        - type: 'text'
          var: '--primary-text-emphasis'
          value: '#016B44'
    
    - name: 'Secondary'
      slug: 'secondary'
      description: 'Secondary brand color for alternative actions and accents. BNP pink #A12B66.'
      variants:
        - type: 'base'
          var: '--secondary'
          value: '#A12B66'
        - type: 'subtle'
          var: '--secondary-bg-subtle'
          value: 'rgba(161, 43, 102, 0.1)'
        - type: 'border'
          var: '--secondary-border-subtle'
          value: 'rgba(161, 43, 102, 0.3)'
        - type: 'text'
          var: '--secondary-text-emphasis'
          value: '#7A2050'
    - name: 'Border'
      var: '--primary-border'
      value: '#00915A'
      description: 'Primary action borders'
    - name: 'Subtle'
      var: '--primary-subtle'
      value: '#D9EFE9'
      description: 'Subtle backgrounds (very light green-100)'
    - name: 'Bg Subtle'
      var: '--primary-bg-subtle'
      value: '#EBF7F4'
      description: 'Light background green-50'
    - name: 'Border Subtle'
      var: '--primary-border-subtle'
      value: '#99D3BD'
      description: 'Subtle borders (green-300)'
    - name: 'Text Emphasis'
      var: '--primary-text-emphasis'
      value: '#01563A'
      description: 'Emphasized text (dark green-900)'

  'Secondary (Secondary Brand - BNP Pink #A12B66)':
    - name: 'Base'
      var: '--secondary'
      value: '#A12B66'
      description: 'Official BNP magenta (from pink-700) - Secondary brand color'
    - name: 'Hover'
      var: '--secondary-hover'
      value: '#8B245A'
      description: 'Hover state (darker shade)'
    - name: 'Active'
      var: '--secondary-active'
      value: '#751D4E'
      description: 'Active/pressed state (darkest)'
    - name: 'Text'
      var: '--secondary-text'
      value: '#FFFFFF'
      description: 'Text on secondary backgrounds (white)'
    - name: 'Border'
      var: '--secondary-border'
      value: '#A12B66'
      description: 'Secondary borders'
    - name: 'Subtle'
      var: '--secondary-subtle'
      value: '#F3D9E5'
      description: 'Subtle backgrounds (very light pink-100)'
    - name: 'Bg Subtle'
      var: '--secondary-bg-subtle'
      value: '#F9ECF2'
      description: 'Light background pink-50'
    - name: 'Border Subtle'
      var: '--secondary-border-subtle'
      value: '#D998B8'
      description: 'Subtle borders (pink-300)'
    - name: 'Text Emphasis'
      var: '--secondary-text-emphasis'
      value: '#751D4E'
      description: 'Emphasized text (dark pink-900)'

  'Success (Positive Feedback - BNP Teal #198754 - DISTINCT from Primary)':
    - name: 'Base'
      var: '--success'
      value: '#198754'
      description: 'Official success color (from teal-600) - DISTINCT from primary green'
    - name: 'Hover'
      var: '--success-hover'
      value: '#167A48'
      description: 'Hover state (darker shade)'
    - name: 'Active'
      var: '--success-active'
      value: '#146247'
      description: 'Active/pressed state (darkest)'
    - name: 'Text'
      var: '--success-text'
      value: '#FFFFFF'
      description: 'Text on success backgrounds (white)'
    - name: 'Border'
      var: '--success-border'
      value: '#198754'
      description: 'Success borders'
    - name: 'Subtle'
      var: '--success-subtle'
      value: '#D1E7DD'
      description: 'Subtle backgrounds (very light teal-100)'
    - name: 'Bg Subtle'
      var: '--success-bg-subtle'
      value: '#E7F4F1'
      description: 'Light background teal-50'
    - name: 'Border Subtle'
      var: '--success-border-subtle'
      value: '#7FB9A3'
      description: 'Subtle borders (teal-300)'
    - name: 'Text Emphasis'
      var: '--success-text-emphasis'
      value: '#124A3B'
      description: 'Emphasized text (dark teal-900)'


  'Danger (Error/Destructive - BNP Red #EB3636)':
    - name: 'Base'
      var: '--danger'
      value: '#EB3636'
      description: 'Official error color (from red-600) - Errors and destructive actions'
    - name: 'Hover'
      var: '--danger-hover'
      value: '#D43131'
      description: 'Hover state (darker shade)'
    - name: 'Active'
      var: '--danger-active'
      value: '#BD2C2C'
      description: 'Active/pressed state (darkest)'
    - name: 'Text'
      var: '--danger-text'
      value: '#FFFFFF'
      description: 'Text on danger backgrounds (white)'
    - name: 'Border'
      var: '--danger-border'
      value: '#EB3636'
      description: 'Error/danger borders'
    - name: 'Subtle'
      var: '--danger-subtle'
      value: '#FDEBEB'
      description: 'Subtle backgrounds (very light red-100)'
    - name: 'Bg Subtle'
      var: '--danger-bg-subtle'
      value: '#FEF7F7'
      description: 'Light background red-50'
    - name: 'Border Subtle'
      var: '--danger-border-subtle'
      value: '#F5B5B5'
      description: 'Subtle borders (red-300)'
    - name: 'Text Emphasis'
      var: '--danger-text-emphasis'
      value: '#A62626'
      description: 'Emphasized text (dark red-900)'

  'Warning (Caution/Attention - Yellow)':
    - name: 'Base'
      var: '--warning'
      value: '#D97706'
      description: 'Warning/caution color (from yellow-600) - Alerts and warnings'
    - name: 'Hover'
      var: '--warning-hover'
      value: '#B45309'
      description: 'Hover state (darker shade)'
    - name: 'Active'
      var: '--warning-active'
      value: '#92400E'
      description: 'Active/pressed state (darkest)'
    - name: 'Text'
      var: '--warning-text'
      value: '#000000'
      description: 'Text on warning backgrounds (black for contrast)'
    - name: 'Border'
      var: '--warning-border'
      value: '#D97706'
      description: 'Warning borders'
    - name: 'Subtle'
      var: '--warning-subtle'
      value: '#FEF3C7'
      description: 'Subtle backgrounds (very light yellow-100)'
    - name: 'Bg Subtle'
      var: '--warning-bg-subtle'
      value: '#FEFCE8'
      description: 'Light background yellow-50'
    - name: 'Border Subtle'
      var: '--warning-border-subtle'
      value: '#FCD34D'
      description: 'Subtle borders (yellow-300)'
    - name: 'Text Emphasis'
      var: '--warning-text-emphasis'
      value: '#78350F'
      description: 'Emphasized text (dark yellow-900)'

  'Info (Informational - Blue)':
    - name: 'Base'
      var: '--info'
      value: '#2563EB'
      description: 'Informational color (from blue-600) - General information'
    - name: 'Hover'
      var: '--info-hover'
      value: '#1D4ED8'
      description: 'Hover state (darker shade)'
    - name: 'Active'
      var: '--info-active'
      value: '#1E40AF'
      description: 'Active/pressed state (darkest)'
    - name: 'Text'
      var: '--info-text'
      value: '#FFFFFF'
      description: 'Text on info backgrounds (white)'
    - name: 'Border'
      var: '--info-border'
      value: '#2563EB'
      description: 'Info borders'
    - name: 'Subtle'
      var: '--info-subtle'
      value: '#DBEAFE'
      description: 'Subtle backgrounds (very light blue-100)'
    - name: 'Bg Subtle'
      var: '--info-bg-subtle'
      value: '#EFF6FF'
      description: 'Light background blue-50'
    - name: 'Border Subtle'
      var: '--info-border-subtle'
      value: '#93C5FD'
      description: 'Subtle borders (blue-300)'
    - name: 'Text Emphasis'
      var: '--info-text-emphasis'
      value: '#1E3A8A'
      description: 'Emphasized text (dark blue-900)'

  'Light (Light Background Mode)':
    - name: 'Base'
      var: '--light'
      value: '#F9F9FB'
      description: 'Very light gray (from gray-50) - Light backgrounds'
    - name: 'Hover'
      var: '--light-hover'
      value: '#EBEDEF'
      description: 'Hover state'
    - name: 'Active'
      var: '--light-active'
      value: '#D6DBDE'
      description: 'Active/pressed state'
    - name: 'Text'
      var: '--light-text'
      value: '#434F57'
      description: 'Text on light backgrounds (dark gray)'
    - name: 'Border'
      var: '--light-border'
      value: '#D6DBDE'
      description: 'Light borders'
    - name: 'Subtle'
      var: '--light-subtle'
      value: '#FFFFFF'
      description: 'White on light backgrounds'
    - name: 'Bg Subtle'
      var: '--light-bg-subtle'
      value: '#F9F9FB'
      description: 'Very light backgrounds'
    - name: 'Border Subtle'
      var: '--light-border-subtle'
      value: '#EBEDEF'
      description: 'Subtle light borders'
    - name: 'Text Emphasis'
      var: '--light-text-emphasis'
      value: '#333333'
      description: 'Emphasized text (dark gray-900)'

  'Dark (Dark Background Mode)':
    - name: 'Base'
      var: '--dark'
      value: '#333333'
      description: 'Dark gray (from gray-900) - Dark backgrounds'
    - name: 'Hover'
      var: '--dark-hover'
      value: '#434F57'
      description: 'Hover state (lighter shade)'
    - name: 'Active'
      var: '--dark-active'
      value: '#777E83'
      description: 'Active/pressed state (lighter still)'
    - name: 'Text'
      var: '--dark-text'
      value: '#FFFFFF'
      description: 'Text on dark backgrounds (white)'
    - name: 'Border'
      var: '--dark-border'
      value: '#333333'
      description: 'Dark borders'
    - name: 'Subtle'
      var: '--dark-subtle'
      value: '#434F57'
      description: 'Subtle on dark (gray-800)'
    - name: 'Bg Subtle'
      var: '--dark-bg-subtle'
      value: '#333333'
      description: 'Dark backgrounds'
    - name: 'Border Subtle'
      var: '--dark-border-subtle'
      value: '#777E83'
      description: 'Subtle dark borders'
    - name: 'Text Emphasis'
      var: '--dark-text-emphasis'
      value: '#FFFFFF'
      description: 'Emphasized text on dark (white)'
    # TEXT COLORS
  Text:
    - name: 'Primary'
      var: '--text-primary'
      value: '#434F57'
      description: 'Main text color (WCAG AAA)'
    - name: 'Secondary'
      var: '--text-secondary'
      value: '#777E83'
      description: 'Secondary text (WCAG AA)'
    - name: 'Disabled'
      var: '--text-disabled'
      value: '#B0B8BD'
      description: 'Disabled text'
    - name: 'Inverse'
      var: '--text-inverse'
      value: '#FFFFFF'
      description: 'Text on dark backgrounds'

  # BORDER COLORS
  Borders:
    - name: 'Default'
      var: '--border-default'
      value: '#D6DBDE'
      description: 'Default borders'
    - name: 'Light'
      var: '--border-light'
      value: '#EBEDEF'
      description: 'Light separators'
    - name: 'Focus'
      var: '--border-focus'
      value: '#333333'
      description: 'Focus ring (dark gray from maquette)'
    - name: 'Error'
      var: '--border-error'
      value: '#EB3636'
      description: 'Error state borders'
    - name: 'Success Done'
      var: '--border-success'
      value: '#00915A'
      description: 'Success/done state borders (BNP green)'

  # BACKGROUND COLORS
  Backgrounds:
    - name: 'Page'
      var: '--bg-page'
      value: '#FFFFFF'
      description: 'Main page background'
    - name: 'Section'
      var: '--bg-section'
      value: '#F9F9FB'
      description: 'Section backgrounds'
    - name: 'Disabled'
      var: '--bg-disabled'
      value: '#F4F5F6'
      description: 'Disabled inputs/buttons'
    - name: 'Success Light'
      var: '--bg-success-light'
      value: '#99D3BD'
      description: 'Light success backgrounds (alerts)'
    - name: 'Danger Light'
      var: '--bg-danger-light'
      value: '#FEE2E2'
      description: 'Light error backgrounds'
    - name: 'Warning Light'
      var: '--bg-warning-light'
      value: '#FEF3C7'
      description: 'Light warning backgrounds'
    - name: 'Info Light'
      var: '--bg-info-light'
      value: '#DBEAFE'
      description: 'Light info backgrounds'

  # OVERLAY COLORS
  Overlays:
    - name: 'Dark Heavy'
      var: '--overlay-dark-heavy'
      value: 'rgba(0, 0, 0, 0.6)'
      description: 'Modals, heavy overlays'
    - name: 'Dark Medium'
      var: '--overlay-dark-medium'
      value: 'rgba(0, 0, 0, 0.36)'
      description: 'Medium overlays'
    - name: 'Dark Light'
      var: '--overlay-dark-light'
      value: 'rgba(0, 0, 0, 0.12)'
      description: 'Light overlays'
    - name: 'Brand Base'
      var: '--overlay-brand-base'
      value: '#1C2D37'
      description: 'Brand overlay base color'
    - name: 'Brand Medium'
      var: '--overlay-brand-medium'
      value: 'rgba(28, 45, 55, 0.36)'
      description: 'Medium brand overlay'
    - name: 'Brand Light'
      var: '--overlay-brand-light'
      value: 'rgba(28, 45, 55, 0.12)'
      description: 'Light brand overlay'
