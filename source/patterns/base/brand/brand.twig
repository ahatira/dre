<section class="demo-brands">
  {# Theme Colors - Large cards display #}
  <div class="theme-colors-section">
    <h3 class="section-title">Theme colors</h3>
    <p class="section-intro">Official BNP Paribas Real Estate semantic color palette for UI components and states.</p>
    <div class="theme-colors-grid">
      {% for title, list in brands %}
        {% for item in list %}
          <div class="theme-color-card theme-color-{{ item.slug }}">
            <span class="theme-color-name">{{ item.name }}</span>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>

  {# Semantic Colors - Table with variants #}
  <div class="brand-grid">
    <h3 class="section-title">All colors and variants</h3>
    <p class="section-intro">Complete semantic token system with base, subtle, border, and text-emphasis variants for each theme color.</p>
    {% for title, list in brands %}
      <div class="brand-group">
        <h3 class="brand-group__title">{{ title }}</h3>
        <table class="brand-table">
          <thead>
            <tr>
              <th style="width: 50%;">Description</th>
              <th style="width: 200px;" class="ps-0">Swatch</th>
              <th>Variables</th>
            </tr>
          </thead>
          <tbody>
            {% for item in list %}
              {# First row with description spanning multiple variant rows #}
              <tr>
                <td rowspan="{{ item.variants|length }}">
                  <p><strong>{{ item.name }} —</strong> {{ item.description }}</p>
                </td>
                {# First variant #}
                {% set first_variant = item.variants[0] %}
                <td class="ps-0">
                  <div class="p-3 rounded-2{% if first_variant.type == 'base' %} bg-{{ item.slug }}{% endif %}{% if first_variant.type == 'border' %} border{% endif %}" 
                    {% if first_variant.type == 'subtle' %}style="background-color: var({{ first_variant.var }})"{% endif %}
                    {% if first_variant.type == 'border' %}style="border: 5px var({{ first_variant.var }}) solid"{% endif %}
                    {% if first_variant.type == 'text' %}style="color: var({{ first_variant.var }})"{% endif %}>
                    {% if first_variant.type == 'text' %}<span class="fw-bold">Text</span>{% else %}&nbsp;{% endif %}
                  </div>
                </td>
                <td>
                  <p><code>{{ first_variant.var }}</code></p>
                </td>
              </tr>
              
              {# Remaining variants (if any) #}
              {% for variant in item.variants|slice(1) %}
                <tr>
                  <td class="ps-0">
                    <div class="p-3 rounded-2{% if variant.type == 'border' %} border{% endif %}" 
                      {% if variant.type == 'subtle' %}style="background-color: var({{ variant.var }})"{% endif %}
                      {% if variant.type == 'border' %}style="border: 5px var({{ variant.var }}) solid"{% endif %}
                      {% if variant.type == 'text' %}style="color: var({{ variant.var }})"{% endif %}>
                      {% if variant.type == 'text' %}<span class="fw-bold">Text</span>{% else %}&nbsp;{% endif %}
                    </div>
                  </td>
                  <td>
                    <p><code>{{ variant.var }}</code></p>
                  </td>
                </tr>
              {% endfor %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endfor %}
  </div>
</section>

