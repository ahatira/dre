<section class="demo-brands">
  {% for title, list in brands %}
    <div class="just-for-gap">
      <h2 class="heading">{{ title }}</h2>
      <article class="brand-demo">
        {% for item in list %}
          <div class="brand-demo__swatch">
            <div 
              class="swatch" 
              style="background-color: {{ item.value }}"
              title="Token: {{ item.var }}"
            >
              {% if item.name contains 'Base' or item.name contains 'Primary' or item.name contains 'Secondary' %}
                <span class="swatch-label">{{ item.value }}</span>
              {% endif %}
            </div>
            <div class="meta">
              <span class="name">{{ item.name }}</span>
              <span class="var">{{ item.var }}</span>
              <span class="value">{{ item.value }}</span>
              {% if item.description %}
                <span class="description">{{ item.description }}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </article>
    </div>
  {% endfor %}
</section>
