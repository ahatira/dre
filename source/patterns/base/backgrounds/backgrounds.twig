{#
/**
 * @file
 * Background utilities documentation story.
 */
#}

{% set semantic_section %}
  <div class="demo-colors">
    <div class="color-grid">
      {% for background in semantic_backgrounds %}
        <div class="color-column">
          <h3 class="color-category__title">{{ background.name }}</h3>
          {% for variant in background.variants %}
            <div class="swatch-main{% if 'subtle' in variant.class %} swatch-dark{% else %} swatch-light{% endif %}"
              style="background-color: var({{ variant.token }});">
              <strong>.{{ variant.class }}</strong>
              <div class="demo-code">{{ variant.token }}</div>
              <div class="demo-notes">{{ variant.description }}</div>
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endset %}

{% set neutral_section %}
  <div class="demo-colors">
    <div class="color-grid">
      {% for background in neutral_backgrounds %}
        <div class="color-column">
          <h3 class="color-category__title">{{ background.name }}</h3>
          <div class="swatch-main{% if 'dark' in background.class %} swatch-light{% else %} swatch-dark{% endif %}"
            style="background-color: var({{ background.token }});">
            <strong>.{{ background.class }}</strong>
            <div class="demo-code">{{ background.token }}</div>
            <div class="demo-notes">{{ background.usage }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{% endset %}

{% set reference_section %}
  <div class="demo-table">
    <table class="demo-table">
      <thead>
        <tr>
          <th>Utility Class</th>
          <th>Description</th>
          <th>Example</th>
        </tr>
      </thead>
      <tbody>
        {% for row in utilities_reference %}
          <tr>
            <td><code>{{ row.utility }}</code></td>
            <td>{{ row.description }}</td>
            <td><code>{{ row.example }}</code></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endset %}

{% include '../_base-story.twig' with {
  header: header,
  sections: [
    {
      badge: 'Semantic',
      title: 'Semantic backgrounds',
      description: 'Color-coded backgrounds with subtle, base, and emphasis levels for status-driven surfaces.',
      content: semantic_section,
    },
    {
      badge: 'Neutral',
      title: 'Neutral backgrounds',
      description: 'Foundational neutrals for content surfaces and inverse layouts.',
      content: neutral_section,
    },
    {
      badge: 'Reference',
      title: 'Utility reference',
      description: 'Available background utility classes and how to apply them.',
      content: reference_section,
    },
  ],
} only %}


