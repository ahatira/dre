<section class="demo-colors">
  {% if neutrals %}
    <div class="color-group">
      <h3 class="color-group__title">Neutrals (12 tokens)</h3>
      {% for title, list in neutrals %}
        <h4 class="color-category__title">{{ title }}</h4>
        <table class="color-table">
          <thead>
            <tr>
              <th style="width: 50%;">Color</th>
              <th style="width: 200px;" class="ps-0">Swatch</th>
              <th>Variables</th>
            </tr>
          </thead>
          <tbody>
            {% for item in list %}
              <tr>
                <td>
                  <p><strong>{{ item.name }}</strong>{% if item.usage %} — {{ item.usage }}{% endif %}</p>
                </td>
                <td class="ps-0">
                  <div class="p-3 rounded-2" style="background-color: {{ item.value }}">&nbsp;</div>
                </td>
                <td>
                  <p><code>{{ item.var }}</code><br><code>{{ item.value }}</code></p>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endfor %}
    </div>
  {% endif %}

  {% if palettes %}
    <div class="color-group">
      <h3 class="color-group__title">Color Palettes (70 tokens)</h3>
      {% for title, list in palettes %}
        <h4 class="color-category__title">{{ title }}</h4>
        <table class="color-table">
          <thead>
            <tr>
              <th style="width: 50%;">Color</th>
              <th style="width: 200px;" class="ps-0">Swatch</th>
              <th>Variables</th>
            </tr>
          </thead>
          <tbody>
            {% for item in list %}
              <tr>
                <td>
                  <p><strong>{{ item.name }}</strong></p>
                </td>
                <td class="ps-0">
                  <div class="p-3 rounded-2" style="background-color: {{ item.value }}">&nbsp;</div>
                </td>
                <td>
                  <p><code>{{ item.var }}</code><br><code>{{ item.value }}</code></p>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endfor %}
    </div>
  {% endif %}
</section>

<style>
.demo-colors .color-category {
  margin-block-start: var(--size-5);
}

.demo-colors .category-title {
  font-size: var(--font-size-1);
  font-weight: var(--font-weight-600);
  color: var(--text-primary);
  margin-block-end: var(--size-3);
  padding-inline-start: var(--size-2);
}

.demo-colors .color-demo__swatch .usage {
  font-size: var(--font-size--1);
  color: var(--text-secondary);
  font-style: italic;
  margin-block-start: var(--size-1);
}
</style>
