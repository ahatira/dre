{#
/**
 * @file
 * Color tokens documentation story.
 */
#}

{% set neutrals_section %}
  {% if neutrals %}
    <div class="demo-colors">
      <div class="color-grid">
          {% for title, list in neutrals %}
            <div class="color-column">
              {% set first = list|first %}
              {% set main_contrast_class = first.var == '--black' ? 'swatch-light' : 'swatch-dark' %}
              <div class="swatch-main {{ main_contrast_class }} font-monospace" style="background-color: var({{ first.var }});">
                <strong class="d-block">{{ first.var }}</strong>
                <div class="demo-code">{{ first.value }}</div>
                {% if first.usage %}<div class="demo-notes">{{ first.usage }}</div>{% endif %}
              </div>
              {% for item in list|slice(1) %}
                {% set contrast_class = loop.index <= 3 ? 'swatch-dark' : 'swatch-light' %}
                {% if item.var == '--black' %}
                  {% set contrast_class = 'swatch-light' %}
                {% endif %}
                <div class="color-shade font-monospace {{ contrast_class }}" style="background-color: var({{ item.var }});">
                  {{ item.var }}
                </div>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
{% endset %}

{% set semantic_section %}
  {% if semantic %}
    <div class="demo-colors">
      <div class="theme-colors-grid">
          {% for item in semantic %}
            {% set contrast_class = item.contrast is defined ? item.contrast : 'swatch-light' %}
            <div class="theme-color-card {{ contrast_class }}" style="background-color: var({{ item.token }});">
              <div class="theme-color-name">{{ item.name }}</div>
              <div class="demo-code">{{ item.token }}</div>
              {% if item.usage %}<div class="demo-notes">{{ item.usage }}</div>{% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
{% endset %}

{% set palettes_section %}
  {% if palettes %}
    <div class="demo-colors">
      <div class="color-grid">
          {% for title, list in palettes %}
            <div class="color-column">
              {% set base_color = list[5] is defined ? list[5] : list|first %}
              <div class="swatch-main swatch-light font-monospace" style="background-color: var({{ base_color.var }});">
                <strong class="d-block">{{ title }}</strong>
                <div class="demo-code">{{ base_color.var }}</div>
                <div class="demo-notes">{{ base_color.value }}</div>
                {% if base_color.usage %}<div class="demo-notes">{{ base_color.usage }}</div>{% endif %}
              </div>
              {% for item in list %}
                {% set contrast_class = loop.index <= 3 ? 'swatch-dark' : 'swatch-light' %}
                {% if item.var == '--black' %}
                  {% set contrast_class = 'swatch-light' %}
                {% endif %}
                <div class="color-shade font-monospace {{ contrast_class }}" style="background-color: var({{ item.var }});">
                  {{ item.var }}
                </div>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
    </div>
  {% endif %}
{% endset %}

{% include '../_base-story.twig' with {
  header: header,
  sections: [
    {
      title: 'Neutral palette',
      description: 'Gray ramp plus white/black for structural surfaces and typography.',
      content: neutrals_section,
    },
    {
      title: 'Semantic colors',
      description: 'Brand and feedback colors from semantic tokens in brand.css.',
      content: semantic_section,
    },
    {
      title: 'Brand and semantic palettes',
      description: 'Official BNP Paribas Real Estate color scales (50–900) for brand and semantic usage.',
      content: palettes_section,
    },
  ],
} only %}
