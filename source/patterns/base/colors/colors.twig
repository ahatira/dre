<section class="demo-colors">
  {# Main Color Swatches - Semantic colors from brand #}
  <div class="theme-colors-section">
    <h3 class="section-title">Official BNP Paribas Real Estate Palettes</h3>
    <p class="section-intro">Complete color palettes including neutrals, primary brand colors, and semantic color scales for UI components.</p>
  </div>

  {% if neutrals %}
    <div class="color-section">
      <h3 class="color-section__title">Neutrals</h3>
      <div class="color-grid">
        {% for title, list in neutrals %}
          <div class="color-column">
            {# First item as header with main color #}
            {% set first = list|first %}
            <div class="p-3 mb-2 position-relative swatch-main font-monospace swatch-light" style="background-color: var({{ first.var }})">
              <strong class="d-block">{{ first.var }}</strong>
              {{ first.value }}
            </div>
            {# Remaining shades - neutrals use contrasting logic: light colors get dark text #}
            {% for item in list|slice(1) %}
              <div class="p-3 font-monospace color-shade {% if loop.index <= 3 %}swatch-dark{% else %}swatch-light{% endif %}" style="background-color: var({{ item.var }})">
                {{ item.var }}
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if palettes %}
    <div class="color-section">
      <h3 class="color-section__title">Color Palettes</h3>
      <div class="color-grid">
        {% for title, list in palettes %}
          <div class="color-column">
            {# Find base color (usually 600) or use first #}
            {% set base_color = list[5] %}
            {% set title_contrast = 'swatch-dark' %}
            {# Special case: Black header needs light text #}
            {% if base_color.var == '--black' %}
              {% set title_contrast = 'swatch-light' %}
            {% endif %}
            <div class="p-3 mb-2 position-relative swatch-main font-monospace {{ title_contrast }}" style="background-color: var({{ base_color.var }})">
              <strong class="d-block">{{ title }}</strong>
              {{ base_color.value }}
            </div>
            {# All shades from 50 to 900 #}
            {% for item in list %}
              {% set contrast_class = 'swatch-light' %}
              {% if loop.index <= 3 %}
                {% set contrast_class = 'swatch-dark' %}
              {% endif %}
              {# Special case: Black needs light text #}
              {% if item.var == '--black' %}
                {% set contrast_class = 'swatch-light' %}
              {% endif %}
              <div class="p-3 font-monospace color-shade {{ contrast_class }}" style="background-color: var({{ item.var }})">
                {{ item.var }}
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

<style>
.demo-colors .color-category {
  margin-block-start: var(--size-5);
}

.demo-colors .category-title {
  font-size: var(--font-size-1);
  font-weight: var(--font-weight-600);
  color: var(--text-primary);
  margin-block-end: var(--size-3);
  padding-inline-start: var(--size-2);
}

.demo-colors .color-demo__swatch .usage {
  font-size: var(--font-size--1);
  color: var(--text-secondary);
  font-style: italic;
  margin-block-start: var(--size-1);
}
</style>
