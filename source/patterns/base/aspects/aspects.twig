{#
/**
 * @file
 * Aspect Ratio System documentation
 * 
 * Documents CSS aspect ratio tokens for consistent image and media container sizing.
 * Source: source/props/aspects.css
 */
#}

{# Content Block: Aspect Ratio Demos #}
{% set aspect_ratios_content %}
  <div class="demo-aspect-ratio">
    <div class="aspect-demo">
      <div style="aspect-ratio: var(--ratio-box)">box<br>1:1</div>
      <div style="aspect-ratio: var(--ratio-photo)">photo<br>3:2</div>
      <div style="aspect-ratio: var(--ratio-portrait)">portrait<br>3:4</div>
      <div style="aspect-ratio: var(--ratio-landscape)">landscape<br>4:3</div>
      <div style="aspect-ratio: var(--ratio-widescreen)">widescreen<br>16:9</div>
      <div style="aspect-ratio: var(--ratio-cinemascope)">cinemascope<br>21:9</div>
      <div style="aspect-ratio: var(--ratio-golden)">golden<br>φ:1</div>
    </div>
  </div>
{% endset %}

{# Include Base Story Template #}
{% include '@base/_base-story.twig' with {
  header: {
    badge: 'Design Tokens',
    title: title,
    description: description,
    meta: [
      { label: 'Tokens', value: count },
      { label: 'Source', value: 'props/aspects.css' }
    ]
  },
  sections: [
    {
      badge: 'CSS Custom Properties',
      title: 'Standard Ratios',
      description: 'Common aspect ratios for images, cards, and media containers. All containers maintain consistent height (--size-40) for comparison.',
      content: aspect_ratios_content
    }
  ]
} only %}
