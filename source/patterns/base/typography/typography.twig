{#
/**
 * @file
 * Typography documentation
 */
#}

{% set headings_content %}
  <div class="typography-demo">
    <section class="typography-section">
      <div class="typography-demo__grid">
        <div class="typography-demo__item">
          <div class="demo-code">h1 — Main page heading</div>
          <h1 style="margin: 0;">This is a h1 heading</h1>
          <small class="demo-notes">Desktop: 48px / 60px • Mobile: 40px / 52px</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h2 — Section title</div>
          <h2 style="margin: 0;">This is a h2 heading</h2>
          <small class="demo-notes">Desktop: 44px / 44px • Mobile: 36px / 44px</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h3 — Subsection</div>
          <h3 style="margin: 0;">This is a h3 heading</h3>
          <small class="demo-notes">Desktop: 32px / 40px • Mobile: 28px / 40px</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h4 — Tertiary title</div>
          <h4 style="margin: 0;">This is a h4 heading</h4>
          <small class="demo-notes">Desktop: 24px / 30px • Mobile: 24px / 30px</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h5 — Minor heading</div>
          <h5 style="margin: 0;">This is a h5 heading</h5>
          <small class="demo-notes">Desktop: 20px / 24px • Mobile: 20px / 24px</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h6 — Tertiary text</div>
          <h6 style="margin: 0;">This is a h6 heading</h6>
          <small class="demo-notes">Desktop: 14px / 20px • Mobile: 14px / 20px</small>
        </div>
      </div>
    </section>
  </div>
{% endset %}

{% set display_content %}
  <div class="typography-demo">
    <section class="typography-section">
      <div class="typography-demo__grid typography-demo__grid--display">
        <div class="typography-demo__item">
          <div class="demo-code">.display-1 — Hero/showcase</div>
          <div class="display-1" style="margin: 0;">Display 1</div>
          <small class="demo-notes">120px • Token: --font-size-14</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-2 — Large impact</div>
          <div class="display-2" style="margin: 0;">Display 2</div>
          <small class="demo-notes">80px • Token: --font-size-13</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-3 — Campaign</div>
          <div class="display-3" style="margin: 0;">Display 3</div>
          <small class="demo-notes">64px • Token: --font-size-12</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-4 — Feature title</div>
          <div class="display-4" style="margin: 0;">Display 4</div>
          <small class="demo-notes">56px • Token: --font-size-11</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-5 — Emphasis</div>
          <div class="display-5" style="margin: 0;">Display 5</div>
          <small class="demo-notes">48px • Token: --font-size-10</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-6 — Alternative</div>
          <div class="display-6" style="margin: 0;">Display 6</div>
          <small class="demo-notes">40px • Token: --font-size-9</small>
        </div>
      </div>
    </section>
  </div>
{% endset %}

{% set body_content %}
  <div class="typography-demo">
    <section class="typography-section">
      <div class="typography-demo__grid">
        <div class="typography-demo__item">
          <div class="demo-code">&lt;p&gt; (default)</div>
          <p style="margin: 0;">This is a body paragraph using the default paragraph font size (1rem/16px) with normal line height for readability.</p>
          <small class="demo-notes">Token: --font-size-1 (1rem/16px), --leading-normal</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.lead</div>
          <p class="lead" style="margin: 0;">This is a lead paragraph using larger text (1.125rem/18px) with relaxed line height for emphasis.</p>
          <small class="demo-notes">Token: --font-size-2 (1.125rem/18px), --leading-relaxed</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">&lt;small&gt;</div>
          <p><small style="margin: 0;">This is small text for captions, footnotes, and supplementary information (0.875rem/14px).</small></p>
          <small class="demo-notes">Token: --font-size-0 (0.875rem/14px)</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.micro</div>
          <p class="micro" style="margin: 0;">Micro text for metadata, timestamps, and UI labels (0.75rem/12px).</p>
          <small class="demo-notes">Token: --font-size--1 (0.75rem/12px)</small>
        </div>
      </div>
    </section>
  </div>
{% endset %}

{% set weights_content %}
  <div class="typography-demo">
    <section class="typography-section">
      <div class="typography-demo__grid">
        <div class="typography-demo__item">
          <div class="demo-code">Light (300)</div>
          <p style="font-weight: var(--font-weight-300); margin: 0;">Light weight text for subtle emphasis</p>
          <small class="demo-notes">Token: --font-weight-300 • Usage: Rarely, for delicate emphasis</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">Regular (400)</div>
          <p style="font-weight: var(--font-weight-400); margin: 0;">Regular weight text for body content and default text</p>
          <small class="demo-notes">Token: --font-weight-400 • Usage: Body text (default)</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">Bold (700)</div>
          <p style="font-weight: var(--font-weight-700); margin: 0;">Bold weight text for headings and emphasis</p>
          <small class="demo-notes">Token: --font-weight-700 • Usage: Headings and strong emphasis</small>
        </div>
      </div>
    </section>
  </div>
{% endset %}

{% include '../_base-story.twig' with {
  header: header,
  sections: [
    {
      title: 'Heading Elements',
      description: 'Semantic heading elements (h1–h6) form the document structure with responsive sizing. Always prefer semantic markup for accessibility and SEO.',
      badge: 'Semantic Elements',
      content: headings_content
    },
    {
      title: 'Display Classes',
      description: 'Non-semantic display classes (.display-1 to .display-6) apply heading-like styles to generic elements when semantic markup isn\'t possible. Use sparingly.',
      badge: 'Display Utilities',
      content: display_content
    },
    {
      title: 'Body Text',
      description: 'Reading text styles for paragraphs, lead text, and small text. Choose the appropriate size for content hierarchy and readability.',
      badge: 'Reading Text',
      content: body_content
    },
    {
      title: 'Font Weights',
      description: 'Three weight levels available: Light (300) for subtle emphasis, Regular (400) for body text, and Bold (700) for headings.',
      badge: 'Text Styling',
      content: weights_content
    }
  ]
} only %}
