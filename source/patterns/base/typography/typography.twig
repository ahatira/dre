{#
/**
 * @file
 * Typography documentation
 */
#}

{% set overview_content %}
  <div class="typography-demo">
    <div class="demo-table-wrapper">
      <h3>Typography Scale Reference</h3>
      <table class="demo-table demo-table--compact">
        <thead>
          <tr>
            <th>Element/Class</th>
            <th>Token</th>
            <th>Size (rem/px)</th>
            <th>Line Height</th>
            <th>Weight</th>
            <th>Usage</th>
          </tr>
        </thead>
        <tbody>
          <tr class="table-section-header">
            <td colspan="6"><strong>Heading Elements</strong></td>
          </tr>
          <tr>
            <td><code>h1</code></td>
            <td><code>--font-size-10</code></td>
            <td>3rem / 48px</td>
            <td>1.25 (tight)</td>
            <td>400 (Regular)</td>
            <td>Main page heading</td>
          </tr>
          <tr>
            <td><code>h2</code></td>
            <td><code>--font-size-9</code></td>
            <td>2.75rem / 44px</td>
            <td>1.25 (tight)</td>
            <td>400 (Regular)</td>
            <td>Section title</td>
          </tr>
          <tr>
            <td><code>h3</code></td>
            <td><code>--font-size-8</code></td>
            <td>2rem / 32px</td>
            <td>1.375 (snug)</td>
            <td>400 (Regular)</td>
            <td>Subsection</td>
          </tr>
          <tr>
            <td><code>h4</code></td>
            <td><code>--font-size-7</code></td>
            <td>1.5rem / 24px</td>
            <td>1.375 (snug)</td>
            <td>400 (Regular)</td>
            <td>Tertiary title</td>
          </tr>
          <tr>
            <td><code>h5</code></td>
            <td><code>--font-size-6</code></td>
            <td>1.25rem / 20px</td>
            <td>1.5 (normal)</td>
            <td>400 (Regular)</td>
            <td>Minor heading</td>
          </tr>
          <tr>
            <td><code>h6</code></td>
            <td><code>--font-size-5</code></td>
            <td>0.875rem / 14px</td>
            <td>1.5 (normal)</td>
            <td>400 (Regular)</td>
            <td>Small heading</td>
          </tr>
          <tr class="table-section-header">
            <td colspan="6"><strong>Display Classes</strong></td>
          </tr>
          <tr>
            <td><code>.display-1</code></td>
            <td><code>--font-size-14</code></td>
            <td>7.5rem / 120px</td>
            <td>1 (none)</td>
            <td>700 (Bold)</td>
            <td>Hero/showcase headlines</td>
          </tr>
          <tr>
            <td><code>.display-2</code></td>
            <td><code>--font-size-13</code></td>
            <td>5rem / 80px</td>
            <td>1 (none)</td>
            <td>700 (Bold)</td>
            <td>Large impact text</td>
          </tr>
          <tr>
            <td><code>.display-3</code></td>
            <td><code>--font-size-12</code></td>
            <td>4rem / 64px</td>
            <td>1 (none)</td>
            <td>700 (Bold)</td>
            <td>Campaign headlines</td>
          </tr>
          <tr>
            <td><code>.display-4</code></td>
            <td><code>--font-size-11</code></td>
            <td>3.5rem / 56px</td>
            <td>1 (none)</td>
            <td>700 (Bold)</td>
            <td>Feature titles</td>
          </tr>
          <tr>
            <td><code>.display-5</code></td>
            <td><code>--font-size-10</code></td>
            <td>3rem / 48px</td>
            <td>1 (none)</td>
            <td>700 (Bold)</td>
            <td>Emphasis text</td>
          </tr>
          <tr>
            <td><code>.display-6</code></td>
            <td><code>--font-size-9</code></td>
            <td>2.5rem / 40px</td>
            <td>1 (none)</td>
            <td>700 (Bold)</td>
            <td>Alternative heading</td>
          </tr>
          <tr class="table-section-header">
            <td colspan="6"><strong>Body Text</strong></td>
          </tr>
          <tr>
            <td><code>.lead</code></td>
            <td><code>--font-size-2</code></td>
            <td>1.125rem / 18px</td>
            <td>1.625 (relaxed)</td>
            <td>400 (Regular)</td>
            <td>Lead paragraphs</td>
          </tr>
          <tr>
            <td><code>p</code> (default)</td>
            <td><code>--font-size-1</code></td>
            <td>1rem / 16px</td>
            <td>1.5 (normal)</td>
            <td>400 (Regular)</td>
            <td>Body text</td>
          </tr>
          <tr>
            <td><code>small</code></td>
            <td><code>--font-size-0</code></td>
            <td>0.875rem / 14px</td>
            <td>1.5 (normal)</td>
            <td>400 (Regular)</td>
            <td>Captions, footnotes</td>
          </tr>
          <tr>
            <td><code>.micro</code></td>
            <td><code>--font-size--1</code></td>
            <td>0.75rem / 12px</td>
            <td>1.5 (normal)</td>
            <td>400 (Regular)</td>
            <td>Metadata, labels</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
{% endset %}

{% set headings_content %}
  <div class="typography-demo">
    <section class="typography-section">
      <div class="typography-demo__grid">
        <div class="typography-demo__item">
          <div class="demo-code">h1 — Main page heading</div>
          <h1 style="margin: 0;">Appartement exceptionnel avec vue panoramique</h1>
          <div class="demo-alphabet" style="margin-top: var(--size-3);">
            <h1 style="margin: 0; font-size: 1.5rem;">ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>abcdefghijklmnopqrstuvwxyz<br>1234567890(,.;:?!$&*)</h1>
          </div>
          <small class="demo-notes">Token: --font-size-10 • 48px / 60px • Weight: 400</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h2 — Section title</div>
          <h2 style="margin: 0;">Découvrez nos biens immobiliers premium</h2>
          <div class="demo-alphabet" style="margin-top: var(--size-3);">
            <h2 style="margin: 0; font-size: 1.25rem;">ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>abcdefghijklmnopqrstuvwxyz<br>1234567890(,.;:?!$&*)</h2>
          </div>
          <small class="demo-notes">Token: --font-size-9 • 44px / 44px • Weight: 400</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h3 — Subsection</div>
          <h3 style="margin: 0;">Caractéristiques du bien</h3>
          <div class="demo-alphabet" style="margin-top: var(--size-3);">
            <h3 style="margin: 0; font-size: 1rem;">ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>abcdefghijklmnopqrstuvwxyz<br>1234567890(,.;:?!$&*)</h3>
          </div>
          <small class="demo-notes">Token: --font-size-8 • 32px / 40px • Weight: 400</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h4 — Tertiary title</div>
          <h4 style="margin: 0;">Équipements et services</h4>
          <small class="demo-notes">Token: --font-size-7 • 24px / 30px • Weight: 400</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h5 — Minor heading</div>
          <h5 style="margin: 0;">Informations complémentaires</h5>
          <small class="demo-notes">Token: --font-size-6 • 20px / 24px • Weight: 400</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">h6 — Small heading</div>
          <h6 style="margin: 0;">Notes et références</h6>
          <small class="demo-notes">Token: --font-size-5 • 14px / 20px • Weight: 400</small>
        </div>
      </div>
    </section>
  </div>
{% endset %}

{% set display_content %}
  <div class="typography-demo">
    <section class="typography-section">
      <div class="typography-demo__grid typography-demo__grid--display">
        <div class="typography-demo__item">
          <div class="demo-code">.display-1 — Hero/showcase</div>
          <div class="display-1" style="margin: 0;">Paris</div>
          <div class="demo-alphabet" style="margin-top: var(--size-3); font-size: 1.5rem; font-weight: 700;">
            ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>abcdefghijklmnopqrstuvwxyz<br>1234567890
          </div>
          <small class="demo-notes">Token: --font-size-14 • 120px • Weight: 700</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-2 — Large impact</div>
          <div class="display-2" style="margin: 0;">Prestige</div>
          <div class="demo-alphabet" style="margin-top: var(--size-3); font-size: 1.25rem; font-weight: 700;">
            ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>abcdefghijklmnopqrstuvwxyz<br>1234567890
          </div>
          <small class="demo-notes">Token: --font-size-13 • 80px • Weight: 700</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-3 — Campaign</div>
          <div class="display-3" style="margin: 0;">Investir</div>
          <small class="demo-notes">Token: --font-size-12 • 64px • Weight: 700</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-4 — Feature title</div>
          <div class="display-4" style="margin: 0;">Excellence</div>
          <small class="demo-notes">Token: --font-size-11 • 56px • Weight: 700</small>
        </div>

        <div class="typography-demo__item">
          <div class="demo-code">.display-5 — Emphasis</div>
          <div class="display-5" style="margin: 0;">Premium</div>
