<section class="demo-typography">
  <div class="typography-header">
    <h1 class="section-title">Typography</h1>
    <p class="section-intro">Complete typography system with semantic heading scales, body text styles, and utility text for all UI needs.</p>
  </div>

  {# Headings showcase #}
  {% if headings %}
    <div class="typography-section">
      <h2 class="section-title-secondary">Heading Scales</h2>
      <p class="section-description">Semantic heading hierarchy from h1 to h6 with actual styling</p>
      
      <div class="headings-showcase">
        {% for heading in headings %}
          <div class="heading-item">
            {# Heading preview with actual styles #}
            {% if heading.level == 'h1' %}
              <h1 style="margin: 0 0 var(--size-2) 0;">{{ heading.example }}</h1>
            {% elseif heading.level == 'h2' %}
              <h2 style="margin: 0 0 var(--size-2) 0;">{{ heading.example }}</h2>
            {% elseif heading.level == 'h3' %}
              <h3 style="margin: 0 0 var(--size-2) 0;">{{ heading.example }}</h3>
            {% elseif heading.level == 'h4' %}
              <h4 style="margin: 0 0 var(--size-2) 0;">{{ heading.example }}</h4>
            {% elseif heading.level == 'h5' %}
              <h5 style="margin: 0 0 var(--size-2) 0;">{{ heading.example }}</h5>
            {% elseif heading.level == 'h6' %}
              <h6 style="margin: 0 0 var(--size-2) 0;">{{ heading.example }}</h6>
            {% endif %}
            
            {# Meta info #}
            <div class="heading-meta">
              <span class="meta-item"><code>{{ heading.level }}</code> {{ heading.name }}</span>
              <span class="meta-item">{{ heading.size_value }}</span>
              <span class="meta-item">Weight: {{ heading.weight }}</span>
              <span class="meta-item">Line: {{ heading.leading }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {# Body text showcase #}
  {% if body %}
    <div class="typography-section">
      <h2 class="section-title-secondary">Body Text</h2>
      <p class="section-description">Text styles for paragraphs, captions, and interface copy</p>
      
      <div class="body-showcase">
        {% for text in body %}
          <div class="body-item">
            {# Body preview #}
            {% if text.name == 'Body Large' %}
              <p class="lead" style="margin: 0 0 var(--size-3) 0;">{{ text.example }}</p>
            {% elseif text.name == 'Body Regular' %}
              <p style="margin: 0 0 var(--size-3) 0;">{{ text.example }}</p>
            {% elseif text.name == 'Body Small' %}
              <p class="small" style="margin: 0 0 var(--size-3) 0;">{{ text.example }}</p>
            {% endif %}
            
            {# Meta info #}
            <div class="body-meta">
              <span class="meta-label">{{ text.name }}</span>
              <span class="meta-value">{{ text.size_value }} • Weight: {{ text.weight }} • Line: {{ text.leading }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {# Utility text showcase #}
  {% if utility %}
    <div class="typography-section">
      <h2 class="section-title-secondary">Utility Styles</h2>
      <p class="section-description">Specialized text for labels, captions, and code</p>
      
      <div class="utility-showcase">
        {% for util in utility %}
          <div class="utility-item">
            {# Utility preview #}
            {% if util.name == 'Overline' %}
              <div class="text-uppercase fw-bold" style="font-size: var(--font-size--1); letter-spacing: var(--tracking-wide); margin: 0 0 var(--size-3) 0;">{{ util.example }}</div>
            {% elseif util.name == 'Caption' %}
              <p class="small text-secondary" style="margin: 0 0 var(--size-3) 0;">{{ util.example }}</p>
            {% elseif util.name == 'Code' %}
              <code style="font-family: var(--font-mono); font-size: var(--font-size--1); display: block; margin: 0 0 var(--size-3) 0;">{{ util.example }}</code>
            {% endif %}
            
            {# Meta info #}
            <div class="utility-meta">
              <span class="meta-label">{{ util.name }}</span>
              <span class="meta-value">{{ util.size_value }} • Weight: {{ util.weight }}{% if util.tracking %} • {{ util.tracking }}{% endif %}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {# Token reference tables #}
  {% if scales %}
    <div class="typography-section">
      <h2 class="section-title-secondary">Token Reference</h2>
      <p class="section-description">Complete typography token scales for fonts, sizes, weights, and spacing</p>
      
      <div class="scales-grid">
        {% for scale in scales %}
          <div class="scale-card">
            <h3 class="scale-title">{{ scale.name }}</h3>
            <div class="scale-tokens">
              {% for token in scale.tokens %}
                <div class="scale-token">
                  <code>{{ token }}</code>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

<style>
.demo-typography {
  padding-block: var(--size-12);
  padding-inline: var(--size-8);
  background: white;
}

.typography-header {
  margin-bottom: var(--size-16);
}

.section-title {
  font-size: var(--font-size-10);
  font-weight: var(--font-weight-700);
  color: var(--text-primary);
  margin: 0 0 var(--size-3) 0;
  letter-spacing: -0.5px;
}

.section-intro {
  font-size: var(--font-size-2);
  color: var(--text-secondary);
  margin: 0;
  line-height: var(--leading-7);
}

.typography-section {
  margin-block: var(--size-12);
  padding-block: var(--size-8);
  border-top: 1px solid var(--border-light);
}

.typography-section:first-of-type {
  border-top: none;
  padding-top: 0;
}

.section-title-secondary {
  font-size: var(--font-size-7);
  font-weight: var(--font-weight-700);
  color: var(--text-primary);
  margin: 0 0 var(--size-2) 0;
}

.section-description {
  font-size: var(--font-size-0);
  color: var(--text-secondary);
  margin: 0 0 var(--size-8) 0;
}

/* Headings showcase */
.headings-showcase {
  display: grid;
  gap: var(--size-6);
}

.heading-item {
  padding: var(--size-6);
  background: var(--bg-section);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2);
}

.heading-item h1,
.heading-item h2,
.heading-item h3,
.heading-item h4,
.heading-item h5,
.heading-item h6 {
  color: var(--text-primary);
  line-height: var(--leading-tight);
}

.heading-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--size-4);
  margin-top: var(--size-4);
  padding-top: var(--size-4);
  border-top: 1px solid var(--border-light);
  font-size: var(--font-size--1);
}

.meta-item {
  color: var(--text-secondary);
}

.meta-item code {
  background: white;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-1);
  padding: var(--size-1) var(--size-2);
  color: var(--primary);
  font-weight: var(--font-weight-600);
}

/* Body text showcase */
.body-showcase {
  display: grid;
  gap: var(--size-6);
}

.body-item {
  padding: var(--size-6);
  background: white;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2);
}

.body-item p {
  color: var(--text-primary);
}

.body-item .lead {
  font-size: var(--font-size-2);
  line-height: var(--leading-7);
}

.body-item .small {
  font-size: var(--font-size-0);
  line-height: var(--leading-5);
}

.body-meta {
  display: flex;
  flex-direction: column;
  gap: var(--size-2);
  margin-top: var(--size-4);
  padding-top: var(--size-4);
  border-top: 1px solid var(--border-light);
  font-size: var(--font-size--1);
}

.meta-label {
  font-weight: var(--font-weight-600);
  color: var(--text-primary);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wide);
}

.meta-value {
  color: var(--text-secondary);
}

/* Utility showcase */
.utility-showcase {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: var(--size-6);
}

.utility-item {
  padding: var(--size-6);
  background: white;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2);
}

.utility-item code {
  background: var(--bg-section);
  padding: var(--size-3);
  border-radius: var(--radius-1);
  font-family: var(--font-mono);
  color: var(--text-primary);
}

.utility-meta {
  display: flex;
  flex-direction: column;
  gap: var(--size-2);
  margin-top: var(--size-4);
  padding-top: var(--size-4);
  border-top: 1px solid var(--border-light);
  font-size: var(--font-size--1);
}

/* Token scales */
.scales-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--size-8);
}

.scale-card {
  padding: var(--size-6);
  background: white;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2);
}

.scale-title {
  font-size: var(--font-size-2);
  font-weight: var(--font-weight-700);
  color: var(--text-primary);
  margin: 0 0 var(--size-4) 0;
}

.scale-tokens {
  display: grid;
  gap: var(--size-2);
}

.scale-token {
  padding: var(--size-2) var(--size-3);
  background: var(--bg-section);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-1);
  font-size: var(--font-size--1);
  color: var(--text-primary);
  font-family: var(--font-mono);
  overflow-x: auto;
}

/* Utility CSS */
.text-uppercase {
  text-transform: uppercase;
}

.fw-bold {
  font-weight: var(--font-weight-700);
}

.small {
  font-size: var(--font-size-0);
  line-height: var(--leading-5);
}

.text-secondary {
  color: var(--text-secondary);
}

/* Responsive */
@media (width < 768px) {
  .demo-typography {
    padding-inline: var(--size-4);
  }

  .utility-showcase {
    grid-template-columns: 1fr;
  }

  .scales-grid {
    grid-template-columns: 1fr;
  }
}
</style>
