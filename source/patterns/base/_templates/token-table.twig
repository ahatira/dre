{#
/**
 * @file
 * Token Table - Reusable component for displaying design tokens
 * 
 * Usage:
 *   {% include '../_templates/token-table.twig' with {
 *     headers: [
 *       { label: 'Token', width: '40%' },
 *       { label: 'Value', width: '30%' },
 *       { label: 'Usage', width: '30%' }
 *     ],
 *     rows: [
 *       { token: '--primary', value: '#00915A', usage: 'Primary actions' },
 *       ...
 *     ]
 *   } only %}
 */
#}

<div class="ps-token-table-wrapper">
  <table class="ps-token-table">
    <thead>
      <tr>
        {% for header in headers %}
          <th {% if header.width %}style="width: {{ header.width }}"{% endif %}>
            {{ header.label }}
          </th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in rows %}
        <tr>
          {% if row.token %}
            <td><code class="ps-token-name">{{ row.token }}</code></td>
          {% endif %}
          {% if row.value %}
            <td><code class="ps-token-value">{{ row.value }}</code></td>
          {% endif %}
          {% if row.usage %}
            <td class="ps-token-usage">{{ row.usage }}</td>
          {% endif %}
          {% if row.swatch %}
            <td>
              <div class="ps-token-swatch" style="background-color: var({{ row.token }})"></div>
            </td>
          {% endif %}
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
