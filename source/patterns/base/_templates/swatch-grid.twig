{#
/**
 * @file
 * Swatch Grid - Generic swatches for any token system
 * 
 * Usage:
 *   {% include '../_templates/swatch-grid.twig' with {
 *     title: 'Shadows',
 *     items: [
 *       { name: 'Small', var: '--shadow-sm', preview: 'box' },
 *       { name: 'Medium', var: '--shadow-md', preview: 'box' },
 *       ...
 *     ],
 *     columns: 3
 *   } only %}
 */
#}

<div class="ps-swatch-grid" style="--columns: {{ columns|default(4) }}">
  {% for item in items %}
    <div class="ps-swatch-item">
      {% if item.preview == 'color' %}
        <div class="ps-swatch-preview ps-swatch-preview--color" style="background-color: var({{ item.var }})"></div>
      {% endif %}
      
      {% if item.preview == 'box' %}
        <div class="ps-swatch-preview ps-swatch-preview--box" style="box-shadow: var({{ item.var }})"></div>
      {% endif %}
      
      {% if item.preview == 'text' %}
        <div class="ps-swatch-preview ps-swatch-preview--text" style="font-size: var({{ item.var }})">Aa</div>
      {% endif %}
      
      <div class="ps-swatch-info">
        <strong class="ps-swatch-name">{{ item.name }}</strong>
        <code class="ps-swatch-token">{{ item.var }}</code>
        {% if item.value %}
          <span class="ps-swatch-value">{{ item.value }}</span>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</div>
