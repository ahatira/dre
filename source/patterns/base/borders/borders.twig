{#
/**
 * @file
 * Borders documentation
 *
 * Design tokens for border widths, radii, and semantic colors.
 * Reference: source/props/borders.css + source/props/brand.css
 */
#}

{# ========================================
   BORDER WIDTHS CONTENT BLOCK
   ======================================== #}
{% set border_widths %}
  <div class="demo-borders">
    <div class="border-demo">
      <div style="border-width: var(--border-size-1);">1</div>
      <div style="border-width: var(--border-size-2);">2</div>
      <div style="border-width: var(--border-size-3);">3</div>
      <div style="border-width: var(--border-size-4);">4</div>
      <div style="border-width: var(--border-size-5);">5</div>
    </div>
  </div>
{% endset %}

{# ========================================
   BORDER RADIUS CONTENT BLOCK
   ======================================== #}
{% set border_radii %}
  <div class="demo-borders">
    <div class="border-demo">
      <div style="border-radius: var(--radius-1);">1</div>
      <div style="border-radius: var(--radius-2);">2</div>
      <div style="border-radius: var(--radius-3);">3</div>
      <div style="border-radius: var(--radius-4);">4</div>
      <div style="border-radius: var(--radius-5);">5</div>
      <div style="border-radius: var(--radius-6);">6</div>
      <div style="border-radius: var(--radius-7);">7</div>
      <div style="border-radius: var(--radius-round);">round</div>
    </div>
  </div>
{% endset %}

{# ========================================
   BORDER COLORS CONTENT BLOCK
   ======================================== #}
{% set border_colors %}
  <div class="border-color-grid">
    <div class="border-swatch">
      <div class="swatch" style="background-color: var(--border-default);"></div>
      <div class="meta">
        <span class="name">Default</span>
        <span class="var">--border-default</span>
        <span class="usage">Standard borders</span>
      </div>
    </div>
    <div class="border-swatch">
      <div class="swatch" style="background-color: var(--border-light);"></div>
      <div class="meta">
        <span class="name">Light</span>
        <span class="var">--border-light</span>
        <span class="usage">Light separators</span>
      </div>
    </div>
    <div class="border-swatch">
      <div class="swatch" style="background-color: var(--border-focus);"></div>
      <div class="meta">
        <span class="name">Focus</span>
        <span class="var">--border-focus</span>
        <span class="usage">Focus rings</span>
      </div>
    </div>
    <div class="border-swatch">
      <div class="swatch" style="background-color: var(--border-error);"></div>
      <div class="meta">
        <span class="name">Error</span>
        <span class="var">--border-error</span>
        <span class="usage">Error states</span>
      </div>
    </div>
    <div class="border-swatch">
      <div class="swatch" style="background-color: var(--border-success);"></div>
      <div class="meta">
        <span class="name">Success</span>
        <span class="var">--border-success</span>
        <span class="usage">Success/done</span>
      </div>
    </div>
  </div>
{% endset %}

{# Include base story template #}
{% include '../_base-story.twig' with {
  header: {
    title: 'Borders',
    description: 'Complete border system: widths, radii, and semantic colors for consistent visual hierarchy.',
    badge: 'Design Tokens',
    meta: [
      { label: 'Widths', value: '5' },
      { label: 'Radii', value: '8' },
      { label: 'Colors', value: '5' }
    ]
  },
  sections: [
    {
      badge: 'Spacing',
      title: 'Border Widths',
      description: 'Five predefined border width tokens from 1px to 5px for visual emphasis and hierarchy.',
      content: border_widths
    },
    {
      badge: 'Spacing',
      title: 'Border Radius',
      description: 'Eight radius tokens from sharp (1) to fully rounded (round). Use for corners, pills, and curves.',
      content: border_radii
    },
    {
      badge: 'Colors',
      title: 'Border Colors',
      description: 'Semantic border colors for different states and contexts (standard, light, focus, error, success).',
      content: border_colors
    }
  ]
} only %}
