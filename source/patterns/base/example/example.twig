{#
/**
 * @file
 * Example Base Story - Complete demonstration
 * 
 * Shows how to use:
 * 1. Base story template (_base-story.twig)
 * 2. All 5 reusable components from _templates/
 * 3. Component CSS library (components.css)
 * 4. Design token integration
 * 
 * This is a reference example for building professional
 * documentation using the template system.
 */
#}

{# Include base template with header + sections #}
{% include '../_base-story.twig' with {
  header: header,
  sections: [
    {
      badge: 'Component 1',
      title: 'Color Cards',
      description: 'Large semantic color cards showing theme colors. Each card displays a semantic color used throughout the system.',
      content: color_cards_content
    },
    {
      badge: 'Component 2',
      title: 'Color Palettes',
      description: 'Vertical color scales showing tint/shade progression from 50 to 900. Click to inspect color values.',
      content: color_palettes_content
    },
    {
      badge: 'Component 3',
      title: 'Token Reference Table',
      description: 'Complete reference table of all design tokens with values and usage descriptions.',
      content: token_table_content
    },
    {
      badge: 'Component 4',
      title: 'Typography Specimens',
      description: 'Font samples showing heading and body text styles with responsive sizing information.',
      content: typography_content
    },
    {
      badge: 'Component 5',
      title: 'Spacing Scale',
      description: 'Visual demonstration of spacing tokens (size scale) used for margins, paddings, and gaps.',
      content: spacing_content
    }
  ]
} only %}

{# ================================================
   COMPONENT 1: Color Cards
   ================================================ #}
{% set color_cards_content %}
  {% include '../_templates/color-cards.twig' with {
    colors: semantic_colors
  } only %}
{% endset %}

{# ================================================
   COMPONENT 2: Color Palettes (Color Columns)
   ================================================ #}
{% set color_palettes_content %}
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--size-5)">
    {% for key, palette in color_palettes %}
      {% include '../_templates/color-column.twig' with {
        title: palette.title,
        base_var: palette.base_var,
        base_value: palette.base_value,
        shades: palette.shades
      } only %}
    {% endfor %}
  </div>
{% endset %}

{# ================================================
   COMPONENT 3: Token Table
   ================================================ #}
{% set token_table_content %}
  {% include '../_templates/token-table.twig' with {
    headers: [
      { label: 'Token', width: '25%' },
      { label: 'Value', width: '20%' },
      { label: 'Usage', width: '55%' }
    ],
    rows: tokens
  } only %}
{% endset %}

{# ================================================
   COMPONENT 4: Typography Samples
   ================================================ #}
{% set typography_content %}
  <div style="display: grid; gap: var(--size-6)">
    {% for sample in typography %}
      {% include '../_templates/type-sample.twig' with {
        label: sample.label,
        element: sample.element,
        text: sample.text,
        specs: sample.specs
      } only %}
    {% endfor %}
  </div>
{% endset %}

{# ================================================
   COMPONENT 5: Swatch Grid (Spacing)
   ================================================ #}
{% set spacing_content %}
  {% include '../_templates/swatch-grid.twig' with {
    items: spacing_tokens,
    columns: 4
  } only %}
{% endset %}

{# ================================================
   IMPORT COMPONENT STYLES
   ================================================ #}
<link rel="stylesheet" href="../_templates/components.css">
