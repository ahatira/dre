{#
/**
 * Pager - Simple pagination component
 * Based on Drupal core pager template
 */
#}
{% if items %}
  {% set heading_id = heading_id|default('pagination') %}
  {% set pagination_heading_level = pagination_heading_level|default('h2') %}
  
  <nav class="pager" role="navigation" aria-labelledby="{{ heading_id }}">
    <{{ pagination_heading_level }} id="{{ heading_id }}" class="visually-hidden">
      {{ 'Pagination'|default('Pagination') }}
    </{{ pagination_heading_level }}>
    
    <ul class="pager__items">
      {# Previous #}
      {% if items.previous %}
        <li class="pager__item pager__item--previous">
          <a href="{{ items.previous.href }}" class="pager__link" rel="prev" title="{{ 'Go to previous page'|default('Go to previous page') }}">
            <span class="visually-hidden">{{ 'Previous page'|default('Previous page') }}</span>
            <span class="pager__link-text" aria-hidden="true">{{ items.previous.text|default('‹ Previous') }}</span>
          </a>
        </li>
      {% endif %}

      {# Ellipsis before #}
      {% if ellipses.previous %}
        <li class="pager__item pager__item--ellipsis" role="presentation">&hellip;</li>
      {% endif %}

      {# Page numbers #}
      {% for key, item in items.pages %}
        <li class="pager__item{{ current == key ? ' pager__item--active' : '' }}">
          {% if current == key %}
            <span class="pager__link pager__link--active" aria-current="page">
              <span class="visually-hidden">{{ 'Current page'|default('Current page') }}</span>
              {{ key }}
            </span>
          {% else %}
            <a href="{{ item.href }}" class="pager__link" title="{{ 'Go to page @key'|default('Go to page ' ~ key) }}">
              <span class="visually-hidden">{{ 'Page'|default('Page') }} </span>
              {{ key }}
            </a>
          {% endif %}
        </li>
      {% endfor %}

      {# Ellipsis after #}
      {% if ellipses.next %}
        <li class="pager__item pager__item--ellipsis" role="presentation">&hellip;</li>
      {% endif %}

      {# Next #}
      {% if items.next %}
        <li class="pager__item pager__item--next">
          <a href="{{ items.next.href }}" class="pager__link" rel="next" title="{{ 'Go to next page'|default('Go to next page') }}">
            <span class="visually-hidden">{{ 'Next page'|default('Next page') }}</span>
            <span class="pager__link-text" aria-hidden="true">{{ items.next.text|default('Next ›') }}</span>
          </a>
        </li>
      {% endif %}
    </ul>
  </nav>
{% endif %}
