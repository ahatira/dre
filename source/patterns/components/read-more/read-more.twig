{#
/**
 * @file
 * Read More (Component / Molecule)
 *
 * JavaScript-powered content expander for WYSIWYG content with toggle.
 * Measures content height and truncates via max-height, then reveals on click.
 *
 * @param {string} content
 *   Full WYSIWYG content (HTML allowed - paragraphs, lists, images, etc.).
 * @param {number} [maxHeight=150]
 *   Maximum height in pixels before truncation (default: 150px ≈ 6 lines).
 * @param {string} [expandLabel='Voir plus']
 *   Label for expand button (French: "See more").
 * @param {string} [collapseLabel='Voir moins']
 *   Label for collapse button (French: "See less").
 * @param {boolean} [expanded=false]
 *   Initial state (true = fully visible, false = truncated).
 * @param {boolean} [showIcon=true]
 *   Show chevron icon next to label.
 * @param {Attribute} [attributes]
 *   Additional HTML attributes for root container.
 *
 * Features:
 * - JavaScript height measurement (supports WYSIWYG content)
 * - Smooth height transitions (animates between collapsed/expanded)
 * - Auto-hide toggle if content shorter than maxHeight
 * - Icon rotation animation (chevron-down → chevron-up)
 * - Configurable via data attributes (Drupal integration)
 * - Accessible button with semantic labels
 *
 * Accessibility:
 * - <button> element for toggle (keyboard operable)
 * - aria-expanded reflects current state
 * - Focus-visible outline (WCAG 2.2 AA)
 * - Label updates dynamically (assistive tech announces change)
 *
 * Composition:
 * - Content wrapper (WYSIWYG slot)
 * - Button element (toggle control)
 * - Icon atom (chevron indicator, optional)
 *
 * Data Attributes (for JavaScript):
 * - data-read-more: Component identifier
 * - data-max-height: Max height before truncation (pixels)
 * - data-expand-label: Custom expand label
 * - data-collapse-label: Custom collapse label
 */
#}

{%- set maxHeight = maxHeight|default(150) -%}
{%- set expandLabel = expandLabel|default('Voir plus') -%}
{%- set collapseLabel = collapseLabel|default('Voir moins') -%}
{%- set expanded = expanded|default(false) -%}
{%- set showIcon = showIcon|default(true) -%}

{%- set classes = [
  'ps-read-more',
  expanded ? 'ps-read-more--expanded' : null
] -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}
{%- set attr = attr.setAttribute('data-read-more', '') -%}
{%- set attr = attr.setAttribute('data-max-height', maxHeight) -%}
{%- set attr = attr.setAttribute('data-expand-label', expandLabel) -%}
{%- set attr = attr.setAttribute('data-collapse-label', collapseLabel) -%}

<div{{ attr }}>
  <div class="ps-read-more__content" data-read-more-content>
    {{ content|raw }}
  </div>
  
  <button type="button" class="ps-read-more__toggle" data-read-more-toggle aria-expanded="{{ expanded ? 'true' : 'false' }}" style="display: none;">
    <span class="ps-read-more__label" data-read-more-label>{{ expanded ? collapseLabel : expandLabel }}</span>
    {%- if showIcon %}
    <span class="ps-read-more__icon" data-icon="chevron-down" aria-hidden="true"></span>
    {%- endif %}
  </button>
</div>
