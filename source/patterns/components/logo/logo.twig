{#
/**
 * @file
 * PS Logo (Component/Molecule) - Brand logo for BNP Paribas Real Estate
 *
 * Flexible, data-driven logo component with automatic layout.
 * Displays what is provided: image, text/label, and/or slogan.
 *
 * @param {string} [image] - Logo image path (e.g. '/logo/logo.svg')
 * @param {string} [text] - Company name/text (e.g. 'BNP Paribas Real Estate')
 * @param {string} [label] - Alias for text (Drupal convention)
 * @param {string} [slogan] - Tagline text (displayed if provided)
 * @param {string} [alt='BNP Paribas Real Estate'] - Alt text for image
 * @param {string} [href] - Link URL (wraps logo in <a> if provided)
 * @param {Drupal\Core\Template\Attribute} [attributes] - Additional HTML attributes
 *
 * Auto-layout:
 * - If image + slogan → flex row with gap (Desktop with slogan look)
 * - If image only → simple logo
 * - If image + text → flex column centered
 * - If text only → text-only fallback
 */
#}

{%- set image = image -%}
{%- set text = text or label -%}
{%- set slogan = slogan -%}
{%- set alt = alt|default('BNP Paribas Real Estate') -%}
{%- set href = href -%}

{%- set classes = ['ps-logo', modifier_class] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

{%- set wrapper_tag = href ? 'a' : 'div' -%}

{%- if wrapper_tag == 'a' -%}
<{{ wrapper_tag }}{{ attr }} href="{{ href }}">
{%- else -%}
<{{ wrapper_tag }}{{ attr }}>
{%- endif -%}
  {%- if image -%}
  <img class="ps-logo__image" src="{{ image }}" alt="{{ alt }}" />
  {%- endif -%}
  {%- if text -%}
  <span class="ps-logo__text">{{ text }}</span>
  {%- endif -%}
  {%- if slogan -%}
  <span class="ps-logo__slogan">{{ slogan }}</span>
  {%- endif -%}
</{{ wrapper_tag }}>
