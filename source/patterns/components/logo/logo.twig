{#
/**
 * @file
 * Logo component
 * 
 * Responsive BNP Paribas Real Estate logo with optional slogan.
 * 
 * @param {string} [site_logo] - Path to logo image (desktop horizontal or mobile square)
 * @param {string} [site_slogan] - Optional slogan text
 * @param {string} [url] - Link URL (wraps in <a> if provided)
 * @param {string} [rel] - Link rel attribute (e.g., "home")
 * @param {object} [attributes] - Additional HTML attributes
 */
#}

{% set site_logo = site_logo|default(null) %}
{% set site_slogan = site_slogan|default(null) %}
{% set url = url|default(null) %}
{% set rel = rel|default(null) %}

{% set classes = [
  'ps-logo',
  modifier_class
] %}

{% set attr = (attributes ? attributes : create_attribute()).addClass(classes) %}

{% if url %}
  <a href="{{ url }}"{{ attr }}{% if rel %} rel="{{ rel }}"{% endif %}>
    {% if site_logo %}
      <img src="{{ site_logo }}" alt="BNP Paribas Real Estate" class="ps-logo__image" />
    {% endif %}
    {% if site_slogan %}
      <span class="ps-logo__slogan">{{ site_slogan }}</span>
    {% endif %}
  </a>
{% else %}
  <div{{ attr }}>
    {% if site_logo %}
      <img src="{{ site_logo }}" alt="BNP Paribas Real Estate" class="ps-logo__image" />
    {% endif %}
    {% if site_slogan %}
      <span class="ps-logo__slogan">{{ site_slogan }}</span>
    {% endif %}
  </div>
{% endif %}
