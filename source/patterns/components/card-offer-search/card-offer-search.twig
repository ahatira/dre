{#
/**
 * @file
 * Card Offer Search (Component/Molecule)
 *
 * Search result card for property listings with horizontal layout (desktop).
 * 
 * Extends Card component with:
 * - Image carousel with navigation
 * - Status badges (viewed, exclusivity)
 * - Action buttons (comparator, favorite)
 * - Horizontal layout on desktop, vertical on mobile
 * - Price with detailed unit
 * - CTA button in footer
 * 
 * @param string title - Property title (required)
 * @param string price - Price value (e.g., "20 000 €")
 * @param string priceUnit - Price unit (e.g., "HT/HC/m²/an")
 * @param string surface - Surface area (e.g., "611.3 m²")
 * @param array images - Array of image objects: [{ url: string, alt: string }] (required)
 * @param string location - Location text (e.g., "28010 MADRID")
 * @param string locationIcon - Location icon name (default: 'pin')
 * @param object cta - Call-to-action: { text: string, url: string }
 * @param boolean isViewed - Already viewed state (default: false)
 * @param boolean isExclusive - Exclusivity state (default: false)
 * @param boolean isComparator - Comparator active state (default: false)
 * @param boolean isFavorite - Favorite state (default: false)
 * @param string bundle - Drupal content type/bundle (default: 'offer')
 * @param string view_mode - Drupal view mode (default: 'search')
 * @param object attributes - Additional HTML attributes
 * 
 * Usage:
 *   {% include '@components/card-offer-search/card-offer-search.twig' with {
 *     title: 'Rent Offices MADRID Barrio de Chamberí',
 *     price: '20 000 €',
 *     priceUnit: 'HT/HC/m²/an',
 *     surface: '611.3 m²',
 *     images: [
 *       { url: '/images/building-1.jpg', alt: 'Office view 1' },
 *       { url: '/images/building-2.jpg', alt: 'Office view 2' }
 *     ],
 *     location: '28010 MADRID',
 *     cta: { text: 'View the property', url: '/property/123' },
 *     isViewed: true,
 *     isExclusive: true,
 *     isFavorite: false
 *   } only %}
 */
#}

{%- set title = title|default('Property title') -%}
{%- set price = price|default(null) -%}
{%- set priceUnit = priceUnit|default(null) -%}
{%- set surface = surface|default(null) -%}
{%- set images = images|default([]) -%}
{%- set location = location|default(null) -%}
{%- set locationIcon = locationIcon|default('pin') -%}
{%- set cta = cta|default({ text: 'Voir le bien', url: '#' }) -%}
{%- set isViewed = isViewed|default(false) -%}
{%- set isExclusive = isExclusive|default(false) -%}
{%- set isComparator = isComparator|default(false) -%}
{%- set isFavorite = isFavorite|default(false) -%}
{%- set bundle = bundle|default('offer') -%}
{%- set view_mode = view_mode|default('search') -%}

{# Build attributes for Card component #}
{%- set cardClasses = 'ps-card-offer-search' -%}
{%- set cardAttributes = (attributes is defined ? attributes : create_attribute()).addClass(cardClasses) -%}

{# Embed Card component for structure reuse #}
{% embed '@components/card/card.twig' with {
  attributes: cardAttributes,
  bundle: bundle,
  view_mode: view_mode,
  layout: 'horizontal',
  variant: 'outlined',
} %}

  {# Media block - Image carousel using Carousel component #}
  {% block media %}
    {% if images and images|length > 0 %}
      {# Transform images array to slides format for Carousel component #}
      {% set carouselSlides = [] %}
      {% for image in images %}
        {% set carouselSlides = carouselSlides|merge([{
          id: 'slide-' ~ loop.index,
          image: {
            src: image.url,
            alt: image.alt|default('Property image ' ~ loop.index)
          }
        }]) %}
      {% endfor %}
      
      {# Include Carousel component #}
      {% include '@components/carousel/carousel.twig' with {
        slides: carouselSlides,
        variant: 'images',
        fit: 'cover',
        loop: carouselSlides|length > 1,
        autoHeight: false,
        withPagination: false,
        ariaLabel: 'Images du bien',
        attributes: create_attribute().addClass('ps-card-offer-search__carousel')
      } only %}
    {% endif %}
  {% endblock %}

  {# Header block - Badges and action buttons #}
  {% block header %}
    <div class="ps-card-offer-search__header">
      {# Left section - Badges #}
      <div class="ps-card-offer-search__badges">
        {% if isViewed %}
          {% include '@elements/badge/badge.twig' with {
            text: 'Déjà consulté',
            icon: 'eye',
            color: 'light',
            pill: true,
            attributes: create_attribute().addClass('ps-card-offer-search__badge ps-card-offer-search__badge--viewed')
          } only %}
        {% endif %}
        
        {% if isExclusive %}
          {% include '@elements/badge/badge.twig' with {
            text: 'Exclusivité',
            color: 'gold',
            pill: true,
            attributes: create_attribute().addClass('ps-card-offer-search__badge ps-card-offer-search__badge--exclusive')
          } only %}
        {% endif %}
      </div>
      
      {# Right section - Action buttons #}
      <div class="ps-card-offer-search__actions">
        {% include '@elements/button/button.twig' with {
          attributes: create_attribute().addClass('ps-card-offer-search__action'),
          variant: 'primary',
          size: 'large',
          icon: 'compare',
          toggle: true,
          active: isComparator,
          ariaLabel: isComparator ? 'Retirer du comparateur' : 'Ajouter au comparateur',
          dataAction: 'comparator'
        } only %}
        
        {% include '@elements/button/button.twig' with {
          attributes: create_attribute().addClass('ps-card-offer-search__action'),
          variant: 'secondary',
          size: 'large',
          icon: 'heart',
          toggle: true,
          active: isFavorite,
          ariaLabel: isFavorite ? 'Retirer des favoris' : 'Ajouter aux favoris',
          dataAction: 'favorite'
        } only %}
      </div>
    </div>
  {% endblock %}
  
  {# Body block - Title, surface, location #}
  {% block body %}
    
    {# Property title #}
    {% include '@elements/heading/heading.twig' with {
      level: 'h3',
      text: title,
      attributes: create_attribute().addClass('ps-card-offer-search__title')
    } only %}
    
    {# Surface area #}
    {% if surface %}
      <div class="ps-card-offer-search__surface">
        <span class="ps-card-offer-search__surface-text">{{ surface }}</span>
      </div>
    {% endif %}
    
    {# Location with icon #}
    {% if location %}
      <div class="ps-card-offer-search__location">
        <span class="ps-card-offer-search__location-icon" data-icon="{{ locationIcon }}" aria-hidden="true"></span>
        <span class="ps-card-offer-search__location-text">{{ location }}</span>
      </div>
    {% endif %}
    
  {% endblock %}
  
  {# Footer block - Price and CTA #}
  {% block footer %}
    <div class="ps-card-offer-search__footer">
      {# Price with unit #}
      {% if price %}
        <div class="ps-card-offer-search__price">
          <span class="ps-card-offer-search__price-value">{{ price }}</span>
          {% if priceUnit %}
            <span class="ps-card-offer-search__price-unit">{{ priceUnit }}</span>
          {% endif %}
        </div>
      {% endif %}
      
      {# CTA button #}
      {% if cta and cta.url %}
        {% include '@elements/link/link.twig' with {
          label: cta.text,
          url: cta.url,
          variant: 'primary',
          icon: 'arrow-right',
          iconPosition: 'end',
          attributes: create_attribute().addClass('ps-card-offer-search__cta no-underline')
        } only %}
      {% endif %}
    </div>
  {% endblock %}

{% endembed %}