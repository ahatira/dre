{#
 * Breadcrumb (Component/Molecule)
 * Navigational trail to show page hierarchy
 * @param array items - Breadcrumb items (required)
 *   Each item: { label: string, url: string (optional) }
 * @param Attribute attributes - Additional HTML attributes (optional)
 #}

<nav {{ attributes ? attributes.addClass('ps-breadcrumb') : create_attribute().addClass('ps-breadcrumb') }} aria-label="Breadcrumb">
  <ol class="ps-breadcrumb__list">
    {% for item in items %}
      {% set is_last = loop.last %}
      
      <li class="ps-breadcrumb__item{{ is_last ? ' ps-breadcrumb__item--current' : '' }}"{% if is_last %} aria-current="page"{% endif %}>
        {% if not is_last and item.url %}
          <a class="ps-breadcrumb__link" href="{{ item.url }}">{{ item.label }}</a>
        {% else %}
          {{ item.label }}
        {% endif %}
      </li>
    {% endfor %}
  </ol>
</nav>
