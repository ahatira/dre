{#
/**
 * Card (Component/Molecule)
 * Generic flexible container with extensible Twig blocks for maximum composition flexibility.
 * 
 * Architecture:
 * - Base container provides visual structure (border, radius, shadow, padding)
 * - Twig blocks allow content composition via {% embed %}
 * - Props support for simple Storybook usage
 * 
 * Available Blocks:
 * - media: Image/media zone (optional)
 * - media_overlay: Content overlaid on media (badges, actions, navigation)
 * - header: Top metadata section (tags, dates, location)
 * - content: Main content wrapper (default block)
 * - body: Main text content (within content wrapper)
 * - footer: Bottom actions/CTAs
 * 
 * @param string variant - Visual variant (default: 'default')
 *   Options: default | outlined | flat | elevated
 * @param string layout - Layout orientation (default: 'vertical')
 *   Options: vertical | horizontal
 * @param string size - Padding size (default: 'medium')
 *   Options: small | medium | large
 * @param string radius - Border radius (default: 'none')
 *   Options: none | sm | md | lg
 * @param string imagePosition - Image position (default: 'start')
 *   Options: start | end
 * @param string url - Optional URL (makes entire card clickable)
 * @param object image - Simple image object for Storybook (src, alt, ratio)
 * @param string bundle - Drupal content type/bundle for contextual styling
 * @param boolean isPromoted - Mark as promoted content (default: false)
 * @param boolean isSticky - Mark as sticky/pinned content (default: false)
 * @param boolean isPublished - Publication status (default: true)
 * @param string view_mode - Drupal view mode (teaser, full, etc.)
 * @param object attributes - Additional HTML attributes
 * 
 * Usage Patterns:
 * 
 * Simple (Storybook props):
 *   {% include '@components/card/card.twig' with {
 *     image: { src: '...', alt: '...' },
 *     header: '<span>Header content</span>',
 *     body: '<h3>Title</h3><p>Description</p>',
 *     footer: '<a href="#">Link</a>'
 *   } only %}
 * 
 * Advanced (Drupal blocks):
 *   {% embed '@components/card/card.twig' with {
 *     layout: 'horizontal',
 *     radius: 'md'
 *   } only %}
 *     {% block media %}
 *       {% include '@elements/image/image.twig' with {...} %}
 *     {% endblock %}
 *     {% block body %}
 *       <h3>{{ title }}</h3>
 *     {% endblock %}
 *   {% endembed %}
 * 
 * @see card.yml for full props documentation
 * @see README.md for detailed usage examples
 */
#}

{%- set variant = variant|default('default') -%}
{%- set layout = layout|default('vertical') -%}
{%- set size = size|default('medium') -%}
{%- set radius = radius|default('none') -%}
{%- set imagePosition = imagePosition|default('start') -%}
{%- set bundle = bundle|default(null) -%}
{%- set isPromoted = isPromoted|default(false) -%}
{%- set isSticky = isSticky|default(false) -%}
{%- set isPublished = isPublished|default(true) -%}
{%- set view_mode = view_mode|default(null) -%}

{# Build BEM classes (Drupal-compatible: ternary without arrow functions) #}
{%- set classes = [
  'ps-card',
  variant != 'default' ? 'ps-card--' ~ variant : null,
  layout == 'horizontal' ? 'ps-card--horizontal' : null,
  size != 'medium' ? 'ps-card--' ~ size : null,
  radius != 'none' ? 'ps-card--radius-' ~ radius : null,
  imagePosition == 'end' ? 'ps-card--image-end' : null,
  bundle ? 'ps-card--' ~ bundle|clean_class : null,
  isPromoted ? 'ps-card--promoted' : null,
  isSticky ? 'ps-card--sticky' : null,
  not isPublished ? 'ps-card--unpublished' : null,
  view_mode ? 'ps-card--view-mode-' ~ view_mode|clean_class : null,
  bundle and view_mode ? 'ps-card--' ~ bundle|clean_class ~ '--' ~ view_mode|clean_class : null
] -%}

{# Determine HTML element (article or a) #}
{%- set element = url ? 'a' : 'article' -%}

<{{ element }}
  class="{{ classes|join(' ')|trim }}"
  {%- if url %} href="{{ url }}"{% endif -%}
  {%- if attributes %} {{ attributes }}{% endif -%}
>
  {# MEDIA BLOCK - Image/visual content (optional) #}
  {%- if block('media') is defined or image -%}
    <div class="ps-card__media">
      {%- block media -%}
        {%- if image -%}
          {# Support both object (Drupal) and raw HTML (Storybook) #}
          {%- if image.src is defined -%}
            {% include '@elements/image/image.twig' with image only %}
          {%- else -%}
            {{- image|raw -}}
          {%- endif -%}
        {%- endif -%}
      {%- endblock -%}
      
      {# MEDIA OVERLAY BLOCK - For badges, actions, navigation over image #}
      {%- block media_overlay -%}{%- endblock -%}
    </div>
  {%- endif -%}

  {# CONTENT WRAPPER #}
  <div class="ps-card__content">
    
    {# HEADER BLOCK - Top metadata (tags, dates, location) #}
    {%- block header -%}
      {%- if header -%}
        <div class="ps-card__header">
          {{- header|raw -}}
        </div>
      {%- endif -%}
    {%- endblock -%}
    
    {# BODY BLOCK - Main content #}
    {%- if block('body') is defined or block('content') is defined or body or content -%}
      <div class="ps-card__body">
        {%- block body -%}
          {%- block content -%}
            {%- if body -%}
              {{- body|raw -}}
            {%- elseif content -%}
              {{- content|raw -}}
            {%- endif -%}
          {%- endblock -%}
        {%- endblock -%}
      </div>
    {%- endif -%}
    
    {# FOOTER BLOCK - Bottom actions/CTAs #}
    {%- block footer -%}
      {%- if footer -%}
        <div class="ps-card__footer">
          {{- footer|raw -}}
        </div>
      {%- endif -%}
    {%- endblock -%}
    
  </div>

</{{ element }}>
