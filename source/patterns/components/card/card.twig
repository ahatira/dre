{#
 * Card (Molecule) - Content presentation with image, title, description, meta, and actions
 *
 * @param string variant - Card variant: product|news|publication|solution|study|push|featured|compact (default: product)
 * @param string layout - Card layout: vertical|horizontal (default: vertical)
 * @param object image - Image data with url and alt properties (optional)
 * @param string image.url - Image source URL
 * @param string image.alt - Image alternative text
 * @param boolean favorite - Show favorite icon (product cards) (default: false)
 * @param boolean favoriteActive - Favorite active state (default: false)
 * @param string icon - Icon name for solution cards (optional)
 * @param string tag - Tag label (news/study cards) (optional)
 * @param string date - Date text (separate from meta) (optional)
 * @param string badge - Badge text to display on the card (optional)
 * @param string eyebrow - Eyebrow text above title (optional)
 * @param string price - Price text (product cards) (optional)
 * @param string surface - Surface/area text (product cards) (optional)
 * @param object status - Status info: viewed (boolean), exclusivity (boolean)
 * @param string title - Card title (required)
 * @param string description - Card description text (optional)
 * @param array meta - Array of metadata items with icon and text properties (optional)
 * @param string meta[].icon - Icon name for metadata item
 * @param string meta[].text - Text for metadata item
 * @param object cta - Call-to-action button configuration (optional)
 * @param string cta.text - CTA button text
 * @param string cta.url - CTA button URL
 * @param string cta.variant - CTA button variant (default: primary)
 * @param boolean cta.outline - Use outline button style (default: false)
 * @param string url - Card link URL (optional, wraps entire card)
 * @param object attributes - Additional HTML attributes
 #}

{%- set variant = variant|default('product') -%}
{%- set layout = layout|default('vertical') -%}
{%- set favorite = favorite|default(false) -%}
{%- set favoriteActive = favoriteActive|default(false) -%}

{%- set card_classes = ['ps-card'] -%}
{%- if variant != 'product' -%}
  {%- set card_classes = card_classes|merge(['ps-card--' ~ variant]) -%}
{%- endif -%}
{%- if layout != 'vertical' -%}
  {%- set card_classes = card_classes|merge(['ps-card--' ~ layout]) -%}
{%- endif -%}

{%- set tag = url ? 'a' : 'article' -%}

<{{ tag }}
  {%- if attributes %} {{ attributes.addClass(card_classes) }}{% else %} class="{{ card_classes|join(' ')|trim }}"{% endif -%}
  {%- if url %} href="{{ url }}"{% endif -%}
>
  {%- if image -%}
    <div class="ps-card__image">
      <img src="{{ image.url }}" alt="{{ image.alt }}" loading="lazy" />
      
      {%- if favorite -%}
        <span class="ps-card__favorite{% if favoriteActive %} ps-card__favorite--active{% endif %}" 
              data-icon="heart" 
              role="button" 
              aria-label="{% if favoriteActive %}Remove from favorites{% else %}Add to favorites{% endif %}"
              tabindex="0"></span>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ps-card__content">
    {%- if icon -%}
      <span class="ps-card__icon" data-icon="{{ icon }}" aria-hidden="true"></span>
    {%- endif -%}

    {%- if status -%}
      <div class="ps-card__status">
        {%- if status.viewed -%}
          <span class="ps-card__viewed">Already viewed</span>
        {%- endif -%}
        {%- if status.exclusivity -%}
          {%- include '@elements/badge/badge.twig' with {
            text: 'EXCLUSIVITY',
            color: 'gold',
            size: 'small'
          } only -%}
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if badge -%}
      {%- include '@elements/badge/badge.twig' with {
        text: badge,
        size: 'small',
        color: 'primary'
      } only -%}
    {%- endif -%}

    {%- if tag or date -%}
      <div class="ps-card__header">
        {%- if tag -%}
          <span class="ps-card__tag">{{ tag }}</span>
        {%- endif -%}
        {%- if date -%}
          <span class="ps-card__date">{{ date }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if eyebrow -%}
      <div class="ps-card__eyebrow">{{ eyebrow }}</div>
    {%- endif -%}

    {%- if price or surface -%}
      <div style="display: flex; align-items: center; gap: var(--size-1); margin-bottom: var(--size-2);">
        {%- if price -%}
          <span class="ps-card__price">{{ price }}</span>
        {%- endif -%}
        {%- if surface -%}
          <span class="ps-card__surface">{{ surface }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <h3 class="ps-card__title">{{ title }}</h3>

    {%- if description -%}
      <p class="ps-card__description">{{ description }}</p>
    {%- endif -%}

    {%- if meta -%}
      <ul class="ps-card__meta">
        {%- for item in meta -%}
          <li class="ps-card__meta-item">
            {%- if item.icon -%}
              <span class="ps-card__meta-icon" data-icon="{{ item.icon }}" aria-hidden="true"></span>
            {%- endif -%}
            <span class="ps-card__meta-text">{{ item.text }}</span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if cta -%}
      <div class="ps-card__actions">
        {%- if cta.outline -%}
          {%- include '@elements/button/button.twig' with {
            label: cta.text,
            url: cta.url,
            variant: cta.variant|default('primary'),
            outline: true,
            size: 'small'
          } only -%}
        {%- else -%}
          {%- include '@elements/link/link.twig' with {
            text: cta.text,
            url: cta.url,
            icon: 'arrow-right',
            color: 'green'
          } only -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</{{ tag }}>
