{#
 * Card (Generic Container) - Flexible card structure for content composition
 *
 * A card is a generic container that provides visual structure (border, padding, shadow)
 * and layout options. Content is composed using Twig blocks for maximum flexibility.
 *
 * @param string variant - Visual variant: default|outlined|flat|elevated (default: default)
 * @param string layout - Layout: vertical|horizontal (default: vertical)
 * @param string size - Size: small|medium|large (default: medium)
 * @param string radius - Border radius: none|sm|md|lg (default: none)
 * @param string imagePosition - Image position: top|bottom (vertical) | left|right (horizontal) (default: top/left)
 * @param string url - Optional link URL (wraps entire card as <a>)
 * @param object attributes - Additional HTML attributes
 *
 * Blocks (all optional):
 * - image: Card image/media area
 * - content: Main content area (default block if no header/body/footer defined)
 * - header: Header section (e.g., badges, meta, actions)
 * - body: Body section (e.g., title, description)
 * - footer: Footer section (e.g., CTA, price, actions)
 *
 * Usage:
 * {% embed '@components/card/card.twig' with { variant: 'elevated' } %}
 *   {% block image %}<img src="..." alt="..." />{% endblock %}
 *   {% block content %}<h3>Title</h3><p>Description</p>{% endblock %}
 * {% endembed %}
 #}

{%- set variant = variant|default('default') -%}
{%- set layout = layout|default('vertical') -%}
{%- set size = size|default('medium') -%}
{%- set radius = radius|default('none') -%}
{%- set imagePosition = imagePosition|default(layout == 'horizontal' ? 'left' : 'top') -%}
{%- set attributes = attributes|default(create_attribute()) -%}

{%- set card_classes = [
  'ps-card',
  variant != 'default' ? 'ps-card--' ~ variant : null,
  layout != 'vertical' ? 'ps-card--' ~ layout : null,
  size != 'medium' ? 'ps-card--' ~ size : null,
  radius != 'none' ? 'ps-card--radius-' ~ radius : null,
  imagePosition != (layout == 'horizontal' ? 'left' : 'top') ? 'ps-card--image-' ~ imagePosition : null
] -%}

{%- set tag = url ? 'a' : 'div' -%}

<{{ tag }} {{ attributes.addClass(card_classes) }}{%- if url %} href="{{ url }}"{% endif -%}>
  {%- if block('image') is defined -%}
    <div class="ps-card__image">
      {{ block('image') }}
    </div>
  {%- endif -%}

  <div class="ps-card__content">
    {%- if block('header') is defined -%}
      <div class="ps-card__header">
        {{ block('header') }}
      </div>
    {%- endif -%}

    {%- if block('body') is defined -%}
      <div class="ps-card__body">
        {{ block('body') }}
      </div>
    {%- elseif block('content') is defined -%}
      {{ block('content') }}
    {%- endif -%}

    {%- if block('footer') is defined -%}
      <div class="ps-card__footer">
        {{ block('footer') }}
      </div>
    {%- endif -%}
  </div>
</{{ tag }}>
