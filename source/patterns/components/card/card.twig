{#
 * Card (Molecule)
 * Generic flexible container with visual structure and layout variants.
 * 
 * @param string variant - Visual variant (optional, default: 'default')
 *   Options: default | outlined | flat | elevated
 * @param string layout - Layout orientation (optional, default: 'vertical')
 *   Options: vertical | horizontal
 * @param string size - Padding size (optional, default: 'medium')
 *   Options: small | medium | large
 * @param string radius - Border radius (optional, default: 'none')
 *   Options: none | sm | md | lg
 * @param string imagePosition - Image position (optional, default: 'top')
 *   Options: top | bottom (vertical) | left | right (horizontal)
 * @param string url - Optional URL (makes card clickable as <a>)
 * @param string|html image - Image/media HTML content (optional)
 * @param string|html header - Header HTML content (optional)
 * @param string|html body - Body HTML content (optional)
 * @param string|html footer - Footer HTML content (optional)
 * @param string|html content - Main content HTML (used if no header/body/footer)
 * @param object attributes - Additional HTML attributes
 * 
 * Note: For Drupal usage with Twig blocks, use {% embed %} pattern.
 * For direct rendering (Storybook), pass HTML strings via props.
 #}

{%- set variant = variant|default('default') -%}
{%- set layout = layout|default('vertical') -%}
{%- set size = size|default('medium') -%}
{%- set radius = radius|default('none') -%}
{%- set imagePosition = imagePosition|default('top') -%}

{# Build BEM classes #}
{%- set classes = ['ps-card'] -%}

{# Visual variants #}
{%- if variant != 'default' -%}
  {%- set classes = classes|merge(['ps-card--' ~ variant]) -%}
{%- endif -%}

{# Layout #}
{%- if layout == 'horizontal' -%}
  {%- set classes = classes|merge(['ps-card--horizontal']) -%}
{%- endif -%}

{# Size #}
{%- if size != 'medium' -%}
  {%- set classes = classes|merge(['ps-card--' ~ size]) -%}
{%- endif -%}

{# Radius #}
{%- if radius != 'none' -%}
  {%- set classes = classes|merge(['ps-card--radius-' ~ radius]) -%}
{%- endif -%}

{# Image position modifiers #}
{%- if layout == 'horizontal' and imagePosition == 'right' -%}
  {%- set classes = classes|merge(['ps-card--image-right']) -%}
{%- endif -%}

{%- if layout == 'vertical' and imagePosition == 'bottom' -%}
  {%- set classes = classes|merge(['ps-card--image-bottom']) -%}
{%- endif -%}

{# Determine HTML element (article or a) #}
{%- set element = url ? 'a' : 'article' -%}

<{{ element }}
  class="{{ classes|join(' ')|trim }}"
  {%- if url %} href="{{ url }}"{% endif -%}
  {%- if attributes %} {{ attributes }}{% endif -%}
>
  {%- if image -%}
    <div class="ps-card__image">
      {{- image|raw -}}
    </div>
  {%- endif -%}

  <div class="ps-card__content">
    {%- if header -%}
      <div class="ps-card__header">
        {{- header|raw -}}
      </div>
    {%- endif -%}

    {%- if body -%}
      <div class="ps-card__body">
        {{- body|raw -}}
      </div>
    {%- elseif content -%}
      {# Fallback: if no body prop, render content prop directly #}
      {{- content|raw -}}
    {%- endif -%}

    {%- if footer -%}
      <div class="ps-card__footer">
        {{- footer|raw -}}
      </div>
    {%- endif -%}
  </div>
</{{ element }}>
