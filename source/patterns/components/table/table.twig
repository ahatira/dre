{#
 * Table molecule - Data display with sorting, selection, and responsive variants
 * @param {array} headers - Column headers (required): [{key:string, label:string, sortable:boolean, numeric:boolean, sticky:boolean}]
 * @param {array} rows - Table rows (required): [{id:string, cells:array, selected:boolean, disabled:boolean}]
 * @param {string} [caption] - Table caption for accessibility
 * @param {string} [variant='default'] - Color variant: neutral, primary, secondary, success, danger, warning, info, light, dark, gold
 * @param {boolean} [striped=true] - Zebra-striped rows
 * @param {boolean} [hover=true] - Hover effect on rows
 * @param {boolean} [bordered=false] - Full borders on cells
 * @param {boolean} [compact=false] - Reduced padding
 * @param {boolean} [responsive=true] - Horizontal scroll on mobile (incompatible with stacked)
 * @param {boolean} [stacked=false] - Card-like stacked layout on mobile (incompatible with responsive)
 * @param {object} [attributes] - Additional HTML attributes for Drupal integration
 #}

{%- set headers = headers|default([]) -%}
{%- set rows = rows|default([]) -%}
{%- set caption = caption|default(null) -%}
{%- set variant = variant|default('default') -%}
{%- set striped = striped is defined ? striped : false -%}
{%- set hover = hover is defined ? hover : true -%}
{%- set bordered = bordered|default(false) -%}
{%- set compact = compact|default(false) -%}
{%- set responsive = responsive is defined ? responsive : true -%}
{%- set stacked = stacked|default(false) -%}

{%- set table_classes = [
  'ps-table',
  variant != 'default' ? 'ps-table--' ~ variant : null,
  striped ? 'ps-table--striped' : null,
  hover ? 'ps-table--hover' : null,
  bordered ? 'ps-table--bordered' : null,
  compact ? 'ps-table--compact' : null,
  stacked ? 'ps-table--stacked' : null
] -%}

{%- set wrapper_classes = [
  'ps-table-wrapper',
  (responsive and not stacked) ? 'ps-table-wrapper--responsive' : null
] -%}

<div class="{{ wrapper_classes|join(' ')|trim }}">
  <table class="{{ table_classes|join(' ')|trim }}"{% if attributes %} {{ attributes|without('class') }}{% endif %}>
    {% if caption -%}
      <caption class="ps-table__caption">{{ caption }}</caption>
    {%- endif %}
    
    {% if headers|length > 0 -%}
      <thead class="ps-table__head">
        <tr class="ps-table__row">
          {% for header in headers -%}
            {%- set header_classes = [
              'ps-table__header',
              header.sortable ? 'ps-table__header--sortable' : null,
              header.numeric ? 'ps-table__header--numeric' : null,
              header.sticky ? 'ps-table__header--sticky' : null
            ] -%}
            <th class="{{ header_classes|join(' ')|trim }}" scope="col"{% if header.sortable %} data-sort="{{ header.key }}"{% endif %}>
              {% if header.sortable -%}
                <button class="ps-table__sort-button" type="button" aria-label="Sort by {{ header.label }}">
                  {{ header.label }}
                  <span class="ps-table__sort-icon" data-icon="chevron-up" aria-hidden="true"></span>
                </button>
              {%- else -%}
                {{ header.label }}
              {%- endif %}
            </th>
          {%- endfor %}
        </tr>
      </thead>
    {%- endif %}
    
    {% if rows|length > 0 -%}
      <tbody class="ps-table__body">
        {% for row in rows -%}
          {%- set row_classes = [
            'ps-table__row',
            row.selected ? 'ps-table__row--selected' : null,
            row.disabled ? 'ps-table__row--disabled' : null
          ] -%}
          <tr class="{{ row_classes|join(' ')|trim }}">
            {% for cell in row.cells -%}
              {%- set cell_classes = [
                'ps-table__cell',
                headers[loop.index0].numeric ? 'ps-table__cell--numeric' : null
              ] -%}
              <td class="{{ cell_classes|join(' ')|trim }}" data-label="{{ headers[loop.index0].label }}">
                {{ cell|raw }}
              </td>
            {%- endfor %}
          </tr>
        {%- endfor %}
      </tbody>
    {%- endif %}
  </table>
</div>
