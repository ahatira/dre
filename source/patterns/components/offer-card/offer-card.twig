{#
/**
 * Offer Card (Component/Molecule)
 * Specialized card for real estate property listings.
 * 
 * Embeds the generic Card component and adds:
 * - Image with overlay badges and actions
 * - Property title, surface, location metadata
 * - Price and call-to-action
 * 
 * @param string layout - Layout orientation (default: 'vertical')
 *   Options: vertical | horizontal
 * @param string title - Property title (required)
 * @param string surface - Surface area (e.g., "611.3 m²")
 * @param string price - Price text (e.g., "20 000 € HT/HC/m²/an")
 * @param object image - Image data: { url: string, alt: string } (required)
 * @param array meta - Metadata items: [{ icon: string, text: string }]
 * @param object status - Status badges: { viewed: boolean, exclusivity: boolean }
 * @param object cta - Call-to-action: { text: string, url: string }
 * @param string url - Optional URL (makes entire card clickable)
 * @param object attributes - Additional HTML attributes
 * 
 * Usage:
 *   {% include '@components/offer-card/offer-card.twig' with {
 *     title: 'Rent Offices MADRID',
 *     surface: '611.3 m²',
 *     price: '20 000 € HT/HC/m²/an',
 *     image: { url: '/images/property.jpg', alt: 'Office space' },
 *     meta: [{ icon: 'pin-map', text: 'Madrid' }],
 *     cta: { text: 'View property', url: '/property/123' }
 *   } only %}
 * 
 * @see offer-card.yml for full props documentation
 * @see README.md for detailed usage examples
 */
#}

{%- set layout = layout|default('vertical') -%}
{%- set status = status|default({ viewed: false, exclusivity: false }) -%}
{%- set cta = cta|default({ text: 'View the property', url: '#' }) -%}

{% embed '@components/card/card.twig' with {
  layout: layout,
  variant: 'elevated',
  radius: 'md',
  size: 'medium',
  url: url,
  attributes: attributes
} only %}

  {# MEDIA BLOCK - Image with overlay (badges + actions) #}
  {% block media %}
    <div class="ps-offer-card__media">
      {# Property Image #}
      {% include '@elements/image/image.twig' with {
        src: image.url,
        alt: image.alt,
        ratio: '3x2',
        loading: 'lazy'
      } only %}
      
      {# Overlay: Badges (left) + Actions (right) #}
      <div class="ps-offer-card__overlay">
        {# Status Badges (left side) #}
        {% if status.viewed or status.exclusivity %}
          <div class="ps-offer-card__badges">
            {% if status.viewed %}
              <span class="ps-offer-card__badge ps-offer-card__badge--viewed">
                <span class="ps-offer-card__badge-icon" data-icon="eye" aria-hidden="true"></span>
                <span class="ps-offer-card__badge-text">Already viewed</span>
              </span>
            {% endif %}
            
            {% if status.exclusivity %}
              <span class="ps-offer-card__badge ps-offer-card__badge--gold">
                <span class="ps-offer-card__badge-text">Exclusivity</span>
              </span>
            {% endif %}
          </div>
        {% endif %}
        
        {# Action Buttons (right side) #}
        <div class="ps-offer-card__actions">
          <button 
            type="button" 
            class="ps-offer-card__action ps-offer-card__action--compare"
            aria-label="Add to comparison"
            data-action="compare"
          >
            <span data-icon="comparateur" aria-hidden="true"></span>
          </button>
          
          <button 
            type="button" 
            class="ps-offer-card__action ps-offer-card__action--favorite"
            aria-label="Add to favorites"
            data-action="favorite"
          >
            <span data-icon="fav-filled" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </div>
  {% endblock %}

  {# BODY BLOCK - Title + Surface + Meta #}
  {% block body %}
    <h3 class="ps-offer-card__title">{{ title }}</h3>
    
    {% if surface %}
      <p class="ps-offer-card__surface">{{ surface }}</p>
    {% endif %}
    
    {% if meta %}
      <ul class="ps-offer-card__meta">
        {% for item in meta %}
          <li class="ps-offer-card__meta-item">
            {% if item.icon %}
              <span class="ps-offer-card__meta-icon" data-icon="{{ item.icon }}" aria-hidden="true"></span>
            {% endif %}
            <span class="ps-offer-card__meta-text">{{ item.text }}</span>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  {% endblock %}

  {# FOOTER BLOCK - Price + CTA #}
  {% block footer %}
    {% if price %}
      <div class="ps-offer-card__price">{{ price }}</div>
    {% endif %}
    
    {% if cta and cta.url %}
      {% include '@elements/link/link.twig' with {
        text: cta.text,
        url: cta.url,
        icon: 'arrow-right',
        iconPosition: 'end',
        color: 'primary'
      } only %}
    {% endif %}
  {% endblock %}

{% endembed %}
