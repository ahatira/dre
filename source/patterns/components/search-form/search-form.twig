{#
/**
 * Search Form (Component/Molecule)
 * Expandable search form that displays below the header on full width.
 * Toggled by JavaScript behavior with once().
 *
 * Props:
 * - string placeholder - Input placeholder text (default: 'What are you looking for ?')
 * - string action - Form action URL (default: '/search')
 * - string method - Form method (default: 'GET')
 * - string input_name - Input field name (default: 'q')
 * - boolean show - Display form initially (default: false, toggled by JavaScript)
 *
 * JavaScript: Drupal behavior with once() for show/hide toggle
 * Accessibility: WCAG 2.2 AA - focus management, keyboard support
 *
 * Rules: Token-First, BEM, Responsive, WCAG 2.2 AA
 #}

{%- set placeholder = placeholder|default('What are you looking for ?') -%}
{%- set action = action|default('/search') -%}
{%- set method = method|default('GET') -%}
{%- set input_name = input_name|default('q') -%}
{%- set show = show|default(false) -%}

{%- set classes = [
  'ps-search-form',
  show ? 'ps-search-form--open' : null
] -%}
{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}
{%- set attr = attr.setAttribute('data-search-form', true) -%}

<div{{ attr }}>
  <div class="ps-search-form__container">
    <form class="ps-search-form__form" action="{{ action }}" method="{{ method }}" role="search">
      {# Search input #}
      <div class="ps-search-form__input-wrapper">
        <input type="search" name="{{ input_name }}" class="ps-search-form__input" placeholder="{{ placeholder }}" aria-label="Search" autocomplete="off" data-search-input />
      </div>
      {# Submit button #}
      <button type="submit" class="ps-search-form__submit" aria-label="Search" data-icon="search" data-icon-only></button>
      {# Close button #}
      <button type="button" class="ps-search-form__close" aria-label="Close search" data-search-close>
        <span class="ps-search-form__close-icon" data-icon="close" aria-hidden="true"></span>
      </button>
    </form>
  </div>
</div>
