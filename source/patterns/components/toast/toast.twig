{#
/**
 * Toast (Component/Molecule)
 * 
 * Temporary notification message that appears at screen edge to provide feedback.
 * Auto-dismissing notification managed via JavaScript for show/hide/duration logic.
 * 
 * @package Surface
 * @category Components
 * @version 1.0.0
 * @since 2024-12-20
 * 
 * @param {string} message - Notification message content (required)
 * @param {string} [type='info'] - Semantic type: success, error, warning, info
 * @param {boolean} [dismissible=true] - Show close button
 * @param {string} [position='bottom-right'] - Screen position
 * @param {number} [duration=4000] - Auto-dismiss duration (ms)
 * @param {object} [attributes] - Additional HTML attributes for Drupal integration
 */
#}

{% set type = type|default('info') %}
{% set dismissible = dismissible|default(true) %}
{% set position = position|default('bottom-right') %}
{% set duration = duration|default(4000) %}

{% set classes = [
  'ps-toast',
  type != 'info' ? 'ps-toast--' ~ type : null,
  position != 'bottom-right' ? 'ps-toast--' ~ position : null,
  modifier_class
] %}

{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}

<div{{ attr }}
  role="status" 
  aria-live="polite" 
  aria-atomic="true"
  data-toast-duration="{{ duration }}"
>
  <div class="ps-toast__content">
    {{ message }}
  </div>
  {% if dismissible %}
    <button 
      type="button" 
      class="ps-toast__close" 
      aria-label="Fermer la notification"
      data-icon="close"
    ></button>
  {% endif %}
</div>
