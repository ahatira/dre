{#
 * Alert Component (Molecule)
 * Semantic alert with flexible content and 8 variants
 * 
 * @param string variant - Semantic variant: 'primary' | 'secondary' | 'success' | 'danger' | 'warning' | 'info' | 'light' | 'dark' (default: 'primary')
 * @param string content - Free HTML content (headings, paragraphs, links, icons optional) (required)
 * @param boolean dismissible - Show close button (optional, default: false)
 * @param boolean rounded - Apply border radius (optional, default: false)
 * @param object attributes - Additional HTML attributes (optional)
 #}

{%- set variant = variant|default('primary') -%}
{%- set dismissible = dismissible|default(false) -%}
{%- set rounded = rounded|default(false) -%}
{%- set content = content|default('') -%}
{%- set title = title|default('') -%}
{%- set text = text|default('') -%}
{%- set icon = icon|default(null) -%}
{%- set actions = actions|default([]) -%}
{%- set attributes = attributes|default(create_attribute()) -%}

{{ attach_library('ps_theme/alert') }}

{# ARIA role and live region - danger/warning are assertive #}
{%- set role = (variant in ['danger', 'warning']) ? 'alert' : 'status' -%}
{%- set ariaLive = (variant in ['danger', 'warning']) ? 'assertive' : 'polite' -%}

{# Build classes array - variant always applied (no default omission) #}
{%- set classes = [
  'ps-alert',
  'ps-alert--' ~ variant,
  dismissible ? 'ps-alert--dismissible' : null,
  rounded ? 'ps-alert--rounded' : null
] -%}

<div {{ attributes.addClass(classes) }} role="{{ role }}" aria-live="{{ ariaLive }}">
  {# If free content provided, render as-is (backward compatibility) #}
  {%- if content -%}
    {{- content|raw -}}
  {%- else -%}
    {%- if icon -%}
      {% include '@elements/icon/icon.twig' with { name: icon, size: 'md', color: 'default' } only %}
    {%- endif -%}
    {%- if title -%}
      {% include '@elements/heading/heading.twig' with { level: 4, text: title } only %}
    {%- endif -%}
    {%- if text -%}
      {% include '@elements/text/text.twig' with { text: text } only %}
    {%- endif -%}
    {%- if actions is iterable and actions|length > 0 -%}
      <div class="ps-alert__actions">
        {%- for action in actions -%}
          {% include '@elements/button/button.twig' with action only %}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- if dismissible -%}
    {% include '@elements/button/button.twig' with {
      baseClass: 'ps-alert__close',
      label: '',
      icon: 'close',
      size: 'small',
      attributes: create_attribute().setAttribute('aria-label', 'Close alert')
    } only %}
  {%- endif -%}
</div>
