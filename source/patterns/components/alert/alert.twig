{#
/**
 * Alert Component (Molecule/Feedback)
 * Semantic alert with flexible content, optional icons, and 9 variants
 *
 * @param {string} content - Alert message content (HTML allowed)
 * @param {string} variant - Alert semantic variant: neutral|primary|success|danger|warning|info|gold|light|dark
 * @param {string} icon - Optional icon name (without icon- prefix)
 * @param {boolean} dismissible - Show close button with dismiss behavior
 * @param {Attribute} attributes - Additional HTML attributes
 */
#}

{%- set content = content|default('') -%}
{%- set variant = variant|default('neutral') -%}
{%- set icon = icon|default(null) -%}
{%- set dismissible = dismissible|default(false) -%}

{# ARIA attributes based on severity #}
{%- if variant in ['danger', 'warning'] -%}
  {%- set role = 'alert' -%}
  {%- set ariaLive = 'assertive' -%}
{%- else -%}
  {%- set role = 'status' -%}
  {%- set ariaLive = 'polite' -%}
{%- endif -%}

{%- set classes = [
  'ps-alert',
  'ps-alert--' ~ variant,
  icon ? 'ps-alert--with-icon' : null,
  dismissible ? 'ps-alert--dismissible' : null
] -%}

<div {{ attributes|without('class').addClass(classes) }} role="{{ role }}" aria-live="{{ ariaLive }}" {{ icon ? 'data-icon="' ~ icon ~ '"' : '' }}>
  {%- if content -%}
    <div class="ps-alert__content">{{ content|raw }}</div>
  {%- endif -%}

  {%- if dismissible -%}
    <button type="button" class="ps-alert__close" aria-label="Fermer cette alerte" data-icon="close">
      <span class="sr-only">Fermer</span>
    </button>
  {%- endif -%}
</div>

{{ attach_library('ps/alert') }}
