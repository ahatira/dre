{#
 * Alert Component (Molecule)
 * Semantic alert with flexible content and 8 variants
 * 
 * @param string variant - Semantic variant: 'primary' | 'secondary' | 'success' | 'danger' | 'warning' | 'info' | 'light' | 'dark' (default: 'primary')
 * @param string content - Free HTML content (headings, paragraphs, links, icons optional) (required)
 * @param boolean dismissible - Show close button (optional, default: false)
 * @param object attributes - Additional HTML attributes (optional)
 #}

{%- set variant = variant|default('primary') -%}
{%- set dismissible = dismissible|default(false) -%}
{%- set content = content|default('') -%}

{{ attach_library('ps_theme/alert') }}

{# ARIA role and live region - danger/warning are assertive #}
{%- set role = (variant in ['danger', 'warning']) ? 'alert' : 'status' -%}
{%- set ariaLive = (variant in ['danger', 'warning']) ? 'assertive' : 'polite' -%}

{# Build classes array - variant always applied (no default omission) #}
{%- set classes = ['ps-alert', 'ps-alert--' ~ variant] -%}
{%- if dismissible -%}
  {%- set classes = classes|merge(['ps-alert--dismissible']) -%}
{%- endif -%}

<div
  class="{{ classes|join(' ')|trim }}"
  role="{{ role }}"
  aria-live="{{ ariaLive }}"
  {% if attributes %}{{ attributes }}{% endif %}
>
  {{- content|raw -}}

  {%- if dismissible -%}
    <button
      class="ps-alert__close"
      type="button"
      aria-label="Close alert"
    >
      <span aria-hidden="true">&times;</span>
    </button>
  {%- endif -%}
</div>
