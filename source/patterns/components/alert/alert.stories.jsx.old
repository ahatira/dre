import alertTwig from './alert.twig';
import iconsRegistry from '../../documentation/icons-registry.json';

export default {
  title: 'Components/Alert',
  tags: ['autodocs'],
  render: (args) => alertTwig(args),
  argTypes: {
    variant: {
      description: 'Semantic variant (default, primary, secondary, success, danger, error, warning, info, light, dark)',
      control: { type: 'select' },
      options: ['primary', 'secondary', 'success', 'danger', 'error', 'warning', 'info', 'light', 'dark'],
      table: {
        category: 'Appearance',
        type: { summary: 'primary | secondary | success | danger | error | warning | info | light | dark' },
        defaultValue: { summary: 'primary' },
      },
    },
    content: {
      description: 'HTML content (headings, paragraphs, links, icons optional)',
      control: { type: 'text' },
      table: {
        category: 'Content',
        type: { summary: 'string (HTML)' },
        defaultValue: { summary: '' },
      },
    },
    dismissible: {
      description: 'Show close button with dismiss behavior',
      control: { type: 'boolean' },
      table: {
        category: 'Behavior',
        type: { summary: 'boolean' },
        defaultValue: { summary: false },
      },
    },
    rounded: {
      description: 'Apply border radius',
      control: { type: 'boolean' },
      table: {
        category: 'Appearance',
        type: { summary: 'boolean' },
        defaultValue: { summary: false },
      },
    },
    icon: {
      description: 'Optional icon name',
      control: { type: 'select' },
      options: [null, ...iconsRegistry.names],
      table: {
        category: 'Content',
        type: { summary: 'string (icon name)' },
        defaultValue: { summary: null },
      },
    },
    iconPosition: {
      description: 'Icon position (start|end)',
      control: { type: 'select' },
      options: ['start', 'end'],
      table: {
        category: 'Content',
        type: { summary: 'start | end' },
        defaultValue: { summary: 'start' },
      },
    },
  },
};

const baseArgs = {
  content: '<strong>Exemple d’alerte :</strong> Ceci est un message d’alerte générique.',
  dismissible: false,
  rounded: false,
  icon: null,
  iconPosition: 'start',
};

export const Default = {
  name: 'Défaut (Primary)',
  args: { ...baseArgs, variant: 'primary' },
};

export const Secondary = {
  name: 'Secondaire',
  args: { ...baseArgs, variant: 'secondary', content: 'Alerte secondaire pour information complémentaire.' },
};

export const Success = {
  name: 'Succès',
  args: { ...baseArgs, variant: 'success', content: 'Votre opération a réussi.' },
};

export const Danger = {
  name: 'Danger',
  args: { ...baseArgs, variant: 'danger', content: 'Erreur critique détectée.' },
};

export const Error = {
  name: 'Erreur (alias danger)',
  args: { ...baseArgs, variant: 'error', content: 'Erreur fatale : action impossible.' },
};

export const Warning = {
  name: 'Avertissement',
  args: { ...baseArgs, variant: 'warning', content: 'Attention : votre session va expirer.' },
};

export const Info = {
  name: 'Info',
  args: { ...baseArgs, variant: 'info', content: 'Nouvelles informations disponibles.' },
};

export const Light = {
  name: 'Clair',
  args: { ...baseArgs, variant: 'light', content: 'Annonce générale non critique.' },
};

export const Dark = {
  name: 'Sombre',
  args: { ...baseArgs, variant: 'dark', content: 'Notification importante à contraste élevé.' },
};

export const Dismissible = {
  name: 'Avec fermeture',
  args: { ...baseArgs, variant: 'info', dismissible: true, content: 'Vous pouvez fermer cette alerte.' },
};

export const Rounded = {
  name: 'Bordures arrondies',
  args: { ...baseArgs, variant: 'success', rounded: true, content: 'Alerte avec coins arrondis.' },
};

export const WithIcon = {
  name: 'Avec icône',
  args: { ...baseArgs, variant: 'warning', icon: 'warning', content: 'Alerte avec icône décorative.' },
};

export const AllVariants = {
  name: 'Toutes les variantes',
  render: (args) => [
    'primary', 'secondary', 'success', 'danger', 'error', 'warning', 'info', 'light', 'dark'
  ].map(variant => alertTwig({ ...baseArgs, ...args, variant, content: `Alerte <strong>${variant}</strong>` })).join('<br>'),
};
