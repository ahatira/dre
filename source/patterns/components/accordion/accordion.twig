{#
 * Accordion (Molecule / Disclosure)
 * Pixel-perfect simplified according to mock: bordered separators by default, optional flush padding.
 * @param array  items        - REQUIRED. [{ id?, title, content, open? }]
 * @param bool   singleOpen   - OPTIONAL. One open at a time (default: true)
 * @param bool   flush        - OPTIONAL. Remove horizontal padding (default: false)
 * @param string headingLevel - OPTIONAL. 'h2'|'h3'|'h4'|'h5' (default: 'h3')
 * @param object attributes   - OPTIONAL. Drupal attributes object
 #}

{%- set heading = headingLevel|default('h3') -%}
{%- set singleOpen = singleOpen is defined ? singleOpen : true -%}
{%- set flush = flush|default(false) -%}

{{ attach_library('ps_theme/accordion') }}

{%- set root_classes = ['ps-accordion'] -%}
{%- if flush -%}
  {%- set root_classes = root_classes|merge(['ps-accordion--flush']) -%}
{%- endif -%}

<div {{ attributes.addClass(root_classes) }} data-accordion data-single-open="{{ singleOpen ? 'true' : 'false' }}">
  {%- for item in items -%}
    {%- set panel_id = item.id ?? ('acc-' ~ loop.index) -%}
    {%- set label_id = panel_id ~ '-label' -%}
    {%- set is_open = item.open ?? false -%}
    <div class="ps-accordion__item {{ is_open ? 'ps-accordion__item--open' }}">
      <{{ heading }} class="ps-accordion__header">
        <button
          class="ps-accordion__trigger"
          type="button"
          aria-expanded="{{ is_open ? 'true' : 'false' }}"
          aria-controls="{{ panel_id }}"
          id="{{ label_id }}"
          data-accordion-trigger
        >
          <span class="ps-accordion__title">{{ item.title }}</span>
          <span class="ps-accordion__icon" aria-hidden="true"></span>
        </button>
      </{{ heading }}>
      <div
        class="ps-accordion__panel"
        id="{{ panel_id }}"
        role="region"
        aria-labelledby="{{ label_id }}"
        data-accordion-panel
        {% if not is_open %}hidden{% endif %}
      >
        {{ item.content|raw }}
      </div>
    </div>
  {%- endfor -%}
</div>
