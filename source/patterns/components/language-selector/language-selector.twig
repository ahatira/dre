{#
 * Language Selector (Molecule/Navigation)
 *
 * @param string name - Input name attribute (default: 'lang')
 * @param string size - sm|md|lg (default: 'sm')
 * @param boolean disabled - Disabled state (default: false)
 * @param string aria_label - Accessible label for nav element (default: 'Language selector')
 * @param object current - Current language
 *   @param string code - Country code ISO (ex: GB, ES, FR)
 *   @param string label - Short label displayed (ex: En, Es, Fr)
 *   @param string locale - Optional BCP 47 tag (ex: en-GB)
 * @param array options - Array of language options
 *   @param string code - Country code for flag
 *   @param string label - Short label
 *   @param string value - Native select value
 *   @param string url - URL for language switch (optional)
 *   @param string locale - Optional BCP 47 tag
 *   @param boolean selected - Is selected (default: false)
 *   @param boolean disabled - Is disabled (default: false)
 * @param Attribute attributes - Additional HTML attributes
 #}

{%- set name = name|default('lang') -%}
{%- set size = size|default('sm') -%}
{%- set disabled = disabled|default(false) -%}
{%- set attributes = attributes ? attributes : create_attribute() -%}
{%- set aria_label = aria_label|default('Language selector') -%}

{%- set classes = [
  'ps-language-selector',
  size != 'sm' ? 'ps-language-selector--' ~ size : null,
  disabled ? 'ps-language-selector--disabled' : null
] -%}

<nav {{ attributes.addClass(classes) }} aria-label="{{ aria_label }}">
  <div class="ps-language-selector__control">
    {# Enhanced button with accessible states #}
    <button
      class="ps-language-selector__button"
      type="button"
      aria-haspopup="listbox"
      aria-expanded="false"
      {{ disabled ? 'disabled' : null }}
      {{ disabled ? 'aria-disabled="true"' : null }}
    >
      <span class="ps-language-selector__current">
        {# Flag component with rect shape as per Figma spec (20x14px) #}
        {% include '@elements/flag/flag.twig' with {
          code: current.code,
          locale: current.locale ?? null,
          size: 'sm',
          shape: 'square',
          decorative: true
        } only %}
        <span class="ps-language-selector__label">{{ current.label }}</span>
      </span>
      {# Icon using data-icon system (no prefix) #}
      <span class="ps-language-selector__icon" data-icon="chevron-down" aria-hidden="true"></span>
    </button>

    {# Dropdown list - hidden by default #}
    <ul class="ps-language-selector__list" role="listbox" hidden>
      {% for option in options %}
        <li
          class="ps-language-selector__option"
          role="option"
          tabindex="{{ option.disabled ? '-1' : '0' }}"
          aria-selected="{{ option.selected ? 'true' : 'false' }}"
          {{ option.disabled ? 'aria-disabled="true"' : null }}
          {{ option.url ? 'data-url="' ~ option.url ~ '"' : null }}
          data-value="{{ option.value }}"
        >
          {# Flag component #}
          {% include '@elements/flag/flag.twig' with {
            code: option.code,
            locale: option.locale ?? null,
            size: 'sm',
            shape: 'square',
            decorative: true
          } only %}
          <span class="ps-language-selector__label">{{ option.label }}</span>
        </li>
      {% endfor %}
    </ul>

    {# Native fallback select - visible only with .no-js #}
    <select class="ps-language-selector__native" name="{{ name }}" {{ disabled ? 'disabled' : null }}>
      {% for option in options %}
        <option value="{{ option.value }}" {{ option.selected ? 'selected' : null }} {{ option.disabled ? 'disabled' : null }}>
          {{ option.label }}
        </option>
      {% endfor %}
    </select>
  </div>
</nav>
