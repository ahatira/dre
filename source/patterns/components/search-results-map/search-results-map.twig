{#
/**
 * Search Results Map (Molecule)
 * 
 * Interactive map for property search results with price/NC markers, clustering, and radius visualization.
 * Supports Google Maps and Leaflet (OpenStreetMap). Drupal-native with drupalSettings integration.
 * 
 * @param {Attribute} attributes - Drupal attributes (required for integration)
 * @param {object} map - Map center and zoom: { lat: number, lng: number, zoom: number }
 * @param {string} provider - Map provider: 'google' or 'leaflet' (default 'leaflet')
 * @param {array} results - Search results: [{ id, lat, lng, price, currency, selected }]
 * @param {boolean} showRadius - Display distance circle (default false)
 * @param {number} radiusMeters - Circle radius in meters (default 1200)
 * @param {boolean} cluster - Enable marker clustering (default true)
 * @param {string|null} selectedId - ID of selected result for highlight
 * @param {string} mapId - Identifier for drupalSettings key (default 'default')
 * 
 * Priority: drupalSettings.psSearchResultsMap[mapId] > data-attributes
 */
#}

{% set mapId = mapId|default('default') %}
{% set map = map|default({ lat: 48.8723, lng: 2.3035, zoom: 13 }) %}
{% set provider = provider|default('leaflet') %}
{% set results = results|default([]) %}
{% set showRadius = showRadius|default(false) %}
{% set radiusMeters = radiusMeters|default(1200) %}
{% set cluster = cluster|default(true) %}
{% set selectedId = selectedId|default(null) %}

{% set classes = ['ps-map'] %}
{% set attr = (attributes ? attributes : create_attribute()).addClass(classes) %}

<div{{ attr }}>
  <div
    class="ps-map__canvas"
    role="region"
    aria-label="Search results map"
    data-map-id="{{ mapId }}"
    data-lat="{{ map.lat }}"
    data-lng="{{ map.lng }}"
    data-zoom="{{ map.zoom }}"
    data-provider="{{ provider }}"
    data-results='{{ results|json_encode() }}'
    data-show-radius='{{ showRadius ? "true" : "false" }}'
    data-radius-meters='{{ radiusMeters }}'
    data-cluster='{{ cluster ? "true" : "false" }}'
    data-selected-id='{{ selectedId }}'
  ></div>
</div>
