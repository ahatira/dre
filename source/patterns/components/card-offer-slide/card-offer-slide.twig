{#
/**
 * Card Offer Slide (Component/Molecule)
 * Compact card for property listings in sliders and galleries.
 * 
 * Extends Card component with:
 * - Property image (3:2 aspect ratio)
 * - Price • Surface compact header
 * - Property title
 * - Location with pin icon
 * - CTA link with arrow
 * - Favorite button overlay (toggle)
 * 
 * @param string title - Property title (required)
 * @param string price - Price value (e.g., "650 €", "20 000 €")
 * @param string surface - Surface area (e.g., "611 m²", "2 450 m²")
 * @param object image - Image data: { url: string, alt: string } (required)
 * @param string location - Location text (e.g., "Madrid", "Paris - La Défense")
 * @param string locationIcon - Location icon name (default: 'pin-map')
 * @param object cta - Call-to-action: { text: string, url: string }
 * @param boolean isFavorite - Favorite state for toggle button (default: false)
 * @param string bundle - Drupal content type/bundle (default: 'offer')
 * @param string view_mode - Drupal view mode (default: 'slide')
 * @param object attributes - Additional HTML attributes
 * 
 * Usage:
 *   {% include '@components/card-offer-slide/card-offer-slide.twig' with {
 *     title: 'Office Space PARIS',
 *     price: '650 €',
 *     surface: '2 450 m²',
 *     image: { url: '/images/building.jpg', alt: 'Office space in Paris' },
 *     location: 'Paris - La Défense',
 *     cta: { text: 'Consulter l\'annonce', url: '/property/123' },
 *     isFavorite: false
 *   } only %}
 */
#}

{%- set title = title|default('Product title') -%}
{%- set price = price|default(null) -%}
{%- set surface = surface|default(null) -%}
{%- set image = image|default(null) -%}
{%- set location = location|default(null) -%}
{%- set locationIcon = locationIcon|default('pin') -%}
{%- set cta = cta|default({ text: "Consulter l'annonce", url: '#' }) -%}
{%- set isFavorite = isFavorite|default(false) -%}
{%- set bundle = bundle|default('offer') -%}
{%- set view_mode = view_mode|default('slide') -%}

{# Embed Card component for structure reuse #}
{% embed '@components/card/card.twig' with {
  attributes: attributes.addClass('ps-card-offer-slide'),
  bundle: bundle,
  view_mode: view_mode,
  title: title,
  price: price,
  surface: surface,
  size: 'small',
  image: image,
  location: location,
  locationIcon: locationIcon,
  cta: cta,
  isFavorite: isFavorite
} %}

  {# Media block - Property image #}
  {% block media %}
    {% if image and image.url %}
      {% include '@elements/image/image.twig' with {
        src: image.url,
        alt: image.alt|default(''),
        class: 'ps-card-offer-slide__image'
      } only %}
    {% endif %}
  {% endblock %}
  
  {# Media overlay block - Favorite button in top-right corner #}
  {% block media_overlay %}
    <div class="ps-card-offer-slide__overlay">
      {% include '@elements/button/button.twig' with {
        class: 'ps-card-offer-slide__favorite',
        variant: 'secondary',
        size: 'xxl',
        icon: 'heart-outline',
        toggle: true,
        active: isFavorite,
        attributes: create_attribute()
          .setAttribute('aria-label', isFavorite ? 'Retirer des favoris' : 'Ajouter aux favoris')
          .setAttribute('data-action', 'favorite')
      } only %}
    </div>
  {% endblock %}
  
  {# Body block - Header, title, location #}
  {% block body %}
    
    {# Compact header: Price • m² #}
    {% if price or surface %}
      <div class="ps-card-offer-slide__header" data-ps-autofit="true">
        {% if price %}
          <span class="ps-card-offer-slide__price">{{ price }}</span>
        {% endif %}
        {% if price and surface %}
          <span class="ps-card-offer-slide__separator" aria-hidden="true"> • </span>
        {% endif %}
        {% if surface %}
          <span class="ps-card-offer-slide__surface">{{ surface }}</span>
        {% endif %}
      </div>
    {% endif %}
    
    {# Property title #}
    {% include '@elements/heading/heading.twig' with {
      level: 'h3',
      text: title,
      class: 'ps-card-offer-slide__title'
    } only %}
    
    {# Location with pin icon #}
    {% if location %}
      <div class="ps-card-offer-slide__location">
        {% include '@elements/icon/icon.twig' with {
          icon: locationIcon,
          class: 'ps-card-offer-slide__location-icon'
        } only %}
        <span class="ps-card-offer-slide__location-text">{{ location }}</span>
      </div>
    {% endif %}
    
  {% endblock %}
  
  {# Footer block - CTA link with arrow #}
  {% block footer %}
    {% if cta and cta.url %}
      <a href="{{ cta.url }}" class="ps-card-offer-slide__cta">
        <span class="ps-card-offer-slide__cta-text">{{ cta.text }}</span>
        <span class="ps-card-offer-slide__cta-icon" data-icon="arrow-right" aria-hidden="true"></span>
      </a>
    {% endif %}
  {% endblock %}

{% endembed %}
