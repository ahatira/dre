{# Search Bar - Search input component #}
<div class="ps-search-bar">
  <form class="ps-search-bar__form" role="search">
    <div class="ps-search-bar__input-wrapper">
      {% if show_icon %}
        <svg class="ps-search-bar__icon ps-search-bar__icon--search" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
        </svg>
      {% endif %}
      <input
        type="search"
        class="ps-search-bar__input"
        placeholder="{{ placeholder }}"
        value="{{ search_text }}"
        aria-label="Search"
      />
    </div>
    {% if has_suggestions and search_text %}
      <ul class="ps-search-bar__suggestions" role="listbox">
        {% for suggestion in suggestions %}
          <li class="ps-search-bar__suggestion" role="option">
            <a href="#" class="ps-search-bar__suggestion-link">{{ suggestion }}</a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </form>
</div>
