{#
/**
 * Carousel Component (Molecule)
 * Responsive image/card carousel with Swiper.js integration
 *
 * @param array slides - Array of slide objects (REQUIRED)
 *   Each slide: { id: string, image?: { src: string, alt: string }, card?: string }
 * @param string variant - Display variant: 'images' | 'cards' (default: 'images')
 * @param string fit - Image object-fit: 'cover' | 'contain' (default: 'cover')
 * @param boolean loop - Enable infinite loop navigation (default: false)
 * @param boolean autoHeight - Auto-adjust height based on active slide (default: false)
 * @param boolean withPagination - Show pagination bullets (default: false)
 * @param object toolbar - Multi-media toolbar config (optional)
 *   Structure: { items: [{ type: string, label: string, icon: string, slideIndex: number }] }
 * @param string ariaLabel - Accessible label for carousel region (default: 'Carousel')
 * @param object attributes - Additional HTML attributes (optional)
 *
 * @example
 * {% include '@components/carousel/carousel.twig' with {
 *   slides: [
 *     { id: 'slide1', image: { src: '/images/property-1.jpg', alt: 'Modern office building' } },
 *     { id: 'slide2', image: { src: '/images/property-2.jpg', alt: 'Luxury apartment' } }
 *   ],
 *   ariaLabel: 'Property gallery'
 * } only %}
 */
#}

{%- set variant = variant|default('images') -%}
{%- set fit = fit|default('cover') -%}
{%- set loop = loop|default(false) -%}
{%- set autoHeight = autoHeight|default(false) -%}
{%- set withPagination = withPagination is defined ? withPagination : false -%}
{%- set lightbox = lightbox|default(false) -%}
{%- set toolbar = toolbar|default({}) -%}
{%- set ariaLabel = ariaLabel|default('Carousel') -%}
{%- set slides = slides|default([]) -%}

{%- set classes = ['ps-carousel'] -%}
{%- if variant != 'images' -%}
  {%- set classes = classes|merge(['ps-carousel--' ~ variant]) -%}
{%- endif -%}
{%- if loop -%}
  {%- set classes = classes|merge(['ps-carousel--loop']) -%}
{%- endif -%}
{%- if autoHeight -%}
  {%- set classes = classes|merge(['ps-carousel--auto-height']) -%}
{%- endif -%}
{%- if toolbar.items|default([])|length > 0 -%}
  {%- set classes = classes|merge(['ps-carousel--with-toolbar']) -%}
{%- endif -%}
{%- if variant == 'images' and fit == 'contain' -%}
  {%- set classes = classes|merge(['ps-carousel--fit-contain']) -%}
{%- endif -%}
{%- if lightbox -%}
  {%- set classes = classes|merge(['ps-carousel--lightbox']) -%}
{%- endif -%}

{%- set classes = classes|merge(['swiper']) -%}
{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}
{%- set attr = attr.setAttribute('aria-label', ariaLabel) -%}
{%- set attr = attr.setAttribute('data-carousel', true) -%}

<section{{ attr }}>
  <div class="swiper-wrapper ps-carousel__track">
    {%- for slide in slides -%}
    <div
      id="{{ slide.id }}"
      class="swiper-slide ps-carousel__slide"
      role="group"
      aria-roledescription="slide"
      aria-label="Slide {{ loop.index }} of {{ slides|length }}"
    >
      {%- if slide.image -%}
      <img
        class="ps-carousel__image"
        src="{{ slide.image.src }}"
        alt="{{ slide.image.alt }}"
        loading="lazy"
      />
      {%- elseif slide.card -%}
      <div class="ps-carousel__card">
        {{ slide.card|raw }}
      </div>
      {%- endif -%}
    </div>
    {%- endfor -%}
  </div>

  <div class="ps-carousel__controls">
    <button
      class="ps-carousel__button ps-carousel__button--prev"
      type="button"
      aria-label="Previous slide"
      data-carousel-prev
    >
      <span class="ps-carousel__icon" data-icon="chevron-left" aria-hidden="true"></span>
    </button>
    <button
      class="ps-carousel__button ps-carousel__button--next"
      type="button"
      aria-label="Next slide"
      data-carousel-next
    >
      <span class="ps-carousel__icon" data-icon="chevron-right" aria-hidden="true"></span>
    </button>
  </div>

  {%- if withPagination -%}
  <div class="swiper-pagination ps-carousel__pagination"></div>
  {%- endif -%}

  {%- if toolbar.items|default([])|length > 0 -%}
  <div class="ps-carousel__toolbar" role="tablist" aria-label="Media groups">
    {%- for item in toolbar.items -%}
    <button
      class="ps-carousel__toolbar-item"
      type="button"
      data-toolbar-item
      data-slide-index="{{ item.slideIndex }}"
      data-media-type="{{ item.type }}"
      role="tab"
      aria-selected="{{ loop.first ? 'true' : 'false' }}"
      tabindex="{{ loop.first ? '0' : '-1' }}"
      aria-label="Go to {{ item.label }}"
    >
      <span class="ps-carousel__toolbar-icon" data-icon="{{ item.icon }}" aria-hidden="true"></span>
      <span class="ps-carousel__toolbar-label">{{ item.label }}</span>
    </button>
    {%- if not loop.last -%}
    <span class="ps-carousel__toolbar-divider" aria-hidden="true"></span>
    {%- endif -%}
    {%- endfor -%}
  </div>
  {%- endif -%}
</section>
