{#
 * Avatar (Component/Molecule)
 * Composition: Image atom + Text atom (initials) + Status Badge atom
 * 
 * @param string src - Image URL (optional)
 * @param string alt - Alt text for image (required when src provided)
 * @param string initials - Initials text (2 letters max, fallback if no image)
 * @param string gender - male | female (default: male, used for icon fallback)
 * @param string size - xs | sm | md | lg | xl (default: md)
 * @param string shape - circle | square | rounded (default: circle)
 * @param string status - online | offline | busy (optional, status badge)
 * @param boolean bordered - White border (default: false)
 * @param boolean clickable - Interactive hover/focus (default: false)
 * @param string href - Link URL if clickable (optional)
 * @param Attribute attributes - Additional HTML attributes
 #}

{%- set size = size|default('md') -%}
{%- set shape = shape|default('circle') -%}
{%- set gender = gender|default('male') -%}
{%- set bordered = bordered|default(false) -%}
{%- set clickable = clickable|default(false) -%}

{%- set has_image = src and src is not empty -%}
{%- set has_initials = initials and initials is not empty and not has_image -%}
{%- set has_fallback = not has_image and not has_initials -%}

{%- set avatar_classes = [
  'ps-avatar',
  size != 'md' ? 'ps-avatar--' ~ size : null,
  shape != 'circle' ? 'ps-avatar--' ~ shape : null,
  has_initials ? 'ps-avatar--initials' : null,
  has_fallback ? 'ps-avatar--' ~ gender : null,
  bordered ? 'ps-avatar--bordered' : null,
  clickable ? 'ps-avatar--clickable' : null
] -%}

{%- set tag = href ? 'a' : 'div' -%}

<{{ tag }} class="{{ avatar_classes|join(' ')|trim }}"
  {%- if href %} href="{{ href }}"{% endif -%}
  {%- if attributes %} {{ attributes }}{% endif -%}
>
  {# Atom 1: Image #}
  {%- if has_image -%}
    {% include '@elements/image/image.twig' with {
      src: src,
      alt: alt|default(''),
      fit: 'cover',
      rounded: shape == 'circle' ? 'full' : (shape == 'rounded' ? 'md' : 'none'),
      loading: 'lazy',
      attributes: create_attribute().addClass('ps-avatar__image')
    } only %}
  {%- endif -%}

  {# Atom 2: Initials Text #}
  {%- if has_initials -%}
    {% include '@elements/text/text.twig' with {
      text: initials,
      tag: 'span',
      strong: true,
      attributes: create_attribute().addClass('ps-avatar__text')
    } only %}
  {%- endif -%}

  {# Atom 3: Status Badge #}
  {%- if status -%}
    {% include '@elements/badge/badge.twig' with {
      text: '',
      color: status == 'online' ? 'success' : (status == 'busy' ? 'danger' : 'default'),
      pill: true,
      size: 'small',
      attributes: create_attribute()
        .addClass('ps-avatar__status')
        .setAttribute('aria-label', status == 'online' ? 'Online' : (status == 'busy' ? 'Busy' : 'Offline'))
    } only %}
  {%- endif -%}
</{{ tag }}>
