{#
/**
 * @file
 * Wizard Steps component template.
 *
 * @component Wizard Steps
 * @description
 * Step progress indicator for multi-step wizards and workflows (property search, account setup).
 * Shows current progress through sequential steps with completed/active/pending states.
 *
 * @molecules
 * @category Navigation
 *
 * @features
 * - Horizontal and vertical orientations
 * - 3 states per step (pending, active, completed)
 * - Animated transitions between states
 * - Check icon for completed steps
 * - Connector lines showing progress
 * - Real Estate context (search wizard, listing process)
 *
 * @accessibility
 * - Semantic <ol> list structure
 * - aria-label for screen reader context
 * - Visual and text indicators for all states
 * - Color-blind friendly (icons + text)
 */
#}

{#
 * @param {array} steps - Array of step objects
 *   Each step: { label: string, completed: boolean, active: boolean }
 * @param {string} orientation - horizontal|vertical (default: horizontal)
 * @param {object} attributes - Additional HTML attributes for <ol> element (optional)
 #}

{%- set orientation = orientation|default('horizontal') -%}
{%- set steps = steps|default([]) -%}

{%- set wizard_classes = ['ps-wizard-steps', 'ps-wizard-steps--' ~ orientation] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(wizard_classes) -%}
{%- set attr = attr.setAttribute('aria-label', 'Progression') -%}

<ol{{ attr }}>
  {% for step in steps %}
    {%- set item_classes = [
      'ps-wizard-steps__item',
      step.active ? 'ps-wizard-steps__item--active' : null,
      step.completed ? 'ps-wizard-steps__item--completed' : null
    ] -%}
    {%- set item_attr = create_attribute().addClass(item_classes) -%}
    
    <li{{ item_attr }}>
      <div class="ps-wizard-steps__marker">
        {% if step.completed %}
          <span class="ps-wizard-steps__icon" data-icon="check" aria-hidden="true"></span>
        {% else %}
          <span class="ps-wizard-steps__number">{{ loop.index }}</span>
        {% endif %}
      </div>
      <span class="ps-wizard-steps__label">{{ step.label }}</span>
    </li>
  {% endfor %}
</ol>
