{#
 * Form Field (Molecule)
 * Complete form field with label, input/select/textarea, helper, and error
 * Derived from Drupal form field rendering
 *
 * @param string label - Label text
 * @param string type - Field type (text, email, password, number, search, tel, url, select, textarea)
 * @param string name - Field name
 * @param string id - Field ID
 * @param string value - Field value
 * @param string placeholder - Placeholder text
 * @param boolean required - Required state
 * @param boolean disabled - Disabled state
 * @param string helper - Helper/description text
 * @param string error - Error message
 * @param string rows - Rows for textarea
 * @param array options - Options for select
 * @param object attributes - Drupal attributes for field
 #}
{%- set type = type|default('text') -%}
{%- set label = label|default('') -%}
{%- set name = name|default('field') -%}
{%- set id = id|default(name) -%}
{%- set value = value|default('') -%}
{%- set placeholder = placeholder|default('') -%}
{%- set required = required|default(false) -%}
{%- set disabled = disabled|default(false) -%}
{%- set helper = helper|default('') -%}
{%- set error = error|default('') -%}
{%- set rows = rows|default(4) -%}
{%- set options = options|default([]) -%}
{%- set attributes = attributes|default(create_attribute()) -%}

<div class="form-item form-group">
  {%- if label -%}
    <label for="{{ id }}" class="form-label">
      {{ label }}
      {%- if required %}<span class="form-required">*</span>{% endif -%}
    </label>
  {%- endif -%}

  {%- if type == 'textarea' -%}
    <textarea
      {{ attributes.addClass('form-control form-textarea') }}
      id="{{ id }}"
      name="{{ name }}"
      rows="{{ rows }}"
      placeholder="{{ placeholder }}"
      {% if required %}required{% endif %}
      {% if disabled %}disabled{% endif %}
    >{{ value }}</textarea>

  {%- elseif type == 'select' -%}
    <select
      {{ attributes.addClass('form-control form-select') }}
      id="{{ id }}"
      name="{{ name }}"
      {% if required %}required{% endif %}
      {% if disabled %}disabled{% endif %}
    >
      {%- for option in options -%}
        <option value="{{ option.value }}" {% if option.selected %}selected{% endif %}>{{ option.label }}</option>
      {%- endfor -%}
    </select>

  {%- else -%}
    <input
      type="{{ type }}"
      {{ attributes.addClass('form-control form-input') }}
      id="{{ id }}"
      name="{{ name }}"
      value="{{ value }}"
      placeholder="{{ placeholder }}"
      {% if required %}required{% endif %}
      {% if disabled %}disabled{% endif %}
    />
  {%- endif -%}

  {%- if error -%}
    <div class="form-error" role="alert">
      {% include '@elements/icon/icon.twig' with {
        name: 'alert',
        attributes: create_attribute().addClass('form-error-icon')
      } only %}
      {{ error }}
    </div>
  {%- elseif helper -%}
    <div class="form-helper" id="{{ id }}-help">
      {{ helper }}
    </div>
  {%- endif -%}
</div>