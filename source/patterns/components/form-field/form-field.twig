{#
 * Form Field (Molecule)
 * 
 * Complete form field composing Atoms: Label + Input/Textarea/Select + Helper/Error
 * Drupal-compatible structure with form-item/form-group wrapper classes
 *
 * @param string label - Label text (required)
 * @param string type - Field type: text|email|password|number|search|tel|url|textarea|select (default: text)
 * @param string name - Field name (required)
 * @param string id - Field ID (optional, defaults to name-based)
 * @param string value - Field value (optional)
 * @param string placeholder - Placeholder text (optional)
 * @param boolean required - Required state (default: false)
 * @param boolean optional - Show "Optional" badge (default: false)
 * @param boolean disabled - Disabled state (default: false)
 * @param string helper - Helper/description text (optional)
 * @param string error - Error message (optional)
 * @param string rows - Rows for textarea (default: 4)
 * @param array options - Options for select: [{ value, label, selected=false }]
 * @param string icon_left - Icon name for left position (optional, e.g., "search")
 * @param string icon_right - Icon name for right position (optional, e.g., "chevron-down")
 * @param object attributes - Drupal attributes for the control input
 * @param object wrapper_attributes - Drupal attributes for form-item wrapper
 #}

{%- set type = type|default('text') -%}
{%- set label = label|default('') -%}
{%- set name = name|default('field') -%}
{%- set id = id|default(name) -%}
{%- set value = value|default('') -%}
{%- set placeholder = placeholder|default('') -%}
{%- set required = required|default(false) -%}
{%- set optional = optional|default(false) -%}
{%- set disabled = disabled|default(false) -%}
{%- set helper = helper|default('') -%}
{%- set error = error|default('') -%}
{%- set rows = rows|default(4) -%}
{%- set options = options|default([]) -%}
{%- set icon_left = icon_left|default(null) -%}
{%- set icon_right = icon_right|default(null) -%}
{%- set attributes = attributes|default(create_attribute()) -%}
{%- set wrapper_attributes = wrapper_attributes|default(create_attribute()) -%}

{# Drupal form-item wrapper (standard for form elements) #}
<div class="form-item form-group {% if error %}form-item--error{% endif %}"{{ wrapper_attributes |without('class') }}>
  {# Label - Atom with Optional badge #}
  {%- if label -%}
    <div class="form-label-wrapper">
      {% include '@elements/label/label.twig' with {
        text: label,
        forId: id,
        required: required,
        disabled: disabled
      } only %}
      {%- if optional -%}
        <span class="form-label-badge">Optional</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  {# Input/Textarea/Select Control with icon support #}
  {%- if icon_left or icon_right -%}
    <div class="form-control-wrapper {% if icon_left %}form-control-wrapper--icon-left{% endif %} {% if icon_right %}form-control-wrapper--icon-right{% endif %}">
      {%- if icon_left -%}
        <span class="form-control-icon form-control-icon--left" data-icon="{{ icon_left }}" aria-hidden="true"></span>
      {%- endif -%}

      {%- if type == 'textarea' -%}
        {% include '@elements/textarea/textarea.twig' with {
          name: name,
          id: id,
          value: value,
          placeholder: placeholder,
          rows: rows,
          disabled: disabled,
          required: required,
          state: error ? 'error' : null,
          attributes: attributes.addClass('form-control')
        } only %}

      {%- elseif type == 'select' -%}
        {% include '@elements/select/select.twig' with {
          name: name,
          id: id,
          options: options,
          disabled: disabled,
          required: required,
          error: error ? true : false,
          wrapper_attributes: create_attribute().addClass('form-control'),
          attributes: attributes
        } only %}

      {%- else -%}
        {% include '@elements/input/input.twig' with {
          type: type,
          name: name,
          id: id,
          value: value,
          placeholder: placeholder,
          disabled: disabled,
          required: required,
          state: error ? 'error' : null,
          attributes: attributes.addClass('form-control')
        } only %}
      {%- endif -%}

      {%- if icon_right -%}
        <span class="form-control-icon form-control-icon--right" data-icon="{{ icon_right }}" aria-hidden="true"></span>
      {%- endif -%}
    </div>
  {%- else -%}
    {# Control without icon wrapper #}
    {%- if type == 'textarea' -%}
      {% include '@elements/textarea/textarea.twig' with {
        name: name,
        id: id,
        value: value,
        placeholder: placeholder,
        rows: rows,
        disabled: disabled,
        required: required,
        state: error ? 'error' : null,
        attributes: attributes.addClass('form-control')
      } only %}

    {%- elseif type == 'select' -%}
      {% include '@elements/select/select.twig' with {
        name: name,
        id: id,
        options: options,
        disabled: disabled,
        required: required,
        error: error ? true : false,
        wrapper_attributes: create_attribute().addClass('form-control'),
        attributes: attributes
      } only %}

    {%- else -%}
      {% include '@elements/input/input.twig' with {
        type: type,
        name: name,
        id: id,
        value: value,
        placeholder: placeholder,
        disabled: disabled,
        required: required,
        state: error ? 'error' : null,
        attributes: attributes.addClass('form-control')
      } only %}
    {%- endif -%}
  {%- endif -%}

  {# Helper text or Error message #}
  {%- if error -%}
    <div class="form-error" role="alert" data-icon="alert-circle" data-icon-position="start">
      <span class="form-error-text">{{ error }}</span>
    </div>
  {%- elseif helper -%}
    <small class="form-helper" id="{{ id }}-help">
      {{ helper }}
    </small>
  {%- endif -%}
</div>