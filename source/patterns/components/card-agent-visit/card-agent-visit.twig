{#
/**
 * Card Agent Visit (Component/Molecule)
 * Invitation à planifier une visite, avec CTA et icône calendrier.
 *
 * Props:
 * - string title (e.g., 'Souhaitez-vous visiter ?')
 * - object cta { text: string, url: string, ariaLabel?: string }
 * - object attributes (HTML attributes)
 *
 * Rules: Token-First, BEM, data-icon, accessibility, attributes API.
 */
#}

{%- set title = title|default('Souhaitez-vous visiter ?') -%}
{%- set cta = cta|default({ text: 'Planifier une visite', url: '#planifier-visite', ariaLabel: 'Planifier une visite' }) -%}
{%- set attributes = (attributes ? attributes : create_attribute()) -%}

{%- set attr = attributes
  .addClass('ps-card-agent-visit')
-%}

<div{{ attr }}>
  {% include '@elements/heading/heading.twig' with {
    level: 'h2',
    text: title,
    attributes: create_attribute().addClass('ps-card-agent-visit__title')
  } only %}

  {% if cta and cta.url %}
    {% include '@elements/button/button.twig' with {
      variant: 'primary',
      label: cta.text,
      url: cta.url,
      icon: 'calendar',
      iconPosition: 'start',
      attributes: create_attribute().addClass('ps-card-agent-visit__cta'),
      ariaLabel: cta.ariaLabel|default(cta.text)
    } only %}
  {% endif %}
</div>
