{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Standardized color lists for PS Theme components",
  "version": "1.0.0",
  "semantic": {
    "description": "Semantic colors for component states and variants",
    "values": ["primary", "secondary", "success", "warning", "danger", "info"],
    "tokens": {
      "primary": "var(--primary)",
      "secondary": "var(--secondary)",
      "success": "var(--success)",
      "warning": "var(--warning)",
      "danger": "var(--danger)",
      "info": "var(--info)"
    },
    "hex": {
      "primary": "#00915A",
      "secondary": "#E0388C",
      "success": "#047857",
      "warning": "#CA8A04",
      "danger": "#DC2626",
      "info": "#2563EB"
    }
  },
  "neutral": {
    "description": "Neutral colors for default and subtle variants",
    "values": ["default", "muted", "subtle"],
    "tokens": {
      "default": "var(--gray-500)",
      "muted": "var(--gray-400)",
      "subtle": "var(--gray-300)"
    }
  },
  "brand": {
    "description": "BNP Paribas RealEstate brand colors",
    "values": ["primary", "secondary", "gold"],
    "tokens": {
      "primary": "var(--primary)",
      "secondary": "var(--secondary)",
      "gold": "var(--gold-500)"
    },
    "hex": {
      "primary": "#00915A",
      "secondary": "#E0388C",
      "gold": "#CA8A04"
    }
  },
  "extended": {
    "description": "Extended color palette (all semantic + neutral + brand)",
    "values": ["default", "primary", "secondary", "success", "warning", "danger", "info", "gold"]
  },
  "link": {
    "description": "Link color variants",
    "values": ["primary", "secondary", "info", "inverse"],
    "tokens": {
      "primary": "var(--ps-link-primary)",
      "secondary": "var(--ps-link-secondary)",
      "info": "var(--ps-link-info)",
      "inverse": "var(--ps-link-inverse)"
    }
  },
  "field": {
    "description": "Field/Input border colors",
    "tokens": {
      "default": "var(--ps-color-border-default)",
      "hover": "var(--ps-color-border-hover)",
      "focus": "var(--ps-color-border-focus)",
      "error": "var(--ps-color-border-error)",
      "success": "var(--ps-color-border-success)"
    }
  }
}
