{#
/**
 * Search Block
 * Simple search trigger button that opens the search form component.
 *
 * Props:
 * - string plugin_id - Drupal block plugin ID (default: 'block_search')
 * - object configuration - Block configuration (default: { provider: 'search' })
 * - string label - Block title (optional, empty by default)
 * - string button_label - Button text label (default: 'Search')
 * - string icon - Icon name without prefix (default: 'search')
 * - object attributes - Drupal Attribute object
 *
 * Extends: @layouts/block/block.twig
 * JavaScript: Drupal behavior via search-form component
 * Architecture: Block → triggers → Search Form component
 */
#}

{% extends '@layouts/block/block.twig' %}

{%- set plugin_id = plugin_id|default('block_search') -%}
{%- set configuration = configuration|default({ provider: 'search' }) -%}
{%- set button_label = button_label|default('Search') -%}
{%- set icon = icon|default('search') -%}

{%- block content -%}
  <button
    class="ps-search-trigger"
    type="button"
    aria-label="{{ button_label }}"
    data-icon="{{ icon }}"
    title="{{ button_label }}"
  >
    <span class="ps-search-trigger__label">{{ button_label }}</span>
  </button>
{%- endblock -%}
