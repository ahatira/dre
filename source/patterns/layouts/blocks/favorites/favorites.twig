{#
/**
 * @file
 * Favorites Block component - Quick access to user favorites with count badge
 *
 * Available variables:
 * - url: Link to favorites page (default: '/favorites')
 * - count: Number of favorites (0 = empty heart, >0 = filled heart with badge)
 * - label: Accessible label for screen readers (default: 'Mes favoris')
 * - attributes: HTML attributes for the link element
 *
 * Usage:
 * {% include '@blocks/favorites/favorites.twig' with {
 *   count: 5,
 *   url: '/user/favorites'
 * } only %}
 */
#}

{% set count = count ?? 0 %}
{% set url = url ?? '/favorites' %}
{% set label = label ?? 'Mes favoris' %}

{% set classes = [
  'ps-favorites',
  count > 0 ? 'ps-favorites--has-items' : null
] %}

{% set attr = (attributes is defined ? attributes : create_attribute())
  .addClass(classes)
  .setAttribute('data-icon', count > 0 ? 'heart' : 'heart-outline')
%}

<a href="{{ url }}" {{ attr }} aria-label="{{ label }}{{ count > 0 ? ' (' ~ count ~ ')' : '' }}">
  {% if count > 0 %}
    <span class="ps-favorites__badge" aria-hidden="true">
      {{ count > 99 ? '99+' : count }}
    </span>
  {% endif %}
</a>
