{#
  @file
  Contact Block

  Block component extending Block layout with a contact button that opens
  a modal dialog containing the Contact Form.

  Uses the Modal component (@components/modal/modal.twig) for dialog handling.
  The contact form is loaded via AJAX when the button is clicked.

  Available variables:
  - button: Contact button object (label, variant, icon, etc.)
  - contact_form_url: URL to fetch the contact form via AJAX
  - modal_id: Modal element ID (default: 'contact-modal')
  - modal_title: Modal title (default: 'Contact')
  - attributes: Drupal Attribute object
#}

{%- set plugin_id = plugin_id|default('block_contact') -%}
{%- set configuration = configuration|default({ provider: 'custom' }) -%}
{%- set button = button|default({}) -%}
{%- set contact_form_url = contact_form_url|default('#contact-form') -%}
{%- set modal_id = modal_id|default('contact-modal') -%}
{%- set modal_title = modal_title|default('Contact') -%}

{% extends '@layouts/block/block.twig' %}

{% block content -%}
  {# Attach required libraries #}
  {{ attach_library('ps/modal') }}
  {{ attach_library('ps/contact-contact-block-modal') }}

  {%- if button -%}
    {%- include '@elements/button/button.twig' with button|merge({
      attributes: create_attribute()
        .setAttribute('data-modal-trigger', modal_id)
    }) only -%}
  {%- endif -%}

  {# Modal with loading state and AJAX content injection #}
  {%- include '@components/modal/modal.twig' with {
    id: modal_id,
    title: modal_title,
    content: '<div class="ps-modal__loader"><span class="ps-loader" aria-label="Chargement du formulaire..."></span></div>',
    size: 'medium',
    backdrop: true,
    attributes: create_attribute()
      .setAttribute('data-ajax-modal', '')
      .setAttribute('data-form-url', contact_form_url)
  } only -%}
{%- endblock %}

