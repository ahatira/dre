{#
  @file
  Block User Account (User menu dropdown or login button)

  Extends the Block layout structure with a user menu dropdown (logged in)
  or login button (logged out).

  Available variables:
  - plugin_id: Drupal block plugin ID (default: block_user_account)
  - configuration: Block configuration with provider
  - label: Block title (optional)
  - logged_in: Boolean - user authentication state (default: false)
  - user_name: String - Display name when logged in
  - menu_items: Array of menu items when logged in
    - label: Link text
    - url: Link URL
    - icon: Icon name (optional)
  - login_button: Object - Button properties for logged out state
    - label: Button text
    - url: Login URL
    - variant: Button variant
    - icon: Icon name
  - attributes: Drupal Attribute object
#}

{% extends '@layouts/block/block.twig' %}

{%- set plugin_id = plugin_id|default('block_user_account') -%}
{%- set configuration = configuration|default({ provider: 'custom' }) -%}
{%- set logged_in = logged_in|default(false) -%}
{%- set user_name = user_name|default('User') -%}
{%- set menu_items = menu_items|default([]) -%}
{%- set login_button = login_button|default({
  label: 'Log in / Sign up',
  url: '/user/login',
  variant: 'primary',
  icon: 'account'
}) -%}

{%- block content -%}
  {%- if logged_in -%}
    <div class="ps-user-account ps-user-account--logged-in" data-user-account>
      <button
        class="ps-user-account__toggle"
        type="button"
        aria-haspopup="menu"
        aria-expanded="false"
        data-user-account-toggle
      >
        <span class="ps-user-account__toggle-icon" data-icon="account" aria-hidden="true"></span>
        <span class="ps-user-account__toggle-label">{{- user_name -}}</span>
        <span class="ps-user-account__toggle-chevron" data-icon="chevron-down" aria-hidden="true"></span>
      </button>

      <nav class="ps-user-account__menu" hidden data-user-account-menu>
        <ul class="ps-user-account__menu-list" role="menu">
          {%- for item in menu_items -%}
            {%- if item.type == 'logout' -%}
              <li class="ps-user-account__menu-item ps-user-account__menu-item--logout">
                {%- include '@elements/button/button.twig' with {
                  label: item.label,
                  url: item.url,
                  variant: 'primary',
                  outline: true,
                  fullWidth: true,
                  icon: item.icon
                } only -%}
              </li>
            {%- else -%}
              <li class="ps-user-account__menu-item" role="none">
                <a href="{{ item.url }}" class="ps-user-account__menu-link" role="menuitem">
                  {%- if item.icon -%}
                    <span class="ps-user-account__menu-icon" data-icon="{{ item.icon }}" aria-hidden="true"></span>
                  {%- endif -%}
                  <span class="ps-user-account__menu-text">{{- item.label -}}</span>
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>
    </div>
  {%- else -%}
    <div class="ps-user-account ps-user-account--logged-out">
      {%- include '@elements/button/button.twig' with login_button only -%}
    </div>
  {%- endif -%}
{%- endblock -%}
