{#
/**
 * Offer location section (address + transports).
 * Variables:
 * - location.title
 * - location.address.lines: Array of strings.
 * - location.transport: Array of { label, items }.
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-location',
  placeholder ? 'offer-location--placeholder' : null,
  location.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }} aria-labelledby="offer-location-heading">
  {% if placeholder %}
    <div class="offer-location__skeleton" aria-hidden="true"></div>
  {% else %}
    <span class="offer-section__title" id="offer-location-heading">{{ location.title|default('Location') }}</span>
    {% if location.address.lines %}
      <address class="offer-location__address">
        {% for line in location.address.lines %}
          <span class="offer-location__address-line">{{ line }}</span>
        {% endfor %}
      </address>
    {% endif %}

    {% if location.transport %}
      <div class="offer-location__transport">
        {% for group in location.transport %}
          <div class="offer-location__transport-group">
            <p class="offer-location__transport-label">{{ group.label }}</p>
            {% if group.items %}
              <ul class="offer-location__transport-list">
                {% for item in group.items %}
                  <li class="offer-location__transport-item">{{ item }}</li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
</section>
