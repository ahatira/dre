{#
/**
 * Offer reference section.
 * Variables:
 * - reference.label: Label text.
 * - reference.value: Reference identifier.
 * - placeholder: Boolean skeleton flag.
 */
#}

{%- set classes = [
  'offer-reference',
  placeholder ? 'offer-reference--placeholder' : null,
  reference.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }}>
  {% if placeholder %}
    <div class="offer-reference__skeleton" aria-hidden="true"></div>
  {% else %}
    <span class="offer-reference__label">{{ reference.label|default('Reference') }}:</span>
    <span class="offer-reference__value">{{ reference.value|default('—') }}</span>
  {% endif %}
</section>
