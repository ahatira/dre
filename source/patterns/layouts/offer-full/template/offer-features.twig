{#
/**
 * Offer features section (equipments, services, conditions, misc).
 * Variables:
 * - features.groups: Array of { title, icon, items: [] }.
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-features',
  placeholder ? 'offer-features--placeholder' : null,
  features.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }} aria-labelledby="offer-features-heading">
  {% if placeholder %}
    <div class="offer-features__skeleton" aria-hidden="true"></div>
  {% else %}
    <h2 class="offer-features__title" id="offer-features-heading">{{ features.title|default('Features') }}</h2>
    <div class="offer-features__grid">
      {% for group in features.groups|default([]) %}
        <section class="offer-features__group">
          <div class="offer-features__group-head">
            {% if group.icon %}<span class="offer-features__icon" data-icon="{{ group.icon }}" aria-hidden="true"></span>{% endif %}
            <h3 class="offer-features__group-title">{{ group.title }}</h3>
          </div>
          {% if group.items %}
            <ul class="offer-features__list">
              {% for item in group.items %}
                <li class="offer-features__item">{{ item }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </section>
      {% endfor %}
    </div>
  {% endif %}
</section>
