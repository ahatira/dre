{#
/**
 * Offer features section (equipments, services, conditions, misc).
 * Composes Features organisms in a grid layout.
 * Variables:
 * - features.groups: Array of { title, icon, items, columns_min_items }.
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-features',
  features.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}
{%- set attr = attr.setAttribute('aria-label', features.title|default('Features')) -%}

<section{{ attr }}>
  {% for group in features.groups|default([]) %}
    {% include '@collections/offer/features/features.twig' with {
      title: group.title,
      icon: group.icon,
      items: group.items,
      columns_min_items: group.columns_min_items|default(0)
    } only %}
  {% endfor %}
</section>
