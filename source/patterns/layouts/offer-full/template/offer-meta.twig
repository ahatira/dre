{#
/**
 * Offer meta section (title, building, pricing, key facts).
 * Variables:
 * - meta.building: { label, value }
 * - meta.title: Main heading string.
 * - meta.price: { label, value, unit }
 * - meta.surface_total: { label, value, unit }
 * - meta.availability: { label, value }
 * - meta.mandate_type: { label, value }
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-meta',
  placeholder ? 'offer-meta--placeholder' : null,
  meta.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }} aria-labelledby="offer-meta-heading">
  {% if placeholder %}
    <div class="offer-meta__skeleton" aria-hidden="true"></div>
  {% else %}
    <div class="offer-meta__header">
      <div class="offer-meta__titles">
        {% if meta.building.value %}
          <span class="offer-meta__building h3">{{ meta.building.value }}</span>
        {% endif %}
        {% if meta.title %}
          <h3 class="offer-meta__title" id="offer-meta-heading">{{ meta.title }}</h3>
        {% endif %}
      </div>
      {% if meta.price.value %}
        <div class="offer-meta__price">
          <div class="offer-meta__price-value">{{ meta.price.value }}</div>
          {% if meta.price.unit %}<div class="offer-meta__price-unit">{{ meta.price.unit }}</div>{% endif %}
          {% if meta.price.tooltip %}
            <span
              class="offer-meta__price-tooltip"
              data-icon="tooltip"
              data-ps-tooltip
              data-ps-tooltip-content="{{ meta.price.tooltip }}"
              data-ps-tooltip-position="top"
              data-ps-tooltip-icon="info"
              aria-label="Price information"
            ></span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if meta.surface_total.value or meta.location %}
      <div class="offer-meta__location-info">
        {% if meta.surface_total.value %}
          <span class="offer-meta__surface">{{ meta.surface_total.value }}{% if meta.surface_total.unit %} {{ meta.surface_total.unit }}{% endif %}</span>
        {% endif %}
        {% if meta.surface_total.value and meta.location %}<span class="offer-meta__separator">•</span>{% endif %}
        {% if meta.location %}
          <span class="offer-meta__location">{{ meta.location }}</span>
        {% endif %}
      </div>
    {% endif %}

    <dl class="offer-meta__facts">
      {% if meta.availability.value %}
        <div class="offer-meta__fact">
          <dt>{{ meta.availability.label|default('Available') }} :</dt>
          <dd>{{ meta.availability.value }}</dd>
        </div>
      {% endif %}
      {% if meta.mandate_type.value %}
        <div class="offer-meta__fact">
          <dt>{{ meta.mandate_type.label|default('Type of mandate') }} :</dt>
          <dd>{{ meta.mandate_type.value }}</dd>
        </div>
      {% endif %}
    </dl>
  {% endif %}
</section>
