{#
/**
 * Offer surface table.
 * Variables:
 * - surface.title: Section heading.
 * - surface.headers: Array of column labels.
 * - surface.rows: Array of rows (each row is array of cells).
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-surface',
  placeholder ? 'offer-surface--placeholder' : null,
  surface.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }} aria-labelledby="offer-surface-heading">
  {% if placeholder %}
    <div class="offer-surface__skeleton" aria-hidden="true"></div>
  {% else %}
    <div class="offer-surface__header">
      <span class="offer-section__title" id="offer-surface-heading">{{ surface.title|default('Surface table') }}</span>
      {% if surface.caption %}<p class="offer-surface__caption">{{ surface.caption }}</p>{% endif %}
    </div>
    <div class="offer-surface__table-wrapper">
      <table class="offer-surface__table">
        {% if surface.headers %}
          <thead>
            <tr>
              {% for header in surface.headers %}
                <th scope="col">{{ header }}</th>
              {% endfor %}
            </tr>
          </thead>
        {% endif %}
        <tbody>
          {% for row in surface.rows|default([]) %}
            <tr>
              {% for cell in row %}
                <td>{{ cell }}</td>
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</section>
