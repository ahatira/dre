{#
/**
 * Offer surface table.
 * Variables:
 * - surface.title: Section heading.
 * - surface.icon: Icon for title.
 * - surface.table: Table data (caption, headers, rows).
 */
#}

{%- set classes = [
  'offer-surface',
  placeholder ? 'offer-surface--placeholder' : null,
  surface.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}
{%- set attr = attr.setAttribute('aria-label', surface.title|default('Surface table')) -%}

<section{{ attr }}>
  {% include '@collections/offer/surface/surface.twig' with {
    title_level: surface.title_level|default('h4'),
    title: surface.title|default('Surface table'),
    icon: surface.icon|default('area'),
    headers: surface.table.headers|default([]),
    rows: surface.table.rows|default([]),
    variant: 'default',
    striped: false,
    hover: true,
    bordered: false,
    attributes: create_attribute()
  } only %}
</section>
