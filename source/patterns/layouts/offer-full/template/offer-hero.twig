{#
/**
 * Offer hero section (media carousel placeholder-friendly).
 * Variables:
 * - hero.media: Carousel configuration { variant, fit, slides, toolbar }.
 * - hero.favorite: Button configuration for favorite toggle.
 * - placeholder: Boolean to render skeleton state.
 */
#}

{%- set classes = [
  'offer-hero',
  placeholder ? 'offer-hero--placeholder' : null,
  hero.modifier_class|default(null)
] -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }} aria-label="Offer media">
  {% if placeholder %}
    <div class="offer-hero__skeleton" aria-hidden="true"></div>
  {% else %}
    <div class="offer-hero__media">
      {% if hero.media|default(null) %}
        {%- include '@components/carousel/carousel.twig' with hero.media only -%}
      {% endif %}

      {% if hero.favorite|default(null) %}
        <div class="offer-hero__favorite-wrapper">
          {%- include '@elements/button/button.twig' with hero.favorite only -%}
        </div>
      {% endif %}
    </div>
  {% endif %}
</section>
