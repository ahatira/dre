{#
/**
 * Offer description section.
 * Variables:
 * - description.title: Optional heading.
 * - description.body: Rich text (pre-rendered HTML or plain text).
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-description',
  placeholder ? 'offer-description--placeholder' : null,
  description.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }} aria-labelledby="offer-description-heading">
  {% if placeholder %}
    <div class="offer-description__skeleton" aria-hidden="true"></div>
  {% else %}
    {% if description.title %}
      <span class="offer-section__title" id="offer-description-heading">{{ description.title }}</span>
    {% endif %}
    {% if description.body %}
      <div class="offer-description__body">
        {% include '@components/read-more/read-more.twig' with {
          content: description.body,
          maxHeight: description.maxHeight|default(150),
          expandLabel: description.expandLabel|default('Voir plus'),
          collapseLabel: description.collapseLabel|default('Voir moins'),
          expanded: description.expanded|default(false),
          showIcon: description.showIcon|default(true)
        } only %}
      </div>
    {% endif %}
  {% endif %}
</section>
