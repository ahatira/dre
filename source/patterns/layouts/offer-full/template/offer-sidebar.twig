{#
/**
 * Offer sidebar (agent card + visit card).
 * Variables:
 * - sidebar.agent: Card Agent configuration { name, title, avatar, phone, cta }.
 * - sidebar.visit: Card Agent Visit configuration { title, cta }.
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-sidebar',
  sidebar.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<div{{ attr }}>
  {% if sidebar.agent|default(null) %}
    <div class="offer-sidebar__agent">
      {%- include '@components/card-agent/card-agent.twig' with sidebar.agent only -%}
    </div>
  {% endif %}

  {% if sidebar.visit|default(null) %}
    <div class="offer-sidebar__visit">
      {%- include '@components/card-agent-visit/card-agent-visit.twig' with sidebar.visit only -%}
    </div>
  {% endif %}
</div>
