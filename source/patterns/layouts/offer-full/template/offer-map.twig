{#
/**
 * Offer map section (full width).
 * Variables:
 * - map.title: Optional heading.
 * - map.embed: Raw HTML for map or iframe.
 * - map.image: Static image fallback { src, alt }.
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-map__inner',
  placeholder ? 'offer-map__inner--placeholder' : null,
  map.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<div{{ attr }} aria-label="Map">
  {% if placeholder %}
    <div class="offer-map__skeleton" aria-hidden="true"></div>
  {% else %}
    {% if map.title %}<h2 class="offer-map__title">{{ map.title }}</h2>{% endif %}
    <div class="offer-map__frame">
      {% if map.embed %}
        {{ map.embed }}
      {% elseif map.image %}
        <img src="{{ map.image.src }}" alt="{{ map.image.alt|default('Map preview') }}" loading="lazy" />
      {% else %}
        <div class="offer-map__placeholder">Map placeholder</div>
      {% endif %}
    </div>
  {% endif %}
</div>
