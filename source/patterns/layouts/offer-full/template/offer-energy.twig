{#
/**
 * Offer energy section (DPE, GES, labels).
 * Variables:
 * - energy.metrics: Array of { label, value, unit, scale }.
 * - energy.label: Optional certification label (text or image src).
 * - placeholder: Skeleton toggle.
 */
#}

{%- set classes = [
  'offer-energy',
  placeholder ? 'offer-energy--placeholder' : null,
  energy.modifier_class|default(null)
] -%}
{%- set attr = (attributes is defined ? attributes : create_attribute()).addClass(classes) -%}

<section{{ attr }} aria-labelledby="offer-energy-heading">
  {% if placeholder %}
    <div class="offer-energy__skeleton" aria-hidden="true"></div>
  {% else %}
    <span class="offer-section__title" id="offer-energy-heading">{{ energy.title|default('Energy') }}</span>
    <div class="offer-energy__metrics">
      {% for metric in energy.metrics|default([]) %}
        <div class="offer-energy__metric" role="group" aria-label="{{ metric.label }}">
          <div class="offer-energy__metric-head">
            {% if metric.icon %}<span class="offer-energy__metric-icon" data-icon="{{ metric.icon }}" aria-hidden="true"></span>{% endif %}
            <p class="offer-energy__metric-label">{{ metric.label }}</p>
          </div>
          <div class="offer-energy__scale">
            <div class="offer-energy__scale-bar" style="--offer-energy-value: {{ metric.value|default(0) }}"></div>
            <span class="offer-energy__metric-value">{{ metric.value|default('—') }}{% if metric.unit %} {{ metric.unit }}{% endif %}</span>
          </div>
          {% if metric.hint %}<p class="offer-energy__metric-hint">{{ metric.hint }}</p>{% endif %}
        </div>
      {% endfor %}
    </div>

    {% if energy.label %}
      <div class="offer-energy__label">
        {% if energy.label.image %}
          <img src="{{ energy.label.image }}" alt="{{ energy.label.text|default('Certification label') }}" loading="lazy" />
        {% else %}
          <span class="offer-energy__label-text">{{ energy.label.text }}</span>
        {% endif %}
      </div>
    {% endif %}
  {% endif %}
</section>
