{#
/**
 * Offer Sidebar (Consultant Card + Visit Card)
 * 
 * @param object consultant - Agent card data
 * @param object visitCard - Visit card data
 * @param boolean skeleton - Loading state
 */
#}

{% set consultant = consultant|default({}) %}
{% set visitCard = visitCard|default({}) %}
{% set skeleton = skeleton|default(false) %}

{# Consultant Card #}
{% if consultant.name %}
  {% if skeleton %}
    {% include '@elements/skeleton/skeleton.twig' with {
      variant: 'card',
      width: '100%',
      height: '250px'
    } only %}
  {% else %}
    {% include '@components/card-agent/card-agent.twig' with consultant only %}
  {% endif %}
{% endif %}

{# Visit Card #}
{% if visitCard.title %}
  {% if skeleton %}
    {% include '@elements/skeleton/skeleton.twig' with {
      variant: 'card',
      width: '100%',
      height: '120px'
    } only %}
  {% else %}
    {% include '@components/card-agent-visit/card-agent-visit.twig' with visitCard only %}
  {% endif %}
{% endif %}
