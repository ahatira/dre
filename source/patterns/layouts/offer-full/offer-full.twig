{#
/**
 * Offer Full Layout (Page Template)
 * Complete property detail page with gallery, specifications, consultant, and location.
 * Drupal-compatible page template for property detail node display.
 *
 * @param boolean skeleton - Loading state with skeleton placeholders (default: false)
 * @param object gallery - Carousel slides with images
 * @param object header - Property header (title, reference, surface, location, price, badges)
 * @param object actions - Action buttons (surface table, brochure, visit)
 * @param object consultant - Agent card data (name, phone, avatar, cta)
 * @param object description - Property description with read-more
 * @param object equipments - Feature section for equipments
 * @param object services - Feature section for services
 * @param object building - Feature section for building condition
 * @param object information - Feature section for additional info
 * @param object energy - Energy performance data (DPE/GES) - PLACEHOLDER
 * @param object surfaceTable - Surface table data (lots, floors, areas)
 * @param object location - Address and map data - PLACEHOLDER
 * @param object poi - Points of interest filters - PLACEHOLDER
 * @param object travelTime - Travel time calculator - PLACEHOLDER
 * @param object attributes - Additional HTML attributes (Drupal)
 */
#}

{%- set skeleton = skeleton|default(false) -%}
{%- set gallery = gallery|default({}) -%}
{%- set header = header|default({}) -%}
{%- set actions = actions|default({}) -%}
{%- set consultant = consultant|default({}) -%}
{%- set description = description|default({}) -%}
{%- set equipments = equipments|default({}) -%}
{%- set services = services|default({}) -%}
{%- set building = building|default({}) -%}
{%- set information = information|default({}) -%}
{%- set energy = energy|default({}) -%}
{%- set surfaceTable = surfaceTable|default({}) -%}
{%- set location = location|default({}) -%}
{%- set poi = poi|default({}) -%}
{%- set travelTime = travelTime|default({}) -%}

{%- set attr = (attributes is defined ? attributes : create_attribute()) -%}

<article{{ attr }}>
  <div class="container">
    <div class="offer-layout">
      
      {# MAIN CONTENT COLUMN #}
      <div class="offer-layout__main">
        
        {# HERO: Gallery Carousel #}
        {% if gallery.slides|default([])|length > 0 %}
          <section class="offer-hero" aria-label="Property gallery">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'rectangle',
              width: '100%',
              height: '500px'
            } only %}
          {% else %}
            {% include '@components/carousel/carousel.twig' with gallery only %}
          {% endif %}
        </section>
      {% endif %}

      {# META: Header + Actions #}
      <section class="offer-meta">
        {# HEADER #}
        <div class="offer-meta__header">
        <div class="offer-meta__header">
        {% if skeleton %}
          {% include '@elements/skeleton/skeleton.twig' with {
            variant: 'text',
            width: '80%',
            height: '40px'
          } only %}
          <div style="margin-top: 16px;">
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'text',
              width: '60%',
              height: '24px'
            } only %}
          </div>
          <div style="margin-top: 12px;">
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'text',
              width: '40%',
              height: '24px'
            } only %}
          </div>
        {% else %}
          {# Badges #}
          {% if header.badges|default([])|length > 0 %}
            <div class="offer-meta__badges">
              {% for badge in header.badges %}
                {% include '@elements/badge/badge.twig' with badge only %}
              {% endfor %}
            </div>
          {% endif %}

          {# Title #}
          {% if header.title %}
            {% include '@elements/heading/heading.twig' with {
              level: 'h1',
              text: header.title,
              attributes: create_attribute().addClass('offer-meta__title')
            } only %}
          {% endif %}

          {# Meta info (reference, surface, location) #}
          <div class="offer-meta__info">
            {% if header.reference %}
              <span class="offer-meta__reference">Référence : {{ header.reference }}</span>
            {% endif %}
            {% if header.surface %}
              <span class="offer-meta__surface">{{ header.surface }}</span>
            {% endif %}
            {% if header.location %}
              <span class="offer-meta__location" data-icon="pin">{{ header.location }}</span>
            {% endif %}
          </div>

          {# Price #}
          {% if header.price %}
            <div class="offer-meta__price">{{ header.price }}</div>
          {% endif %}

          {# Availability & Mandate #}
          {% if header.availability or header.mandate %}
            <div class="offer-meta__details">
              {% if header.availability %}
                <span class="offer-meta__availability">Disponible : {{ header.availability }}</span>
              {% endif %}
              {% if header.mandate %}
                <span class="offer-meta__mandate">Mandat : {{ header.mandate }}</span>
              {% endif %}
            </div>
          {% endif %}
        {% endif %}
        </div>

        {# ACTIONS #}
        {% if actions.buttons|default([])|length > 0 %}
          <div class="offer-meta__actions" aria-label="Property actions">
          {% if skeleton %}
            <div style="display: flex; gap: 12px;">
              {% include '@elements/skeleton/skeleton.twig' with {
                variant: 'button',
                width: '180px',
                height: '44px'
              } only %}
              {% include '@elements/skeleton/skeleton.twig' with {
                variant: 'button',
                width: '180px',
                height: '44px'
              } only %}
              {% include '@elements/skeleton/skeleton.twig' with {
                variant: 'button',
                width: '180px',
                height: '44px'
              } only %}
            </div>
          {% else %}
            <div class="offer-meta__actions-list">
              {% for action in actions.buttons %}
                {% include '@elements/button/button.twig' with action only %}
              {% endfor %}
            </div>
          {% endif %}
          </div>
        {% endif %}
      </section>

      {# DESCRIPTION #}
      {% if description.content %}
        <section class="offer-description">
        <section class="offer-description">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'text',
              width: '100%',
              height: '150px'
            } only %}
          {% else %}
            {% include '@elements/heading/heading.twig' with {
              level: 'h2',
              text: 'Description',
              attributes: create_attribute().addClass('offer-description__title')
            } only %}
            {% include '@components/read-more/read-more.twig' with description only %}
          {% endif %}
        </section>
      {% endif %}

      {# FEATURES: Equipments, Services, Building, Information #}
      <section class="offer-features">
        {# EQUIPMENTS #}
        {% if equipments.items|default([])|length > 0 %}
          <div class="offer-features__section">
          <div class="offer-features__section">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'text',
              width: '100%',
              height: '120px'
            } only %}
          {% else %}
            {% include '@collections/feature-section/feature-section.twig' with equipments only %}
          {% endif %}
          </div>
        {% endif %}

        {# SERVICES #}
        {% if services.items|default([])|length > 0 %}
          <div class="offer-features__section">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'text',
              width: '100%',
              height: '150px'
            } only %}
          {% else %}
            {% include '@collections/feature-section/feature-section.twig' with services only %}
          {% endif %}
          </div>
        {% endif %}

        {# BUILDING CONDITION #}
        {% if building.items|default([])|length > 0 %}
          <div class="offer-features__section">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'text',
              width: '100%',
              height: '100px'
            } only %}
          {% else %}
            {% include '@collections/feature-section/feature-section.twig' with building only %}
          {% endif %}
          </div>
        {% endif %}

        {# MORE INFORMATION #}
        {% if information.items|default([])|length > 0 %}
          <div class="offer-features__section">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'text',
              width: '100%',
              height: '100px'
            } only %}
          {% else %}
            {% include '@collections/feature-section/feature-section.twig' with information only %}
          {% endif %}
          </div>
        {% endif %}
      </section>

      {# ENERGY #}
      {% if energy.dpe or energy.ges %}
        <section class="offer-energy" aria-label="Energy performance">
        <section class="offer-energy" aria-label="Energy performance">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'rectangle',
              width: '100%',
              height: '200px'
            } only %}
          {% else %}
            {% include '@elements/heading/heading.twig' with {
              level: 'h2',
              text: 'Énergie',
              icon: 'energy',
              attributes: create_attribute().addClass('offer-energy__title')
            } only %}
            <div class="offer-energy__placeholder">
              <p>🔌 DPE & GES widgets - Component to be implemented</p>
              <p>Data: DPE {{ energy.dpe|default('N/A') }} | GES {{ energy.ges|default('N/A') }}</p>
            </div>
          {% endif %}
        </section>
      {% endif %}

      {# SURFACE TABLE #}
      {% if surfaceTable.rows|default([])|length > 0 %}
        <section class="offer-surface-table" aria-label="Surface details">
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'rectangle',
              width: '100%',
              height: '300px'
            } only %}
          {% else %}
            {% include '@elements/heading/heading.twig' with {
              level: 'h2',
              text: 'Tableau des surfaces',
              icon: 'table',
              attributes: create_attribute().addClass('offer-surface-table__title')
            } only %}
            {% include '@components/table/table.twig' with surfaceTable only %}
          {% endif %}
        </section>
      {% endif %}

      </div> {# /offer-layout__main #}

      {# SIDEBAR: Consultant Card #}
      <aside class="offer-layout__sidebar">
        {% if consultant.name %}
          {% if skeleton %}
            {% include '@elements/skeleton/skeleton.twig' with {
              variant: 'card',
              width: '100%',
              height: '250px'
            } only %}
          {% else %}
            {% include '@components/card-agent/card-agent.twig' with consultant only %}
          {% endif %}
        {% endif %}
      </aside>

    </div> {# /offer-layout #}
  </div> {# /container #}

  {# FULL-WIDTH MAP SECTION #}
  {% if location.address or location.map or poi.categories|default([])|length > 0 or travelTime.enabled %}
    <section class="offer-map" aria-label="Location and map">
      {% if skeleton %}
        {% include '@elements/skeleton/skeleton.twig' with {
          variant: 'rectangle',
          width: '100%',
          height: '500px'
        } only %}
      {% else %}
        <div class="offer-map__container">
          {# Address #}
          {% if location.address %}
            <div class="offer-map__address">
              <p><strong>{{ location.address.street }}</strong></p>
              <p>{{ location.address.city }}, {{ location.address.postal }}</p>
            </div>
          {% endif %}

          {# Map Placeholder #}
          <div class="offer-map__placeholder">
            <p>🗺️ Interactive map widget - Component to be implemented</p>
            <p>Coordinates: {{ location.map.lat|default('N/A') }}, {{ location.map.lng|default('N/A') }}</p>
          </div>

          {# POI Filters #}
          {% if poi.categories|default([])|length > 0 %}
            <div class="offer-map__poi">
              <p>📍 POI Filters: {{ poi.categories|join(', ') }}</p>
              <p>Checkboxes for: Transports, Parking, Restaurants, Hotels</p>
            </div>
          {% endif %}

          {# Travel Time Calculator #}
          {% if travelTime.enabled %}
            <div class="offer-map__travel-time">
              <p>🚗 Calculate travel time - Component to be implemented</p>
              <p>Origin: {{ travelTime.origin|default('N/A') }}</p>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </section>
  {% endif %}
</article>
