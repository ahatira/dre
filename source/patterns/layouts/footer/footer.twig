{#
/**
 * @file
 * Footer Layout (Template)
 *
 * Available variables:
 * - page.footer_contact: Drupal region (Contact Us block)
 * - page.footer_social: Drupal region (Follow Us block)
 * - page.footer_menu_col1: Drupal region (Menu Links sections Column 1)
 * - page.footer_menu_col2: Drupal region (Menu Links sections Column 2)
 * - page.footer_legal: Drupal region (Legal Links menu)
 * - page.footer_branding: Drupal region (Logo / Branding)
 * - page.footer_copyright: Drupal region (Copyright notice)
 * - attributes: Drupal Attribute object for root element
 * - modifier_class: Optional modifier class
 *
 * Drupal integration:
 * - Utilise exclusivement les régions Drupal (aucun fallback interne)
 * - Aucun include de blocs (Drupal injecte le contenu des blocs via régions)
 * - Laisser Drupal gérer l'organisation des contenus
 *
 * @see footer.css
 */
#}

{%- set classes = ['ps-footer'] -%}
{%- if modifier_class -%}
  {%- set classes = classes|merge([modifier_class]) -%}
{%- endif -%}
{%- set attr = (attributes ? attributes : create_attribute()).addClass(classes) -%}

<footer{{ attr }} role="contentinfo">
  {# ========== TOP: 3 Colonnes (Contact+Social | Menu1 | Menu2) ========== #}
  <div class="ps-footer__top">
    {# Colonne 1: Contact + Social #}
    <div class="ps-footer__column ps-footer__column--1">
      {% if page.footer_contact %}
        <div class="ps-footer__contact">
          {{ page.footer_contact }}
        </div>
      {% endif %}

      {% if page.footer_social %}
        <div class="ps-footer__social">
          {{ page.footer_social }}
        </div>
      {% endif %}
    </div>

    {# Colonne 2: Menu Links (Section 1) #}
    <div class="ps-footer__column ps-footer__column--2">
      {% if page.footer_menu_col1 %}
        <div class="ps-footer__menu">
          {{ page.footer_menu_col1 }}
        </div>
      {% endif %}
    </div>

    {# Colonne 3: Menu Links (Section 2) #}
    <div class="ps-footer__column ps-footer__column--3">
      {% if page.footer_menu_col2 %}
        <div class="ps-footer__menu">
          {{ page.footer_menu_col2 }}
        </div>
      {% endif %}
    </div>
  </div>

  {# ========== BOTTOM: Logo | Legal Menu | Copyright ========== #}
  <div class="ps-footer__bottom">
    {# Logo / Branding #}
    {% if page.footer_branding %}
      <div class="ps-footer__branding">
        {{ page.footer_branding }}
      </div>
    {% endif %}

    {# Legal Links #}
    {% if page.footer_legal %}
      <div class="ps-footer__legal">
        {{ page.footer_legal }}
      </div>
    {% endif %}

    {# Copyright #}
    {% if page.footer_copyright %}
      <div class="ps-footer__copyright">
        {{ page.footer_copyright }}
      </div>
    {% endif %}
  </div>
</footer>
