{
  "name": "ps-project-libraries",
  "version": "1.0.0",
  "description": "Third-party JavaScript libraries for PS Project Drupal site",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/ps-project.git"
  },
  "author": "PS Project Team",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "libs": "npm run libs:clean && npm run libs:copy",
    "libs:clean": "rimraf web/libraries",
    "libs:copy": "copy-files-from-to",
    "ckeditor-plugins": "cd web && ../vendor/bin/drush ckeditor_media_embed:install -y"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-media-embed": "47.6.0",
    "ace-builds": "^1.36.5",
    "clipboard": "^2.0.11",
    "dropzone": "^6.0.0-beta.2",
    "nouislider": "^15.8.1",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "copy-files-from-to": "^3.2.4",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
