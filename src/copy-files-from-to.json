{
  "copyFiles": [
    {
      "//": "--- Ace Editor Library ---",
      "from": [
        "node_modules/ace-builds/src-min-noconflict/ace.js",
        "node_modules/ace-builds/src-min-noconflict/ext-*.js",
        "node_modules/ace-builds/src-min-noconflict/mode-*.js",
        "node_modules/ace-builds/src-min-noconflict/theme-*.js",
        "node_modules/ace-builds/src-min-noconflict/worker-*.js",
        "node_modules/ace-builds/src-min-noconflict/snippets/*.js"
      ],
      "to": "web/libraries/ace/",
      "toFlat": true
    },
    {
      "//": "--- Clipboard.js Library ---",
      "from": [
        "node_modules/clipboard/dist/clipboard.min.js",
        "node_modules/clipboard/dist/clipboard.js"
      ],
      "to": "web/libraries/clipboard/",
      "toFlat": true
    },
    {
      "//": "--- Dropzone Library ---",
      "from": [
        "node_modules/dropzone/dist/dropzone-min.js",
        "node_modules/dropzone/dist/dropzone.js",
        "node_modules/dropzone/dist/dropzone.css",
        "node_modules/dropzone/dist/basic.css"
      ],
      "to": "web/libraries/dropzone/",
      "toFlat": true
    },
    {
      "//": "--- Slick Carousel Library (structure preservée) ---",
      "from": [
        "node_modules/slick-carousel/slick/**/*"
      ],
      "to": "web/libraries/slick-carousel/slick/"
    },
    {
      "//": "--- noUiSlider Library ---",
      "from": [
        "node_modules/nouislider/dist/nouislider.js",
        "node_modules/nouislider/dist/nouislider.min.js",
        "node_modules/nouislider/dist/nouislider.mjs",
        "node_modules/nouislider/dist/nouislider.min.mjs",
        "node_modules/nouislider/dist/nouislider.css",
        "node_modules/nouislider/dist/nouislider.min.css",
        "node_modules/nouislider/dist/nouislider.d.ts",
        "node_modules/nouislider/LICENSE.md",
        "node_modules/nouislider/README.md",
        "node_modules/nouislider/package.json"
      ],
      "to": "web/libraries/nouislider/",
      "toFlat": true
    },
    {
      "//": "--- Swiper 11 (hero carousel) ---",
      "from": [
        "node_modules/swiper/swiper-bundle.min.js",
        "node_modules/swiper/swiper-bundle.min.css"
      ],
      "to": "web/libraries/swiper/",
      "toFlat": true
    },
    {
      "//": "--- PhotoSwipe 5 (zoom lightbox) ---",
      "from": [
        "node_modules/photoswipe/dist/photoswipe.css",
        "node_modules/photoswipe/dist/umd/photoswipe.umd.min.js",
        "node_modules/photoswipe/dist/umd/photoswipe-lightbox.umd.min.js"
      ],
      "to": "web/libraries/photoswipe/",
      "toFlat": true
    },
    {
      "//": "--- Bootstrap (ui_suite_bnp theme dependency) ---",
      "from": [
        "web/themes/custom/ui_suite_bnp/node_modules/bootstrap/**/*"
      ],
      "to": "web/libraries/bootstrap/"
    },
    {
      "//": "--- CKEditor 5 Media Embed Plugin (structure préservée) ---",
      "from": [
        "node_modules/@ckeditor/ckeditor5-media-embed/**/*"
      ],
      "to": "web/libraries/ckeditor5/plugins/media-embed/"
    }
  ],
  "settings": {
    "whenFileExists": "overwrite"
  }
}
