APP_ENV=dev

## For DevX Only — replaced when running: make env (or scripts/main.sh tools setup-env)
USER_UID={USER_UID}

## Database
DB_USER=drupal
DB_PASSWORD=drupal
DB_HOST=postgres
DB_PORT=5432

### Database names (USER_UID substituted from template)
DB_NAME_COM={USER_UID}_psv2_com_db
DB_NAME_BE={USER_UID}_psv2_be_db
DB_NAME_ES={USER_UID}_psv2_es_db
DB_NAME_FR={USER_UID}_psv2_fr_db
DB_NAME_IE={USER_UID}_psv2_ie_db
DB_NAME_IT={USER_UID}_psv2_it_db
DB_NAME_LU={USER_UID}_psv2_lu_db
DB_NAME_NL={USER_UID}_psv2_nl_db
DB_NAME_PL={USER_UID}_psv2_pl_db

## Memcached (legacy typo CHACHE_HOST still read in bootstrap)
CACHE_HOST=memcache

## Solr
SOLR_HOST=solr
SOLR_PORT=8983
SOLR_PATH=/
SOLR_CORE_COM={USER_UID}_ps_core_com_db
SOLR_CORE_BE={USER_UID}_ps_core_be_db
SOLR_CORE_ES={USER_UID}_ps_core_es_db
SOLR_CORE_FR={USER_UID}_ps_core_fr_db
SOLR_CORE_IE={USER_UID}_ps_core_ie_db
SOLR_CORE_IT={USER_UID}_ps_core_it_db
SOLR_CORE_LU={USER_UID}_ps_core_lu_db
SOLR_CORE_NL={USER_UID}_ps_core_nl_db
SOLR_CORE_PL={USER_UID}_ps_core_pl_db

## Directories — per country by default (never shared across multisites)
APP_ASSETS_PATH=
# Optional global base → {base}/{country}  e.g. APP_PUBLIC_PATH=/var/ps/files → /var/ps/files/fr
APP_PUBLIC_PATH=
# Optional per-country override: APP_PUBLIC_PATH_FR, APP_PRIVATE_PATH_FR, etc.
APP_PRIVATE_PATH=
APP_TEMP_PATH=

## Proxy
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
HTTPS_VERIFY=0

## Google Maps (optional — geofield_map + geocoder at install)
GOOGLE_MAPS_API_KEY=

## Applications Domains
APP_DOMAIN_SERVICE=localhost
APP_DOMAIN_PROBES=localhost

### Master Domain (COM)
APP_DOMAIN_COM=com.localhost
APP_DOMAIN_COM_ADMIN=admin.com.localhost
APP_DOMAIN_COM_PORT=8080

### Belgium Domain (BE)
APP_DOMAIN_BE=be.localhost
APP_DOMAIN_BE_ADMIN=admin.be.localhost
APP_DOMAIN_BE_PORT=8080

### Spain Domain (ES)
APP_DOMAIN_ES=es.localhost
APP_DOMAIN_ES_ADMIN=admin.es.localhost
APP_DOMAIN_ES_PORT=8080

### French Domain (FR)
APP_DOMAIN_FR=fr.localhost
APP_DOMAIN_FR_ADMIN=admin.fr.localhost
APP_DOMAIN_FR_PORT=8080

### Ireland Domain (IE)
APP_DOMAIN_IE=ie.localhost
APP_DOMAIN_IE_ADMIN=admin.ie.localhost
APP_DOMAIN_IE_PORT=8080

### Italy Domain (IT)
APP_DOMAIN_IT=it.localhost
APP_DOMAIN_IT_ADMIN=admin.it.localhost
APP_DOMAIN_IT_PORT=8080

### Luxembourg Domain (LU)
APP_DOMAIN_LU=lu.localhost
APP_DOMAIN_LU_ADMIN=admin.lu.localhost
APP_DOMAIN_LU_PORT=8080

### Netherland Domain (NL)
APP_DOMAIN_NL=nl.localhost
APP_DOMAIN_NL_ADMIN=admin.nl.localhost
APP_DOMAIN_NL_PORT=8080

### Poland Domain (PL)
APP_DOMAIN_PL=pl.localhost
APP_DOMAIN_PL_ADMIN=admin.pl.localhost
APP_DOMAIN_PL_PORT=8080
