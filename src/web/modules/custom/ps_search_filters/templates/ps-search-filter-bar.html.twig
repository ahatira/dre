{#
/**
 * @file
 * BNPPRE search filter bar — desktop popins + mobile unified offcanvas.
 *
 * Breakpoint: lg (992px) — see ps-search-filters-mobile.css decisions.
 */
#}
{% set type_value %}
  {%- if active_asset_label and active_op_label -%}
    {{ active_asset_label }} {{ active_op_label|lower }}
  {%- elseif active_asset_label -%}
    {{ active_asset_label }}
  {%- elseif active_op_label -%}
    {{ active_op_label }}
  {%- else -%}
    {{ 'Property type'|t }}
  {%- endif -%}
{% endset %}

<div class="ps-search-filters-root">

  {# ── Desktop filter bar (≥ lg) — Figma Frame 41 #}
  <div class="ps-filter-bar ps-filter-bar--desktop d-none d-lg-grid" role="search" aria-label="{{ 'Property search filters'|t }}">

    <div class="dropdown ps-filter-bar__item ps-filter-bar__item--type" data-ps-htmx-popin="type">
      <label class="form-label ps-filter-bar__field-label text-nowrap" for="ps-filter-type-trigger">
        {{ 'Property type'|t }}
      </label>
      <button
        id="ps-filter-type-trigger"
        class="ps-filter-bar__toggle d-flex align-items-center w-100{% if active_op or active_asset %} is-active{% endif %}"
        type="button"
        data-bs-toggle="dropdown"
        data-bs-auto-close="outside"
        aria-expanded="false"
      >
        <span class="ps-filter-bar__toggle-label text-truncate">{{ type_value }}</span>
        <span class="ps-filter-bar__chevron flex-shrink-0" aria-hidden="true"></span>
      </button>

      <div class="dropdown-menu ps-filter-popin ps-filter-popin--type">
        {% include '@ps_search_filters/ps-search-filter-section-type-fields.twig' %}
        <div class="ps-filter-popin__footer ps-filter-popin__footer--type">
          <button class="ps-apply-btn ps-apply-btn--full js-ps-apply-btn js-ps-apply-btn--type" type="button" disabled data-ps-htmx-apply="type">
            {{ 'Show'|t }}
            <span id="ps-filter-type-count-label" class="js-ps-count-label js-ps-count-label--htmx-type">…</span>
            {{ 'results'|t }}
            <span class="ps-apply-btn__loader" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </div>

    <div class="dropdown ps-filter-bar__item ps-filter-bar__item--location" data-ps-htmx-popin="location">
      <label class="form-label ps-filter-bar__field-label text-nowrap" for="ps-filter-location-input">
        {{ 'Location(s)'|t }}
      </label>
      {% include '@ps_search_filters/ps-search-filter-section-location-fields.twig' with {
        id_suffix: '',
        layout: 'dropdown',
      } only %}

      <div class="dropdown-menu ps-filter-popin ps-filter-popin--location">
        <div class="ps-location-popin__selected js-ps-location-selected-panel" hidden>
          <h3 class="ps-filter-popin__heading ps-location-popin__heading">{{ 'Location'|t }} :</h3>
          <div class="ps-location-popin__chips js-ps-location-popin-chips"></div>
        </div>
        <div id="ps-location-suggest" class="ps-filter-bar__location-suggest js-ps-location-suggest" role="listbox" hidden></div>
        <div class="ps-filter-popin__footer ps-filter-popin__footer--location">
          <button class="ps-apply-btn ps-apply-btn--full js-ps-location-apply js-ps-apply-btn js-ps-apply-btn--location" type="button" disabled data-ps-htmx-apply="location">
            {{ 'Show'|t }}
            <span id="ps-filter-location-count-label" class="js-ps-count-label js-ps-count-label--htmx-location">…</span>
            {{ 'results'|t }}
            <span class="ps-apply-btn__loader" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </div>

    <div class="dropdown ps-filter-bar__item ps-filter-bar__item--surface js-ps-surface-item" data-ps-htmx-popin="surface"{% if not show_surface_filter %} hidden{% endif %}>
      <label class="form-label ps-filter-bar__field-label text-nowrap js-ps-surface-field-label" for="ps-filter-surface-trigger">
        {{ 'Surface (m²)'|t }}
      </label>
      <button
        id="ps-filter-surface-trigger"
        class="ps-filter-bar__toggle d-flex align-items-center w-100"
        type="button"
        data-bs-toggle="dropdown"
        data-bs-auto-close="outside"
        aria-expanded="false"
      >
        <span class="ps-filter-bar__toggle-label js-ps-surface-label text-truncate">{{ 'Surface'|t }}</span>
        <span class="ps-filter-bar__chevron flex-shrink-0" aria-hidden="true"></span>
      </button>
      <div class="dropdown-menu ps-filter-popin ps-filter-popin--surface ps-filter-popin--range">
        {% include '@ps_search_filters/ps-search-filter-section-range-fields.twig' with { section: 'surface', id_suffix: '' } only %}
        <div class="ps-filter-popin__footer ps-filter-popin__footer--range">
          <button class="ps-filter-clear js-ps-section-clear" type="button" data-section="surface">{{ 'Delete all'|t }}</button>
          <button class="ps-apply-btn js-ps-apply-btn js-ps-apply-btn--surface" type="button" disabled data-ps-htmx-apply="surface">
            {{ 'Show'|t }}
            <span id="ps-filter-surface-count-label" class="js-ps-count-label js-ps-count-label--htmx-surface">…</span>
            {{ 'results'|t }}
          </button>
        </div>
      </div>
    </div>

    <div class="dropdown ps-filter-bar__item ps-filter-bar__item--capacity js-ps-capacity-item" data-ps-htmx-popin="capacity"{% if not show_capacity_filter %} hidden{% endif %}>
      <label class="form-label ps-filter-bar__field-label js-ps-capacity-field-label" for="ps-filter-capacity-trigger">
        {{ capacity_filter_label|capitalize }}
      </label>
      <button
        id="ps-filter-capacity-trigger"
        class="ps-filter-bar__toggle d-flex align-items-center w-100"
        type="button"
        data-bs-toggle="dropdown"
        data-bs-auto-close="outside"
        aria-expanded="false"
      >
        <span class="ps-filter-bar__toggle-label js-ps-capacity-label text-truncate">{{ capacity_filter_label|capitalize }}</span>
        <span class="ps-filter-bar__chevron flex-shrink-0" aria-hidden="true"></span>
      </button>
      <div class="dropdown-menu ps-filter-popin ps-filter-popin--capacity ps-filter-popin--range">
        {% include '@ps_search_filters/ps-search-filter-section-range-fields.twig' with {
          section: 'capacity',
          id_suffix: '',
          capacity_filter_label: capacity_filter_label,
        } only %}
        <div class="ps-filter-popin__footer ps-filter-popin__footer--range">
          <button class="ps-filter-clear js-ps-section-clear" type="button" data-section="capacity">{{ 'Delete all'|t }}</button>
          <button class="ps-apply-btn js-ps-apply-btn js-ps-apply-btn--capacity" type="button" disabled data-ps-htmx-apply="capacity">
            {{ 'Show'|t }}
            <span id="ps-filter-capacity-count-label" class="js-ps-count-label js-ps-count-label--htmx-capacity">…</span>
            {{ 'results'|t }}
          </button>
        </div>
      </div>
    </div>

    <div class="dropdown ps-filter-bar__item ps-filter-bar__item--budget" data-ps-htmx-popin="budget">
      <label class="form-label ps-filter-bar__field-label text-nowrap js-ps-budget-field-label" for="ps-filter-budget-trigger">
        {{ budget_config.field_label|default('Budget'|t) }}
      </label>
      <button
        id="ps-filter-budget-trigger"
        class="ps-filter-bar__toggle d-flex align-items-center w-100"
        type="button"
        data-bs-toggle="dropdown"
        data-bs-auto-close="outside"
        aria-expanded="false"
      >
        <span class="ps-filter-bar__toggle-label js-ps-budget-label text-truncate">{{ budget_config.toggle_default|default('Budget'|t) }}</span>
        <span class="ps-filter-bar__chevron flex-shrink-0" aria-hidden="true"></span>
      </button>
      <div class="dropdown-menu ps-filter-popin ps-filter-popin--budget ps-filter-popin--range">
        {% include '@ps_search_filters/ps-search-filter-section-range-fields.twig' with {
          section: 'budget',
          id_suffix: '',
          budget_config: budget_config,
        } only %}
        <div class="ps-filter-popin__footer ps-filter-popin__footer--range">
          <button class="ps-filter-clear js-ps-section-clear" type="button" data-section="budget">{{ 'Delete all'|t }}</button>
          <button class="ps-apply-btn js-ps-apply-btn js-ps-apply-btn--budget" type="button" disabled data-ps-htmx-apply="budget">
            {{ 'Show'|t }}
            <span id="ps-filter-budget-count-label" class="js-ps-count-label js-ps-count-label--htmx-budget">…</span>
            {{ 'results'|t }}
          </button>
        </div>
      </div>
    </div>

    <div class="ps-filter-bar__item ps-filter-bar__item--more">
      <button
        class="btn btn-outline-primary ps-filter-bar__toggle ps-filter-bar__toggle--more d-inline-flex align-items-center js-ps-more-trigger"
        type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#ps-more-offcanvas"
        aria-controls="ps-more-offcanvas"
      >
        <span class="ps-filter-bar__toggle-label js-ps-more-label">{{ 'More filters'|t }}</span>
        <span class="ps-filter-bar__chevron ps-filter-bar__chevron--primary flex-shrink-0" aria-hidden="true"></span>
      </button>
    </div>

  </div>

  <div class="ps-filter-bar-backdrop js-ps-filter-bar-backdrop d-none d-lg-block" hidden aria-hidden="true"></div>

  {# Desktop — More filters offcanvas (≥ lg) #}
  <div class="offcanvas offcanvas-end ps-more-offcanvas" tabindex="-1" id="ps-more-offcanvas" aria-labelledby="ps-more-offcanvas-label" data-bs-scroll="false">
    <div class="offcanvas-header border-bottom">
      <h2 class="offcanvas-title h6 fw-bold mb-0" id="ps-more-offcanvas-label">{{ 'More filters'|t }}</h2>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'Close'|t }}"></button>
    </div>

    <div class="offcanvas-body">
      {% include '@ps_search_filters/ps-search-filter-section-more-accordion.twig' with {
        accordion_id: 'ps-more-accordion',
      } %}
    </div>

    <div class="offcanvas-footer ps-filter-popin__footer border-top">
      <button class="ps-filter-clear js-ps-section-clear" type="button" data-section="more">{{ 'Clear'|t }}</button>
      <button class="ps-apply-btn js-ps-apply-btn" type="button" disabled>
        {{ 'Show'|t }} <span id="ps-filter-more-count-label" class="js-ps-count-label js-ps-count-label--htmx-more">…</span> {{ 'results'|t }}
      </button>
    </div>
  </div>

  {# Mobile — unified filters offcanvas (< lg) — maquette Filters.png #}
  <div class="offcanvas offcanvas-end ps-mobile-filters-offcanvas" tabindex="-1" id="ps-mobile-filters" aria-labelledby="ps-mobile-filters-label" data-bs-scroll="false" data-ps-htmx-popin="mobile">
    <div class="offcanvas-header border-bottom">
      <h2 class="offcanvas-title h6 fw-bold mb-0" id="ps-mobile-filters-label">{{ 'Filter'|t }}</h2>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'Close'|t }}"></button>
    </div>

    <div class="offcanvas-body ps-mobile-filters-offcanvas__body">
      {% include '@ps_search_filters/ps-search-filter-mobile-offcanvas-body.twig' %}
    </div>

    <div class="offcanvas-footer ps-filter-popin__footer ps-mobile-filters-offcanvas__footer border-top">
      <button class="ps-filter-clear js-ps-mobile-reset-all" type="button">{{ 'Reset'|t }}</button>
      <button class="ps-apply-btn js-ps-apply-btn js-ps-mobile-apply js-ps-apply-btn--mobile" type="button" disabled data-ps-htmx-apply="mobile">
        {{ 'Show'|t }}
        <span id="ps-filter-mobile-count-label" class="js-ps-count-label js-ps-count-label--htmx-mobile">…</span>
        {{ 'results'|t }}
      </button>
    </div>
  </div>

</div>
