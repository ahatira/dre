{#
/**
 * @file
 * Highlighted availability dates block for schedule_visit emails.
 *
 * Variables: title, dates (list of formatted date strings).
 */
#}
{% set green = email_primary_color|default('#00915a') %}
{% set secondary = email_secondary_color|default('#ba3075') %}
{% set text = email_text_color|default('#333333') %}
{% set border = email_border_color|default('#ebedef') %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="ps-schedule-visit-availabilities-email-block" style="margin:0 0 24px;border:1px solid {{ border }};border-collapse:collapse;width:100%;">
  <tr>
    <td colspan="2" style="padding:12px 16px;background:{{ green }};font-size:13px;font-weight:700;line-height:1.4;color:#ffffff;text-transform:uppercase;letter-spacing:0.04em;">
      {{ title }}
    </td>
  </tr>
  {% for date in dates %}
    <tr>
      <td width="28" valign="middle" style="padding:12px 0 12px 16px;border-bottom:1px solid {{ border }};background:#ffffff;font-size:16px;line-height:1;color:{{ secondary }};font-weight:700;">
        &#9679;
      </td>
      <td valign="middle" style="padding:12px 16px 12px 0;border-bottom:1px solid {{ border }};background:#ffffff;font-size:15px;line-height:1.5;font-weight:600;color:{{ text }};">
        {{ date }}
      </td>
    </tr>
  {% endfor %}
</table>
