{#
/**
 * @file
 * Table-safe snapshot recap for offer webform emails.
 *
 * Variables: rows (list of {label, value}).
 */
#}
{% set green = email_primary_color|default('#00915a') %}
{% set text = email_text_color|default('#333333') %}
{% set muted = email_muted_color|default('#777e83') %}
{% set border = email_border_color|default('#ebedef') %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="ps-offer-snapshot-email-recap" style="margin:0 0 24px;border:1px solid {{ border }};border-collapse:collapse;width:100%;">
  <tr>
    <td colspan="2" style="padding:12px 16px;background:#f9f9fb;border-bottom:1px solid {{ border }};font-size:13px;font-weight:700;line-height:1.4;color:{{ green }};text-transform:uppercase;letter-spacing:0.04em;">
      {{ 'Offer snapshot'|t }}
    </td>
  </tr>
  {% for row in rows %}
    <tr>
      <th scope="row" width="38%" valign="top" style="padding:10px 16px;border-bottom:1px solid {{ border }};font-size:13px;line-height:1.5;font-weight:600;color:{{ muted }};text-align:left;background:#ffffff;">
        {{ row.label }}
      </th>
      <td valign="top" style="padding:10px 16px;border-bottom:1px solid {{ border }};font-size:13px;line-height:1.5;color:{{ text }};word-break:break-word;">
        {{ row.value }}
      </td>
    </tr>
  {% endfor %}
</table>
