{#
/**
 * @file
 * Market study card — bnppre floating text box pattern (§8).
 */
#}
<article class="ps-market-study-card">
  {% if image %}
    <div class="ps-market-study-card__media">
      {% if url %}
        <a href="{{ url }}" class="ps-market-study-card__media-link"{% if url_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}>
      {% endif %}
      <img src="{{ image }}" alt="{{ image_alt|default(title) }}" class="ps-market-study-card__image" loading="lazy" />
      {% if url %}
        </a>
      {% endif %}
    </div>
  {% endif %}
  <div class="ps-market-study-card__body">
    {% if category %}
      <div class="ps-market-study-card__category">
        {% if category_url %}
          <a href="{{ category_url }}" class="ps-market-study-card__category-link">{{ category }}</a>
        {% else %}
          <span class="ps-market-study-card__category-label">{{ category }}</span>
        {% endif %}
      </div>
    {% endif %}
    {% if title %}
      <h3 class="ps-market-study-card__title">
        {% if url %}
          <a href="{{ url }}" class="ps-market-study-card__title-link"{% if url_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ title }}</a>
        {% else %}
          {{ title }}
        {% endif %}
      </h3>
    {% endif %}
    {% if date %}
      <p class="ps-market-study-card__date">
        {% if url %}
          <a href="{{ url }}" class="ps-market-study-card__date-link"{% if url_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ 'Published on'|t }} {{ date }}</a>
        {% else %}
          <span>{{ 'Published on'|t }} {{ date }}</span>
        {% endif %}
      </p>
    {% endif %}
  </div>
</article>
