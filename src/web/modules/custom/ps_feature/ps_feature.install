<?php

/**
 * @file
 * Install hooks for ps_feature module.
 */

declare(strict_types=1);

/**
 * Installs the entity_offer_feature content entity schema.
 */
function ps_feature_install(): void {
  $entity_type = \Drupal::entityTypeManager()->getDefinition('entity_offer_feature');
  \Drupal::entityDefinitionUpdateManager()->installEntityType($entity_type);
}
