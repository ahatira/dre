{
  "name": "drupal/bnp_editor",
  "description": "Enhanced CKEditor 5 configuration with contrib plugins for BNP property search platform.",
  "type": "drupal-custom-module",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "Drupal",
    "CKEditor",
    "WYSIWYG",
    "Editor",
    "BNP"
  ],
  "homepage": "https://github.com/bnppre/ps_project",
  "support": {
    "issues": "https://github.com/bnppre/ps_project/issues",
    "source": "https://github.com/bnppre/ps_project"
  },
  "require": {
    "php": ">=8.3",
    "drupal/core": "^11.0",
    "drupal/node": "^11.0",
    "drupal/editor": "^11.0",
    "drupal/ckeditor5": "^11.0",
    "drupal/filter": "^11.0",
    "drupal/media": "^11.0",
    "drupal/media_library": "^11.0",
    "drupal/ace_editor": "*",
    "drupal/anchor_link": "*",
    "drupal/ckeditor_bidi": "*",
    "drupal/ckeditor_emoji": "*",
    "drupal/ckeditor5_paste_filter": "*",
    "drupal/ckeditor5_plugin_pack": "*",
    "drupal/ckeditor_media_embed": "*",
    "drupal/ckeditor_media_resize": "*",
    "drupal/edit_media_modal": "*",
    "drupal/editor_advanced_link": "*",
    "drupal/entity_embed": "*",
    "drupal/linkit": "*",
    "drupal/pathologic": "*",
    "drupal/token_filter": "*"
  },
  "suggest": {
    "drupal/blazy": "^3.0 - Lazy loading for images and media (optional enhancement)",
    "drupal/slick": "^3.0 - Carousel/slider for media (optional enhancement)"
  },
  "require-dev": {
    "drupal/core-dev": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Drupal\\bnp_editor\\": "src/"
    }
  },
  "extra": {
    "drush": {
      "services": {
        "drush.services.yml": "^11"
      }
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
