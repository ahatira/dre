msgid "BNP Editor"
msgstr "Éditeur BNP"

msgid "BNP Editor Settings"
msgstr "Paramètres de l'éditeur BNP"

msgid "Configure CKEditor settings and plugins for BNP platform."
msgstr "Configurer les paramètres et plugins CKEditor pour la plateforme BNP."

msgid "General Settings"
msgstr "Paramètres généraux"

msgid "Enable custom CKEditor plugins"
msgstr "Activer les plugins CKEditor personnalisés"

msgid "Enable custom plugins developed for BNP platform."
msgstr "Activer les plugins personnalisés développés pour la plateforme BNP."

msgid "Enable media embed"
msgstr "Activer l'intégration de médias"

msgid "Allow embedding media items in rich text content."
msgstr "Autoriser l'intégration d'éléments média dans le contenu riche."

msgid "Plugin Configuration"
msgstr "Configuration des plugins"

msgid "Allowed link protocols"
msgstr "Protocoles de liens autorisés"

msgid "Enter one protocol per line (e.g., http, https, mailto, tel)."
msgstr "Entrez un protocole par ligne (ex: http, https, mailto, tel)."

msgid "Enable custom plugins"
msgstr "Activer les plugins personnalisés"

msgid "Enable media embed"
msgstr "Activer l'intégration média"

msgid "Full HTML"
msgstr "HTML complet"

msgid "Basic HTML"
msgstr "HTML de base"

msgid "Restricted HTML"
msgstr "HTML restreint"

msgid "Plain text"
msgstr "Texte brut"

msgid "Use Full HTML text format"
msgstr "Utiliser le format HTML complet"

msgid "Access to Full HTML format with complete CKEditor capabilities."
msgstr "Accès au format HTML complet avec toutes les fonctionnalités CKEditor."

msgid "Use Basic HTML text format"
msgstr "Utiliser le format HTML de base"

msgid "Access to Basic HTML format with standard editing tools."
msgstr "Accès au format HTML de base avec les outils d'édition standards."

msgid "Use Restricted HTML text format"
msgstr "Utiliser le format HTML restreint"

msgid "Access to Restricted HTML format (limited tags)."
msgstr "Accès au format HTML restreint (balises limitées)."

msgid "Use Plain text format"
msgstr "Utiliser le format texte brut"

msgid "Access to Plain text format (no HTML)."
msgstr "Accès au format texte brut (sans HTML)."
