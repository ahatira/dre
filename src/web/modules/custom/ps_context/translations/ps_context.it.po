msgstr "Stato"

msgid "Tab"
msgstr "Scheda"

msgid "Tabs"
msgstr "Schede"

msgid "Target (field or tab machine name)"
msgstr "Target (nome macchina del campo o della scheda)"

msgid "The delta value for \"Hide surface row\" must be a positive integer (e"
".g. 1 for DISPO, 2 for ETREF)."
msgstr "Il valore delta per «Nascondi riga superficie» deve essere un intero p"
"ositivo (es. 1 per DISPO, 2 per ETREF)."

msgid "UUID"
msgstr "UUID"

