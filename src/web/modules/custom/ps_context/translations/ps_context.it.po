msgstr "Nascondi scheda"

msgid "Implements the offer form matrix rules engine: conditional field visib"
"ility driven by asset_type × operation_type × field_divisible."
msgstr "Implementa il motore di regole a matrice del modulo offerta: visibilit"
"à condizionale dei campi guidata da asset_type × operation_type × fiel"
"d_divisible."

msgid "LOC + COW: Set price unit to PER_POSTE"
msgstr "LOC + COW: imposta unità prezzo su PER_POSTE"

msgid "LOC: Set price period to YEAR"
msgstr "LOC: imposta periodo prezzo su YEAR"

msgid "LOC: Set price unit to PER_M2"
msgstr "LOC: imposta unità prezzo su PER_M2"

msgid "Label"
msgstr "Etichetta"

msgid "Leave empty to make this rule always apply (unconditional)."
msgstr "Lasciare vuoto per applicare sempre questa regola (incondizionata)."

msgid "Machine name"
msgstr "Nome macchina"

msgid "Make optional"
msgstr "Rendi facoltativo"

msgid "Make required"
msgstr "Rendi obbligatorio"

msgid "Matrix rules"
msgstr "Regole matrice"

msgid "Max budget (€)"
msgstr "Prezzo max (€)"

msgid "Max price (€)"
msgstr "Prezzo massimo (€)"

msgid "Max rent (€/m²/year)"
msgstr "Canone max (€/m²/anno)"

msgid "Max rent (€/seat/year)"
msgstr "Canone max (€/postazione/anno)"

