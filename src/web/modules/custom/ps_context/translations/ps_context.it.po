msgid "Rule %label has no valid actions and will have no effect."
msgstr "La regola %label non ha azioni valide e non avrà alcun effetto."

msgid "Rules with lower weight are evaluated first. When two rules affect the"
" same element, the last evaluated wins."
msgstr "Le regole con peso inferiore vengono valutate per prime. Quando due re"
"gole influenzano lo stesso elemento, prevale l'ultima valutata."

msgid "Set default value"
msgstr "Imposta valore predefinito"

msgid "Show field"
msgstr "Mostra campo"

msgid "Show tab"
msgstr "Mostra scheda"

