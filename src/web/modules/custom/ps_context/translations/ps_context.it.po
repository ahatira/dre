msgstr "Logica delle condizioni (E/O)"

msgid "Configure offer form field visibility rules (conditional rules engine)"
"."
msgstr "Configurare le regole di visibilità dei campi del modulo offerta (moto"
"re di regole condizionali)."

msgid "Configure the offer form field visibility matrix rules."
msgstr "Configurare le regole della matrice di visibilità dei campi del modulo"
" offerta."

msgid "Context rule"
msgstr "Regola di contesto"

msgid "Context rules"
msgstr "Regole di contesto"

msgid "Created context rule %label."
msgstr "Regola di contesto %label creata."

msgid "Default: Hide Capacity tab"
msgstr "Predefinito: nascondi scheda Capacità"

msgid "Default: Hide Lots tab"
msgstr "Predefinito: nascondi scheda Lotti"

msgid "Default: Hide Price tab"
msgstr "Predefinito: nascondi scheda Prezzo"

msgid "Default: Hide Surface tab"
msgstr "Predefinito: nascondi scheda Superficie"

msgid "Default: Set price currency to EUR"
msgstr "Predefinito: imposta la valuta del prezzo su EUR"

msgid "Disable field"
msgstr "Disabilita campo"

msgid "Disabled"
msgstr "Disabilitato"

msgid "Divisible: Show Lots tab"
msgstr "Divisibile: mostra scheda Lotti"

msgid "E.g. BUR, COW, ENT, ACT, COM, TER (asset type) · LOC, VEN (operation t"
"ype) · 1 / 0 (checkbox)."
msgstr "Es.: BUR, COW, ENT, ACT, COM, TER (tipo asset) · LOC, VEN (tipo operaz"
"ione) · 1 / 0 (casella di controllo)."

msgid "Enabled"
msgstr "Abilitato"

msgid "Expected value"
msgstr "Valore atteso"

msgid "Field"
msgstr "Campo"

msgid "Field machine name"
msgstr "Nome macchina del campo"

msgid "Fields"
msgstr "Campi"

msgid "For \"Set default value\": value to fill in. For \"Hide surface row\":"
" delta index (1 = DISPO, 2 = ETREF)."
msgstr "Per «Imposta valore predefinito»: valore da compilare. Per «Nascondi r"
"iga superficie»: indice delta (1 = DISPO, 2 = ETREF)."

msgid "Hide field"
msgstr "Nascondi campo"

msgid "Hide surface row (delta)"
msgstr "Nascondi riga superficie (delta)"

