{#
/**
 * @file
 * PS search offers list — promo card slots (Bootstrap grid compatible).
 */
#}
{% for row in rows %}
  {%
    set row_classes = [
      default_row_class ? 'views-row',
      'col-12',
    ]
  %}
  <div{{ row.attributes.addClass(row_classes) }}>
    {{- row.content -}}
  </div>
  {% if promo_card_slots[loop.index] is defined %}
    <div class="col-12 promo-card-slot">
      {{ promo_card_slots[loop.index] }}
    </div>
  {% endif %}
{% endfor %}
