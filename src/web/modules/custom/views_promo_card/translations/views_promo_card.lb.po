msgstr "Wéi et funktionéiert"

msgid "Inject promotional SDC cards into Views search result lists (for example offer grids). Create reusable cards, attach them to view displays via placements, and control position, rotation, and visibility conditions."
msgstr "Injectez des cartes promotionnelles SDC dans les listes de resultats Views (grilles d'offres par exemple). Creez des cartes reutilisables, associez-les aux affichages via des emplacements, et controlez position, rotation et conditions de visibilite."

msgid "Injects composable promotional cards between Views result rows."
msgstr "Injecte des cartes promotionnelles composables entre les lignes de resultats Views."

msgid "Insert after row (fixed)"
msgstr "Inserer apres la ligne (fixe)"

msgid "Interstitial search card promoting the surface area calculator."
msgstr "Carte interstitielle de recherche promouvant le calculateur de surface."

msgid "Interval starts at row"
msgstr "L'intervalle commence a la ligne"

msgid "Label"
msgstr "Libelle"

msgid "Leave empty to ignore this condition."
msgstr "Laisser vide pour ignorer cette condition."

msgid "Leave empty to match any value for the parameter."
msgstr "Laisser vide pour accepter toute valeur du parametre."

