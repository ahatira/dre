<?php

declare(strict_types=1);

/**
 * @file
 * Module pour la fonctionnalité « Delegate my search ».
 */

/**
 * Implements hook_theme().
 */
function ps_delegate_search_theme($existing, $type, $theme, $path) {
  return [
    'delegate_search_modal' => [
      'template' => 'templates/delegate-search-modal',
      'render element' => 'form',
    ],
  ];
}
