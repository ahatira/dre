msgid "+ Add division"
msgstr "+ Ajouter une division"

msgid "Administer PS surface entities"
msgstr "Administrer les entités de surface PS"

msgid "Availability"
msgstr "Disponibilité"

msgid "Available"
msgstr "Disponible"

msgid "Business identifier for the division."
msgstr "Identifiant métier de la division."

msgid "Changed"
msgstr "Modifié"

