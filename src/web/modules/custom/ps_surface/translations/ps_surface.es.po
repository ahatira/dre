msgid "+ Add division"
msgstr "+ Añadir división"

msgid "Administer PS surface entities"
msgstr "Administrar entidades de superficie PS"

msgid "Availability"
msgstr "Disponibilidad"

msgid "Available"
msgstr "Disponible"

msgid "Business identifier for the division."
msgstr "Identificador de negocio para la división."

msgid "Changed"
msgstr "Modificado"

msgid "Created"
msgstr "Creado"

msgid "DISPO surface (@dispo m²) exceeds TOTAL surface (@total m²). Available"
" surface cannot be greater than total."
msgstr "La superficie DISPO (@dispo m²) supera la superficie TOTAL (@total m²)"
". La superficie disponible no puede ser mayor que la total."

msgid "Define the qualified surface values for this division. TOTAL is the to"
"tal area, DISPO is the available area, and ETREF is the reference surf"
"ace (ERP regulations)."
msgstr "Defina los valores de superficie cualificada para esta división. TOTAL"
" es la superficie total, DISPO es la superficie disponible y ETREF es "
"la superficie de referencia (normativa ERP)."

msgid "Division label"
msgstr "Etiqueta de la división"

msgid "Division reference"
msgstr "Referencia de la división"

msgid "Division status"
msgstr "Estado de la división"

msgid "ETREF surface (@etref m²) exceeds TOTAL surface (@total m²). ETREF sho"
"uld be less than or equal to TOTAL."
msgstr "La superficie ETREF (@etref m²) supera la superficie TOTAL (@total m²)"
". ETREF debe ser menor o igual que TOTAL."

msgid "Floor"
msgstr "Planta"

msgid "Floor level for the division (e.g. RDC, R+5)."
msgstr "Nivel de planta para la división (p. ej., RDC, R+5)."

msgid "Human readable label for the division."
msgstr "Etiqueta legible para humanos de la división."

msgid "Label"
msgstr "Etiqueta"

msgid "Linked offers"
msgstr "Ofertas vinculadas"

msgid "Lot"
msgstr "Lote"

msgid "Manage surface division entities and configuration."
msgstr "Gestionar divisiones de superficie y configuración."

msgid "Nature"
msgstr "Naturaleza"

msgid "Nature or usage label for the division (e.g. Bureaux)."
msgstr "Etiqueta de naturaleza o uso para la división (p. ej., Oficinas)."

msgid "Operational status of the division."
msgstr "Estado operativo de la división."

msgid "PS surface item"
msgstr "Elemento de superficie PS"

msgid "PS surface — Compare table"
msgstr "PS superficie — Tabla de comparación"

msgid "PS surface — Contextual (matrix-driven)"
msgstr "PS superficie — Contextual (dirigido por matriz)"

msgid "PS surface — Offer (TOTAL / DISPO / ETREF / MINIM)"
msgstr "PS superficie — Oferta (TOTAL / DISPO / ETREF / MINIM)"

msgid "Partial"
msgstr "Parcial"

msgid "Qualification"
msgstr "Calificación"

msgid "Qualification code"
msgstr "Código de calificación"

msgid "Qualified surface values attached to this division."
msgstr "Valores de superficie cualificada asociados a esta división."

msgid "Raw availability text imported from external systems. This is for refe"
"rence only."
msgstr "Texto bruto de disponibilidad importado de sistemas externos. Solo par"
"a referencia."

msgid "Reference"
msgstr "Referencia"

msgid "Select a qualification code from dictionary entries."
msgstr "Seleccione un código de calificación de las entradas del diccionario."

msgid "Select the operational status of this division based on its availabili"
"ty."
msgstr "Seleccione el estado operativo de esta división según su disponibilida"
"d."

msgid "Sort by @column, currently @direction."
msgstr "Ordenar por @column, actualmente @direction."

msgid "Sort by @column."
msgstr "Ordenar por @column."

msgid "Status"
msgstr "Estado"

msgid "Stores a qualified physical surface item."
msgstr "Almacena un elemento de superficie física cualificada."

msgid "Surface"
msgstr "Superficie"

msgid "Surface @qual has negative value (@value). Negative surfaces are not a"
"llowed."
msgstr "La superficie @qual tiene un valor negativo (@value). No se permiten s"
"uperficies negativas."

msgid "Surface division"
msgstr "División de superficie"

msgid "Surface division table"
msgstr "Tabla de división de superficie"

msgid "Surface divisions"
msgstr "Divisiones de superficie"

msgid "Surface domain foundation for divisions, projections, and governance p"
"olicies."
msgstr "Fundamento del dominio de superficie para divisiones, proyecciones y p"
"olíticas de gobernanza."

msgid "Surface table"
msgstr "Tabla de superficies"

msgid "Surfaces"
msgstr "Superficies"

msgid "Unavailable"
msgstr "No disponible"

msgid "Unit"
msgstr "Unidad"

msgid "Unit code"
msgstr "Código de unidad"

msgid "Unknown"
msgstr "Desconocido"

msgid "Value"
msgstr "Valor"

msgid "surface division"
msgstr "división de superficie"

msgid "surface divisions"
msgstr "divisiones de superficie"

msgid "⚠️ <strong>Enable this lock to prevent automated imports from overwrit"
"ing manually curated data.</strong> Use this when you have manually co"
"rrected or customized this division and want to protect it from future"
" automatic updates."
msgstr "⚠️ <strong>Active este bloqueo para evitar que las importaciones autom"
"áticas sobrescriban los datos mantenidos manualmente.</strong> Úselo c"
"uando haya corregido o personalizado manualmente esta división y quier"
"a protegerla de futuras actualizaciones automáticas."
