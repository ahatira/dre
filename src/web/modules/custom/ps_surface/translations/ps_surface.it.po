msgstr "PS superficie — Tabella di confronto"

msgid "PS surface — Contextual (matrix-driven)"
msgstr "PS superficie — Contestuale (guidata da matrice)"

msgid "PS surface — Offer (TOTAL / DISPO / ETREF / MINIM)"
msgstr "PS superficie — Offerta (TOTAL / DISPO / ETREF / MINIM)"

msgid "Partial"
msgstr "Parziale"

msgid "Qualification"
msgstr "Qualificazione"

msgid "Qualification code"
msgstr "Codice qualifica"

msgid "Qualified surface values attached to this division."
msgstr "Valori di superficie qualificata associati a questa divisione."

msgid "Raw availability text imported from external systems. This is for refe"
"rence only."
msgstr "Testo grezzo di disponibilità importato da sistemi esterni. Solo a tit"
"olo di riferimento."

msgid "Reference"
msgstr "Riferimento"

msgid "Select a qualification code from dictionary entries."
msgstr "Seleziona un codice qualifica dalle voci del dizionario."

msgid "Select the operational status of this division based on its availabili"
"ty."
msgstr "Seleziona lo stato operativo di questa divisione in base alla sua disp"
"onibilità."

msgid "Sort by @column, currently @direction."
msgstr "Ordina per @column, attualmente @direction."

msgid "Sort by @column."
msgstr "Ordina per @column."

msgid "Status"
msgstr "Stato"

msgid "Stores a qualified physical surface item."
msgstr "Memorizza un elemento di superficie fisica qualificata."

msgid "Surface"
msgstr "Superficie"

msgid "Surface @qual has negative value (@value). Negative surfaces are not a"
"llowed."
msgstr "La superficie @qual ha un valore negativo (@value). Le superfici negat"
"ive non sono consentite."

msgid "Surface division"
msgstr "Divisione di superficie"

msgid "Surface division table"
msgstr "Tabella delle divisioni di superficie"

msgid "Surface divisions"
msgstr "Divisioni di superficie"

msgid "Surface domain foundation for divisions, projections, and governance p"
