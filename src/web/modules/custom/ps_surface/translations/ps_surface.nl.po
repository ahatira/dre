msgid "+ Add division"
msgstr "+ Divisie toevoegen"

msgid "Administer PS surface entities"
msgstr "PS-oppervlakte-entiteiten beheren"

msgid "Availability"
msgstr "Beschikbaarheid"

msgid "Available"
msgstr "Beschikbaar"

msgid "Business identifier for the division."
msgstr "Zakelijke identifier voor de divisie."

msgid "Changed"
msgstr "Gewijzigd"

msgid "Created"
msgstr "Aangemaakt"

msgid "DISPO surface (@dispo m²) exceeds TOTAL surface (@total m²). Available"
" surface cannot be greater than total."
msgstr "DISPO-oppervlakte (@dispo m²) is groter dan TOTAL-oppervlakte (@total "
"m²). Beschikbare oppervlakte mag niet groter zijn dan de totale opperv"
"lakte."

msgid "Define the qualified surface values for this division. TOTAL is the to"
"tal area, DISPO is the available area, and ETREF is the reference surf"
"ace (ERP regulations)."
msgstr "Definieer de gekwalificeerde oppervlaktewaarden voor deze divisie. TOT"
"AL is de totale oppervlakte, DISPO is de beschikbare oppervlakte en ET"
"REF is de referentie-oppervlakte (ERP-regelgeving)."

msgid "Division label"
msgstr "Label van de divisie"

msgid "Division reference"
msgstr "Referentie van de divisie"

msgid "Division status"
msgstr "Status van de divisie"

msgid "ETREF surface (@etref m²) exceeds TOTAL surface (@total m²). ETREF sho"
"uld be less than or equal to TOTAL."
msgstr "ETREF-oppervlakte (@etref m²) is groter dan TOTAL-oppervlakte (@total "
"m²). ETREF moet kleiner dan of gelijk zijn aan TOTAL."

msgid "Floor"
msgstr "Verdieping"

msgid "Floor level for the division (e.g. RDC, R+5)."
msgstr "Verdiepingsniveau voor de divisie (bijv. RDC, R+5)."

msgid "Human readable label for the division."
msgstr "Menselijk leesbaar label voor de divisie."

msgid "Label"
msgstr "Label"

msgid "Linked offers"
msgstr "Gekoppelde aanbiedingen"

msgid "Lot"
msgstr "Perceel"

msgid "Manage surface division entities and configuration."
msgstr "Oppervlaktedivisies en configuratie beheren."

msgid "Nature"
msgstr "Aard"

msgid "Nature or usage label for the division (e.g. Bureaux)."
msgstr "Label voor aard of gebruik van de divisie (bijv. Kantoren)."

msgid "Operational status of the division."
msgstr "Operationele status van de divisie."

msgid "PS surface item"
msgstr "PS-oppervlakte-item"

msgid "PS surface — Compare table"
msgstr "PS-oppervlakte — Vergelijkingstabel"

msgid "PS surface — Contextual (matrix-driven)"
msgstr "PS-oppervlakte — Contextueel (matrix-gestuurd)"

msgid "PS surface — Offer (TOTAL / DISPO / ETREF / MINIM)"
msgstr "PS-oppervlakte — Aanbod (TOTAL / DISPO / ETREF / MINIM)"

msgid "Partial"
msgstr "Gedeeltelijk"

msgid "Qualification"
msgstr "Kwalificatie"

msgid "Qualification code"
msgstr "Kwalificatiecode"

msgid "Qualified surface values attached to this division."
msgstr "Gekwalificeerde oppervlaktewaarden gekoppeld aan deze divisie."

msgid "Raw availability text imported from external systems. This is for refe"
"rence only."
msgstr "Ruwe beschikbaarheidstekst geïmporteerd uit externe systemen. Alleen t"
"er referentie."

msgid "Reference"
msgstr "Referentie"

msgid "Select a qualification code from dictionary entries."
msgstr "Selecteer een kwalificatiecode uit de woordenboekitems."

msgid "Select the operational status of this division based on its availabili"
"ty."
msgstr "Selecteer de operationele status van deze divisie op basis van de besc"
"hikbaarheid."

msgid "Sort by @column, currently @direction."
msgstr "Sorteren op @column, momenteel @direction."

msgid "Sort by @column."
msgstr "Sorteren op @column."

msgid "Status"
msgstr "Status"

msgid "Stores a qualified physical surface item."
msgstr "Slaat een gekwalificeerd fysiek oppervlakte-item op."

msgid "Surface"
msgstr "Oppervlakte"

msgid "Surface @qual has negative value (@value). Negative surfaces are not a"
"llowed."
msgstr "Oppervlakte @qual heeft een negatieve waarde (@value). Negatieve opper"
"vlaktes zijn niet toegestaan."

msgid "Surface division"
msgstr "Oppervlakteverdeling"

msgid "Surface division table"
msgstr "Tabel oppervlakteverdeling"

