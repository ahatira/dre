msgstr "Carica un file CSV con le colonne: type,code,label,weight e traduzioni"
" facoltative con label_{langcode} (ad esempio label_fr, label_en)."

msgid "Uploaded file could not be loaded."
msgstr "Impossibile caricare il file caricato."

msgid "Weight"
msgstr "Peso"

msgid "Weights saved."
msgstr "Pesi salvati."

