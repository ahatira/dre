msgid "- Select -"
msgstr "- Wybierz -"

msgid "@count dictionary entries deleted."
msgstr "Usunięto @count wpisów słownika."

msgid "Action"
msgstr "Akcja"

msgid "Add dictionary entry"
msgstr "Dodaj wpis słownika"

msgid "Add dictionary type"
msgstr "Dodaj typ słownika"

msgid "An entry with this type/code already exists."
msgstr "Wpis z tym typem/kodem już istnieje."

msgid "Apply"
msgstr "Zastosuj"

msgid "Autocomplete"
msgstr "Autouzupełnianie"

msgid "CSV file"
msgstr "Plik CSV"

msgid "CSV source"
msgstr "Źródło CSV"

msgid "Canonical business code, for example BUR or RENT."
msgstr "Kanoniczny kod biznesowy, na przykład BUR lub RENT."

msgid "Check boxes/radio buttons"
msgstr "Pola wyboru/przyciski opcji"

msgid "Code"
msgstr "Kod"

msgid "Code is required."
msgstr "Kod jest wymagany."

msgid "Config-first business dictionaries and resolvers."
msgstr "Słowniki biznesowe i resolvery config-first."

msgid "Configure a dictionary type on the field settings to enable autocomple"
"te."
msgstr "Skonfiguruj typ słownika w ustawieniach pola, aby włączyć autouzupełni"
"anie."

msgid "Created dictionary entry %label."
msgstr "Utworzono wpis słownika %label."

msgid "Created dictionary type %label."
msgstr "Utworzono typ słownika %label."

msgid "Default fixture bundled with module"
msgstr "Domyślny zestaw danych dostarczony z modułem"

msgid "Defines which dictionary is used to build options and autocomplete mat"
"ches."
msgstr "Określa, który słownik jest używany do budowania opcji i trafień autou"
"zupełniania."

msgid "Delete selected entries"
msgstr "Usuń wybrane wpisy"

msgid "Description"
msgstr "Opis"

msgid "Dictionary code"
msgstr "Kod słownika"

msgid "Dictionary entry"
msgstr "Wpis słownika"

msgid "Dictionary field value from node page"
msgstr "Wartość pola słownika ze strony węzła"

msgid "Dictionary label"
msgstr "Etykieta słownika"

msgid "Dictionary type"
msgstr "Typ słownika"

msgid "Dictionary type is not configured yet."
msgstr "Typ słownika nie jest jeszcze skonfigurowany."

msgid "Dictionary type: @type"
msgstr "Typ słownika: @type"

msgid "Dictionary types"
msgstr "Typy słowników"

msgid "Edit"
msgstr "Edytuj"

msgid "Entries"
msgstr "Wpisy"

msgid "Entries for @type"
msgstr "Wpisy dla @type"

msgid "ID"
msgstr "ID"

msgid "Icon"
msgstr "Ikona"

msgid "Import CSV"
msgstr "Importuj CSV"

msgid "Import finished: @imported imported, @skipped skipped, @errors errors."
msgstr "Import zakończony: @imported zaimportowano, @skipped pominięto, @error"
"s błędów."

msgid "Label"
msgstr "Etykieta"

msgid "Machine name"
msgstr "Nazwa maszynowa"

msgid "Machine name of the dictionary type to import only this type."
msgstr "Nazwa maszynowa typu słownika, aby importować tylko ten typ."

msgid "Manage dictionary types."
msgstr "Zarządzaj typami słowników."

msgid "No entries selected."
msgstr "Nie wybrano żadnych wpisów."

msgid "Optional description to document the purpose of this dictionary entry."
msgstr "Opcjonalny opis dokumentujący cel tego wpisu słownika."

msgid "Optional description to document the purpose of this dictionary type."
msgstr "Opcjonalny opis dokumentujący cel tego typu słownika."

msgid "Please upload a CSV file."
msgstr "Prześlij plik CSV."

msgid "Save weights"
msgstr "Zapisz wagi"

msgid "Select"
msgstr "Wybierz"

msgid "Select @entry"
msgstr "Wybierz @entry"

msgid "Select list"
msgstr "Lista wyboru"

msgid "Stores a business dictionary code (ex: BUR, SALE, EUR)."
msgstr "Przechowuje kod słownika biznesowego (np. BUR, SALE, EUR)."

msgid "The dictionary entry %label has been deleted."
msgstr "Wpis słownika %label został usunięty."

msgid "The dictionary entry has been assigned to the offer."
msgstr "Wpis słownika został przypisany do oferty."

msgid "The dictionary entry was created but could not be automatically assign"
"ed to the offer. Please assign it manually."
msgstr "Wpis słownika został utworzony, ale nie można go było automatycznie pr"
"zypisać do oferty. Przypisz go ręcznie."

msgid "Translate"
msgstr "Przetłumacz"

msgid "Type"
msgstr "Typ"

msgid "Type filter (optional)"
msgstr "Filtr typu (opcjonalny)"

msgid "UI Icon"
msgstr "Ikona UI"

msgid "UI Icon shown for this dictionary entry. Leave empty to use the defaul"
"t icon when available."
msgstr "Ikona interfejsu wyświetlana dla tego wpisu słownika. Pozostaw puste, "
"aby użyć domyślnej ikony, jeśli jest dostępna."

msgid "Unable to read uploaded CSV file."
msgstr "Nie można odczytać przesłanego pliku CSV."

msgid "Updated dictionary entry %label."
msgstr "Zaktualizowano wpis słownika %label."

msgid "Updated dictionary type %label."
msgstr "Zaktualizowano typ słownika %label."

msgid "Upload a CSV file"
msgstr "Prześlij plik CSV"

msgid "Upload a CSV file with columns: type,code,label,weight and optional tr"
"anslations with label_{langcode} (for example label_fr, label_en)."
msgstr "Prześlij plik CSV z kolumnami: type,code,label,weight oraz opcjonalnym"
"i tłumaczeniami z label_{langcode} (na przykład label_fr, label_en)."

msgid "Uploaded file could not be loaded."
msgstr "Nie udało się wczytać przesłanego pliku."

msgid "Weight"
msgstr "Waga"

msgid "Weights saved."
msgstr "Wagi zapisane."

msgid "ps_dictionary field settings"
msgstr "Ustawienia pola ps_dictionary"

msgid "ps_dictionary field storage settings"
msgstr "Ustawienia przechowywania pola ps_dictionary"
