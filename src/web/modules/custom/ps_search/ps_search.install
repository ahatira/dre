<?php

/**
 * @file
 * Install hooks for ps_search.
 */

declare(strict_types=1);

/**
 * Installs the search_alert content entity schema.
 */
function ps_search_install(): void {
  $entity_type = \Drupal::entityTypeManager()->getDefinition('search_alert');
  \Drupal::entityDefinitionUpdateManager()->installEntityType($entity_type);
}
