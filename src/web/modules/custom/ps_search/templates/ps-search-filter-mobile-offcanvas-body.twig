{#
/**
 * @file
 * Mobile filters offcanvas body — composes desktop SDC section wrappers (Phase 5A.6).
 */
#}
{% set type_fields %}
  {% include '@ps_search/ps-search-filter-section-type-fields.twig' %}
{% endset %}
{% include 'ps_theme:search-filter-mobile-section' with {
  title: 'Property type'|t,
  section_modifiers: 'ps-filter-bar__item ps-filter-bar__item--type js-ps-type-section-mobile ps-filter-popin--type',
  content: type_fields,
} only %}

{% set location_fields %}
  {% include '@ps_search/ps-search-filter-section-location-fields.twig' with {
    id_suffix: '-m',
    layout: 'stacked',
  } only %}
  <div id="ps-location-suggest-m" class="ps-filter-bar__location-suggest js-ps-location-suggest" role="listbox" hidden></div>
{% endset %}
{% include 'ps_theme:search-filter-mobile-section' with {
  title: 'Location(s)'|t,
  section_modifiers: 'ps-filter-bar__item ps-filter-bar__item--location',
  content: location_fields,
} only %}

{% set surface_fields %}
  {% include '@ps_search/ps-search-filter-section-range-fields.twig' with { section: 'surface', id_suffix: '-m' } only %}
{% endset %}
{% include 'ps_theme:search-filter-mobile-section' with {
  title: 'Surface (m²)'|t,
  title_class: 'js-ps-surface-field-label',
  section_modifiers: 'ps-filter-bar__item ps-filter-bar__item--surface js-ps-surface-item js-ps-surface-section-mobile',
  hidden: not show_surface_filter,
  content: surface_fields,
} only %}

{% set capacity_fields %}
  {% include '@ps_search/ps-search-filter-section-range-fields.twig' with {
    section: 'capacity',
    id_suffix: '-m',
    capacity_filter_label: capacity_filter_label,
    capacity_config: capacity_config|default({}),
  } only %}
{% endset %}
{% include 'ps_theme:search-filter-mobile-section' with {
  title: capacity_config.field_label|default(capacity_filter_label)|capitalize,
  title_class: 'js-ps-capacity-field-label',
  section_modifiers: 'ps-filter-bar__item ps-filter-bar__item--capacity js-ps-capacity-item js-ps-capacity-section-mobile',
  hidden: not show_capacity_filter,
  content: capacity_fields,
} only %}

{% set budget_fields %}
  {% include '@ps_search/ps-search-filter-section-range-fields.twig' with {
    section: 'budget',
    id_suffix: '-m',
    budget_config: budget_config,
  } only %}
{% endset %}
{% include 'ps_theme:search-filter-mobile-section' with {
  title: budget_config.field_label|default('Budget'|t),
  title_class: 'js-ps-budget-field-label',
  section_modifiers: 'ps-filter-mobile-section--budget',
  content: budget_fields,
} only %}

{% include '@ps_search/ps-search-filter-section-more-stacked.twig' with {
  id_prefix: 'ps-more-m',
  more_criteria_groups: more_criteria_groups,
  core_criteria_items: core_criteria_items,
} only %}
