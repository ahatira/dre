{#
/**
 * @file
 * Search alert digest email body fragment (wrapped by email-wrap shell).
 *
 * Variables: list_title, cards (list of HTML card fragments), search_url.
 */
#}
{% set text = email_text_color|default('#333333') %}
{% set green = email_primary_color|default('#00915a') %}
{% set hover = email_primary_hover_color|default('#04af6e') %}

{% if list_title %}
  <p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:{{ text }};font-weight:700;">{{ list_title }}</p>
{% endif %}

{% if cards %}
  {% for card in cards %}
    {{ card|raw }}
  {% endfor %}
{% endif %}

{% if search_url %}
  <p style="margin:0;font-size:14px;line-height:1.6;color:{{ text }};">
    <a href="{{ search_url }}" style="color:{{ hover }};text-decoration:none;">{{ 'View your saved search'|t }} &gt;</a>
  </p>
{% endif %}
