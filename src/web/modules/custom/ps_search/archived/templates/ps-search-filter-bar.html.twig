{#
/**
 * @file
 * Template for the ps_search filter bar block.
 *
 * Available variables:
 * - operation_types: array of {code, slug, label, url, active}.
 * - asset_types: array of {code, slug, label, icon_class, active}.
 * - active_op: currently active operation type code (LOC/VEN) or NULL.
 * - active_asset: currently active asset type code (BUR/ENT...) or NULL.
 * - active_op_label: human-readable label for the active op.
 * - active_asset_label: human-readable label for the active asset.
 * - lang_prefix: language URL prefix (e.g. '/fr' or '').
 * - clear_url: URL to clear all filters.
 */
#}
{% set button_label %}
  {%- if active_asset_label and active_op_label -%}
    {{ active_asset_label }} — {{ active_op_label }}
  {%- elseif active_asset_label -%}
    {{ active_asset_label }}
  {%- elseif active_op_label -%}
    {{ active_op_label }}
  {%- else -%}
    {{ 'Type & need'|t }}
  {%- endif -%}
{% endset %}

<div class="ps-filter-bar" role="search" aria-label="{{ 'Property search filters'|t }}">

  {# ── 1. Type + Operation combined filter ──────────────────────────────── #}
  <div class="ps-filter-bar__item ps-filter-bar__item--type js-ps-filter-dropdown">
    <button
      class="ps-filter-bar__btn{% if active_op or active_asset %} is-active{% endif %}"
      type="button"
      aria-expanded="false"
      aria-controls="ps-type-popin"
    >
      <span class="ps-filter-bar__btn-label">{{ button_label }}</span>
      <span class="ps-filter-bar__btn-arrow" aria-hidden="true">▾</span>
    </button>

    <div class="ps-type-popin" id="ps-type-popin" hidden>

      {# ── Asset type grid ──────────────────────────────────────────────── #}
      <div class="ps-type-popin__section">
        <h3 class="ps-type-popin__heading">{{ 'What are you looking for?'|t }}</h3>
        <ul class="ps-asset-grid" role="list">
          {% for asset in asset_types %}
            <li class="ps-asset-card{% if asset.active %} is-active{% endif %}" role="listitem">
              <button
                class="ps-asset-card__link js-ps-asset-btn"
                type="button"
                data-code="{{ asset.code }}"
                aria-pressed="{{ asset.active ? 'true' : 'false' }}"
              >
                <span class="ps-asset-card__icon {{ asset.icon_class }}" aria-hidden="true"></span>
                <span class="ps-asset-card__label">{{ asset.label }}</span>
              </button>
            </li>
          {% endfor %}
        </ul>
      </div>

      {# ── Operation type buttons ───────────────────────────────────────── #}
      <div class="ps-type-popin__section ps-type-popin__section--op">
        <h3 class="ps-type-popin__heading">{{ 'What is your need?'|t }}</h3>
        <div class="ps-op-choices" role="group" aria-label="{{ 'Transaction type'|t }}">
          {% for op in operation_types %}
            <button
              class="ps-op-btn{% if op.active %} is-active{% endif %} js-ps-op-btn"
              type="button"
              data-code="{{ op.code }}"
              aria-pressed="{{ op.active ? 'true' : 'false' }}"
            >
              {{ op.label }}
            </button>
          {% endfor %}
        </div>
      </div>

      {# ── Sticky footer ─────────────────────────────────────────────────── #}
      <div class="ps-type-popin__footer">
        <button class="ps-filter-clear js-ps-clear-btn" type="button">
          {{ 'Clear'|t }}
        </button>
        <button class="ps-apply-btn js-ps-apply-btn" type="button" disabled>
          {{ 'Show'|t }} <span class="js-ps-count-label">…</span> {{ 'results'|t }}
          <span class="ps-apply-btn__loader" aria-hidden="true"></span>
        </button>
      </div>

    </div>{# /.ps-type-popin #}
  </div>{# /.ps-filter-bar__item--type #}

  {# ── 2. Localisation filter (text input directly in bar) ─────────────── #}
  <div class="ps-filter-bar__item ps-filter-bar__item--location">
    <div class="ps-filter-bar__location-wrap">
      <span class="ps-filter-bar__location-icon" aria-hidden="true">⌖</span>
      <div class="ps-filter-bar__location-editor js-ps-location-editor">
        <div class="ps-filter-bar__location-chips js-ps-location-chips"></div>
      <input
        type="text"
        class="ps-filter-bar__location-input js-ps-locality-input"
        placeholder="{{ 'City, postal code...'|t }}"
        autocomplete="off"
        aria-label="{{ 'Location: city or postal code'|t }}"
        aria-autocomplete="list"
        role="combobox"
        aria-controls="ps-location-suggest"
        aria-expanded="false"
        maxlength="100"
      >
      </div>
      <div id="ps-location-suggest" class="ps-filter-bar__location-suggest js-ps-location-suggest" role="listbox" hidden></div>
    </div>
  </div>{# /.ps-filter-bar__item--location #}

  {# ── 3. Surface filter ────────────────────────────────────────────────── #}
  <div class="ps-filter-bar__item ps-filter-bar__item--surface">
    <button
      class="ps-filter-bar__btn js-ps-filter-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="ps-surface-popin"
    >
      <span class="ps-filter-bar__btn-label js-ps-surface-label">{{ 'Surface'|t }}</span>
      <span class="ps-filter-bar__btn-arrow" aria-hidden="true">▾</span>
    </button>

    <div class="ps-type-popin" id="ps-surface-popin" hidden>
      <div class="ps-type-popin__section">
        <h3 class="ps-type-popin__heading">{{ 'Area (m²)'|t }}</h3>
        <div class="ps-range-inputs">
          <div class="ps-range-inputs__field">
            <label class="ps-range-inputs__label" for="ps-surface-min">{{ 'Min'|t }}</label>
            <div class="ps-range-inputs__input-wrap">
              <input
                type="number"
                id="ps-surface-min"
                class="ps-range-inputs__input js-ps-surface-min"
                min="0"
                step="50"
                placeholder="0"
              >
              <span class="ps-range-inputs__unit">m²</span>
            </div>
          </div>
          <span class="ps-range-inputs__sep">—</span>
          <div class="ps-range-inputs__field">
            <label class="ps-range-inputs__label" for="ps-surface-max">{{ 'Max'|t }}</label>
            <div class="ps-range-inputs__input-wrap">
              <input
                type="number"
                id="ps-surface-max"
                class="ps-range-inputs__input js-ps-surface-max"
                min="0"
                step="50"
                placeholder="∞"
              >
              <span class="ps-range-inputs__unit">m²</span>
            </div>
          </div>
        </div>
      </div>

      <div class="ps-type-popin__footer">
        <button class="ps-filter-clear js-ps-section-clear" type="button" data-section="surface">
          {{ 'Clear'|t }}
        </button>
        <button class="ps-apply-btn js-ps-apply-btn" type="button" disabled>
          {{ 'Show'|t }} <span class="js-ps-count-label">…</span> {{ 'results'|t }}
          <span class="ps-apply-btn__loader" aria-hidden="true"></span>
        </button>
      </div>
    </div>{# /.ps-surface-popin #}
  </div>{# /.ps-filter-bar__item--surface #}

  {# ── 4. Budget filter ─────────────────────────────────────────────────── #}
  <div class="ps-filter-bar__item ps-filter-bar__item--budget">
    <button
      class="ps-filter-bar__btn js-ps-filter-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="ps-budget-popin"
    >
      <span class="ps-filter-bar__btn-label js-ps-budget-label">{{ 'Budget'|t }}</span>
      <span class="ps-filter-bar__btn-arrow" aria-hidden="true">▾</span>
    </button>

    <div class="ps-type-popin" id="ps-budget-popin" hidden>
      <div class="ps-type-popin__section">
        <h3 class="ps-type-popin__heading">{{ 'Budget (€/m²/year)'|t }}</h3>
        <div class="ps-range-inputs">
          <div class="ps-range-inputs__field">
            <label class="ps-range-inputs__label" for="ps-budget-min">{{ 'Min'|t }}</label>
            <div class="ps-range-inputs__input-wrap">
              <input
                type="number"
                id="ps-budget-min"
                class="ps-range-inputs__input js-ps-budget-min"
                min="0"
                step="10"
                placeholder="0"
              >
              <span class="ps-range-inputs__unit">€</span>
            </div>
          </div>
          <span class="ps-range-inputs__sep">—</span>
          <div class="ps-range-inputs__field">
            <label class="ps-range-inputs__label" for="ps-budget-max">{{ 'Max'|t }}</label>
            <div class="ps-range-inputs__input-wrap">
              <input
                type="number"
                id="ps-budget-max"
                class="ps-range-inputs__input js-ps-budget-max"
                min="0"
                step="10"
                placeholder="∞"
              >
              <span class="ps-range-inputs__unit">€</span>
            </div>
          </div>
        </div>
      </div>

      <div class="ps-type-popin__footer">
        <button class="ps-filter-clear js-ps-section-clear" type="button" data-section="budget">
          {{ 'Clear'|t }}
        </button>
        <button class="ps-apply-btn js-ps-apply-btn" type="button" disabled>
          {{ 'Show'|t }} <span class="js-ps-count-label">…</span> {{ 'results'|t }}
          <span class="ps-apply-btn__loader" aria-hidden="true"></span>
        </button>
      </div>
    </div>{# /.ps-budget-popin #}
  </div>{# /.ps-filter-bar__item--budget #}

</div>{# /.ps-filter-bar #}

