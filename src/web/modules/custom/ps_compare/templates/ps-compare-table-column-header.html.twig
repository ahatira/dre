{#
/**
 * @file
 * Column header card for the comparison table (page + modal).
 */
#}
<div class="ps-compare-table__column-header">
  <div class="ps-compare-table__column-top">
    {% if show_actions and (favorite or remove) %}
      <div class="ps-compare-table__column-actions">
        {% if remove %}
          <div class="ps-compare-table__column-action ps-compare-table__column-action--compare">
            {{ remove }}
          </div>
        {% endif %}
        {% if favorite %}
          <div class="ps-compare-table__column-action ps-compare-table__column-action--favorite">
            {{ favorite }}
          </div>
        {% endif %}
      </div>
    {% endif %}
    {% if title %}
      <a href="{{ url }}" class="ps-compare-table__column-title fw-semibold link-body-emphasis text-decoration-none d-block">{{ title }}</a>
    {% endif %}
    {% if address %}
      <p class="ps-compare-table__column-address mb-0">{{ address }}</p>
    {% endif %}
  </div>
  <div class="ps-compare-table__column-body">
    <a href="{{ url }}" class="btn btn-primary btn-sm w-100 ps-compare-table__column-cta">{{ 'View property'|t }}</a>
  </div>
  <div class="ps-compare-table__column-media">
    {{ gallery }}
  </div>
</div>
