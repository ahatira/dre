{#
/**
 * @file
 * Compare share email body (intro → table desktop / cards mobile → CTA).
 *
 * Single root <table> keeps markup valid inside MJML mj-raw (nested tables
 * cannot sit as siblings of <p>/<div> without being hoisted out of hidden
 * wrappers). Row classes toggle visibility via shell CSS @media.
 *
 * Variables: intro_message, compare_url, mobile_cards, table.
 */
#}
{% set green = email_primary_color|default('#00915a') %}
{% set text = email_text_color|default('#333333') %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="ps-compare-email-root">
  {% if intro_message %}
    <tr>
      <td style="padding:0 0 24px;font-size:14px;line-height:1.6;color:{{ text }};">
        {{ intro_message|e }}
      </td>
    </tr>
  {% endif %}

  {% if mobile_cards %}
    <tr class="ps-compare-email-mobile-cards">
      <td style="padding:0 0 24px;">
        {{ mobile_cards }}
      </td>
    </tr>
  {% endif %}

  {% if table %}
    <tr class="ps-compare-email-table-desktop">
      <td style="padding:0;">
        {{ table }}
      </td>
    </tr>
  {% endif %}

  {% if compare_url %}
    <tr>
      <td style="padding:32px 0 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td align="center" class="ps-email-btn-cell">
              <a href="{{ compare_url }}" class="ps-email-btn" style="display:inline-block;max-width:100%;padding:14px 28px;background:{{ green }};color:#ffffff;text-decoration:none;font-size:13px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;white-space:normal;text-align:center;line-height:1.4;">{{ 'View full comparison online'|t }}</a>
            </td>
          </tr>
          <tr>
            <td style="padding-top:16px;font-size:13px;line-height:1.5;color:{{ text }};">
              {{ 'If the button does not work, copy the following URL into your browser:'|t }}<br>
              <a href="{{ compare_url }}" style="color:{{ green }};text-decoration:none;word-break:break-all;">{{ compare_url }}</a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  {% endif %}
</table>
