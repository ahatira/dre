{#
/**
 * @file
 * Compare share email body fragment (wrapped by email-wrap.html.twig).
 */
#}
{% set green = '#00915a' %}

{% if intro_message %}
  <p style="margin:0 0 24px;font-size:14px;line-height:1.6;color:#333333;">{{ intro_message|e }}</p>
{% endif %}

{% if compare_url %}
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
    <tr>
      <td align="center" class="ps-email-btn-cell">
        <a href="{{ compare_url }}" class="ps-email-btn" style="display:inline-block;max-width:100%;padding:14px 28px;background:{{ green }};color:#ffffff;text-decoration:none;font-size:13px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;">{{ 'View full comparison online'|t }}</a>
      </td>
    </tr>
    <tr>
      <td style="padding-top:16px;font-size:13px;line-height:1.5;color:#333333;">
        {{ 'If the button does not work, copy the following URL into your browser:'|t }}<br>
        <a href="{{ compare_url }}" style="color:{{ green }};text-decoration:none;word-break:break-all;">{{ compare_url }}</a>
      </td>
    </tr>
  </table>
{% endif %}

{% if table %}
  {{ table }}
{% endif %}
