{#
/**
 * @file
 * Compare toolbar — share action on full page only.
 */
#}
<div class="ps-compare-toolbar{% if context != 'modal' %} mb-3{% endif %}" data-ps-compare-toolbar>
  <div class="ps-compare-toolbar__inner d-flex flex-wrap align-items-center justify-content-end gap-3">
    {% if share_enabled %}
      <button
        type="button"
        class="btn btn-primary ps-compare-toolbar__share"
        data-ps-compare-share-open
      >
        {{ 'Send my selection'|t }}
        <span class="ps-compare-toolbar__share-icon" aria-hidden="true">{{ icon('bnp_custom', 'arrow-right', {'size': '16px'}) }}</span>
      </button>
    {% endif %}

    {% if context == 'modal' and compare_url %}
      <a
        href="{{ compare_url }}"
        class="btn btn-outline-secondary ps-compare-toolbar__full-page"
        target="_blank"
        rel="noopener"
      >
        {{ 'Open full page'|t }}
      </a>
    {% endif %}
  </div>
</div>
