msgstr "Format attendu"

msgid "Fallback title with canonical link."
msgstr "Titre de repli avec lien canonique."

msgid "Favorite card rendering"
msgstr "Rendu des cartes de favoris"

msgid "Favorite card view mode mapping"
msgstr "Mapping du mode d'affichage carte favori"

msgid "Favorite card view modes"
msgstr "Modes d'affichage des cartes de favoris"

msgid "Favorite limit reached (@limit)."
msgstr "Limite de favoris atteinte (@limit)."

msgid "Favorite system for offers with authenticated and anonymous persistenc"
"e."
msgstr "Système de favoris pour les offres avec persistance authentifiée et an"
"onyme."

msgid "Favorite target"
msgstr "Cible favori"

msgid "Favorite targets"
msgstr "Cibles de favoris"

msgid "Favorite-enabled entity targets and limits"
msgstr "Cibles d'entité favorables et limites"

msgid "Favorites"
msgstr "Favoris"

msgid "Favorites settings"
msgstr "Paramètres des favoris"

msgid "Fixed limit"
msgstr "Limite fixe"

msgid "ID"
msgstr "ID"

msgid "Invalid CSRF token."
msgstr "Jeton CSRF invalide."

msgid "Label"
msgstr "Libellé"

msgid "Limit mode"
msgstr "Mode de limite"

msgid "Line @line duplicates an existing target rule: @value"
msgstr "La ligne @line duplique une règle de cible existante : @value"

msgid "Line @line duplicates an existing view mode rule: @value"
msgstr "La ligne @line duplique une règle de mode d'affichage existante : @val"
"ue"

msgid "Line @line has an invalid format: @value"
msgstr "La ligne @line a un format invalide : @value"

msgid "Line @line has an invalid view mode format: @value"
msgstr "La ligne @line a un format de mode d'affichage invalide : @value"

msgid "Manage Property Search favorites"
msgstr "Gérer les favoris Property Search"

msgid "Manage favorite system integrations and settings."
msgstr "Gérer les intégrations et paramètres du système de favoris."

msgid "Max favorites"
msgstr "Maximum de favoris"

msgid "Maximum favorites"
msgstr "Nombre maximum de favoris"

msgid "Maximum favorites mapping"
msgstr "Mapping du nombre maximum de favoris"

msgid "My favorites"
msgstr "Mes favoris"

msgid "No custom view mode configured. The module will try teaser, then fall "
"back to a title link."
msgstr "Aucun mode d'affichage personnalisé n'est configuré. Le module essaier"
"a teaser, puis un lien sur le titre."

msgid "No eligible bundle found for this entity type."
msgstr "Aucun bundle éligible trouvé pour ce type d'entité."

msgid "No favorites yet"
msgstr "Aucun favori pour le moment"

msgid "No limit"
msgstr "Aucune limite"

msgid "No preview available"
msgstr "Aucun aperçu disponible"

msgid "No target configured. Favorite buttons remain hidden until at least on"
"e target is declared."
msgstr "Aucune cible n'est configurée. Les boutons favoris restent masqués tan"
"t qu'au moins une cible n'est pas déclarée."

msgid "Open favorites panel"
msgstr "Ouvrir le panneau des favoris"

msgid "Optional. Use one rule per line to force a preferred view mode for fav"
"orite cards."
msgstr "Optionnel. Utilisez une règle par ligne pour forcer un mode d'affichag"
"e préféré pour les cartes de favoris."

msgid "Optional. Use one rule per line, for example: <code>node.offer:favorit"
"e_card</code>. Format: <code>entity_type.bundle:view_mode</code>. You "
"may also use <code>entity_type.*:view_mode</code>. If no configured vi"
"ew mode exists, the module tries <code>teaser</code>, then falls back "
"to a title link."
msgstr "Optionnel. Utilisez une règle par ligne, par exemple : <code>node.offe"
"r:favorite_card</code>. Format : <code>entity_type.bundle:view_mode</c"
"ode>. Vous pouvez aussi utiliser <code>entity_type.*:view_mode</code>."
" Si aucun mode d'affichage configuré n'existe, le module essaie <code>"
"teaser</code>, puis bascule vers un lien sur le titre."

msgid "PS Favorite settings"
msgstr "Paramètres PS Favorite"

msgid "Preferred view mode"
msgstr "Mode d'affichage préféré"

msgid "Remove from favorites"
msgstr "Retirer des favoris"

msgid "Removed from favorites."
msgstr "Retiré des favoris."

msgid "Rendering fallback order"
msgstr "Ordre de repli du rendu"

msgid "Save"
msgstr "Enregistrer"

msgid "Saved"
msgstr "Enregistré"

msgid "Saved 1 favorite target rule."
msgstr "1 règle de cible favorite enregistrée."

msgid "Saved 1 view mode rule."
msgstr "1 règle de mode d'affichage enregistrée."

msgid "Saved @count favorite target rules."
msgstr "@count règles de cible favorite enregistrées."

msgid "Saved @count view mode rules."
msgstr "@count règles de mode d'affichage enregistrées."

msgid "Selected view mode is invalid for @target."
msgstr "Le mode d'affichage sélectionné est invalide pour @target."

msgid "Set a positive maximum for @target when using a fixed limit."
msgstr "Définissez un maximum positif pour @target lors de l'utilisation d'une"
" limite fixe."

msgid "Teaser view mode when available."
msgstr "Mode d'affichage teaser quand il est disponible."

msgid "UUID"
msgstr "UUID"

msgid "Unable to add this favorite right now."
msgstr "Impossible d'ajouter ce favori pour le moment."

msgid "Unable to update favorite."
msgstr "Impossible de mettre à jour le favori."

msgid "Unsupported entity target."
msgstr "Cible d'entité non prise en charge."

msgid "Use one rule per line, for example: <code>node.offer:20</code>. Format"
": <code>entity_type.bundle:max</code>. You may also use <code>entity_t"
"ype.*:max</code>. Only configured targets are favoritable. Use <code>:"
"0</code> for no limit."
msgstr "Utilisez une règle par ligne, par exemple : <code>node.offer:20</code>"
". Format : <code>entity_type.bundle:max</code>. Vous pouvez aussi util"
"iser <code>entity_type.*:max</code>. Seules les cibles configurées peu"
"vent être ajoutées aux favoris. Utilisez <code>:0</code> pour ne pas f"
"ixer de limite."

msgid "Use one rule per line. Only configured targets are favoritable."
msgstr "Utilisez une règle par ligne. Seules les cibles configurées peuvent êt"
"re ajoutées aux favoris."

msgid "Use the favorite button on a supported entity to keep it close at hand"
"."
msgstr "Utilisez le bouton favori sur une entité prise en charge pour la garde"
"r à portée de main."

msgid "View all favorites"
msgstr "Voir tous les favoris"

msgid "favorite target"
msgstr "cible favori"

msgid "favorite targets"
msgstr "cibles favori"
