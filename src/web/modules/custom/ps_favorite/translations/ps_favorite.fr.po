msgid "<code>media.*:5</code> enables favorites for all media bundles with a "
"shared limit of 5 items per bundle rule."
msgstr "<code>media.*:5</code> active les favoris pour tous les bundles media "
"avec une limite partagée de 5 éléments par règle de bundle."

msgid "<code>node.article:10</code> enables favorites for article nodes with "
"a limit of 10 items."
msgstr "<code>node.article:10</code> active les favoris pour les nœuds article"
" avec une limite de 10 éléments."

msgid "<code>node.offer:0</code> enables favorites for all offer nodes with n"
"o limit."
msgstr "<code>node.offer:0</code> active les favoris pour tous les nœuds offer"
" sans limite."

msgid "@entity_type: @bundle"
msgstr "@entity_type : @bundle"

msgid "Add to favorites"
msgstr "Ajouter aux favoris"

msgid "Added to favorites."
msgstr "Ajouté aux favoris."

msgid "All items"
msgstr "Tous les éléments"

msgid "Automatic fallback"
msgstr "Repli automatique"

msgid "Bundle"
msgstr "Type de contenu"

msgid "Card favorite view mode when available."
msgstr "Mode d'affichage carte favori lorsque disponible."

msgid "Configure favorites behavior."
msgstr "Configurer le comportement des favoris."

msgid "Configure which entity targets can be favorited and how favorite cards"
" should be rendered."
msgstr "Configure quelles cibles d'entité peuvent être ajoutées aux favoris et"
" comment les cartes de favoris doivent être rendues."

msgid "Configured card view modes"
msgstr "Modes d'affichage de carte configurés"

msgid "Configured favorite targets"
msgstr "Cibles de favoris configurées"

msgid "Configured view mode for the matching entity target."
msgstr "Mode d'affichage configuré pour la cible d'entité correspondante."

msgid "Current configuration summary"
msgstr "Résumé de la configuration actuelle"

msgid "Enable"
msgstr "Activer"

msgid "Enable favorites per entity target, then choose whether the target has"
" no limit or a fixed maximum."
msgstr "Activez les favoris par cible d'entité, puis choisissez si la cible es"
"t sans limite ou avec un maximum fixe."

msgid "Enabled"
msgstr "Activé"

msgid "Entity type ID"
msgstr "ID du type d'entité"

