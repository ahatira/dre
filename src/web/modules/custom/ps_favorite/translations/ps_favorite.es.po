msgstr "Token CSRF no válido."

msgid "Label"
msgstr "Etiqueta"

msgid "Limit mode"
msgstr "Modo de límite"

msgid "Line @line duplicates an existing target rule: @value"
msgstr "La línea @line duplica una regla existente: @value"

msgid "Line @line duplicates an existing view mode rule: @value"
msgstr "La línea @line duplica una regla de modo de vista: @value"

