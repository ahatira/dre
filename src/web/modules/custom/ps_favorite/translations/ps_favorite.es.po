msgstr "La línea @line tiene formato de modo de vista no válido: @value"

msgid "Manage Property Search favorites"
msgstr "Gestionar favoritos de Property Search"

msgid "Manage favorite system integrations and settings."
msgstr "Gestionar integraciones y ajustes del sistema de favoritos."

msgid "Max favorites"
msgstr "Máx. favoritos"

msgid "Maximum favorites"
msgstr "Máximo de favoritos"

