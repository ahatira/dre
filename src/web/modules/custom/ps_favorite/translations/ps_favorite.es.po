msgid "<code>media.*:5</code> enables favorites for all media bundles with a "
"shared limit of 5 items per bundle rule."
msgstr "<code>media.*:5</code> activa favoritos para todos los bundles media c"
"on límite compartido de 5."

msgid "<code>node.article:10</code> enables favorites for article nodes with "
"a limit of 10 items."
msgstr "<code>node.article:10</code> activa favoritos para nodos article con l"
"ímite de 10."

msgid "<code>node.offer:0</code> enables favorites for all offer nodes with n"
"o limit."
msgstr "<code>node.offer:0</code> activa favoritos para todos los nodos offer "
"sin límite."

msgid "@entity_type: @bundle"
msgstr "@entity_type: @bundle"

msgid "Add to favorites"
msgstr "Añadir a favoritos"

msgid "Added to favorites."
msgstr "Añadido a favoritos."

msgid "All items"
msgstr "Todos los elementos"

msgid "Automatic fallback"
msgstr "Reemplazo automático"

msgid "Bundle"
msgstr "Tipo de contenido"

msgid "Card favorite view mode when available."
msgstr "Modo de vista tarjeta favorito cuando esté disponible."

