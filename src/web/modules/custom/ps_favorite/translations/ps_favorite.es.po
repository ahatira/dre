msgstr "Mis favoritos"

msgid "No custom view mode configured. The module will try teaser, then fall "
"back to a title link."
msgstr "Sin modo de vista personalizado. El módulo intentará teaser y luego un"
" enlace al título."

msgid "No eligible bundle found for this entity type."
msgstr "No se encontró un tipo de contenido válido para este tipo de entidad."

msgid "No favorites yet"
msgstr "Aún no hay favoritos"

msgid "No limit"
msgstr "Sin límite"

msgid "No preview available"
msgstr "Sin vista previa disponible"

msgid "No target configured. Favorite buttons remain hidden until at least on"
"e target is declared."
msgstr "No hay objetivo configurado. Los botones de favoritos permanecen ocult"
"os hasta declarar al menos un objetivo."

msgid "Open favorites panel"
msgstr "Abrir panel de favoritos"

msgid "Optional. Use one rule per line to force a preferred view mode for fav"
"orite cards."
msgstr "Opcional. Una regla por línea para forzar el modo de vista preferido d"
"e las tarjetas favorito."

msgid "Optional. Use one rule per line, for example: <code>node.offer:favorit"
"e_card</code>. Format: <code>entity_type.bundle:view_mode</code>. You "
"may also use <code>entity_type.*:view_mode</code>. If no configured vi"
"ew mode exists, the module tries <code>teaser</code>, then falls back "
"to a title link."
msgstr "Opcional. Una regla por línea, ej. <code>node.offer:favorite_card</cod"
"e>. Formato: <code>entity_type.bundle:view_mode</code>. Si no hay modo"
" configurado, intenta <code>teaser</code>, luego enlace al título."

msgid "PS Favorite settings"
msgstr "Ajustes de PS Favorite"

msgid "Preferred view mode"
msgstr "Modo de vista preferido"

msgid "Remove from favorites"
msgstr "Eliminar de favoritos"

msgid "Removed from favorites."
msgstr "Eliminado de favoritos."

msgid "Rendering fallback order"
msgstr "Orden de reemplazo de presentación"

msgid "Save"
msgstr "Guardar"

msgid "Saved"
msgstr "Guardado"

msgid "Saved 1 favorite target rule."
msgstr "1 regla de objetivo favorito guardada."

msgid "Saved 1 view mode rule."
msgstr "1 regla de modo de vista guardada."

msgid "Saved @count favorite target rules."
msgstr "@count reglas de objetivo favorito guardadas."

msgid "Saved @count view mode rules."
msgstr "@count reglas de modo de vista guardadas."

msgid "Selected view mode is invalid for @target."
msgstr "El modo de vista seleccionado no es válido para @target."

msgid "Set a positive maximum for @target when using a fixed limit."
msgstr "Establezca un máximo positivo para @target al usar un límite fijo."

msgid "Teaser view mode when available."
msgstr "Modo de vista resumen cuando esté disponible."

msgid "UUID"
msgstr "UUID"

msgid "Unable to add this favorite right now."
msgstr "No se puede añadir este favorito en este momento."

msgid "Unable to update favorite."
msgstr "No se pudo actualizar el favorito."

msgid "Unsupported entity target."
msgstr "Objetivo de entidad no compatible."

msgid "Use one rule per line, for example: <code>node.offer:20</code>. Format"
": <code>entity_type.bundle:max</code>. You may also use <code>entity_t"
"ype.*:max</code>. Only configured targets are favoritable. Use <code>:"
"0</code> for no limit."
msgstr "Una regla por línea, ej. <code>node.offer:20</code>. Formato: <code>en"
"tity_type.bundle:max</code>. También <code>entity_type.*:max</code>. S"
"olo objetivos configurados. <code>:0</code> sin límite."

msgid "Use one rule per line. Only configured targets are favoritable."
msgstr "Una regla por línea. Solo los objetivos configurados pueden marcarse c"
"omo favoritos."

msgid "Use the favorite button on a supported entity to keep it close at hand"
"."
msgstr "Use el botón de favoritos en una entidad compatible para tenerla al al"
"cance."

msgid "View all favorites"
msgstr "Ver todos los favoritos"

msgid "favorite target"
msgstr "objetivo favorito"

msgid "favorite targets"
msgstr "objetivos favorito"
