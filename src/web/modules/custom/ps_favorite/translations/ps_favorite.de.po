msgid "<code>media.*:5</code> enables favorites for all media bundles with a "
"shared limit of 5 items per bundle rule."
msgstr "<code>media.*:5</code> aktiviert Favoriten für alle Media-Bundles mit "
"gemeinsamem Limit 5."

msgid "<code>node.article:10</code> enables favorites for article nodes with "
"a limit of 10 items."
msgstr "<code>node.article:10</code> aktiviert Favoriten für Artikel-Nodes mit"
" Limit 10."

msgid "<code>node.offer:0</code> enables favorites for all offer nodes with n"
"o limit."
msgstr "<code>node.offer:0</code> aktiviert Favoriten für alle Offer-Nodes ohn"
"e Limit."

msgid "@entity_type: @bundle"
msgstr "@entity_type: @bundle"

msgid "Add to favorites"
msgstr "Zu Favoriten hinzufügen"

msgid "Added to favorites."
msgstr "Zu Favoriten hinzugefügt."

msgid "All items"
msgstr "Alle Elemente"

