{#
/**
 * @file
 * Single item in the favorites panel or list.
 */
#}
<article class="ps-favorite-panel-item" data-ps-favorite-card data-entity-type-id="{{ entity_type_id }}" data-entity-id="{{ entity_id }}">
  {% if thumbnail and url %}
    <a href="{{ url }}" class="ps-favorite-panel-item__media">
      <img src="{{ thumbnail }}" alt="" width="72" height="72" loading="lazy" />
    </a>
  {% elseif entity_view %}
    <div class="ps-favorite-panel-item__media">{{ entity_view }}</div>
  {% endif %}
  <div class="ps-favorite-panel-item__content">
    {% if title %}
      <p class="ps-favorite-panel-item__title">
        {% if url %}
          <a href="{{ url }}">{{ title }}</a>
        {% else %}
          {{ title }}
        {% endif %}
      </p>
    {% endif %}
    {% if surface %}
      <p class="ps-favorite-panel-item__surface">{{ surface }}</p>
    {% endif %}
    {% if price_amount %}
      <p class="ps-favorite-panel-item__price">
        <span class="ps-favorite-panel-item__price-amount">{{ price_amount }}</span>
        {% if price_qualifiers %}
          <span class="ps-favorite-panel-item__price-qualifiers">{{ price_qualifiers|replace({'m²': 'm<sup>2</sup>'})|raw }}</span>
        {% endif %}
      </p>
    {% endif %}
  {% if entity_view and not thumbnail and not title %}
      <div class="ps-favorite-panel-item__preview">{{ entity_view }}</div>
    {% endif %}
  </div>
  <div class="ps-favorite-panel-item__action">
    {{ toggle_button }}
  </div>
</article>
