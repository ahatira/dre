<div class="ps-favorite-header" data-ps-favorite-header>
  <a
    href="{{ offcanvas_url }}"
    class="ps-favorite-header__trigger use-ajax"
    data-dialog-type="dialog"
    data-dialog-renderer="off_canvas"
    data-dialog-options="{{ dialog_options }}"
    aria-label="{{ 'Open favorites panel'|t }}"
  >
    <span class="ps-favorite-header__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54z" />
      </svg>
    </span>
    <span class="visually-hidden">{{ 'Favorites'|t }}</span>
    {{ count }}
  </a>
</div>
