msgstr "Omitir filas protegidas por completo"

msgid "Unpublish"
msgstr "Despublicar"

msgid "When checked, media created in the back office start with field_internal_lock enabled."
msgstr "Si está marcado, los medios creados en back office empiezan con field_internal_lock activado."

msgid "When unchecked, existing media keeps its image alt text and virtual tour link title during CRM imports."
msgstr "Si no está marcado, los medios existentes conservan el texto alternativo y el título del enlace de visita virtual durante importaciones CRM."
