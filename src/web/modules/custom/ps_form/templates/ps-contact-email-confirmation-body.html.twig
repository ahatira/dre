{#
/**
 * @file
 * Contact hub confirmation email body fragment (wrapped by email-wrap.html.twig).
 *
 * Available variables:
 * - greeting, intro_text, recap_intro, recap_rows, closing_text, signoff_text
 */
#}
<p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#333333;">{{ greeting }}</p>

<p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#333333;">{{ intro_text }}</p>

{% if recap_rows %}
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;color:#333333;">{{ recap_intro }}</p>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
    {% for row in recap_rows %}
      <tr>
        <td style="padding:6px 0;font-size:14px;line-height:1.6;color:#333333;vertical-align:top;">
          <strong style="color:#333333;">{{ row.label }}:</strong> {{ row.value }}
        </td>
      </tr>
    {% endfor %}
  </table>
{% endif %}

<p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#333333;">{{ closing_text }}</p>
<p style="margin:0;font-size:14px;line-height:1.6;color:#333333;">{{ signoff_text }}</p>
