{% set attributes = create_attribute(attributes|default({})) %}
{% set ordered_codes = ['a', 'b', 'c', 'd', 'e', 'f', 'g'] %}
{% set code_positions = {'A': 0, 'B': 40, 'C': 80, 'D': 120, 'E': 160, 'F': 200, 'G': 240} %}
{% set raw_value = item.value is defined ? item.value : '' %}
{% set raw_class = item.class is defined ? item.class : '' %}
{% set value_number = raw_value is not empty ? raw_value + 0 : null %}
{% set is_dimmed = is_disabled|default(false) %}
{% set has_data = not is_dimmed and (value_number is not null or raw_class is not empty) %}
{% set display_text_override = is_dimmed ? '?' : '' %}
{% set empty_message = disabled_message|default('') %}

{% set classes_by_code = {} %}
{% for class in classes|default([]) %}
  {% set code = (class.label|default('')|upper) %}
  {% if code in ['A', 'B', 'C', 'D', 'E', 'F', 'G'] %}
    {% set classes_by_code = classes_by_code|merge({ (code|lower): class }) %}
  {% endif %}
{% endfor %}

{% set derived_class = active_class ? active_class.label|upper : '' %}
{% if derived_class == '' and raw_class is not empty %}
  {% set derived_class = raw_class|upper %}
{% endif %}
{% if derived_class == '' and value_number is not null and not display_text_override %}
  {% for code in ordered_codes %}
    {% if classes_by_code[code] is defined and derived_class == '' %}
      {% set max_value = classes_by_code[code].range_max is defined ? classes_by_code[code].range_max : null %}
      {% if max_value is not null and value_number <= max_value %}
        {% set derived_class = classes_by_code[code].label|default(code)|upper %}
      {% endif %}
    {% endif %}
  {% endfor %}
  {% if derived_class == '' %}
    {% for code in ordered_codes|reverse %}
      {% if classes_by_code[code] is defined and derived_class == '' %}
        {% set derived_class = classes_by_code[code].label|default(code)|upper %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endif %}

{% set display_text = display_text_override ?: (derived_class ?: '?') %}
{% set cursor_x = code_positions[display_text|upper] is defined ? code_positions[display_text|upper] : 120 %}
{% set legend_x_percent = ((cursor_x + 20) / 280 * 100)|round(4) %}
{% set show_message = is_dimmed or display_text_override or not has_data %}
{% set show_legend = has_data and unit and raw_value is not empty and not display_text_override %}
{% set bar_opacity = is_dimmed ? 0.3 : 1 %}
{% set badge_fill = cursor_fill|default('#989a9f') %}
{% set badge_text = cursor_text|default('#ffffff') %}

<figure{{ attributes.addClass('ps-diagnostic', 'ps-diagnostic--horizontal').setAttribute('data-class', derived_class|default('unknown')|lower) }}>
  <figcaption>
    <h3 class="ps-diagnostic__title">
      {% if icon %}
        {{ icon }}
      {% endif %}
      <span class="ps-diagnostic__title-label">{{ type_label|default('Diagnostic'|t) }}</span>
    </h3>
  </figcaption>

  <div class="ps-diagnostic__scale">
    <svg class="ps-diagnostic__svg class-{{ derived_class|default('unknown')|lower }}" width="280" height="40" viewBox="0 0 280 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g stroke-width="0" opacity="{{ bar_opacity }}">
        {% for code in ordered_codes %}
          {% if classes_by_code[code] is defined %}
            <rect x="{{ loop.index0 * 40 }}" y="10" width="40" height="20" fill="{{ classes_by_code[code].color }}"></rect>
          {% else %}
            <rect x="{{ loop.index0 * 40 }}" y="10" width="40" height="20" fill="#d7dadd"></rect>
          {% endif %}
        {% endfor %}
        <rect x="{{ cursor_x }}" width="40" height="40" fill="{{ badge_fill }}"></rect>
      </g>
      <text x="{{ cursor_x + 20 }}" y="28.35" fill="{{ badge_text }}" font-size="24px" stroke-width="1.2977" text-anchor="middle">{{ display_text|upper }}</text>
    </svg>

    <div class="ps-diagnostic__legend-track" aria-hidden="{{ show_legend ? 'false' : 'true' }}">
      {% if show_legend %}
        <span class="ps-diagnostic__legend" style="--legend-x: {{ legend_x_percent }}%;">
          {{ raw_value }} {{ unit }}
        </span>
      {% endif %}
    </div>
  </div>

  {% if show_dates and (diagnostic_date_display or validity_end_date_display) %}
    <div class="ps-diagnostic__dates">
      {% if diagnostic_date_display %}
        <span>{{ 'From:'|t }} {{ diagnostic_date_display }}</span>
      {% endif %}
      {% if validity_end_date_display %}
        <span>{{ 'Until:'|t }} {{ validity_end_date_display }}</span>
      {% endif %}
    </div>
  {% endif %}

  {% if show_message %}
    <p class="ps-diagnostic__message">{{ empty_message }}</p>
  {% endif %}
</figure>
