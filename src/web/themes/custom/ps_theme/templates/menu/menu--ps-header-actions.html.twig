{#
/**
 * @file
 * Header actions — flat menu (classes via Menu Link Attributes, icons via UI Icons).
 */
#}
{% if items %}
  <div class="ps-header-actions">
    <div class="ps-header-actions__main">
      {% for item in items %}
        {% set link_attributes = item.attributes|default(create_attribute()) %}
        <a href="{{ item.url.toString() }}"
           {{ link_attributes }}>
          {{ item.title }}
        </a>
      {% endfor %}
    </div>
  </div>
{% endif %}
