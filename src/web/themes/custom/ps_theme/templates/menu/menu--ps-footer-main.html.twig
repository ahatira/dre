{#
/**
 * @file
 * Footer main navigation — multi-column layout (parent items = columns).
 */
#}
{% import _self as menus %}

{% macro menu_links(items, attributes, menu_level, dropdown_classes) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes.addClass(['nav', 'flex-column', 'ps-site-footer__column-nav']) }}>
    {% else %}
      <ul{{ attributes.addClass(['nav', 'flex-column', 'ps-site-footer__subnav']) }}>
    {% endif %}
    {% for item in items %}
      {% set item_classes = [
        'nav-item',
        item.below ? 'menu-item--expanded',
        item.in_active_trail ? 'active',
      ] %}
      <li{{ item.attributes.addClass(item_classes) }}>
        {% if menu_level == 0 %}
          {% set route_name = item.url.isRouted() ? item.url.getRouteName() : '' %}
          {% if route_name == '<nolink>' %}
            <span class="ps-site-footer__column-title footer-title">{{ item.title }}</span>
          {% else %}
            {{ link(item.title, item.url, item.attributes.addClass(['ps-site-footer__column-title', 'footer-title', 'nav-link'])) }}
          {% endif %}
        {% else %}
          {{ link(item.title, item.url, item.attributes.addClass(['nav-link'])) }}
        {% endif %}
        {% if item.below %}
          {{ menus.menu_links(item.below, attributes, menu_level + 1, dropdown_classes) }}
        {% endif %}
      </li>
    {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}

{% if items %}
  <nav class="ps-site-footer__columns" aria-label="{{ 'Footer navigation'|t }}">
    {{ menus.menu_links(items, attributes, 0, dropdown_classes) }}
  </nav>
{% endif %}
