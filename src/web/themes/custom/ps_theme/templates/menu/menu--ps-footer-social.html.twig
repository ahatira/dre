{#
/**
 * @file
 * Follow us — social links rendered via footer-social SDC.
 */
#}
{% if items %}
  {% set heading = items|first %}
  {% set social_links = [] %}
  {% for item in heading.below|default([]) %}
    {% set class_string = item.attributes.class|default([])|join(' ') %}
    {% set icon = 'linkedin' in class_string ? 'linkedin' : ('mail' in class_string ? 'mail-outline' : '') %}
    {% set social_links = social_links|merge([{
      title: item.title,
      url: item.url.toString(),
      icon: icon,
    }]) %}
  {% endfor %}
  {{ include('ps_theme:footer-social', {
    title: heading.title,
    links: social_links,
  }, with_context = false) }}
{% endif %}
