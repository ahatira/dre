{#
/**
 * @file
 * Header branding — logo only, no block wrapper (navbar grid layout).
 */
#}
{% if site_logo %}
  {{ attach_library('core/components.ui_suite_bnp--navbar') }}
  <a class="navbar-brand ps-site-header__brand" href="{{ path('<front>') }}" title="{{ 'Home'|t }}" rel="home">
    <img src="{{ site_logo }}" alt="{{ 'Home'|t }}" width="162" height="31" fetchpriority="high" />
  </a>
{% elseif site_name %}
  {{ attach_library('core/components.ui_suite_bnp--navbar') }}
  <a class="navbar-brand ps-site-header__brand" href="{{ path('<front>') }}" title="{{ 'Home'|t }}" rel="home">{{ site_name }}</a>
{% endif %}
{% if site_slogan %}
  <span class="navbar-text">{{ site_slogan }}</span>
{% endif %}
