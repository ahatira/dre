{#
/**
 * @file
 * Property search results page — grid layout + transaction toggle.
 */
#}
{%
  set classes = [
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
    'ps-search-view',
  ]
%}
<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {{ title }}
  {{ title_suffix }}

  {% if header %}
    <header>{{ header }}</header>
  {% endif %}

  <div class="ps-search-view__hero container-fluid px-0 mb-4">
    {% set hero_search %}{% endset %}
    {% include 'ps_theme:search-hero' with {
      title: 'Find your professional space'|t,
      subtitle: 'Offices, logistics, retail — across France'|t,
      search: hero_search,
    } only %}
  </div>

  {% if exposed %}
    <div class="ps-search-view__filters ps-search-view__filters--legacy visually-hidden" aria-hidden="true">
      {{ exposed }}
    </div>
  {% endif %}

  <div class="ps-search-view__filter-bar container mb-4">
    {% if search_filter_bar %}
      {{ search_filter_bar }}
    {% endif %}
  </div>

  {% if rows %}
    <div class="ps-search-view__results container">
      <div class="row g-4">
        {{ rows }}
      </div>
    </div>
  {% elseif empty %}
    <div class="container">{{ empty }}</div>
  {% endif %}

  {% if pager %}
    <div class="container">{{ pager }}</div>
  {% endif %}

  {% if attachment_after %}
    <div class="attachment attachment-after">{{ attachment_after }}</div>
  {% endif %}

  {% if more %}
    {{ more }}
  {% endif %}

  {% if footer %}
    <footer>{{ footer }}</footer>
  {% endif %}

  {% if feed_icons %}
    <div class="feed-icons">{{ feed_icons }}</div>
  {% endif %}
</div>
