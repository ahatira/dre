{#
/**
 * @file
 * Search results rows — Bootstrap grid columns for offer cards.
 */
#}
{% for row in rows %}
  {%
    set row_classes = [
      default_row_class ? 'views-row',
      'col-12',
    ]
  %}
  <div{{ row.attributes.addClass(row_classes) }}>
    {{- row.content -}}
  </div>
  {% if search_push_card and search_push_insert_after and loop.index == search_push_insert_after %}
    <div class="col-12 ps-search-push-slot">
      {{ search_push_card }}
    </div>
  {% endif %}
{% endfor %}
