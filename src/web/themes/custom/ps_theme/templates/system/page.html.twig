{#
/**
 * @file
 * Property Search — global page shell.
 *
 * Bootstrap grid via ui_suite_bnp grid_row_* + theme container setting.
 * gx-0 on rows; px-0 on container/col when full-bleed is required (homepage).
 */
#}
{% set has_site_header = page.branding or page.shortcut or ps_site_header_navigation_mobile or ps_site_header_navigation_desktop or ps_site_header_actions or ps_site_header_search or ps_site_header_favorites or ps_site_header_account %}
{% set ps_grid_gx = 'gx-0' %}
{% set ps_grid_bleed_container = { class: ['px-0'] } %}
{% set ps_grid_bleed_col = { class: ['px-0'] } %}

<div class="ps-page-layout{{ has_site_header ? ' ps-page-layout--with-header' : '' }}{{ ps_page_layout_account ? ' ps-page-layout--account' : '' }}">
  {% if has_site_header %}
    <header class="site-header ps-site-header" role="banner" data-ps-site-header>
      {{ include('ps_theme:site-header', {
        container: container,
        branding: page.branding,
        shortcut: page.shortcut,
        navigation_mobile: ps_site_header_navigation_mobile,
        navigation_desktop: ps_site_header_navigation_desktop,
        search_panel: ps_site_header_search.panel|default(null),
        search_mobile_trigger: ps_site_header_search.mobile_trigger|default(null),
        search_toolbar_trigger: ps_site_header_search.toolbar_trigger|default(null),
        favorites: ps_site_header_favorites,
        actions: ps_site_header_actions,
        account: ps_site_header_account,
      }, with_context = false) }}
    </header>
  {% endif %}

  {% if page.breadcrumb %}
    <div class="ps-page-breadcrumb region-breadcrumb">
      {{ include('ui_suite_bnp:grid_row_1', {
        container: container,
        gutters_horizontal: ps_grid_gx,
        col_xs: 12,
        col_1_content: page.breadcrumb,
      }, with_context = false) }}
    </div>
  {% endif %}

  {% if page.editor_tools and ps_show_editor_tools and not is_front %}
    <div class="ps-editor-tools region-editor-tools">
      {{ include('ui_suite_bnp:grid_row_1', {
        container: container,
        gutters_horizontal: ps_grid_gx,
        col_xs: 12,
        col_1_content: page.editor_tools,
      }, with_context = false) }}
    </div>
  {% endif %}

  {% set main_content = [page.highlighted] %}
  {% if ps_show_editor_tools %}
    {% set main_content = main_content|merge([page.help]) %}
  {% endif %}
  {% set main_content = main_content|merge([
    {
      '#type': 'html_tag',
      '#tag': 'div',
      '#attributes': {
        'id': 'main-content',
      },
    },
    page.content,
  ]) %}

  <main class="ps-main{{ is_front ? ' ps-main--homepage' : '' }}" role="main">
    {% if page.sidebar_first and page.sidebar_second %}
      {{ include('ui_suite_bnp:grid_row_3', {
        container: container,
        gutters_horizontal: ps_grid_gx,
        col_xs: [12, 12, 12],
        col_sm: [3, 6, 3],
        col_1_content: page.sidebar_first,
        col_1_attributes: { role: 'complementary' },
        col_2_content: main_content,
        col_3_content: page.sidebar_second,
        col_3_attributes: { role: 'complementary' },
      }, with_context = false) }}
    {% elseif page.sidebar_first %}
      {{ include('ui_suite_bnp:grid_row_2', {
        container: container,
        gutters_horizontal: ps_grid_gx,
        col_xs: [12, 12],
        col_sm: [3, 9],
        col_1_content: page.sidebar_first,
        col_1_attributes: { role: 'complementary' },
        col_2_content: main_content,
      }, with_context = false) }}
    {% elseif page.sidebar_second %}
      {{ include('ui_suite_bnp:grid_row_2', {
        container: container,
        gutters_horizontal: ps_grid_gx,
        col_xs: [12, 12],
        col_sm: [9, 3],
        col_1_content: main_content,
        col_2_content: page.sidebar_second,
        col_2_attributes: { role: 'complementary' },
      }, with_context = false) }}
    {% else %}
      {{ include('ui_suite_bnp:grid_row_1', {
        container: container,
        gutters_horizontal: ps_grid_gx,
        container_attributes: is_front ? ps_grid_bleed_container : {},
        col_xs: 12,
        col_attributes: is_front ? ps_grid_bleed_col : {},
        col_1_content: main_content,
      }, with_context = false) }}
    {% endif %}
  </main>

  {% if ps_has_site_footer %}
    <footer class="site-footer ps-site-footer" role="contentinfo">
      {{ include('ps_theme:site-footer', {
        container_prefooter: container,
        container_main: 'container',
        container_bottom: 'container-fluid',
        prefooter: ps_site_footer.prefooter,
        contact: ps_site_footer.contact,
        social: ps_site_footer.social,
        business: ps_site_footer.business,
        about: ps_site_footer.about,
        branding: ps_site_footer.branding,
        legal: ps_site_footer.legal,
        copyright: ps_site_footer.copyright,
      }, with_context = false) }}
    </footer>
  {% endif %}
</div>
