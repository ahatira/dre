{#
/**
 * @file
 * Offer search view mode — horizontal search card for search results.
 */
#}
{% if offer_search_card_component %}
  <div class="ps-offer-search-card-wrapper">
    {{ offer_search_card_component }}
  </div>
{% else %}
  {{ title_prefix }}
  {% if label %}
    <h2{{ title_attributes }}>{{ label }}</h2>
  {% endif %}
  {{ title_suffix }}
  {{ content }}
{% endif %}
