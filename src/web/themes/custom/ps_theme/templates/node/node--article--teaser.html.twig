{#
/**
 * @file
 * Article teaser — renders the news-teaser-card SDC.
 */
#}
{% if news_teaser_card_component %}
  <div class="ps-news-teaser-card-wrapper">
    {{ news_teaser_card_component }}
  </div>
{% else %}
  {{ title_prefix }}
  {% if label %}
    <h2{{ title_attributes }}>{{ label }}</h2>
  {% endif %}
  {{ title_suffix }}
  {{ content }}
{% endif %}
