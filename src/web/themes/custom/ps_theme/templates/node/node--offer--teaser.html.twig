{#
/**
 * @file
 * Offer teaser — renders the offer-card SDC (vertical grid / homepage).
 */
#}
{% if offer_card_component %}
  <div class="ps-offer-card-wrapper h-100">
    {{ offer_card_component }}
  </div>
{% elseif offer_card %}
  <div class="ps-offer-card-wrapper h-100">
    {% include 'ps_theme:offer-card' with offer_card only %}
  </div>
{% else %}
  {{ title_prefix }}
  {% if label and view_mode != 'teaser' %}
    <h2{{ title_attributes }}>{{ label }}</h2>
  {% endif %}
  {{ title_suffix }}
  {{ content }}
{% endif %}
