{#
/**
 * @file
 * Homepage search hero — BNPPRE 2-column layout.
 */
#}
<section{{ attributes.addClass('ps-search-hero', 'position-relative') }}>
  {% if background_image %}
    <div class="ps-search-hero__background" aria-hidden="true">
      <img src="{{ background_image }}" alt="{{ background_alt|default('') }}" class="ps-search-hero__image" />
      <div class="ps-search-hero__overlay"></div>
    </div>
  {% endif %}

  <div class="container position-relative py-4 py-lg-5">
    {% if title %}
      <h1 class="ps-search-hero__title">{{ title }}</h1>
    {% endif %}
    <div class="row g-0 align-items-stretch ps-search-hero__card">
      <div class="col-lg-6 ps-search-hero__form-col">
        {% if search %}
          <div class="ps-search-hero__search">
            {{ search }}
          </div>
        {% endif %}
      </div>

      <div class="col-lg-6 ps-search-hero__promo-col">
        <aside class="ps-search-hero__promo" aria-label="{{ promo_title|default('') }}">
          {% if promo_background_image %}
            <div class="ps-search-hero__promo-background" aria-hidden="true">
              <img src="{{ promo_background_image }}" alt="{{ promo_background_alt|default('') }}" class="ps-search-hero__promo-image" />
              <div class="ps-search-hero__promo-overlay"></div>
            </div>
          {% endif %}
          <div class="ps-search-hero__promo-content">
            {% if promo_title %}
              <h2 class="ps-search-hero__promo-title">{{ promo_title }}</h2>
            {% endif %}
            {% if promo_offers_line %}
              <p class="ps-search-hero__promo-count">{{ promo_offers_line }}</p>
            {% endif %}
            {% if promo_description %}
              <p class="ps-search-hero__promo-body">{{ promo_description }}</p>
            {% endif %}
            {% if promo_cta_label and promo_cta_url %}
              <a class="btn btn-outline-light ps-search-hero__promo-cta" href="{{ promo_cta_url }}">{{ promo_cta_label }}</a>
            {% endif %}
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>
