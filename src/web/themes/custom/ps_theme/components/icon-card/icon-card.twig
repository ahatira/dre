{#
/**
 * @file
 * Homepage service icon card — Figma Frame 38/39 (§2 Services).
 */
#}
{% set button_class = button_style|default('primary') == 'primary' ? 'btn-primary' : 'btn-outline-primary' %}
{% set btn_width_class = button_width|default('full') == 'full' ? 'w-100' : '' %}
{% set card_classes = ['ps-icon-card'] %}
{% set bg = background|default('transparent') %}
{% if bg != 'transparent' and bg != '' %}
  {% set card_classes = card_classes|merge(['ps-icon-card--bg-' ~ bg]) %}
{% endif %}
{% set align = text_align|default('center') %}
{% if align == 'left' %}
  {% set card_classes = card_classes|merge(['ps-icon-card--align-left']) %}
{% endif %}
{% set elev = elevation|default('none') %}
{% if elev == 'sm' or elev == 'md' %}
  {% set card_classes = card_classes|merge(['ps-icon-card--elevation-' ~ elev]) %}
{% endif %}
{% set icon_sizes = { 'sm': '24px', 'md': '32px', 'lg': '48px' } %}
{% set icon_px = icon_sizes[icon_size|default('md')] ?? '32px' %}
<article{{ attributes.addClass(card_classes) }}>
  {% if icon_pack and icon_id %}
    <div class="ps-icon-card__icon" aria-hidden="true">
      {{ icon(icon_pack, icon_id, {size: icon_px}) }}
    </div>
  {% endif %}
  {% if title %}
    <h3 class="ps-icon-card__title">{{ title }}</h3>
  {% endif %}
  {% if body %}
    <p class="ps-icon-card__text">{{ body }}</p>
  {% endif %}
  {% if button_label %}
    <div class="ps-icon-card__actions">
      {% if link_type == 'modal' and modal_id %}
        <button type="button" class="btn {{ button_class }} {{ btn_width_class }} ps-icon-card__button" data-bs-toggle="modal" data-bs-target="#{{ modal_id }}">
          {{ button_label }}
        </button>
      {% elseif link_type in ['offcanvas', 'ajax_modal'] and button_url %}
        <a href="{{ button_url }}"
           class="btn {{ button_class }} {{ btn_width_class }} ps-icon-card__button {{ dialog_attributes.class|default('use-ajax') }}"
           {% for attribute, value in dialog_attributes|default({}) %}
             {% if attribute != 'class' %}
               {{ attribute }}="{{ value|e('html_attr') }}"
             {% endif %}
           {% endfor %}>
          {{ button_label }}
        </a>
      {% elseif button_url %}
        <a href="{{ button_url }}" class="btn {{ button_class }} {{ btn_width_class }} ps-icon-card__button">{{ button_label }}</a>
      {% endif %}
    </div>
  {% endif %}
</article>
