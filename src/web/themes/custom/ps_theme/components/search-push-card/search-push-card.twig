{#
/**
 * @file
 * Search results push card — calculator interstitial (maquette Property search - Push).
 */
#}
{% set cta_class = cta_button_style|default('outline') == 'primary' ? 'btn-primary' : 'btn-outline-primary' %}
{% set card_classes = ['ps-search-push-card'] %}
{% set bg = background|default('default') %}
{% if bg != 'default' and bg != '' %}
  {% set card_classes = card_classes|merge(['ps-search-push-card--bg-' ~ bg]) %}
{% endif %}
{% set align = text_align|default('left') %}
{% if align == 'center' %}
  {% set card_classes = card_classes|merge(['ps-search-push-card--align-center']) %}
{% endif %}
{% if cta_width|default('auto') == 'full' %}
  {% set card_classes = card_classes|merge(['ps-search-push-card--cta-full']) %}
{% endif %}
{% set border_v = border|default('default') %}
{% if border_v == 'none' or border_v == 'accent' %}
  {% set card_classes = card_classes|merge(['ps-search-push-card--border-' ~ border_v]) %}
{% endif %}
{% set elev = elevation|default('none') %}
{% if elev == 'sm' or elev == 'md' %}
  {% set card_classes = card_classes|merge(['ps-search-push-card--elevation-' ~ elev]) %}
{% endif %}
<article{{ attributes.addClass(card_classes) }}>
  <h3 class="ps-search-push-card__title">{{ title }}</h3>
  {% if body %}
    <p class="ps-search-push-card__body">{{ body }}</p>
  {% endif %}
  {% if cta_label and cta_url %}
    <a href="{{ cta_url }}" class="btn {{ cta_class }} ps-search-push-card__cta">{{ cta_label }}</a>
  {% endif %}
</article>
