{#
/**
 * @file
 * Search results push card — calculator interstitial (maquette Property search - Push).
 */
#}
<article class="ps-search-push-card">
  <h3 class="ps-search-push-card__title">{{ title }}</h3>
  {% if body %}
    <p class="ps-search-push-card__body">{{ body }}</p>
  {% endif %}
  {% if cta_label and cta_url %}
    <a href="{{ cta_url }}" class="btn btn-outline-primary ps-search-push-card__cta">{{ cta_label }}</a>
  {% endif %}
</article>
