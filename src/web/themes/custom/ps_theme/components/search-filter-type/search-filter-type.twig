{#
/**
 * @file
 * Property type grid + transaction buttons (filter bar popin / mobile stack).
 */
#}
<div class="ps-filter-popin__section ps-filter-popin__section--assets">
  <ul class="ps-asset-grid" role="list">
    {% for asset in asset_types %}
      <li class="ps-asset-card{% if asset.active %} is-active{% endif %}" role="listitem">
        <button
          class="ps-asset-card__link js-ps-asset-btn"
          type="button"
          data-code="{{ asset.code }}"
          aria-pressed="{{ asset.active ? 'true' : 'false' }}"
        >
          <span class="ps-asset-card__icon" aria-hidden="true">{{ asset.icon }}</span>
          <span class="ps-asset-card__label">{{ asset.label }}</span>
        </button>
      </li>
    {% endfor %}
  </ul>
</div>

<div class="ps-filter-popin__section ps-filter-popin__section--op js-ps-operation-section"{% if hide_operation_section|default(false) %} hidden{% endif %}>
  <h3 class="ps-filter-popin__heading ps-filter-popin__heading--sentence">{{ 'Transaction type'|t }}</h3>
  <div class="ps-op-choices" role="group" aria-label="{{ 'Transaction type'|t }}">
    {% for op in operation_types %}
      <button
        class="ps-op-btn{% if op.active %} is-active{% endif %} js-ps-op-btn"
        type="button"
        data-code="{{ op.code }}"
        aria-pressed="{{ op.active ? 'true' : 'false' }}"
      >
        {{ op.label }}
      </button>
    {% endfor %}
    <button
      class="ps-op-btn{% if active_flexible %} is-active{% endif %} js-ps-op-btn"
      type="button"
      data-code="FLEX"
      aria-pressed="{{ active_flexible ? 'true' : 'false' }}"
    >
      {{ "I'm flexible"|t }}
    </button>
  </div>
</div>
