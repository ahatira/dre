{#
/**
 * @file
 * Location editor row — chips + text input (filter bar / mobile stack).
 */
#}
{% set input_id = 'ps-filter-location-input' ~ id_suffix|default('') %}
{% set suggest_controls = suggest_id|default('ps-location-suggest' ~ id_suffix|default('')) %}

<div
  class="ps-filter-bar__toggle ps-filter-bar__toggle--location js-ps-location-toggle d-flex align-items-center w-100{% if layout|default('dropdown') == 'stacked' %} ps-filter-bar__toggle--stacked{% endif %}"
  aria-expanded="false"
>
  <div class="ps-filter-bar__location-editor js-ps-location-editor min-w-0 flex-grow-1">
    <div class="ps-filter-bar__location-chips js-ps-location-chips"></div>
    <input
      id="{{ input_id }}"
      type="text"
      class="ps-filter-bar__location-input js-ps-locality-input"
      placeholder="{{ placeholder|default('City, district or zip code'|t) }}"
      autocomplete="off"
      aria-label="{{ aria_label|default('Location: city or postal code'|t) }}"
      aria-autocomplete="list"
      role="combobox"
      aria-controls="{{ suggest_controls }}"
      maxlength="100"
    >
  </div>
  <button
    type="button"
    class="ps-filter-bar__location-clear js-ps-location-clear-input"
    hidden
    aria-label="{{ 'Clear location search'|t }}"
  >
    ×
  </button>
</div>
