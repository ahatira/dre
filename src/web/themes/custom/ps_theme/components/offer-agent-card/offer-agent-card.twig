<div class="ps-offer-agent-card ps-offer-agent-panel">
  <div class="ps-offer-agent-card__consultant">
    {% if agent %}
      <div class="ps-offer-agent-card__profile">
        {{ agent }}
      </div>
    {% endif %}
    {% if contact_url %}
      <a href="{{ contact_url }}"
         class="btn btn-primary ps-offer-agent-card__contact use-ajax"
         data-dialog-type="modal"
         data-dialog-options="{{ contact_dialog_options|e('html_attr') }}">
        {{ contact_label }}
      </a>
    {% else %}
      <button type="button" class="btn btn-primary ps-offer-agent-card__contact" disabled aria-disabled="true">
        {{ contact_label }}
      </button>
    {% endif %}
  </div>

  {% if visit_enabled and visit_phone %}
    <div class="ps-offer-agent-card__visit">
      {% if visit_title %}
        <h3 class="ps-offer-agent-card__visit-title">{{ visit_title }}</h3>
      {% endif %}
      <a href="{{ visit_phone }}" class="btn ps-offer-agent-card__visit-btn">
        {{ icon('bootstrap', 'calendar', {'size': '20px', 'class': 'ps-offer-agent-card__visit-icon'}) }}
        {{ visit_label }}
      </a>
    </div>
  {% endif %}

  <div class="ps-offer-agent-card__mobile-actions{% if not (visit_enabled and visit_phone) %} ps-offer-agent-card__mobile-actions--contact-only{% endif %}" role="group" aria-label="{{ 'Offer actions'|t }}">
    {% if visit_enabled and visit_phone %}
      <a href="{{ visit_phone }}" class="btn ps-offer-agent-card__mobile-visit">
        {{ visit_label_mobile }}
      </a>
    {% endif %}
    {% if contact_url %}
      <a href="{{ contact_url }}"
         class="btn btn-primary ps-offer-agent-card__mobile-contact use-ajax"
         data-dialog-type="modal"
         data-dialog-options="{{ contact_dialog_options|e('html_attr') }}">
        {{ contact_label_mobile }}
      </a>
    {% else %}
      <button type="button" class="btn btn-primary ps-offer-agent-card__mobile-contact" disabled aria-disabled="true">
        {{ contact_label_mobile }}
      </button>
    {% endif %}
  </div>
</div>
