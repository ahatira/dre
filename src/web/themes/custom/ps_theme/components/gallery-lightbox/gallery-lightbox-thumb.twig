{#
  Lightbox thumb — image or placeholder with centered type icon.
#}
{% set slide_type = slide.type|default('image') %}
{% set slide_label = slide.label|default(slide.alt|default('')) %}
{% set is_image_slide = slide_type in ['image', 'plan_image'] %}
{% set media_icon = slide_type starts with 'video' ? 'play' : (slide_type == 'visit_3d' ? '3d' : (slide_type starts with 'plan' ? 'file' : '')) %}

{% if is_image_slide and slide.thumb_url %}
  <img src="{{ slide.thumb_url }}" alt="" loading="lazy" />
{% else %}
  <span class="ps-gallery-lightbox__thumb-media">
    {% if slide.thumb_url %}
      <img src="{{ slide.thumb_url }}" alt="" loading="lazy" />
    {% else %}
      <span class="ps-gallery-lightbox__thumb-placeholder" aria-hidden="true"></span>
    {% endif %}
    {% if media_icon %}
      <span class="ps-gallery-lightbox__thumb-icon ps-gallery-lightbox__thumb-icon--{{ media_icon }}" aria-hidden="true"></span>
    {% endif %}
  </span>
  <span class="visually-hidden">{{ slide_label }}</span>
{% endif %}
