{#
/**
 * @file
 * News article teaser card.
 */
#}
<article class="ps-news-teaser-card card h-100 border-0">
  {% if image %}
    <div class="ps-news-teaser-card__media ratio" style="--bs-aspect-ratio: 56%;">
      <img src="{{ image }}" alt="{{ image_alt|default(title) }}" class="card-img-top object-fit-cover h-100 w-100" loading="lazy" />
    </div>
  {% endif %}
  <div class="card-body ps-news-teaser-card__body d-flex flex-column">
    {% if categories %}
      <ul class="ps-news-teaser-card__tags list-unstyled d-flex flex-wrap gap-2 mb-2">
        {% for category in categories %}
          <li><span class="badge text-bg-light">{{ category }}</span></li>
        {% endfor %}
      </ul>
    {% endif %}
    {% if date %}
      <p class="ps-news-teaser-card__date small text-muted mb-2">{{ date }}</p>
    {% endif %}
    <h3 class="ps-news-teaser-card__title card-title h6 mb-2">
      {% if url %}
        <a href="{{ url }}" class="stretched-link text-decoration-none text-body">{{ title }}</a>
      {% else %}
        {{ title }}
      {% endif %}
    </h3>
    {% if excerpt %}
      <p class="ps-news-teaser-card__excerpt small text-muted mb-0">{{ excerpt }}</p>
    {% endif %}
  </div>
</article>
