{#
/**
 * @file
 * Primary CTA button + optional fallback URL line.
 */
#}
{% set green = email_primary_color|default('#00915a') %}
{% set hover = email_primary_hover_color|default('#04af6e') %}
{% set text = email_text_color|default('#333333') %}
{% set surface = email_surface_color|default('#ffffff') %}
{% set radius = email_button_radius|default('0') %}
{% set url = button_url|default('') %}
{% set label = button_label|default('') %}

{% if url and label %}
  <mj-section background-color="{{ surface }}" padding="0 16px 24px">
    <mj-column>
      <mj-button href="{{ url }}" background-color="{{ green }}" color="#ffffff" font-size="13px" font-weight="700" letter-spacing="0.06em" text-transform="uppercase" border-radius="{{ radius }}" inner-padding="14px 28px">
        {{ label }}
      </mj-button>
      {% if button_show_fallback|default(true) %}
        <mj-text color="{{ text }}" font-size="13px" padding-top="16px">
          {{ 'If the button does not work, copy the following URL into your browser:'|t }}<br />
          <a href="{{ url }}" style="color:{{ hover }};text-decoration:none;word-break:break-all;">{{ url }}</a>
        </mj-text>
      {% endif %}
    </mj-column>
  </mj-section>
{% endif %}
