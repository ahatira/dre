{#
/**
 * @file
 * Email header — logo, vertical divider, slogan (Stellar-aligned).
 */
#}
{% set text = email_text_color|default('#333333') %}
{% set muted = email_muted_color|default('#777e83') %}
{% set surface = email_surface_color|default('#ffffff') %}
{% set divider = email_header_divider_color|default('#cccccc') %}

<mj-section background-color="{{ surface }}" padding="20px 16px 16px">
  <mj-group>
    <mj-column width="40%" vertical-align="middle">
      {% if email_logo_url %}
        <mj-image src="{{ email_logo_url }}" alt="{{ 'BNP Paribas Real Estate'|t }}" width="{{ email_logo_width|default(162) }}px" align="left" padding="0" />
      {% else %}
        <mj-text font-size="11px" font-weight="700" letter-spacing="0.04em" text-transform="uppercase" color="{{ text }}" padding="0">
          BNP Paribas Real Estate
        </mj-text>
      {% endif %}
    </mj-column>
    {% if site_slogan %}
      <mj-column width="4%" vertical-align="middle" padding="0">
        <mj-divider border-width="1px" border-color="{{ divider }}" padding="0 4px" width="1px" />
      </mj-column>
      <mj-column width="56%" vertical-align="middle" css-class="ps-email-slogan-wrap">
        <mj-text font-size="16px" line-height="24px" color="{{ muted }}" padding="0 0 0 9px">
          {{ site_slogan }}
        </mj-text>
      </mj-column>
    {% endif %}
  </mj-group>
</mj-section>
