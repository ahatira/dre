{#
/**
 * @file
 * Footer zones from ps_email.footer — HTML table via mj-raw in mj-section.
 *
 * mj-raw must be a direct child of mj-section (not mj-column) so the 2-column
 * table layout is not nested inside MJML column tables.
 *
 * Variables: email_footer, email_legal.
 */
#}
{% if email_footer %}
  <mj-section padding="0" background-color="transparent">
    <mj-raw>{{ email_footer|raw }}</mj-raw>
  </mj-section>
{% endif %}

{% if email_legal %}
  <mj-section padding="0" background-color="transparent">
    <mj-raw>{{ email_legal|raw }}</mj-raw>
  </mj-section>
{% endif %}
