{#
/**
 * @file
 * Rendered footer zones (email_footer + email_legal) from ps_email.footer WYSIWYG.
 */
#}
{% if email_footer %}
  <mj-section padding="0" background-color="transparent">
    <mj-column padding="0">
      <mj-raw>{{ email_footer|raw }}</mj-raw>
    </mj-column>
  </mj-section>
{% endif %}

{% if email_legal %}
  <mj-section padding="0" background-color="transparent">
    <mj-column padding="0">
      <mj-raw>{{ email_legal|raw }}</mj-raw>
    </mj-column>
  </mj-section>
{% endif %}
