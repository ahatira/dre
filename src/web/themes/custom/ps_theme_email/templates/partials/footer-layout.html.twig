{#
/**
 * @file
 * Legal-only footer — green accent rule + legal block (variant H).
 *
 * Variables: email_accent_rule, email_legal.
 */
#}
{% if email_accent_rule %}
  <mj-section padding="0" background-color="transparent">
    <mj-raw>{{ email_accent_rule|raw }}</mj-raw>
  </mj-section>
{% endif %}

{% if email_legal %}
  <mj-section padding="0" background-color="transparent">
    <mj-raw>{{ email_legal|raw }}</mj-raw>
  </mj-section>
{% endif %}
