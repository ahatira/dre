{#
/**
 * @file
 * Search-style offer card for HTML emails (horizontal desktop, stacked mobile).
 *
 * Mirrors ps_theme:offer-search-card layout with table-safe markup.
 */
#}
{% set green = email_primary_color|default('#00915a') %}
{% set text = email_text_color|default('#333333') %}
{% set muted = email_muted_color|default('#777e83') %}
{% set border = email_border_color|default('#ebedef') %}
{% set badge = email_exclusive_badge_color|default('#C5A26D') %}
{% set card_url = url|default('') %}
{% set surface_line = surface_primary|default(surface|default('')) %}
{% set cta = cta_label|default('View the property'|t) %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="ps-offer-email-search-card" style="margin:0 0 16px;border:1.5px solid {{ border }};border-collapse:collapse;width:100%;">
  <tr>
    <td style="padding:0;">
      {% if card_url %}
        <a href="{{ card_url }}" style="color:{{ text }};text-decoration:none;display:block;">
      {% endif %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="ps-offer-email-search-card__layout" style="border-collapse:collapse;width:100%;">
        <tr>
          {% if image %}
            <td class="ps-offer-email-search-card__media" width="33%" valign="top" style="padding:0;width:33%;background:#f9f9fb;vertical-align:top;">
              <img src="{{ image }}" alt="{{ image_alt|default(title)|e('html_attr') }}" width="200" class="ps-offer-email-search-card__image" style="display:block;width:100%;max-width:100%;height:auto;min-height:160px;object-fit:cover;border:0;">
            </td>
          {% endif %}
          <td class="ps-offer-email-search-card__content" valign="top" style="padding:16px 20px 20px;vertical-align:top;{% if not image %}width:100%;{% endif %}">
            {% if exclusive %}
              <p style="margin:0 0 8px;font-size:11px;line-height:1.4;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:{{ badge }};">{{ 'Exclusivity'|t }}</p>
            {% endif %}
            {% if title %}
              <p class="ps-offer-email-search-card__title" style="margin:0 0 8px;font-size:16px;line-height:1.4;font-weight:700;color:{{ text }};">{{ title }}</p>
            {% endif %}
            {% if surface_line %}
              <p style="margin:0 0 8px;font-size:14px;line-height:1.4;color:{{ text }};">
                <span style="font-weight:700;">{{ surface_line }}</span>{% if surface_suffix %} <span style="font-weight:400;">{{ surface_suffix }}</span>{% endif %}
              </p>
            {% endif %}
            {% if location %}
              <p style="margin:0 0 12px;font-size:13px;line-height:1.4;color:{{ muted }};">{{ location }}</p>
            {% endif %}
            {% if reference %}
              <p style="margin:0 0 12px;font-size:12px;line-height:1.4;color:{{ muted }};">{{ 'Ref.'|t }} {{ reference }}</p>
            {% endif %}
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="ps-offer-email-search-card__footer" style="border-collapse:collapse;width:100%;">
              <tr>
                <td valign="bottom" style="padding:0;vertical-align:bottom;">
                  {% if price_amount %}
                    <p style="margin:0;font-size:16px;line-height:1.4;font-weight:700;color:{{ text }};">
                      {{ price_amount }}{% if price_qualifiers %} <span style="font-weight:400;">{{ price_qualifiers|raw }}</span>{% endif %}
                    </p>
                  {% elseif price_on_request_label %}
                    <p style="margin:0;font-size:16px;line-height:1.4;font-weight:700;color:{{ text }};">{{ price_on_request_label }}</p>
                  {% endif %}
                </td>
                {% if card_url %}
                  <td align="right" valign="bottom" class="ps-offer-email-search-card__cta-cell" style="padding:0 0 0 12px;vertical-align:bottom;white-space:nowrap;">
                    <span style="font-size:14px;line-height:1.4;font-weight:700;color:{{ green }};">{{ cta }} &gt;</span>
                  </td>
                {% endif %}
              </tr>
            </table>
          </td>
        </tr>
      </table>
      {% if card_url %}
        </a>
      {% endif %}
    </td>
  </tr>
</table>
