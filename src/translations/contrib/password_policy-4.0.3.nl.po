msgstr "Aantal tekens"
msgid "Password Blacklist"
msgstr "Wachtwoord-zwarte lijst"
msgid "password policy"
msgstr "wachtwoordbeleid"
msgid "Password must not contain the username."
msgstr "Het wachtwoord mag niet de gebruikersnaam bevatten."
msgid "Blacklisted passwords"
msgstr "Wachtwoorden op de zwarte lijst"
msgid "at least"
msgstr "ten minste"
msgid "Unique name"
msgstr "Unieke naam"
msgid "There are no constraints for the selected user roles"
msgstr "Er zijn geen beperkingen voor de geselecteerde gebruikersrollen"
msgid ""
"New role was added or existing password policy changed. Please update "
"your password."
msgstr ""
"Nieuwe rol is toegevoegd of bestaand wachtwoordbeleid gewijzigd. Werk "
"uw wachtwoord bij."
msgid "Sets up constraints and expiration of passwords."
msgstr "Stelt beperkingen en vervaltijd in voor wachtwoorden."
msgid "Add Policy"
msgstr "Beleid toevoegen"
msgid "Force Password Reset"
msgstr "Forceer het opnieuw instellen van wachtwoord"
msgid "Manage password reset"
msgstr "Wachtwoordverloop beheren"
msgid "Be able to manually override user password reset dates."
msgstr "Het is mogelijk handmatig de wachtwoord-reset datum te wijzigen."
msgid "Password Policies"
msgstr "Wachtwoordbeleid"
msgid "Delete policy"
msgstr "Beleid verwijderen"
msgid "Constraint settings"
msgstr "Beperkingsinstellingen"
msgid "Character type"
msgstr "Tekensoort"
msgid "The number of characters must be a positive number."
msgstr "Het aantal tekens moet een positief getal zijn."
msgid "Password character type"
msgstr "Wachtwoord tekensoort"
msgid "Verifying that a password has a specific number of characters"
msgstr "Controleren of een wachtwoord een specifiek aantal tekens heeft"
msgid ""
"The password does not contain a the correct number of certain "
"characters."
msgstr "Het wachtwoord bevat niet het juiste aantal van bepaalde tekens."
msgid "Password Policy History"
msgstr "Wachtwoordbeleid geschiedenis"
msgid ""
"Sets up a password constraint to limit repeated use of the same "
"password."
msgstr ""
"Stelt een wachtwoordbeperking in om herhaald gebruik van hetzelfde "
"wachtwoord te beperken."
msgid "The number of repeated passwords value must be zero or greater."
msgstr "Het aantal herhaalde wachtwoorden moet nul of groter zijn."
msgid "Password History"
msgstr "Wachtwoordgeschiedenis"
msgid "Provide restrictions on previously used passwords."
msgstr "Biedt beperkingen op eerder gebruikte wachtwoorden."
msgid "You have used the same password previously and cannot."
msgstr "U hebt eerder hetzelfde wachtwoord gebruikt en dat is niet toegestaan."
msgid "Password Character Length Policy"
msgstr "Wachtwoordbeleid aantal tekens"
msgid "Sets up a character length constraint for passwords."
msgstr "Beperkt de maximale lengte in van wachtwoorden."
msgid "The character length must be a positive number."
msgstr "De tekenlengte moet een positief getal zijn."
msgid "Password character length"
msgstr "Wachtwoord tekenlengte"
msgid "Verifying that a password has a minimum character length"
msgstr "Controleren of een wachtwoord een minimale tekenlengte heeft"
msgid "The length of your password is too short."
msgstr "Uw wachtwoord bevat te weinig tekens."
msgid "Are you sure you want to delete the @label constraint?"
msgstr "Weet u zeker dat u de beperking @label wilt verwijderen?"
msgid "Configure Constraint Settings"
msgstr "Beperkingsinstellingen configureren"
msgid "Plugin Id"
msgstr "Plugin Id"
msgid "No constraints have been configured."
msgstr "Er zijn geen beperkingen geconfigureerd."
msgid "Configure Required Context"
msgstr "Verplichte context instellen"
msgid "Are you sure you want to delete the %name policy?"
msgstr "Weet u zeker dat u het beleid %name wilt verwijderen?"
msgid "The @label password policy has been deleted."
msgstr "Het beleid @label is verwijderd."
msgid "Password Reset Days"
msgstr "Wachtwoordverloop"
msgid "Apply to Roles"
msgstr "Toepassen op Rollen"
msgid "Select Roles to which this policy applies."
msgstr "Selecteer Rollen waarop dit beleid van toepassing is."
msgid "Force password reset of selected roles."
msgstr "Forceer opnieuw instellen voor de geselecteerde rollen."
msgid "Exclude Myself"
msgstr "Sluit mezelf uit"
msgid "Exclude your account if you are included in the roles."
msgstr "Sluit uw account uit als u deel uitmaakt van de rollen."
msgid "No roles selected."
msgstr "Geen rollen geselecteerd."
msgid "Reset the %roles role."
msgid_plural "Reset the %roles roles."
msgstr[0] "De rol %roles opnieuw instellen."
msgstr[1] "De rollen %roles opnieuw instellen."
msgid "Policy Name"
msgstr "Beleidsnaam"
msgid "Configuring security settings."
msgstr "Beveiligingsinstellingen configureren."
msgid "Create password policies."
msgstr "Wachtwoordbeleid maken."
msgid "Last Password Reset"
msgstr "Laatste wachtwoordreset"
msgid "Enter label for this context."
msgstr "Voer een label in voor deze context."
msgid "Password Character Types Policy"
msgstr "Wachtwoordbeleid voor tekendiversiteit"
msgid "Character Types"
msgstr "Soorten tekens"
msgid "Invalid plugin configuration."
msgstr "Ongeldige pluginconfiguratie."
msgid "Minimum number of character types"
msgstr "Minimum aantal karaktertypes"
msgid "The number of character types must be between 2 and 4."
msgstr "Het aantal tekensoorten moet tussen 2 en 4 liggen."
msgid "Minimum password character types: @types"
msgstr "Minimaal aantal tekensoorten: @types"
msgid "Password character types"
msgstr "Wachtwoordbeleid tekensoorten"
msgid "Verifying that a password has a minimum number of character types."
msgstr "Controleren of een wachtwoord een minimaal aantal tekensoorten heeft."
msgid "Your password must have different character types."
msgstr "Het wachtwoord moet verschillende soorten tekens bevatten."
msgid "Password length must be at least 1 character."
msgid_plural "Password length must be at least @count characters."
msgstr[0] "Het wachtwoord moet minimaal 1 teken lang zijn."
msgstr[1] "Het wachtwoord moet minimaal @count tekens lang zijn."
msgid "Password length must not exceed 1 character."
msgid_plural "Password length must not exceed @count characters."
msgstr[0] "Het wachtwoord mag niet langer zijn dan 1 teken."
msgstr[1] "Het wachtwoord mag niet langer zijn dan @count tekens."
msgid "Password Username Policy"
msgstr "Wachtwoordbeleid gebruikersnamen"
msgid "Restrict users from having their username in their password."
msgstr "Gebruikers mogen niet hun gebruikersnaam in hun wachtwoord opnemen."
msgid "Disallow username"
msgstr "Gebruikersnaam niet toestaan"
msgid "Prevent user from having a password containing their username."
msgstr ""
"Voorkom dat gebruikers een wachtwoord hebben met hun gebruikersnaam "
"erin."
msgid "Password must not contain the user's username."
msgstr "Wachtwoord mag niet de gebruikersnaam van de gebruiker bevatten."
msgid "Password username"
msgstr "Wachtwoord gebruikersnaam"
msgid "Password must not contain their username"
msgstr "Het wachtwoord mag niet hun gebruikersnaam bevatten."
msgid "Your password contains your username."
msgstr "Uw wachtwoord bevat uw gebruikersnaam."
msgid "password policies"
msgstr "wachtwoordbeleiden"
msgid "Expired Password"
msgstr "Verlopen Wachtwoord"
msgid "Non-expired Password"
msgstr "Niet-verlopen Wachtwoord"
msgid "Fail - @message"
msgstr "Mislukt - @message"
msgid "The password does not satisfy the password policies."
msgstr "Het wachtwoord voldoet niet aan de voorwaarden."
msgid "Password Policy settings"
msgstr "Wachtwoordbeleid instellingen"
msgid "Cron threshold"
msgstr "Cron-drempel"
msgid "Password Consecutive Characters Policy"
msgstr "Wachtwoordbeleid voor opeenvolgende tekens"
msgid "Sets up a consecutive characters constraint for passwords."
msgstr "Stelt een beperking in op het aantal opeenvolgende tekens."
msgid "Maximum consecutive character count"
msgstr "Maximaal aantal opeenvolgende tekens."
msgid ""
"Password must have fewer than @max consecutive identical characters. "
"This is case sensitive."
msgstr ""
"Wachtwoord moet minder dan @max opeenvolgende identieke tekens "
"bevatten. Dit is hoofdlettergevoelig."
msgid ""
"The number of consecutive identical characters must be higher than 1 "
"otherwise all passwords will fail."
msgstr ""
"Het aantal opeenvolgende identieke tekens moet groter zijn dan 1, "
"anders mislukken alle wachtwoorden."
msgid "Consecutive characters"
msgstr "Opeenvolgende tekens"
msgid ""
"Verifying that a password has a maximum number of consecutive "
"identical characters."
msgstr ""
"Controleren of een wachtwoord een maximum aantal opeenvolgende "
"identieke tekens heeft."
msgid "Your password has too many consecutive characters."
msgstr "Uw wachtwoord heeft te veel opeenvolgende tekens."
msgid "Minimum number of different character types the password must contain."
msgstr ""
"Minimum aantal verschillende soorten tekens dat het wachtwoord moet "
"bevatten."
msgid ""
"Password must contain at least @types types of characters from the "
"following character types: lowercase letters, uppercase letters, "
"digits, special characters."
msgstr ""
"Wachtwoord moet ten minste tekens bevatten uit @types van de volgende "
"tekensoorten: kleine letters, hoofdletters, cijfers, speciale tekens."
msgid ""
"Select the minimum number of character types which must be found in a "
"password. The four supported character types are given as: lowercase "
"letters, uppercase letters, digits, special characters."
msgstr ""
"Selecteer het minimum aantal tekensoorten dat in een wachtwoord "
"aanwezig moet zijn. De vier ondersteunde soorten worden gegeven als: "
"kleine letters, hoofdletters, cijfers, speciale tekens."
msgid "Password Characters of Type Policy"
msgstr "Wachtwoordbeleid voor aantal tekens per soort"
msgid "Minimum characters of a particular type the password must contain."
msgstr ""
"Minimaal aantal tekens van een bepaald type dat het wachtwoord moet "
"bevatten."
msgid "Your password has expired, please update it"
msgstr "Uw wachtwoord is verlopen, werk het bij alstublieft"
msgid "Add Constraint"
msgstr "Beperking toevoegen"
msgid "Policy Constraints"
msgstr "Beleidsbeperkingen"
msgid "Password character length of @operation 1 character"
msgid_plural "Password character length of @operation @characters characters"
msgstr[0] "Wachtwoordlengte van @operation één teken"
msgstr[1] "Wachtwoordlengte van @operation @characters tekens"
msgid "Password must contain at least 1 letter character."
msgid_plural "Password must contain at least @count letter characters."
msgstr[0] "Wachtwoord moet minimaal 1 letterteken bevatten."
msgstr[1] "Wachtwoord moet minimaal @count lettertekens bevatten."
msgid ""
"Your password has expired. Please visit the following link to reset "
"your password: :link"
msgstr ""
"Uw wachtwoord is verlopen. Klik op de volgende link om uw wachtwoord "
"opnieuw in te stellen: :link"
msgid ""
"Your password will expire in less than :pending days. Please visit the "
"following link to reset your password: :link"
msgstr ""
"Uw wachtwoord verloopt over minder dan :pending dagen. Klik op de "
"volgende link om uw wachtwoord opnieuw in te stellen: :link"
msgid "You need to reset your password."
msgstr "U moet uw wachtwoord opnieuw instellen."
msgid "Your password will expire soon."
msgstr "Uw wachtwoord verloopt binnenkort."
msgid ""
"The Password Policy module has updated user accounts. Total update "
"count: @count"
msgstr ""
"De module The Password Policy heeft gebruikersaccounts bijgewerkt. "
"Totaal aantal updates: @count"
msgid "Password reset send email"
msgstr "E-mail verzenden bij wachtwoordherstel"
msgid "Password reset pending days"
msgstr "Openstaande dagen voor wachtwoordherstel"
msgid "Password reset pending day"
msgstr "Openstaande dag voor wachtwoordherstel"
msgid "Send email upon password expiring"
msgstr "E-mail verzenden wanneer een wachtwoord verloopt"
msgid ""
"If checked, an email will go to each user when their password expires, "
"with a link to the request password reset email page."
msgstr ""
"Indien aangevinkt, wordt naar elke gebruiker een e-mail verstuurd als "
"het wachtwoord verloopt, met een link naar de pagina voor het opnieuw "
"instellen van het wachtwoord."
msgid "Send pending email days before"
msgstr "Aantal dagen tevoren melding versturen"
msgid ""
"Send password expiration pending email X days before expiration. 0 "
"days indicates this email will not be sent. The box above must also be "
"checked. Separate by comma if sending multiple notifications."
msgstr ""
"Stuur een e-mail over het verlopen van het wachtwoord een aantal dagen "
"voor de vervaldatum. 0 dagen geeft aan dat deze e-mail niet wordt "
"verzonden. Als u meerdere meldingen wilt laten versturen plaatst u "
"komma's tussen de getallen. Bovenstaand vakje moet ook aangevinkt "
"zijn."
msgid ""
"Control whether the user must reset their password. If the password "
"has expired, this field is automatically checked after the execution "
"of Cron."
msgstr ""
"De gebruiker dient zijn wachtwoord opnieuw in te stellen. Als het "
"wachtwoord is verlopen, wordt dit veld automatisch aangevinkt na het "
"uitvoeren van de cronjob."
msgid "Pending Expiration Mail Count"
msgstr "Aantal verzonden e-mails wachtwoord verlopen"
msgid ""
"Whether an email notifying of a pending password expiration has been "
"sent"
msgstr ""
"Of er een e-mail is verzonden met de melding dat het wachtwoord is "
"verlopen"
msgid "Edit password_policy"
msgstr "Wachtwoordbeleid bewerken"
msgid "Add Password Policy"
msgstr "Wachtwoordbeleid toevoegen"
msgid "Show policy table"
msgstr "Beleidstabel tonen"
msgid "Password Blacklist Policy"
msgstr "Wachtwoord zwarte lijstbeleid"
msgid "Create a blacklist of phrases that cannot be used in passwords."
msgstr ""
"Maak een zwarte lijst van zinnen die niet in wachtwoorden gebruikt "
"mogen worden."
msgid "Match substrings"
msgstr "Deelreeksen vergelijken"
msgid ""
"There are restricted terms in your password. Please modify your "
"password."
msgstr "Uw wachtwoord bevat verboden termen. Pas uw wachtwoord aan."
msgid "Your password is on the blacklist. Please choose a different password."
msgstr "Uw wachtwoord staat op de zwarte lijst. Kies een ander wachtwoord."
msgid "Also disallow passwords containing blacklisted passwords"
msgstr "Ook wachtwoorden die woorden van de zwarte lijst bevatten verbieden"
msgid ""
"Password cannot be a member of this list, ignoring case. Enter one "
"password per line."
msgstr ""
"Het wachtwoord mag niet voorkomen in deze lijst, "
"hoofdletterongevoelig. Voer één wachtwoord per regel in."
msgid "Password must not contain any restricted words or phrases."
msgstr "Het wachtwoord mag geen verboden woorden of zinnen bevatten."
msgid "Password must not be on the blacklist."
msgstr "Het wachtwoord mag niet op de zwarte lijst staan."
msgid "Password cannot match certain disallowed passwords"
msgstr ""
"Het wachtwoord mag niet overeenkomen met bepaalde verboden "
"wachtwoorden"
msgid "Your password contains restricted words or phrases."
msgstr "Uw wachtwoord bevat verboden woorden of zinnen."
msgid "Special Character"
msgstr "Speciaal teken"
msgid "Password must contain at least 1 uppercase character."
msgid_plural "Password must contain at least @count unique uppercase characters."
msgstr[0] "Het wachtwoord moet minimaal 1 hoofdletter bevatten."
msgstr[1] "Het wachtwoord moet minimaal @count unieke hoofdletters bevatten."
msgid "Password must contain at least 1 lowercase character."
msgid_plural "Password must contain at least @count unique lowercase characters."
msgstr[0] "Het wachtwoord moet minimaal 1 kleine letter bevatten."
msgstr[1] "Het wachtwoord moet minimaal @count unieke kleine letters bevatten."
msgid "Password must contain at least 1 special character."
msgid_plural "Password must contain at least @count unique special characters."
msgstr[0] "Het wachtwoord moet minimaal 1 speciaal teken bevatten."
msgstr[1] "Het wachtwoord moet minimaal @count unieke speciale tekens bevatten."
msgid "Password must contain at least 1 numeric character."
msgid_plural "Password must contain at least @count unique numeric characters."
msgstr[0] "Het wachtwoord moet minimaal 1 cijfer bevatten."
msgstr[1] "Het wachtwoord moet minimaal @count unieke cijfers bevatten."
msgid "No consecutive identical characters are allowed."
msgstr "Opeenvolgende identieke tekens zijn niet toegestaan."
msgid "Consecutive identical characters fewer than: @max"
msgstr "Opeenvolgende identieke tekens minder dan: @max"
msgid "Consecutive identical characters fewer than"
msgstr "Opeenvolgende identieke tekens minder dan"
msgid ""
"This many or more consecutive identical characters will not be allowed "
"in the password."
msgstr ""
"Zoveel of meer opeenvolgende identieke tekens zijn niet toegestaan in "
"het wachtwoord."
msgid "Password Policy Delay"
msgstr "Wachtwoordbeleid vertraging"
msgid ""
"Sets up a password constraint to limit how soon before a password can "
"be reset again."
msgstr ""
"Stelt een wachtwoordbeperking in om te bepalen hoe snel een wachtwoord "
"opnieuw kan worden ingesteld."
msgid "Hours until next password reset may be performed."
msgstr "Uren tot het wachtwoord opnieuw kan worden ingesteld."
msgid "Hours until password can be reset again."
msgstr "Uren tot het wachtwoord opnieuw kan worden ingesteld."
msgid "A value of 0 represents no delay"
msgstr "Een waarde van 0 betekent geen vertraging"
msgid "The delay value must be zero or greater."
msgstr "De vertragingswaarde moet nul of groter zijn."
msgid "Delay in hours until password can be reset: @delay"
msgstr ""
"Vertraging in uren tot het wachtwoord opnieuw kan worden ingesteld: "
"@delay"
msgid "Password Delay"
msgstr "Wachtwoordvertraging"
msgid "Provide delay before password can be reset again."
msgstr ""
"Stel een vertraging in voordat het wachtwoord opnieuw kan worden "
"ingesteld."
msgid "You cannot reset your password until the delay has as elapsed."
msgstr ""
"U kunt uw wachtwoord niet opnieuw instellen totdat de vertraging is "
"verstreken."
msgid ""
"Number of passwords that will be checked in the user password update "
"history"
msgstr ""
"Aantal wachtwoorden dat wordt gecontroleerd in de "
"wachtwoordgeschiedenis van de gebruiker"
msgid ""
"A value of 0 represents that the user can not repeat any of the old "
"passwords."
msgstr ""
"Een waarde van 0 betekent dat de gebruiker geen enkel oud wachtwoord "
"opnieuw mag gebruiken."
msgid ""
"Number of passwords that will be checked in the user password update "
"history: @number-repeats"
msgstr ""
"Aantal gecontroleerde wachtwoorden in de wachtwoordgeschiedenis: "
"@number-repeats"
msgid ""
"The last @count password cannot be reused. Choose a different "
"password."
msgid_plural ""
"The last @count passwords cannot be reused. Choose a different "
"password."
msgstr[0] ""
"Het laatste @count wachtwoord kan niet opnieuw worden gebruikt. Kies "
"een ander wachtwoord."
msgstr[1] ""
"De laatste @count wachtwoorden kunnen niet opnieuw worden gebruikt. "
"Kies een ander wachtwoord."
msgid "PASSWORD POLICY"
msgstr "WACHTWOORDBELEID"
msgid ""
"User password will reset after the selected number of days. 0 days "
"indicates that passwords never expire."
msgstr ""
"Het wachtwoord van de gebruiker wordt opnieuw ingesteld na het "
"geselecteerde aantal dagen. 0 dagen geeft aan dat wachtwoorden nooit "
"verlopen."
msgid ""
"Indicate whether this policy should show the password policy table on "
"the user add/edit form."
msgstr ""
"Geef aan of dit beleid de wachtwoordbeleidstabel moet tonen op het "
"formulier voor het toevoegen/bewerken van gebruikers."
msgid "The password policy %label has been added."
msgstr "Het wachtwoordbeleid %label is toegevoegd."
msgid "The password policy was not saved."
msgstr "Het wachtwoordbeleid is niet opgeslagen."
msgid ""
"No password constraint available. Enable one of the modules that has "
"password constraints."
msgstr ""
"Geen wachtwoordbeperking beschikbaar. Schakel een van de modules in "
"die wachtwoordbeperkingen bevat."
msgid "Previous passwords cannot be reused. Choose a different password."
msgstr ""
"Vorige wachtwoorden kunnen niet opnieuw worden gebruikt. Kies een "
"ander wachtwoord."
msgid "Not enough time has passed since this password was last reset."
msgstr ""
"Er is nog niet genoeg tijd verstreken sinds het laatste "
"wachtwoordherstel."
msgid "The selected operation (@operation) already exists."
msgstr "De geselecteerde bewerking (@operation) bestaat al."
msgid ""
"The selected length (@new) is higher than the maximum length defined "
"(@length)."
msgstr ""
"De geselecteerde lengte (@new) is groter dan de gedefinieerde "
"maximumlengte (@length)."
msgid ""
"The selected length (@new) is lower than the minimum length defined "
"(@length)."
msgstr ""
"De geselecteerde lengte (@new) is kleiner dan de gedefinieerde "
"minimumlengte (@length)."
