{#
 * Icon (Atom)
 * @param string name - Icon name WITHOUT "icon-" prefix (required)
 * @param string size - small|medium|large|xlarge (default: medium)
 * @param string color - Semantic color variant (primary|secondary|success|warning|danger|info) (default: primary)
 * @param boolean disabled - Disabled state (default: false)
 * @param string ariaLabel - Accessibility label for informative icons (optional)
 #}

{% set name = name|default('search') %}
{% set size = size|default('medium') %}
{% set color = color|default('primary') %}
{% set disabled = disabled|default(false) %}

{# BEM classes: minimal markup, only modifiers if not default #}
{% set classes = [] %}
{% set classes = classes|merge(['icon-' ~ name]) %}
{% if size != 'medium' %}
  {% set classes = classes|merge(['ps-icon--' ~ size]) %}
{% endif %}
{% if color != 'primary' %}
  {% set classes = classes|merge(['ps-icon--' ~ color]) %}
{% endif %}
{% if disabled %}
  {% set classes = classes|merge(['ps-icon--disabled']) %}
{% endif %}

<i
  class="{{ classes|join(' ')|trim }}"
  {% if attributes %}{{ attributes }}{% endif %}
  {% if ariaLabel %}aria-label="{{ ariaLabel }}" role="img"{% else %}aria-hidden="true"{% endif %}
></i>
